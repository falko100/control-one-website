---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Control One — ISO Management Eenvoudig Gemaakt',
  description = 'Control One helpt bedrijven bij het implementeren, bijhouden en beheren van ISO-compliance met begeleide workflows, risicobeheer, audits en documentbeheer.',
  image = '/og-image.png',
  ogType = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://control-one.nl';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;

const gtmId = import.meta.env.PUBLIC_GTM_ID;
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'Control One',
  legalName: 'Control One B.V.',
  alternateName: 'Control-One',
  url: siteUrl,
  logo: `${siteUrl}/logo.svg`,
  image: `${siteUrl}/og-image.png`,
  description: 'Control One is het Nederlandse SaaS-platform voor ISO-compliance voor het MKB. Implementeer ISO 27001, 9001, 14001 en 45001 zelfstandig via een stapsgewijze coach, sjablonen, risicoanalyse, documentbeheer en auditmanagement.',
  slogan: 'ISO Compliance Software voor het MKB',
  foundingDate: '2024',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Twekkeler Es 42',
    postalCode: '7547 SM',
    addressLocality: 'Enschede',
    addressRegion: 'Overijssel',
    addressCountry: 'NL',
  },
  areaServed: {
    '@type': 'Country',
    name: 'Netherlands',
  },
  knowsAbout: [
    'ISO 27001',
    'ISO/IEC 27001:2022',
    'ISO 9001',
    'ISO 14001',
    'ISO 45001',
    'Information Security Management System (ISMS)',
    'Quality Management System (QMS)',
    'Environmental Management System (EMS)',
    'Occupational Health and Safety Management',
    'Risicomanagement',
    'Informatiebeveiliging',
    'NIS2',
    'SOC 2',
    'AVG',
    'GDPR',
    'Annex A controls',
    'Compliance management',
    'Interne audits',
    'Management Review',
    'PDCA',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: 'info@control-one.nl',
    availableLanguage: ['Dutch', 'English'],
    areaServed: 'NL',
  },
  sameAs: [
    'https://www.linkedin.com/company/control-one',
  ],
};

const allSchemas: Record<string, unknown>[] = [
  organizationSchema,
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Robots -->
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Control One" />
    <meta property="og:locale" content="nl_NL" />

    <!-- Twitter / X Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Google Search Console verificatie -->
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2DC727QSZN"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2DC727QSZN');
    </script>

    <!-- Google Tag Manager -->
    {gtmId && (
      <script is:inline define:vars={{ gtmId }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}

    <!-- LLM / AI discovery -->
    <link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=TikTok+Sans:opsz,wght@12..36,300..900&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <!-- Structured Data (JSON-LD) -->
    {allSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  <!-- Control One Visitor Tracker -->
  <script src="https://control-one.nl/tracker.js" defer></script>
  </head>
  <body class="bg-white text-primary-950 antialiased">

    <!-- Google Tag Manager (noscript) -->
    {gtmId && (
      <noscript>
        <iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0" width="0" style="display:none;visibility:hidden"></iframe>
      </noscript>
    )}

    <slot />
  </body>
</html>
