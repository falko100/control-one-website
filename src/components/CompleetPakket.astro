---
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 mb-4">Alles inbegrepen</p>
      <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-primary-950 leading-[1.1]">
        Meer dan software.<br />Een compleet pakket.
      </h2>
      <p class="mt-5 text-lg text-primary-900/55 leading-relaxed">
        Van stap-voor-stap begeleiding tot expert-ondersteuning: alles wat je nodig hebt om zelf te certificeren zit inbegrepen.
      </p>
    </div>

    <!-- 4 pillars -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-6xl mx-auto items-stretch">

      <!-- 1: Implementatiecoach -->
      <div class="rounded-2xl bg-white border border-primary-100 shadow-sm p-7 flex flex-col h-full">
        <div class="w-12 h-12 rounded-2xl bg-primary-100 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-bold text-primary-950 mb-2">Virtuele implementatiecoach</h3>
          <p class="text-sm text-primary-900/60 leading-relaxed">Een online coach in het platform begeleidt je stap voor stap van gap analyse tot certificeringsaudit. Elke stap legt uit wat ISO vereist en wat jij vandaag concreet moet doen.</p>
        </div>
        <div class="pt-4 mt-5 border-t border-primary-100">
          <span class="text-xs font-bold text-primary-400 uppercase tracking-widest">28 stappen · 4 fasen</span>
        </div>
      </div>

      <!-- 2: Kennisbank -->
      <div class="rounded-2xl bg-white border border-primary-100 shadow-sm p-7 flex flex-col h-full">
        <div class="w-12 h-12 rounded-2xl bg-violet-100 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-bold text-primary-950 mb-2">Kennisbank</h3>
          <p class="text-sm text-primary-900/60 leading-relaxed">Alle theoretische ISO-kennis op één plek. Uitleg over normen, clausules, begrippen en best practices, altijd beschikbaar in het platform.</p>
        </div>
        <div class="pt-4 mt-5 border-t border-primary-100">
          <span class="text-xs font-bold text-violet-400 uppercase tracking-widest">Theorie · Best practices</span>
        </div>
      </div>

      <!-- 3: Sjablonen -->
      <div class="rounded-2xl bg-white border border-primary-100 shadow-sm p-7 flex flex-col h-full">
        <div class="w-12 h-12 rounded-2xl bg-emerald-100 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-bold text-primary-950 mb-2">Vooringevulde sjablonen</h3>
          <p class="text-sm text-primary-900/60 leading-relaxed">200+ sjablonen vooraf ingevuld door ISO-experts. Handboek, beleid, gap analyse en VvT: klaar om te personaliseren voor jouw organisatie.</p>
        </div>
        <div class="pt-4 mt-5 border-t border-primary-100">
          <span class="text-xs font-bold text-emerald-500 uppercase tracking-widest">200+ sjablonen</span>
        </div>
      </div>

      <!-- 4: Chat Consultancy -->
      <div class="rounded-2xl p-7 flex flex-col h-full text-white relative" style="background: linear-gradient(135deg, #1a3d6e 0%, #2554a0 60%, #1a3d6e 100%);">
        <div class="absolute top-0 right-0 w-40 h-40 bg-white/5 rounded-full blur-2xl pointer-events-none"></div>
        <div class="absolute -top-3.5 right-5 inline-flex items-center gap-1 px-3 py-1 text-[10px] font-bold tracking-widest uppercase bg-white text-primary-700 rounded-full shadow">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Gratis inbegrepen
        </div>
        <div class="w-12 h-12 rounded-2xl bg-white/15 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-bold text-white mb-2">5 uur chat consultancy</h3>
          <p class="text-sm text-white/80 leading-relaxed">Snel een vraag? Chat met een echte ISO-expert. Geen AI, geen chatbot: gewoon een mens die jouw vraag begrijpt en direct antwoord geeft.</p>
        </div>
        <div class="pt-4 mt-5 border-t border-white/20">
          <span class="text-xs font-bold text-white/60 uppercase tracking-widest">Echte ISO-expert</span>
        </div>
      </div>

    </div>
  </div>
</section>
