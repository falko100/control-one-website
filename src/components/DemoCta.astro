---
interface Props {
  /** Korte naam module — wordt in eyebrow getoond, bijv. "Audit module" */
  module: string;
  /** Grote kop bovenaan, bijv. "Wil je zien hoe audits werken in de portal?" */
  title: string;
  /** Korte ondersteunende zin onder de titel */
  description?: string;
  /** Tekst op de demo-button */
  ctaText?: string;
  /** URL-segment dat in de browser-chrome verschijnt, bijv. "audit / intern" */
  urlPath?: string;
  /** Tailwind kleur-classes voor accent (bg + text). Default = primary-blauw */
  accentBg?: string;
  accentText?: string;
  /** Welke thema-specifieke visual te tonen rechts */
  variant?:
    | 'audit'
    | 'portal'
    | 'templates'
    | 'maatregelen'
    | 'documenten'
    | 'coach'
    | 'kennisbank'
    | 'risico'
    | 'leveranciers'
    | 'directie';
}

const {
  module,
  title,
  description = 'Klik door de live demo en zie zelf hoe je dagelijks werkt in Control One. Geen registratie nodig.',
  ctaText = 'Bekijk de live demo',
  urlPath = 'demo',
  accentBg = 'bg-accent-500',
  accentText = 'text-accent-300',
  variant = 'portal',
} = Astro.props;
---

<section class="py-16 sm:py-20 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <div class="relative rounded-2xl sm:rounded-3xl overflow-hidden shadow-2xl ring-1 ring-white/10" style="background: linear-gradient(135deg, #1e3a6f 0%, #2554a0 55%, #1e3a6f 100%);">

      <!-- Decoratieve gloed -->
      <div class="absolute -top-24 -right-20 w-72 h-72 rounded-full opacity-30 blur-3xl pointer-events-none" style="background: radial-gradient(circle, rgba(120,180,255,0.6), transparent 70%);"></div>
      <div class="absolute -bottom-32 -left-16 w-80 h-80 rounded-full opacity-20 blur-3xl pointer-events-none" style="background: radial-gradient(circle, rgba(80,200,255,0.5), transparent 70%);"></div>

      <div class="relative grid lg:grid-cols-[1fr_auto] gap-8 lg:gap-12 items-center px-7 sm:px-10 lg:px-12 py-10 sm:py-12">

        <!-- ── Tekst ── -->
        <div class="relative z-10">

          <!-- Live-eyebrow -->
          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-5 text-[11px] font-semibold tracking-[0.18em] uppercase text-blue-100 bg-white/10 rounded-full border border-white/20 backdrop-blur-sm">
            <span class="relative flex w-2 h-2">
              <span class="absolute inline-flex w-full h-full rounded-full bg-emerald-300 opacity-75 animate-ping"></span>
              <span class="relative inline-flex w-2 h-2 rounded-full bg-emerald-400"></span>
            </span>
            Live demo &bull; {module}
          </div>

          <h2 class="text-2xl sm:text-3xl lg:text-[2rem] font-bold text-white tracking-tight leading-[1.2]">
            {title}
          </h2>

          {description && (
            <p class="mt-3 text-[15px] sm:text-base text-blue-100/85 leading-relaxed max-w-xl">
              {description}
            </p>
          )}

          <div class="mt-7 flex flex-col sm:flex-row sm:items-center gap-x-5 gap-y-3">
            <a
              href="/demo/"
              class="group relative inline-flex items-center gap-3 pl-2 pr-6 py-2 text-sm sm:text-[15px] font-semibold text-primary-900 bg-white hover:bg-white rounded-full transition-all shadow-[0_8px_30px_-6px_rgba(0,0,0,0.4)] hover:shadow-[0_12px_36px_-4px_rgba(0,0,0,0.5)] hover:-translate-y-0.5 ring-1 ring-white/30"
            >
              <span class="flex items-center justify-center w-9 h-9 rounded-full text-white shadow-inner group-hover:scale-105 transition-transform" style="background: linear-gradient(135deg, #2554a0, #1e3a6f);">
                <svg class="w-3.5 h-3.5 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
              <span>{ctaText}</span>
            </a>
          </div>
        </div>

        <!-- ── Visuele preview rechts (demo-poster) ── -->
        <a href="/demo/" class="hidden lg:block relative z-10 w-[340px] xl:w-[380px] shrink-0 group/poster">
          <!-- Glow rings achter de kaart -->
          <div class="absolute -inset-4 rounded-[28px] opacity-50 blur-2xl pointer-events-none transition-opacity duration-500 group-hover/poster:opacity-80" style="background: radial-gradient(circle at 50% 30%, rgba(120,180,255,0.45), transparent 65%);"></div>

          <div class="relative rounded-2xl overflow-hidden ring-1 ring-white/15 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.55)] bg-primary-950 transition-transform duration-500 group-hover/poster:-translate-y-1">

            <!-- Chrome bar -->
            <div class="flex items-center gap-2 px-3 py-2 bg-primary-900 border-b border-white/5">
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-amber-400/70"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-emerald-400/70"></span>
              </div>
              <div class="flex-1 flex justify-center">
                <div class="flex items-center gap-1.5 px-3 py-0.5 rounded-md bg-white/[0.06] border border-white/10 text-[10px] text-white/60 font-mono truncate max-w-[220px]">
                  <svg class="w-2.5 h-2.5 text-emerald-400/80 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6z"/></svg>
                  app.control-one.nl/{urlPath}
                </div>
              </div>
            </div>

            <!-- Inhoud preview -->
            <div class="relative p-4 min-h-[230px] bg-gradient-to-br from-primary-900 via-primary-950 to-primary-900">

              <!-- Module pill + status -->
              <div class="flex items-center justify-between">
                <div class={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md ${accentBg}/15 ring-1 ${accentBg}/40 ring-inset text-[10px] font-semibold ${accentText} uppercase tracking-wider`}>
                  {module}
                </div>
                <div class="flex items-center gap-1 text-[9px] font-medium text-white/40 uppercase tracking-wider">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                  Live
                </div>
              </div>

              {/* ====== AUDIT ====== */}
              {variant === 'audit' && (
                <>
                  <div class="mt-3 flex items-center gap-1.5">
                    <span class="px-2 py-0.5 rounded-md bg-orange-500/20 ring-1 ring-orange-400/40 text-[9px] font-semibold text-orange-200">Intern</span>
                    <span class="px-2 py-0.5 rounded-md bg-white/[0.04] ring-1 ring-white/10 text-[9px] font-semibold text-white/50">Extern</span>
                    <span class="px-2 py-0.5 rounded-md bg-white/[0.04] ring-1 ring-white/10 text-[9px] font-semibold text-white/50">Hercert</span>
                  </div>
                  <div class="mt-3 space-y-1.5">
                    <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 p-2.5">
                      <div class="flex items-center justify-between gap-2">
                        <span class="text-[10px] font-semibold text-white/85 truncate">H8.1 Operationele planning</span>
                        <span class="text-[9px] px-1.5 py-0.5 rounded bg-amber-400/15 text-amber-300 font-semibold shrink-0">Open · 2 NC</span>
                      </div>
                      <div class="mt-1 flex items-center gap-1.5">
                        <span class="text-[9px] text-white/40">CPAR</span>
                        <span class="text-[9px] text-orange-300 font-mono">3</span>
                        <span class="text-[9px] text-white/40">·</span>
                        <span class="text-[9px] text-white/40">06 mei</span>
                      </div>
                    </div>
                    <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 p-2.5">
                      <div class="flex items-center justify-between gap-2">
                        <span class="text-[10px] font-semibold text-white/85 truncate">H9.2 Interne audit</span>
                        <span class="text-[9px] px-1.5 py-0.5 rounded bg-emerald-400/15 text-emerald-300 font-semibold shrink-0">Voltooid</span>
                      </div>
                      <div class="mt-1 flex items-center gap-1.5">
                        <span class="text-[9px] text-white/40">0 NC · 2 OFI</span>
                      </div>
                    </div>
                  </div>
                </>
              )}

              {/* ====== PORTAL (features) ====== */}
              {variant === 'portal' && (
                <>
                  <div class="mt-3 grid grid-cols-2 gap-2">
                    <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 p-2.5">
                      <div class="flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                        <span class="text-[9px] uppercase tracking-wider text-white/50 font-semibold">Coach</span>
                      </div>
                      <div class="mt-1 text-[10px] text-white/80">Stap 18 / 28</div>
                      <div class="mt-1 h-1 rounded-full bg-white/10 overflow-hidden">
                        <div class="h-full rounded-full bg-amber-400" style="width: 64%;"></div>
                      </div>
                    </div>
                    <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 p-2.5">
                      <div class="flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
                        <span class="text-[9px] uppercase tracking-wider text-white/50 font-semibold">Risico's</span>
                      </div>
                      <div class="mt-1 flex items-baseline gap-1">
                        <span class="text-base font-bold text-white tabular-nums">42</span>
                        <span class="text-[9px] text-white/50">geïdentificeerd</span>
                      </div>
                    </div>
                    <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 p-2.5">
                      <div class="flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-blue-300"></span>
                        <span class="text-[9px] uppercase tracking-wider text-white/50 font-semibold">Maatregelen</span>
                      </div>
                      <div class="mt-1 flex items-baseline gap-1">
                        <span class="text-base font-bold text-white tabular-nums">87</span>
                        <span class="text-[9px] text-emerald-300">/ 93</span>
                      </div>
                    </div>
                    <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 p-2.5">
                      <div class="flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-orange-400"></span>
                        <span class="text-[9px] uppercase tracking-wider text-white/50 font-semibold">Audits</span>
                      </div>
                      <div class="mt-1 text-[10px] text-white/80">3 ingepland</div>
                    </div>
                  </div>
                </>
              )}

              {/* ====== TEMPLATES ====== */}
              {variant === 'templates' && (
                <div class="mt-3 rounded-lg bg-white/[0.03] ring-1 ring-white/10 divide-y divide-white/5">
                  {[
                    { name: 'Beleid Informatiebeveiliging.docx', tag: 'Beleid', tagColor: 'bg-emerald-400/15 text-emerald-300' },
                    { name: 'Risicoregister.xlsx', tag: 'Register', tagColor: 'bg-blue-400/15 text-blue-300' },
                    { name: 'Procedure Incident.docx', tag: 'Procedure', tagColor: 'bg-violet-400/15 text-violet-300' },
                    { name: 'VvT Annex A.xlsx', tag: 'Register', tagColor: 'bg-blue-400/15 text-blue-300' },
                  ].map((f) => (
                    <div class="flex items-center gap-2 px-2.5 py-1.5">
                      <svg class="w-3 h-3 text-white/40 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11z"/></svg>
                      <span class="text-[10px] text-white/85 truncate flex-1">{f.name}</span>
                      <span class={`text-[9px] px-1.5 py-0.5 rounded ${f.tagColor} font-semibold shrink-0`}>{f.tag}</span>
                    </div>
                  ))}
                </div>
              )}

              {/* ====== MAATREGELEN ====== */}
              {variant === 'maatregelen' && (
                <>
                  <div class="mt-3 grid grid-cols-2 gap-2">
                    {[
                      { code: 'A.5', name: 'Organisatorisch', count: 37, color: 'text-blue-300' },
                      { code: 'A.6', name: 'Mensen', count: 8, color: 'text-emerald-300' },
                      { code: 'A.7', name: 'Fysiek', count: 14, color: 'text-orange-300' },
                      { code: 'A.8', name: 'Technologisch', count: 34, color: 'text-violet-300' },
                    ].map((c) => (
                      <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 p-2">
                        <div class="flex items-center justify-between">
                          <span class={`text-[10px] font-mono font-bold ${c.color}`}>{c.code}</span>
                          <span class="text-[9px] text-white/40 tabular-nums">{c.count}</span>
                        </div>
                        <div class="mt-0.5 text-[9px] text-white/60 truncate">{c.name}</div>
                      </div>
                    ))}
                  </div>
                  <div class="mt-2 flex items-center gap-1.5 text-[9px] text-white/50">
                    <span class="px-1.5 py-0.5 rounded bg-emerald-400/15 text-emerald-300 font-semibold">78 OK</span>
                    <span class="px-1.5 py-0.5 rounded bg-amber-400/15 text-amber-300 font-semibold">14 open</span>
                    <span class="px-1.5 py-0.5 rounded bg-red-400/15 text-red-300 font-semibold">1 risico</span>
                  </div>
                </>
              )}

              {/* ====== DOCUMENTEN ====== */}
              {variant === 'documenten' && (
                <div class="mt-3 rounded-lg bg-white/[0.03] ring-1 ring-white/10 divide-y divide-white/5">
                  {[
                    { name: 'ISO 27001 Handboek', version: 'v3.2', status: 'Goedgekeurd', color: 'bg-emerald-400/15 text-emerald-300' },
                    { name: 'Beleid Informatiebeveiliging', version: 'v2.1', status: 'In review', color: 'bg-amber-400/15 text-amber-300' },
                    { name: 'Procedure Incident Response', version: 'v1.5', status: 'Concept', color: 'bg-blue-400/15 text-blue-300' },
                    { name: 'Risicobeleid', version: 'v2.0', status: 'Goedgekeurd', color: 'bg-emerald-400/15 text-emerald-300' },
                  ].map((d) => (
                    <div class="flex items-center gap-2 px-2.5 py-1.5">
                      <svg class="w-3 h-3 text-violet-300/70 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 7V3.5L18.5 9H13z"/></svg>
                      <span class="text-[10px] text-white/85 truncate flex-1">{d.name}</span>
                      <span class="text-[9px] text-white/40 font-mono shrink-0">{d.version}</span>
                      <span class={`text-[9px] px-1.5 py-0.5 rounded ${d.color} font-semibold shrink-0`}>{d.status}</span>
                    </div>
                  ))}
                </div>
              )}

              {/* ====== COACH ====== */}
              {variant === 'coach' && (
                <>
                  <div class="mt-3 flex items-center justify-between text-[10px]">
                    <span class="text-white/60">Implementatie-voortgang</span>
                    <span class="text-amber-300 font-semibold tabular-nums">64%</span>
                  </div>
                  <div class="mt-1.5 h-1.5 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full rounded-full bg-gradient-to-r from-amber-400 to-orange-400" style="width: 64%;"></div>
                  </div>
                  <div class="mt-3 grid grid-cols-5 gap-1">
                    {['Voor­bereiding', 'Scoping', 'Risico', 'Imple­mentatie', 'Audit'].map((p, i) => (
                      <div class="flex flex-col items-center gap-1">
                        <div class={`w-full h-1 rounded-full ${i < 3 ? 'bg-amber-400' : i === 3 ? 'bg-amber-400/50' : 'bg-white/10'}`}></div>
                        <span class="text-[8px] text-white/50 text-center leading-tight">{p}</span>
                      </div>
                    ))}
                  </div>
                  <div class="mt-3 rounded-lg bg-white/[0.04] ring-1 ring-amber-400/30 p-2.5">
                    <div class="flex items-center gap-1.5">
                      <span class="text-[9px] font-mono text-amber-300 font-bold">STAP 18</span>
                      <span class="text-[9px] text-white/40">·</span>
                      <span class="text-[9px] text-white/60">Fase Risico</span>
                    </div>
                    <div class="mt-0.5 text-[10px] font-semibold text-white/85">Risicoregister opbouwen</div>
                  </div>
                </>
              )}

              {/* ====== KENNISBANK ====== */}
              {variant === 'kennisbank' && (
                <>
                  <div class="mt-3 relative">
                    <svg class="absolute left-2 top-1/2 -translate-y-1/2 w-3 h-3 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    <div class="pl-7 pr-2 py-1.5 rounded-lg bg-white/[0.04] ring-1 ring-white/10 text-[10px] text-white/60">Zoek artikel of maatregel…</div>
                  </div>
                  <div class="mt-2 flex items-center gap-1 flex-wrap">
                    <span class="px-1.5 py-0.5 rounded-full bg-teal-400/15 ring-1 ring-teal-400/30 text-[9px] font-semibold text-teal-300">ISO 27001</span>
                    <span class="px-1.5 py-0.5 rounded-full bg-white/[0.04] ring-1 ring-white/10 text-[9px] font-semibold text-white/50">Annex A</span>
                    <span class="px-1.5 py-0.5 rounded-full bg-white/[0.04] ring-1 ring-white/10 text-[9px] font-semibold text-white/50">Audit</span>
                    <span class="px-1.5 py-0.5 rounded-full bg-white/[0.04] ring-1 ring-white/10 text-[9px] font-semibold text-white/50">Templates</span>
                  </div>
                  <div class="mt-2.5 rounded-lg bg-white/[0.03] ring-1 ring-white/10 divide-y divide-white/5">
                    {[
                      { title: 'Wat is een ISMS?', cat: 'ISO 27001' },
                      { title: 'A.5.15 Toegangsbeheer toelichting', cat: 'Annex A' },
                      { title: 'Auditbevindingen registreren', cat: 'Audit' },
                    ].map((a) => (
                      <div class="flex items-center gap-2 px-2.5 py-1.5">
                        <svg class="w-3 h-3 text-teal-300/70 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M19 2H5c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 6h2v2h-2V8zm0 4h2v6h-2v-6zm-3-4h2v10H9V8z"/></svg>
                        <span class="text-[10px] text-white/85 truncate flex-1">{a.title}</span>
                        <span class="text-[9px] text-teal-300/70 shrink-0">{a.cat}</span>
                      </div>
                    ))}
                  </div>
                </>
              )}

              {/* ====== RISICO (5x5 matrix) ====== */}
              {variant === 'risico' && (
                <>
                  <div class="mt-3 flex items-center gap-3">
                    <div class="grid grid-cols-5 gap-0.5 shrink-0">
                      {[
                        ['e','e','a','a','r'],
                        ['e','a','a','a','r'],
                        ['e','a','a','r','r'],
                        ['a','a','r','r','d'],
                        ['a','r','r','d','d'],
                      ].flat().map((cell, i) => {
                        const colors = {
                          e: 'bg-emerald-500/70',
                          a: 'bg-amber-500/70',
                          r: 'bg-red-500/70',
                          d: 'bg-red-700/80',
                        };
                        const isHighlight = i === 12;
                        return (
                          <div class={`w-4 h-4 rounded-sm ${colors[cell]} ${isHighlight ? 'ring-2 ring-white' : ''}`}></div>
                        );
                      })}
                    </div>
                    <div class="flex-1 space-y-1.5">
                      <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 px-2 py-1.5">
                        <div class="flex items-center justify-between">
                          <span class="text-[9px] font-mono text-red-300">R-04</span>
                          <span class="text-[9px] px-1.5 py-0.5 rounded bg-red-500/20 text-red-300 font-semibold">12</span>
                        </div>
                        <div class="text-[9px] text-white/70 truncate">Datalek via leverancier</div>
                      </div>
                      <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 px-2 py-1.5">
                        <div class="flex items-center justify-between">
                          <span class="text-[9px] font-mono text-amber-300">R-09</span>
                          <span class="text-[9px] px-1.5 py-0.5 rounded bg-amber-500/20 text-amber-300 font-semibold">8</span>
                        </div>
                        <div class="text-[9px] text-white/70 truncate">Phishing-aanval</div>
                      </div>
                    </div>
                  </div>
                  <div class="mt-2 flex items-center gap-2 text-[9px] text-white/50">
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm bg-emerald-500/70"></span>Laag</span>
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm bg-amber-500/70"></span>Midden</span>
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm bg-red-500/70"></span>Hoog</span>
                  </div>
                </>
              )}

              {/* ====== LEVERANCIERS ====== */}
              {variant === 'leveranciers' && (
                <div class="mt-3 rounded-lg bg-white/[0.03] ring-1 ring-white/10 divide-y divide-white/5">
                  {[
                    { name: 'AWS Cloud Services', cls: 'Hoog', clsColor: 'bg-red-400/15 text-red-300', iso: true },
                    { name: 'Microsoft Azure', cls: 'Hoog', clsColor: 'bg-red-400/15 text-red-300', iso: true },
                    { name: 'Salesforce NL', cls: 'Midden', clsColor: 'bg-amber-400/15 text-amber-300', iso: true },
                    { name: 'KPN Zakelijk', cls: 'Laag', clsColor: 'bg-emerald-400/15 text-emerald-300', iso: false },
                  ].map((v) => (
                    <div class="flex items-center gap-2 px-2.5 py-1.5">
                      <div class="w-5 h-5 rounded bg-cyan-400/15 ring-1 ring-cyan-400/30 flex items-center justify-center shrink-0">
                        <svg class="w-2.5 h-2.5 text-cyan-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/></svg>
                      </div>
                      <span class="text-[10px] text-white/85 truncate flex-1">{v.name}</span>
                      <span class={`text-[9px] px-1.5 py-0.5 rounded ${v.clsColor} font-semibold shrink-0`}>{v.cls}</span>
                      {v.iso && (
                        <span class="text-[9px] text-emerald-300 font-semibold shrink-0 flex items-center gap-0.5">
                          <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                          ISO
                        </span>
                      )}
                    </div>
                  ))}
                </div>
              )}

              {/* ====== DIRECTIEBEOORDELING ====== */}
              {variant === 'directie' && (
                <>
                  <div class="mt-3 rounded-lg bg-white/[0.04] ring-1 ring-white/10 px-2.5 py-2">
                    <div class="flex items-center justify-between gap-2">
                      <span class="text-[10px] font-semibold text-white/85">MR-0003 · Q1 2026</span>
                      <span class="text-[9px] px-1.5 py-0.5 rounded bg-blue-400/15 text-blue-300 font-semibold">In behandeling</span>
                    </div>
                    <div class="mt-0.5 text-[9px] text-white/50">Voorzitter: J. de Vries · 16 apr 2026</div>
                  </div>
                  <div class="mt-2 grid grid-cols-2 gap-2">
                    <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 p-2">
                      <div class="text-[9px] uppercase tracking-wider text-indigo-300 font-semibold">Input</div>
                      <div class="mt-1 space-y-0.5">
                        {['Externe issues','Interne audits','Risico-update','Incidenten','KPI-resultaten'].map((s) => (
                          <div class="flex items-center gap-1">
                            <svg class="w-2.5 h-2.5 text-emerald-400 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                            <span class="text-[9px] text-white/70 truncate">{s}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                    <div class="rounded-lg bg-white/[0.04] ring-1 ring-white/10 p-2">
                      <div class="text-[9px] uppercase tracking-wider text-indigo-300 font-semibold">Output</div>
                      <div class="mt-1 space-y-0.5">
                        {['Verbeterkansen','Resourcebehoefte','Beleidswijzigingen','6 acties'].map((s, i) => (
                          <div class="flex items-center gap-1">
                            <span class={`w-1.5 h-1.5 rounded-full ${i === 3 ? 'bg-amber-400' : 'bg-white/30'}`}></span>
                            <span class="text-[9px] text-white/70 truncate">{s}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </>
              )}

              <!-- Vignet over content (voor poster-feel) -->
              <div class="absolute inset-0 pointer-events-none rounded-b-2xl" style="background: radial-gradient(ellipse at center, transparent 35%, rgba(10,21,46,0.55) 100%);"></div>

              <!-- Centrale play-button overlay -->
              <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                <div class="relative">
                  <span class="absolute inset-0 rounded-full bg-white/20 animate-ping"></span>
                  <span class="absolute -inset-2 rounded-full bg-white/10 blur-md"></span>
                  <span class="relative flex items-center justify-center w-14 h-14 rounded-full bg-white/95 shadow-[0_10px_30px_-5px_rgba(0,0,0,0.5)] ring-1 ring-white/40 group-hover/poster:scale-110 transition-transform duration-300">
                    <svg class="w-5 h-5 text-primary-900 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          </div>
        </a>

      </div>
    </div>
  </div>
</section>
