---

<section class="py-24 bg-gradient-to-b from-white to-primary-50/50 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-12">
      <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Ervaringen</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
        Organisaties die zelf de regie pakken
      </h2>
      <p class="mt-4 text-lg text-primary-900/60">
        Van informatiebeveiliging tot kwaliteitsmanagement: onze klanten behalen certificering op eigen kracht, zonder dure consultants.
      </p>
    </div>
  </div>

  <!-- Testimonial slider -->
  <div class="max-w-7xl mx-auto px-6">
    <div class="relative">

      <!-- Slider track wrapper -->
      <div class="overflow-hidden" id="testimonials-outer">
        <div class="flex gap-6 transition-transform duration-400 ease-in-out" id="testimonials-track">
          {testimonials.map(t => (
            <div class="testimonial-card shrink-0 bg-white rounded-2xl border border-primary-100 p-6 flex flex-col shadow-sm hover:shadow-lg hover:shadow-primary-100/50 transition-shadow">

              <!-- Company logo + framework badge row -->
              <div class="flex items-center justify-between mb-5">
                <img
                  src={t.logo}
                  alt={t.company}
                  class="h-9 w-auto object-contain"
                  loading="lazy"
                />
                <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-2.5 py-1 rounded-full border border-primary-100 shrink-0 ml-2">{t.framework}</span>
              </div>

              <!-- Stars -->
              <div class="flex gap-0.5 mb-4">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                ))}
              </div>

              <!-- Quote -->
              <blockquote class="text-primary-900/70 leading-relaxed flex-1 text-sm">
                &ldquo;{t.quote}&rdquo;
              </blockquote>

              <!-- Author row with photo -->
              <div class="mt-5 pt-4 border-t border-primary-100 flex items-center gap-3">
                <img
                  src={t.photo}
                  alt={t.author}
                  class="w-9 h-9 rounded-full object-cover shrink-0 border-2 border-primary-100"
                  loading="lazy"
                />
                <div>
                  <p class="font-semibold text-primary-950 text-sm leading-tight">{t.author}</p>
                  <p class="text-[11px] text-primary-900/45 leading-tight">{t.company}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation arrows -->
      <button id="testimonials-prev" class="absolute -left-5 top-1/2 -translate-y-1/2 w-10 h-10 bg-white border border-primary-200 rounded-full shadow-md flex items-center justify-center text-primary-700 hover:bg-primary-50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed z-10" aria-label="Vorige">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </button>
      <button id="testimonials-next" class="absolute -right-5 top-1/2 -translate-y-1/2 w-10 h-10 bg-white border border-primary-200 rounded-full shadow-md flex items-center justify-center text-primary-700 hover:bg-primary-50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed z-10" aria-label="Volgende">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </button>
    </div>

    <!-- Dot navigation -->
    <div class="flex justify-center gap-2 mt-8" id="testimonials-dots">
    </div>
  </div>
</section>

<script>
  (function () {
    const track = document.getElementById('testimonials-track') as HTMLElement;
    const outer = document.getElementById('testimonials-outer') as HTMLElement;
    const prevBtn = document.getElementById('testimonials-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('testimonials-next') as HTMLButtonElement;
    const dotsContainer = document.getElementById('testimonials-dots') as HTMLElement;

    if (!track || !outer || !prevBtn || !nextBtn || !dotsContainer) return;

    const cards = Array.from(track.querySelectorAll('.testimonial-card')) as HTMLElement[];
    const total = cards.length;
    let current = 0;

    function getVisible(): number {
      if (window.innerWidth >= 1024) return 3;
      if (window.innerWidth >= 768) return 2;
      return 1;
    }

    function getCardWidth(): number {
      if (cards[0]) {
        return cards[0].offsetWidth + 24;
      }
      return 0;
    }

    function getMaxIndex(): number {
      return Math.max(0, total - getVisible());
    }

    function setCardWidths() {
      const vis = getVisible();
      const gap = 24;
      const totalGap = gap * (vis - 1);
      const containerWidth = outer.offsetWidth;
      const cardW = (containerWidth - totalGap) / vis;
      cards.forEach(c => {
        c.style.width = `${cardW}px`;
      });
    }

    function buildDots() {
      dotsContainer.innerHTML = '';
      const maxIdx = getMaxIndex();
      for (let i = 0; i <= maxIdx; i++) {
        const dot = document.createElement('button');
        dot.className = `h-2 rounded-full transition-all duration-300 ${i === current ? 'bg-primary-600 w-6' : 'bg-primary-200 w-2 hover:bg-primary-400'}`;
        dot.setAttribute('aria-label', `Ga naar slide ${i + 1}`);
        dot.addEventListener('click', () => { resetAutoPlay(); goTo(i); });
        dotsContainer.appendChild(dot);
      }
    }

    function updateDots() {
      const dotEls = dotsContainer.querySelectorAll('button');
      dotEls.forEach((dot, i) => {
        if (i === current) {
          dot.className = 'h-2 w-6 rounded-full transition-all duration-300 bg-primary-600';
        } else {
          dot.className = 'h-2 w-2 rounded-full transition-all duration-300 bg-primary-200 hover:bg-primary-400';
        }
      });
    }

    function updateButtons() {
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current >= getMaxIndex();
    }

    function goTo(index: number) {
      const max = getMaxIndex();
      current = Math.max(0, Math.min(index, max));
      const cardW = getCardWidth();
      track.style.transform = `translateX(-${current * cardW}px)`;
      updateDots();
      updateButtons();
    }

    prevBtn.addEventListener('click', () => { resetAutoPlay(); goTo(current - 1); });
    nextBtn.addEventListener('click', () => { resetAutoPlay(); goTo(current + 1); });

    const AUTO_INTERVAL = 2500;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function startAutoPlay() {
      autoTimer = setInterval(() => {
        const next = current >= getMaxIndex() ? 0 : current + 1;
        goTo(next);
      }, AUTO_INTERVAL);
    }

    function stopAutoPlay() {
      if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
    }

    function resetAutoPlay() {
      stopAutoPlay();
      startAutoPlay();
    }

    outer.addEventListener('mouseenter', stopAutoPlay);
    outer.addEventListener('mouseleave', startAutoPlay);

    function init() {
      setCardWidths();
      buildDots();
      updateButtons();
      track.style.transform = 'translateX(0)';
      current = 0;
    }

    init();
    startAutoPlay();
    window.addEventListener('resize', () => { stopAutoPlay(); init(); startAutoPlay(); });
  })();
</script>
