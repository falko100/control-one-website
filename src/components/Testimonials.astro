---
const testimonials = [
  {
    quote: 'Control One heeft onze aanpak van ISO 27001 compleet veranderd. De begeleide coach maakte de implementatie behapbaar in plaats van overweldigend.',
    author: 'Sarah van den Berg',
    role: 'CISO',
    company: 'DataGuard Solutions',
  },
  {
    quote: 'We hebben onze audit-voorbereidingstijd gehalveerd. Alles op één plek hebben — documenten, risico\'s, bewijs — is een enorm verschil.',
    author: 'Mark de Vries',
    role: 'Kwaliteitsmanager',
    company: 'TechFlow BV',
  },
  {
    quote: 'De risicobeheermodule alleen al is het abonnement waard. We hebben eindelijk een helder overzicht van ons risicolandschap.',
    author: 'Linda Bakker',
    role: 'Compliance Officer',
    company: 'SecureNow Group',
  },
];
---

<section class="py-24 bg-gradient-to-b from-white to-primary-50/50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-16">
      <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Ervaringen</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
        Vertrouwd door compliance-teams
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map(t => (
        <div class="bg-white rounded-2xl border border-primary-100 p-8 flex flex-col">
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
            ))}
          </div>

          <blockquote class="text-primary-900/70 leading-relaxed flex-1">
            &ldquo;{t.quote}&rdquo;
          </blockquote>

          <div class="mt-6 pt-6 border-t border-primary-100">
            <p class="font-semibold text-primary-950">{t.author}</p>
            <p class="text-sm text-primary-900/50">{t.role}, {t.company}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
