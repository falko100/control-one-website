---
const testimonials = [
  {
    quote: 'We hadden ISO 27001 nodig voor een contract met een grote opdrachtgever, en snel ook. Zonder Control One hadden we een consultant ingehuurd voor tienduizenden euro\'s. Nu hebben we het zelf gedaan, in vier maanden, voor een fractie van die kosten. De auditor was onder de indruk van ons dossier.',
    author: 'Daan Loohuis',
    role: 'Eigenaar',
    company: 'De Digitale Basis',
    framework: 'ISO 27001',
    photo: '/team/portrait-daan-loohuis.jpg',
    logo: '/logos/de-digitale-basis.png',
    logoDark: true,
    initials: 'DL',
    color: 'bg-primary-600',
  },
  {
    quote: 'Wij zijn een productiebedrijf, geen ISO-specialisten. De coach legde elke stap uit in gewone taal, en de sjablonen waren al voor 80% ingevuld. Op de momenten dat we vastzaten, hadden we direct een echte ISO-expert via de chat. Geen chatbot, maar iemand die onze situatie begreep. Vijf maanden na de start: gecertificeerd.',
    author: 'Lisa Hofman',
    role: 'Operations Manager',
    company: 'Brinkman Techniek',
    framework: 'ISO 9001',
    photo: null,
    logo: null,
    logoDark: false,
    initials: 'LH',
    color: 'bg-emerald-600',
  },
  {
    quote: 'Twee normen in één systeem klinkt logisch, maar de meeste tools dwingen je alsnog tot losse sheets en dubbel werk. Control One heeft dat opgelost. Gedeelde documenten, één risicoregister, altijd audit-ready. Onze surveillance-audit vorig jaar: geen enkele afwijking.',
    author: 'Fatima El-Amin',
    role: 'QHSE Manager',
    company: 'Greenleaf Logistics',
    framework: 'ISO 27001 & 14001',
    photo: null,
    logo: null,
    logoDark: false,
    initials: 'FE',
    color: 'bg-violet-600',
  },
];
---

<section class="py-24 bg-gradient-to-b from-white to-primary-50/50">
  <div class="max-w-7xl mx-auto px-6">

    <div class="max-w-2xl mx-auto text-center mb-14">
      <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Ervaringen</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
        Organisaties die zelf de regie pakken
      </h2>
      <p class="mt-4 text-lg text-primary-900/60">
        Van informatiebeveiliging tot kwaliteitsmanagement: onze klanten behalen certificering op eigen kracht, zonder dure consultants.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {testimonials.map((t, i) => (
        <div class:list={[
          'rounded-2xl border p-7 flex flex-col shadow-sm',
          i === 1
            ? 'bg-primary-950 border-primary-800 shadow-xl shadow-primary-950/20'
            : 'bg-white border-primary-100 hover:shadow-md hover:border-primary-200 transition-all',
        ]}>

          <!-- Logo + framework row -->
          <div class="flex items-center justify-between mb-5">
            {t.logo ? (
              <img
                src={t.logo}
                alt={t.company}
                class:list={[
                  'h-6 w-auto object-contain',
                  i === 1 ? 'brightness-0 invert' : t.logoDark ? 'opacity-70' : '',
                ]}
                loading="lazy"
              />
            ) : (
              <span class:list={[
                'text-xs font-bold tracking-wide',
                i === 1 ? 'text-white/40' : 'text-primary-400',
              ]}>{t.company}</span>
            )}
            <span class:list={[
              'text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded-full shrink-0 ml-2',
              i === 1
                ? 'bg-white/10 text-white/60'
                : 'bg-primary-50 text-primary-500 border border-primary-100',
            ]}>{t.framework}</span>
          </div>

          <!-- Stars -->
          <div class="flex gap-0.5 mb-5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class:list={[
            'text-sm leading-relaxed flex-1',
            i === 1 ? 'text-white/80' : 'text-primary-900/70',
          ]}>
            &ldquo;{t.quote}&rdquo;
          </blockquote>

          <!-- Author -->
          <div class:list={[
            'mt-6 pt-5 border-t flex items-center gap-3',
            i === 1 ? 'border-white/10' : 'border-primary-100',
          ]}>
            {t.photo ? (
              <img
                src={t.photo}
                alt={t.author}
                class="w-9 h-9 rounded-full object-cover object-top shrink-0 border-2 border-primary-100"
                loading="lazy"
              />
            ) : (
              <div class:list={[
                'w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0',
                t.color,
              ]}>
                {t.initials}
              </div>
            )}
            <div class="flex-1 min-w-0">
              <p class:list={[
                'font-semibold text-sm leading-tight',
                i === 1 ? 'text-white' : 'text-primary-950',
              ]}>{t.author}</p>
              <p class:list={[
                'text-[11px] leading-tight mt-0.5',
                i === 1 ? 'text-white/45' : 'text-primary-900/45',
              ]}>{t.role} · {t.company}</p>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
