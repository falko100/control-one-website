---
const phases = [
  {
    label: 'Plan',
    steps: [
      { num: 1, title: 'Directiebetrokkenheid vastleggen', done: true },
      { num: 2, title: 'Scope & toepassingsgebied bepalen', done: true },
      { num: 3, title: 'Gap analyse uitvoeren (150 vragen)', done: true },
      { num: 4, title: 'Milieuaspecten identificeren', done: true },
      { num: 5, title: 'Risico\'s en kansen beoordelen', done: true },
      { num: 6, title: 'Risicoregister opzetten', done: true },
      { num: 7, title: 'Behandelingsplan opstellen', active: true },
      { num: 8, title: 'Beleidsdocumenten schrijven', done: false },
    ],
  },
  {
    label: 'Do',
    steps: [
      { num: 9, title: 'Processen implementeren', done: false },
      { num: 10, title: 'Leveranciers registreren', done: false },
    ],
  },
];
---

<div class="relative w-full rounded-xl overflow-hidden shadow-2xl shadow-primary-950/30 border border-slate-200 bg-white select-none">

  <!-- Browser chrome -->
  <div class="flex items-center gap-3 px-4 py-2.5 bg-slate-100 border-b border-slate-200">
    <div class="flex gap-1.5 shrink-0">
      <div class="w-3 h-3 rounded-full bg-red-400"></div>
      <div class="w-3 h-3 rounded-full bg-amber-400"></div>
      <div class="w-3 h-3 rounded-full bg-emerald-400"></div>
    </div>
    <div class="flex-1 flex items-center gap-2 px-3 py-1 bg-white rounded-md text-xs text-slate-400 font-mono border border-slate-200">
      <svg class="w-3 h-3 text-slate-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
      app.control-one.nl/coach
    </div>
  </div>

  <!-- App UI -->
  <div class="flex" style="height: 400px;">

    <!-- Sidebar -->
    <div class="w-44 shrink-0 bg-primary-950 flex flex-col overflow-hidden">
      <div class="px-4 py-3 border-b border-white/10">
        <div class="text-white font-bold text-sm tracking-tight">Control One</div>
      </div>
      <div class="px-3 py-2.5 border-b border-white/10">
        <div class="flex items-center gap-2 px-2 py-1.5 bg-white/10 rounded-lg">
          <div class="w-1.5 h-1.5 rounded-full bg-primary-400 shrink-0"></div>
          <span class="text-xs text-white/80 font-medium">ISO 27001</span>
        </div>
      </div>
      <nav class="flex-1 px-2 py-2 space-y-0.5 overflow-hidden">
        <div class="flex items-center gap-2 px-2 py-1.5 rounded-lg">
          <svg class="w-3.5 h-3.5 text-white/40 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          <span class="text-xs text-white/50">Dashboard</span>
        </div>
        <div class="flex items-center gap-2 px-2 py-1.5 rounded-lg bg-white/15">
          <svg class="w-3.5 h-3.5 text-white shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span class="text-xs text-white font-semibold">Coach</span>
        </div>
        {['Risico\'s', 'Documenten', 'VvT / SoA', 'Audits', 'Leveranciers'].map(label => (
          <div class="flex items-center gap-2 px-2 py-1.5 rounded-lg">
            <span class="w-3.5 h-3.5 shrink-0"></span>
            <span class="text-xs text-white/50">{label}</span>
          </div>
        ))}
      </nav>
    </div>

    <!-- Main content: Coach -->
    <div class="flex-1 flex flex-col bg-slate-50 overflow-hidden">
      <div class="flex items-center justify-between px-5 py-2.5 bg-white border-b border-slate-100 shrink-0">
        <div>
          <div class="text-sm font-semibold text-slate-800">Implementatiecoach</div>
          <div class="text-xs text-slate-400">ISO 27001: 28 stappen</div>
        </div>
        <div class="flex items-center gap-2">
          <div class="text-xs text-slate-500">Voortgang</div>
          <div class="w-20 h-1.5 bg-slate-200 rounded-full overflow-hidden">
            <div class="h-full bg-primary-600 rounded-full" style="width: 50%"></div>
          </div>
          <div class="text-xs font-bold text-primary-700">14/28</div>
        </div>
      </div>

      <div class="flex-1 overflow-hidden flex gap-0">

        <!-- Steps list -->
        <div class="flex-1 p-4 overflow-hidden space-y-2">
          {phases.map(phase => (
            <div>
              <div class="flex items-center gap-2 mb-2">
                <div class="text-xs font-bold text-slate-400 uppercase tracking-wider">{phase.label}</div>
                <div class="flex-1 h-px bg-slate-200"></div>
              </div>
              <div class="space-y-1">
                {phase.steps.map(step => (
                  <div class:list={[
                    'flex items-center gap-3 px-3 py-2 rounded-lg',
                    step.active ? 'bg-primary-50 border border-primary-200' : 'bg-white border border-slate-100',
                  ]}>
                    <div class:list={[
                      'w-5 h-5 rounded-full shrink-0 flex items-center justify-center text-xs font-bold',
                      step.done ? 'bg-primary-600 text-white' : step.active ? 'bg-primary-100 text-primary-700 border-2 border-primary-600' : 'bg-slate-100 text-slate-400',
                    ]}>
                      {step.done ? (
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                      ) : step.num}
                    </div>
                    <div class="flex-1 min-w-0">
                      <span class:list={[
                        'text-xs',
                        step.active ? 'font-semibold text-primary-900' : step.done ? 'text-slate-400 line-through' : 'text-slate-600',
                      ]}>
                        {step.title}
                      </span>
                    </div>
                    {step.active && (
                      <div class="px-2 py-0.5 bg-primary-600 text-white text-xs font-semibold rounded-full shrink-0">Actief</div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- Step detail panel -->
        <div class="w-52 shrink-0 border-l border-slate-100 bg-white p-4 overflow-hidden">
          <div class="text-xs font-bold text-primary-700 uppercase tracking-wide mb-1">Stap 7</div>
          <div class="text-sm font-semibold text-slate-800 mb-3 leading-tight">Behandelingsplan opstellen</div>
          <div class="text-xs text-slate-500 leading-relaxed mb-4">
            Kies per risico een behandelingsoptie: mitigeren, accepteren, vermijden of overdragen. Documenteer de onderbouwing.
          </div>
          <div class="space-y-2 mb-4">
            <div class="text-xs font-semibold text-slate-600 mb-1">Actiepunten</div>
            {['Risicoregister openen', 'Behandeloptie selecteren', 'Verantwoordelijke toewijzen', 'Deadline instellen'].map((action, i) => (
              <div class="flex items-center gap-2">
                <div class:list={['w-4 h-4 rounded border flex items-center justify-center shrink-0', i < 2 ? 'bg-primary-600 border-primary-600' : 'border-slate-300']}>
                  {i < 2 && <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>}
                </div>
                <span class:list={['text-xs', i < 2 ? 'text-slate-400 line-through' : 'text-slate-600']}>{action}</span>
              </div>
            ))}
          </div>
          <button class="w-full py-1.5 bg-primary-600 text-white text-xs font-semibold rounded-lg">
            Markeer als gereed →
          </button>
        </div>

      </div>
    </div>
  </div>
</div>
