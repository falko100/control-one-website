---
const documents = [
  { name: 'ISMS Handboek', category: 'Handboek', pages: '42 pagina\'s' },
  { name: 'Informatiebeveiligingsbeleid', category: 'Beleid', pages: '8 pagina\'s' },
  { name: 'Toegangsbeheer procedure', category: 'Procedure', pages: '6 pagina\'s' },
  { name: 'Risicobeheer procedure', category: 'Procedure', pages: '9 pagina\'s' },
  { name: 'Incidentbeheer procedure', category: 'Procedure', pages: '7 pagina\'s' },
  { name: 'Verklaring van Toepasselijkheid', category: 'SoA', pages: '93 maatregelen' },
  { name: 'Leveranciersbeleid', category: 'Beleid', pages: '5 pagina\'s' },
];

const categoryColors: Record<string, string> = {
  'Handboek':  'bg-primary-100 text-primary-700',
  'Beleid':    'bg-emerald-50 text-emerald-700',
  'Procedure': 'bg-amber-50 text-amber-700',
  'SoA':       'bg-violet-50 text-violet-700',
};

const stats = [
  { value: '22+', label: 'Beleidsdocumenten voorbereid' },
  { value: '150', label: 'Gap-analyse vragen' },
  { value: '93',  label: 'ISO-maatregelen in VvT' },
];
---

<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">

    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- ── Left: copy ── -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-emerald-700 bg-emerald-50 rounded-full border border-emerald-100">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Klaar om te gebruiken
        </div>

        <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight leading-[1.1]">
          Start met 80% voorsprong<br />met onze Templates
        </h2>

        <p class="mt-5 text-lg text-primary-900/60 leading-relaxed">
          Alles in Control One is <strong class="text-primary-900 font-semibold">template-gebaseerd en vooraf ingevuld</strong> door ISO-experts. Het ISMS handboek, alle beleidsdocumenten, de gap analyse, de VvT, risico-sjablonen: al het benodigde ISO-materiaal staat er al in.
        </p>
        <p class="mt-4 text-lg text-primary-900/60 leading-relaxed">
          U hoeft het alleen nog maar <strong class="text-primary-900 font-semibold">aan te vullen en specifiek te maken voor uw organisatie</strong>. Geen formatteren, geen uitvinden. Gewoon invullen en verder.
        </p>

        <!-- Highlights -->
        <div class="mt-8 space-y-4">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-xl bg-primary-50 flex items-center justify-center text-primary-600 shrink-0 mt-0.5">
              <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-primary-950">Opgesteld door ISO-experts</p>
              <p class="text-sm text-primary-900/55 mt-0.5">Alle sjablonen zijn geschreven conform de actuele ISO-normen en direct bruikbaar als bewijs voor uw auditor.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-xl bg-primary-50 flex items-center justify-center text-primary-600 shrink-0 mt-0.5">
              <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-primary-950">Pas alleen aan wat uniek is voor u</p>
              <p class="text-sm text-primary-900/55 mt-0.5">Vul uw bedrijfsnaam, processen en specifieke situatie in. De structuur en ISO-inhoud staan er al in.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-xl bg-primary-50 flex items-center justify-center text-primary-600 shrink-0 mt-0.5">
              <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-primary-950">Binnen 5 minuten aan de slag</p>
              <p class="text-sm text-primary-900/55 mt-0.5">Account aanmaken en direct beginnen. Geen leertraject, geen consultants. Gewoon de portal openen en starten.</p>
            </div>
          </div>
        </div>

        <!-- Stats row -->
        <div class="mt-10 grid grid-cols-3 gap-4">
          {stats.map(s => (
            <div class="text-center p-4 rounded-2xl bg-primary-50/60 border border-primary-100">
              <p class="text-2xl font-bold text-primary-700">{s.value}</p>
              <p class="text-xs text-primary-900/55 mt-0.5 leading-snug">{s.label}</p>
            </div>
          ))}
        </div>

        <div class="mt-8">
          <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-primary-700 hover:bg-primary-800 rounded-lg transition-all shadow-lg shadow-primary-200/60">
            Gratis uitproberen
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
      </div>

      <!-- ── Right: portal document mockup ── -->
      <div class="relative">

        <!-- Glow -->
        <div class="absolute -inset-8 bg-primary-50 rounded-3xl -z-10"></div>
        <div class="absolute -top-4 -right-4 w-48 h-48 bg-primary-200/30 rounded-full blur-2xl -z-10"></div>

        <!-- Window frame -->
        <div class="rounded-2xl border border-primary-200/60 shadow-2xl shadow-primary-200/30 bg-white overflow-hidden">

          <!-- Chrome bar -->
          <div class="flex items-center gap-3 px-4 py-3 bg-primary-50 border-b border-primary-100">
            <div class="flex gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span>
            </div>
            <div class="flex-1">
              <div class="bg-white/80 rounded px-3 py-1 text-xs text-primary-400 border border-primary-100 max-w-[180px] mx-auto text-center">
                app.control-one.nl/documenten
              </div>
            </div>
          </div>

          <!-- Document list -->
          <div class="p-5">

            <!-- Header row -->
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="text-sm font-bold text-primary-950">Documenten & Sjablonen</h3>
                <p class="text-xs text-primary-900/50 mt-0.5">ISO 27001: volledig voorbereid</p>
              </div>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-emerald-50 border border-emerald-100 text-xs font-semibold text-emerald-700">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                22 klaar
              </span>
            </div>

            <!-- Doc items -->
            <div class="space-y-2">
              {documents.map((doc) => (
                <div class="flex items-center gap-3 p-3 rounded-xl hover:bg-primary-50/60 transition-colors group">
                  <!-- Doc icon -->
                  <div class="w-8 h-8 rounded-lg bg-primary-100/70 flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                  </div>
                  <!-- Name + category -->
                  <div class="flex-1 min-w-0">
                    <p class="text-xs font-semibold text-primary-950 truncate">{doc.name}</p>
                    <div class="flex items-center gap-2 mt-0.5">
                      <span class:list={['text-[10px] px-1.5 py-0.5 rounded font-medium', categoryColors[doc.category] ?? 'bg-primary-50 text-primary-600']}>
                        {doc.category}
                      </span>
                      <span class="text-[10px] text-primary-900/40">{doc.pages}</span>
                    </div>
                  </div>
                  <!-- Pre-filled badge -->
                  <div class="flex items-center gap-1 shrink-0">
                    <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-[10px] font-semibold text-emerald-600 hidden sm:block">Vooringevuld</span>
                  </div>
                </div>
              ))}
            </div>

            <!-- Footer hint -->
            <div class="mt-3 pt-3 border-t border-primary-50 flex items-center justify-between">
              <p class="text-xs text-primary-900/40">... en nog 15 andere documenten</p>
              <button class="text-xs font-semibold text-primary-600 hover:text-primary-700 transition-colors flex items-center gap-1">
                Alles bekijken
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </button>
            </div>
          </div>

          <!-- Bottom bar: annotation -->
          <div class="px-5 py-3.5 bg-primary-950 flex items-center gap-3">
            <div class="w-6 h-6 rounded-lg bg-accent-400/20 flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <p class="text-xs text-primary-300/80 leading-snug">
              <span class="text-white font-medium">Alles is al vooraf ingevuld.</span> Vul alleen aan wat specifiek is voor uw organisatie.
            </p>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>
