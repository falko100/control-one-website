---
const items = [
  {
    id: 'dashboard',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6.75v6.75"></path></svg>`,
    label: 'Dashboard',
    headline: 'Alles in één oogopslag',
    description: 'Realtime compliance-overzicht met voortgang per framework, openstaande acties, risico-status en certificeringsdatum. Altijd weten waar je organisatie staat.',
    screenshot: '/screenshots/portal-dashboard.png',
  },
  {
    id: 'coach',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
    label: 'Implementatiecoach',
    headline: 'Stap voor stap naar certificering',
    description: '28 begeleide stappen door de volledige PDCA-cyclus. Elke stap legt uit wat ISO vereist, wat je moet doen en koppelt direct aan je documenten en risico\'s.',
    screenshot: '/screenshots/portal-coach.png',
  },
  {
    id: 'risks',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"></path></svg>`,
    label: 'Risicoanalyse',
    headline: 'Risico\'s begrijpen en beheersen',
    description: 'Volledig risicoregister met configureerbare 5×5 risicomatrix, kans- en impactscoring en behandelingsopties. Met historische snapshots voor trendanalyse.',
    screenshot: '/screenshots/portal-risks.png',
  },
  {
    id: 'documents',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path></svg>`,
    label: 'Documentbeheer',
    headline: 'Alle documenten op één plek',
    description: 'Gecentraliseerd documentbeheer met versiebeheer, goedkeuringsworkflows en kant-en-klare sjablonen per ISO-clausule. Altijd de juiste versie beschikbaar.',
    screenshot: '/screenshots/portal-documents.png',
  },
  {
    id: 'audits',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path></svg>`,
    label: 'Audits',
    headline: 'Interne en externe audits beheren',
    description: 'Plan audits, registreer bevindingen en koppel non-conformiteiten aan corrigerende maatregelen. Geautomatiseerde reminders houden uw auditprogramma op schema.',
    screenshot: '/screenshots/portal-audits.png',
  },
  {
    id: 'vendors',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path></svg>`,
    label: 'Leveranciers',
    headline: 'Grip op uw leveranciersrisico\'s',
    description: 'Registreer leveranciers, classificeer op risiconiveau, volg ISO-certificaten en plan periodieke beoordelingen. Altijd inzicht in uw complete leverancierslandschap.',
    screenshot: '/screenshots/portal-vendors.png',
  },
  {
    id: 'soa',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"></path></svg>`,
    label: 'Verklaring van Toepasselijkheid',
    headline: 'De VvT altijd compleet en actueel',
    description: 'Genereer en beheer uw Verklaring van Toepasselijkheid direct vanuit uw risicoanalyse. Exporteer als PDF voor uw certificeringsaudit, altijd up-to-date.',
    screenshot: '/screenshots/portal-soa.png',
  },
  {
    id: 'maatregelen',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"></path></svg>`,
    label: 'Maatregelen',
    headline: 'Beheersmaatregelen volledig onder controle',
    description: 'Registreer en monitor alle ISO-maatregelen (Annex A controls), wijs eigenaren toe en volg de implementatiestatus. Direct gekoppeld aan risico\'s en audits.',
    screenshot: '/screenshots/portal-maatregelen.png',
  },
  {
    id: 'directie',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"></path></svg>`,
    label: 'Directiebeoordeling',
    headline: 'Management reviews gestructureerd vastleggen',
    description: 'Leg directiebeoordelingen vast conform ISO-eisen. Documenteer input, output, besluiten en actiepunten en koppel ze direct aan uw managementsysteem.',
    screenshot: '/screenshots/portal-directie.png',
  },
];
---

<section class="relative py-24 overflow-hidden" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);">

  <!-- Background glow orbs -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-white/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-1/4 w-[400px] h-[300px] bg-white/5 rounded-full blur-[80px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-[400px] h-[300px] bg-blue-300/10 rounded-full blur-[80px] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6">

    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-5 text-xs font-semibold tracking-widest uppercase text-accent-400 bg-white/8 rounded-full border border-white/10">
        <span class="w-1.5 h-1.5 bg-accent-400 rounded-full animate-pulse"></span>
        De portal
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight leading-tight">
        Ontdek de Control One portal
      </h2>
      <p class="mt-4 text-lg text-primary-300/70 leading-relaxed">
        Eén overzichtelijk platform voor je volledige ISO-traject, van gap analyse tot certificering.
      </p>
    </div>

    <!-- Tab selector -->
    <div class="flex justify-center mb-8">
      <div id="sc-nav" class="flex items-center gap-1 p-1.5 rounded-2xl border border-white/20 bg-black/20 backdrop-blur-sm overflow-x-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
        {items.map((item, i) => (
          <button
            class="sc-tab flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 whitespace-nowrap shrink-0 text-white/80 hover:text-white"
            data-tab={item.id}
          >
            <span class="sc-tab-icon w-4 h-4 shrink-0 transition-colors duration-200">
              <Fragment set:html={item.icon} />
            </span>
            <span class="sc-tab-label transition-colors duration-200">{item.label}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Screenshot window -->
    <div class="relative mx-auto" style="max-width: 960px;">

      <!-- Outer ring glow -->
      <div class="absolute -inset-px rounded-2xl bg-gradient-to-b from-white/10 to-transparent pointer-events-none"></div>
      <div class="absolute -inset-6 rounded-3xl bg-primary-600/10 blur-2xl pointer-events-none"></div>

      <!-- Nav arrows -->
      <button id="sc-prev" aria-label="Vorige" class="absolute -left-14 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white/15 hover:bg-white/30 border border-white/20 backdrop-blur-sm flex items-center justify-center text-white transition-all duration-200 shadow-lg">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <button id="sc-next" aria-label="Volgende" class="absolute -right-14 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white/15 hover:bg-white/30 border border-white/20 backdrop-blur-sm flex items-center justify-center text-white transition-all duration-200 shadow-lg">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>

      <!-- Browser frame -->
      <div class="relative rounded-2xl overflow-hidden shadow-[0_40px_100px_rgba(0,0,0,0.6),0_0_0_1px_rgba(255,255,255,0.06)]">

        <!-- Chrome bar -->
        <div class="flex items-center gap-3 px-4 py-3 bg-[#1a2035] border-b border-white/[0.06]">
          <div class="flex gap-1.5 shrink-0">
            <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
            <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
            <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          </div>
          <div class="hidden sm:flex gap-2 text-white/20 shrink-0">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="flex items-center gap-2 bg-white/[0.06] hover:bg-white/[0.09] rounded-lg px-3 py-1.5 transition-colors" style="width: min(280px, 100%);">
              <svg class="w-3 h-3 text-emerald-400/80 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
              <span class="text-xs text-white/40 font-mono tracking-tight">app.control-one.nl</span>
            </div>
          </div>
          <div class="hidden sm:block w-14 shrink-0"></div>
        </div>

        <!-- Screenshot area (clickable to enlarge) -->
        <div
          id="sc-screen"
          class="relative bg-[#0f172a] overflow-hidden cursor-zoom-in group"
          style="height: 520px;"
          title="Klik om te vergroten"
        >
          {items.map((item, i) => (
            <img
              src={item.screenshot}
              alt={`Control One: ${item.label}`}
              class="sc-img absolute inset-0 w-full h-full object-cover object-top"
              style={i !== 0 ? 'opacity: 0; pointer-events: none;' : 'opacity: 1;'}
              data-tab={item.id}
            />
          ))}

          <!-- Zoom hint overlay -->
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none">
            <div class="flex items-center gap-2 px-4 py-2 bg-black/60 backdrop-blur-sm rounded-full text-white/90 text-xs font-medium shadow-lg">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
              Klik om te vergroten
            </div>
          </div>

          <!-- Auto-advance progress bar -->
          <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-white/5">
            <div id="sc-progress" class="h-full bg-gradient-to-r from-accent-400 to-primary-400 rounded-full" style="width: 0%;"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Description strip -->
    <div class="mt-8 mx-auto sc-desc-container" style="max-width: 960px; position: relative; min-height: 80px;">
      {items.map((item, i) => (
        <div
          class="sc-desc"
          data-tab={item.id}
          style={i !== 0 ? 'opacity: 0; pointer-events: none; position: absolute; top: 0; left: 0; right: 0;' : ''}
        >
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5 sm:gap-8">
            <div class="flex items-start gap-4 flex-1 min-w-0">
              <div class="w-10 h-10 rounded-xl bg-white/8 border border-white/10 flex items-center justify-center text-primary-300 shrink-0">
                <Fragment set:html={item.icon} />
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-white leading-snug">{item.headline}</p>
                <p class="text-sm text-primary-400/80 mt-0.5 leading-relaxed">{item.description}</p>
              </div>
            </div>
            <a
              href="https://app.control-one.nl/register"
              class="shrink-0 inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-primary-950 bg-white hover:bg-primary-50 rounded-xl transition-all shadow-lg shadow-black/20 whitespace-nowrap"
            >
              Gratis uitproberen
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── Lightbox overlay ── -->
<div
  id="sc-lightbox"
  class="fixed inset-0 z-[999] flex items-center justify-center p-4 sm:p-8"
  style="display: none;"
  aria-label="Sluit vergroting"
>
  <!-- Backdrop -->
  <div id="sc-lb-backdrop" class="absolute inset-0 backdrop-blur-sm" style="background: linear-gradient(135deg, rgba(14,36,112,0.72) 0%, rgba(26,63,122,0.68) 50%, rgba(30,75,143,0.72) 100%);"></div>

  <!-- Image container -->
  <div class="relative w-full max-w-6xl mx-auto">
    <!-- Close button -->
    <button
      id="sc-lb-close"
      class="absolute -top-12 right-0 flex items-center gap-2 text-white/70 hover:text-white transition-colors text-sm font-medium"
      aria-label="Sluiten"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      Sluiten (Esc)
    </button>

    <!-- Screenshot -->
    <div class="rounded-xl overflow-hidden shadow-2xl border border-white/10">
      <img
        id="sc-lb-img"
        src=""
        alt="Portal schermafbeelding vergroot"
        class="w-full h-auto block"
      />
    </div>
  </div>
</div>

<style>
  /* Tab: inactive */
  .sc-tab {
    color: rgba(255, 255, 255, 0.80);
    background: transparent;
  }
  .sc-tab:hover {
    color: rgba(255, 255, 255, 1);
    background: rgba(255, 255, 255, 0.12);
  }
  /* Tab: active */
  .sc-tab.active {
    background: white;
    color: #0f172a !important;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
  }
  .sc-tab.active .sc-tab-icon,
  .sc-tab.active .sc-tab-label {
    color: #0f172a !important;
  }

  /* Screenshot crossfade */
  .sc-img {
    transition: opacity 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Progress bar fill animation */
  @keyframes sc-fill {
    from { width: 0%; }
    to   { width: 100%; }
  }
  #sc-progress.running {
    animation: sc-fill 5s linear forwards;
  }
  .sc-desc {
    transition: opacity 0.35s ease;
  }

  /* Lightbox show/hide */
  #sc-lightbox.open {
    display: flex !important;
  }
  #sc-lightbox {
    animation: lb-in 0.2s ease;
  }
  @keyframes lb-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Hide scrollbar on tab nav */
  #sc-nav::-webkit-scrollbar { display: none; }
</style>

<script>
  const tabs   = document.querySelectorAll<HTMLElement>('.sc-tab');
  const imgs   = document.querySelectorAll<HTMLImageElement>('.sc-img');
  const descs  = document.querySelectorAll<HTMLElement>('.sc-desc');
  const prog   = document.getElementById('sc-progress') as HTMLElement;
  const screen = document.getElementById('sc-screen') as HTMLElement;
  const lb     = document.getElementById('sc-lightbox') as HTMLElement;
  const lbImg  = document.getElementById('sc-lb-img') as HTMLImageElement;
  const lbClose  = document.getElementById('sc-lb-close') as HTMLButtonElement;
  const lbBack   = document.getElementById('sc-lb-backdrop') as HTMLElement;

  const IDS = Array.from(tabs).map(t => t.dataset.tab!);
  let current = 0;
  let timer: ReturnType<typeof setInterval> | null = null;

  // ── Tab switching ──────────────────────────────────────
  function startProgress() {
    prog.classList.remove('running');
    void prog.offsetWidth;
    prog.classList.add('running');
  }

  let isManualClick = false;
  let hovered = false;

  function activate(id: string, resetTimer = true) {
    tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === id));
    imgs.forEach(img => {
      const on = img.dataset.tab === id;
      img.style.opacity = on ? '1' : '0';
      img.style.pointerEvents = on ? 'auto' : 'none';
    });
    descs.forEach(d => {
      const on = d.dataset.tab === id;
      (d as HTMLElement).style.opacity = on ? '1' : '0';
      (d as HTMLElement).style.pointerEvents = on ? '' : 'none';
      (d as HTMLElement).style.position = on ? '' : 'absolute';
    });
    // Only scroll the tab into view on manual click, never on init or auto-advance
    if (isManualClick) {
      const activeTab = Array.from(tabs).find(t => t.dataset.tab === id);
      activeTab?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
    startProgress();

    if (resetTimer) {
      current = IDS.indexOf(id);
      if (timer) clearInterval(timer);
      if (!hovered) timer = setInterval(advance, 5000);
    }
  }

  function advance() {
    current = (current + 1) % IDS.length;
    activate(IDS[current], false);
  }

  activate(IDS[0]);

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      isManualClick = true;
      activate(tab.dataset.tab!);
      isManualClick = false;
    });
  });

  // Arrow navigation
  const prevBtn = document.getElementById('sc-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('sc-next') as HTMLButtonElement;

  prevBtn?.addEventListener('click', () => {
    isManualClick = true;
    current = (current - 1 + IDS.length) % IDS.length;
    activate(IDS[current]);
    isManualClick = false;
  });

  nextBtn?.addEventListener('click', () => {
    isManualClick = true;
    current = (current + 1) % IDS.length;
    activate(IDS[current]);
    isManualClick = false;
  });

  // Pause auto-advance on hover
  screen.addEventListener('mouseenter', () => {
    hovered = true;
    if (timer) { clearInterval(timer); timer = null; }
  });
  screen.addEventListener('mouseleave', () => {
    hovered = false;
    if (!timer) timer = setInterval(advance, 5000);
  });

  // ── Lightbox ──────────────────────────────────────────
  function openLightbox() {
    const activeImg = Array.from(imgs).find(img => img.style.opacity === '1');
    if (!activeImg) return;
    lbImg.src = activeImg.src;
    lbImg.alt = activeImg.alt;
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.style.display = 'none';
    document.body.style.overflow = '';
    setTimeout(() => { lbImg.src = ''; }, 200);
  }

  screen.addEventListener('click', openLightbox);
  lbClose.addEventListener('click', closeLightbox);
  lbBack.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
