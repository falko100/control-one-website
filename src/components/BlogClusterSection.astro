---
// Toont 6 meest recente blogposts uit een bepaalde categorie. Bedoeld voor pillar→cluster
// linking: elke pillar (bv. /iso-27001) linkt naar zijn cluster-artikelen, en omgekeerd
// elk artikel linkt terug naar zijn pillar via [slug].astro CTA-config.
import { getCollection } from 'astro:content';

interface Props {
  /** Frontmatter category-waarde, exact gespeld (bv. "ISO 27001") */
  category: string;
  /** Korte label voor de norm — gebruikt in de h2 ("Artikelen over X") */
  normLabel: string;
  /** Maximaal aantal artikelen om te tonen (default 6) */
  limit?: number;
  /** Tailwind achtergrondkleur van de sectie (default bg-slate-50) */
  bgClass?: string;
}

const { category, normLabel, limit = 6, bgClass = 'bg-slate-50' } = Astro.props;

const now = new Date(new Date().getTime() + 24 * 60 * 60 * 1000);
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.publishDate <= now);

const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, limit);
---

{posts.length > 0 && (
  <section class={`relative py-20 sm:py-24 ${bgClass} overflow-hidden`}>
    <div class="max-w-7xl mx-auto px-6">

      <!-- Sectie-header -->
      <div class="max-w-3xl mx-auto text-center mb-12">
        <p class="text-sm font-semibold tracking-widest uppercase text-primary-500 mb-3">Inzichten</p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-primary-950 leading-[1.1]">
          Artikelen over <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #0e2470 0%, #196bd7 50%, #01a2e8 100%);">{normLabel}</span>
        </h2>
        <p class="mt-4 text-base sm:text-lg text-primary-900/70 leading-relaxed">
          Diepgaande gidsen, praktijkvoorbeelden en checklists — gepubliceerd door de Control One redactie.
        </p>
      </div>

      <!-- Posts grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-6xl mx-auto">
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}`}
            class="group block p-5 rounded-2xl border border-primary-100 bg-white hover:shadow-lg hover:shadow-primary-100/40 hover:border-primary-200 hover:-translate-y-0.5 transition-all"
          >
            <div class="flex items-center gap-2 text-xs text-primary-900/50 mb-3">
              <span class="px-2 py-0.5 rounded-full bg-primary-50 text-primary-600 font-medium">{post.data.category}</span>
              <span>{post.data.readTime}</span>
            </div>
            <h3 class="text-base font-bold text-primary-950 leading-snug mb-2 group-hover:text-primary-700 transition-colors">
              {post.data.title}
            </h3>
            <p class="text-sm text-primary-900/60 leading-relaxed line-clamp-3">{post.data.description}</p>
            <div class="mt-4 flex items-center gap-1.5 text-xs font-semibold text-primary-600 group-hover:text-primary-800 transition-colors">
              Lees artikel
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </a>
        ))}
      </div>

      <!-- Link naar volledige blog-cluster sectie -->
      <div class="mt-10 flex justify-center">
        <a
          href={`/blog#${category.toLowerCase().replace(/\s+/g, '-')}`}
          class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-primary-700 bg-white hover:bg-primary-50 border border-primary-200 rounded-xl transition-colors shadow-sm"
        >
          Alle {normLabel}-artikelen
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>
)}

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
