---
// Vergelijkingssectie: Control One vs. spreadsheets en generieke tools.
const rows = [
  { feature: 'Begeleide implementatie (coach)', us: true, sheets: false, generic: false },
  { feature: 'Vooraf ingevulde ISO-sjablonen', us: true, sheets: false, generic: false },
  { feature: 'Risicoanalyse met Annex A-koppeling', us: true, sheets: false, generic: false },
  { feature: 'Interne audit module', us: true, sheets: false, generic: true },
  { feature: 'CPAR & incidentbeheer', us: true, sheets: false, generic: true },
  { feature: 'Multi-framework in één omgeving', us: true, sheets: false, generic: false },
  { feature: 'PDF-export voor externe auditor', us: true, sheets: false, generic: false },
  { feature: 'Direct te starten (geen setup)', us: true, sheets: false, generic: false },
  { feature: '5 uur chat consultancy (echte expert)', us: true, sheets: false, generic: false },
];
---

<section class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-12" data-reveal="0">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 mb-3">Vergelijking</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-primary-950 leading-tight">Control One <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #0e2470 0%, #196bd7 50%, #01a2e8 100%);">vs. de rest</span></h2>
      <p class="mt-4 text-lg text-primary-900/70 leading-relaxed">Spreadsheets en generieke tools kunnen veel, maar zijn niet gebouwd voor ISO. Dit is het verschil.</p>
    </div>

    <div class="rounded-3xl border border-primary-100 bg-white p-5 sm:p-10 shadow-lg shadow-primary-100/40" data-reveal="120">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-primary-100">
            <th class="text-left font-medium text-primary-400 pb-4 pr-4"></th>
            <th class="pb-4 px-3 text-center">
              <span class="inline-flex items-center bg-white rounded-xl px-3 py-1.5 shadow-md border border-primary-100">
                <img src="/logo.svg" alt="Control One" class="h-5 w-auto" />
              </span>
            </th>
            <th class="pb-4 px-3 text-center font-medium text-primary-400 text-xs uppercase tracking-wide">Spreadsheets</th>
            <th class="hidden sm:table-cell pb-4 px-3 text-center font-medium text-primary-400 text-xs uppercase tracking-wide">Generieke tools</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class={i % 2 === 0 ? 'bg-primary-50/40' : ''}>
              <td class="py-3 pr-4 text-primary-800 font-medium rounded-l-lg pl-2 text-xs sm:text-sm">{row.feature}</td>
              <td class="py-3 px-3 text-center">
                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-emerald-100">
                  <svg class="w-3.5 h-3.5 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                </span>
              </td>
              <td class="py-3 px-3 text-center">
                {row.sheets
                  ? <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-emerald-100"><svg class="w-3.5 h-3.5 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg></span>
                  : <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-red-50"><svg class="w-3.5 h-3.5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg></span>
                }
              </td>
              <td class="hidden sm:table-cell py-3 px-3 text-center rounded-r-lg">
                {row.generic
                  ? <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-amber-100"><svg class="w-3.5 h-3.5 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg></span>
                  : <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-red-50"><svg class="w-3.5 h-3.5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg></span>
                }
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
