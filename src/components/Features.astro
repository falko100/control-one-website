<script>
  (function () {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.features-tab'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('.features-panel'));
    const prevBtn = document.getElementById('features-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('features-next') as HTMLButtonElement | null;
    let currentIdx = 0;

    // Per-tab active styles (border + text + icon bg/color)
    const activeStyles: Record<number, { border: string; text: string; iconBg: string; iconColor: string }> = {
      0: { border: 'border-blue-500',    text: 'text-blue-700',    iconBg: 'bg-blue-50',    iconColor: 'text-blue-600' },
      1: { border: 'border-amber-500',   text: 'text-amber-700',   iconBg: 'bg-amber-50',   iconColor: 'text-amber-600' },
      2: { border: 'border-violet-500',  text: 'text-violet-700',  iconBg: 'bg-violet-50',  iconColor: 'text-violet-600' },
      3: { border: 'border-indigo-500',  text: 'text-indigo-700',  iconBg: 'bg-indigo-50',  iconColor: 'text-indigo-600' },
      4: { border: 'border-emerald-500', text: 'text-emerald-700', iconBg: 'bg-emerald-50', iconColor: 'text-emerald-600' },
      5: { border: 'border-teal-500',    text: 'text-teal-700',    iconBg: 'bg-teal-50',    iconColor: 'text-teal-600' },
      6: { border: 'border-cyan-500',    text: 'text-cyan-700',    iconBg: 'bg-cyan-50',    iconColor: 'text-cyan-600' },
      7: { border: 'border-rose-500',    text: 'text-rose-700',    iconBg: 'bg-rose-50',    iconColor: 'text-rose-600' },
      8: { border: 'border-primary-500', text: 'text-primary-700', iconBg: 'bg-primary-50',  iconColor: 'text-primary-600' },
      9: { border: 'border-green-500',   text: 'text-green-700',   iconBg: 'bg-green-50',   iconColor: 'text-green-600' },
     10: { border: 'border-teal-500',    text: 'text-teal-700',    iconBg: 'bg-teal-50',    iconColor: 'text-teal-600' },
     11: { border: 'border-violet-500',  text: 'text-violet-700',  iconBg: 'bg-violet-50',  iconColor: 'text-violet-600' },
    };

    function activateTab(idx: number) {
      tabs.forEach((tab, i) => {
        const s = activeStyles[i];
        const iconWrap = tab.querySelector('span:first-child') as HTMLElement;
        const iconInner = iconWrap?.querySelector('span') as HTMLElement;

        if (i === idx) {
          tab.className = tab.className
            .replace('border-transparent', '')
            .replace('text-primary-900/50', '')
            .replace('hover:text-primary-800', '')
            .replace('hover:bg-white/70', '')
            .trim();
          tab.classList.add(s.border, s.text, 'bg-white');
          if (iconWrap) {
            iconWrap.className = iconWrap.className
              .replace('bg-primary-100/60', '').replace('group-hover:bg-primary-100', '').trim();
            iconWrap.classList.add(s.iconBg);
          }
          if (iconInner) {
            iconInner.className = iconInner.className
              .replace('text-primary-400', '').replace('group-hover:text-primary-600', '').trim();
            iconInner.classList.add(s.iconColor);
          }
        } else {
          // Reset to inactive
          tab.classList.remove(s.border, s.text, 'bg-white');
          tab.classList.add('border-transparent', 'text-primary-900/50', 'hover:text-primary-800', 'hover:bg-white/70');
          if (iconWrap) {
            iconWrap.classList.remove(s.iconBg);
            iconWrap.classList.add('bg-primary-100/60', 'group-hover:bg-primary-100');
          }
          if (iconInner) {
            iconInner.classList.remove(s.iconColor);
            iconInner.classList.add('text-primary-400', 'group-hover:text-primary-600');
          }
        }
      });

      // Show/hide panels with fade
      panels.forEach((panel, i) => {
        if (i === idx) {
          panel.classList.remove('hidden');
          panel.style.animation = 'featFadeIn 0.2s ease';
        } else {
          panel.classList.add('hidden');
        }
      });

      // Scroll active tab into view
      tabs[idx]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });

      // Track current and update arrow states
      currentIdx = idx;
      if (prevBtn) prevBtn.disabled = idx === 0;
      if (nextBtn) nextBtn.disabled = idx === tabs.length - 1;
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => activateTab(i));
    });

    prevBtn?.addEventListener('click', () => activateTab(Math.max(0, currentIdx - 1)));
    nextBtn?.addEventListener('click', () => activateTab(Math.min(tabs.length - 1, currentIdx + 1)));

    // Init arrow state
    if (prevBtn) prevBtn.disabled = true;
    if (nextBtn) nextBtn.disabled = tabs.length <= 1;
  })();
</script>

<style>
  @keyframes featFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
</style>
