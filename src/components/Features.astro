    description: 'Meer dan 100 artikelen, richtlijnen en stappenplannen voor ISO 27001, AVG, NIS2 en meer, in begrijpelijk Nederlands, direct toepasbaar en gekoppeld aan je ISMS.',
    bullets: [
      '100+ artikelen over ISO 27001, AVG, NIS2 en aanverwante normen',
      'Contextgevoelig zoeken in gewone taal, geen ISO-jargon',
      'Gekoppeld aan maatregelen, templates en coach-stappen in je ISMS',
      'Altijd actueel bij wijzigingen in wet- en regelgeving',
    ],
    tags: ['100+ artikelen', 'ISO & AVG & NIS2', 'Coach-integratie'],
    iconBg: 'bg-teal-50', iconColor: 'text-teal-600',
    tagStyle: 'bg-teal-50 text-teal-700 border-teal-100',
    borderActive: 'border-teal-500', textActive: 'text-teal-700', bgActive: 'bg-teal-50/30',
    pageHref: '/kennisbank',
  },
  {
    id: 'directiebeoordeling',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
    tabIcon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
    title: 'Directiebeoordeling',
    description: 'Bereid directiebeoordelingen voor met alle verplichte inputpunten conform ISO 9.3. Leg besluiten en actiepunten vast en exporteer een kant-en-klaar verslag voor je auditor.',
    bullets: [
      'Alle verplichte inputpunten conform ISO 27001 clausule 9.3',
      'Notulen, besluiten en actiepunten in één gestructureerd overzicht',
      'Actiepunten direct doorgezet als taken met eigenaar en deadline',
      'PDF-export van het volledige verslag, auditklaar in één klik',
    ],
    tags: ['Clausule 9.3', 'PDF-export', 'Actiepunten'],
    iconBg: 'bg-violet-50', iconColor: 'text-violet-600',
    tagStyle: 'bg-violet-50 text-violet-700 border-violet-100',
    borderActive: 'border-violet-500', textActive: 'text-violet-700', bgActive: 'bg-violet-50/30',
    pageHref: '/directiebeoordeling',
  },
];

const extraFeatures = [
  { title: 'Personeelsregister', description: 'Medewerkersregister met competentieregistratie en koppeling aan portaalrollen.' },
  { title: 'ISMS Handboek', description: 'Vooraf ingevuld handboek op basis van ISO 27001:2022, direct bewerkbaar.' },
  { title: 'Multi-framework', description: 'Beheer ISO 27001, 9001 en 14001 binnen één organisatie en één dashboard.' },
  { title: 'PDF Export', description: 'Exporteer VvT, auditrapportages en documenten direct als auditklare PDF.' },
  { title: 'Bewustwordingstraining', description: 'Trainingsmateriaal en quizzes voor medewerkers, koppelbaar aan competentieregistratie.' },
  { title: 'Normencomparator', description: 'Vergelijk overlappende eisen tussen ISO 27001, 9001 en 14001 voor efficiënt beheer.' },
];
---

<section id="functies" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-12">
      <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Alles wat je nodig hebt</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
        Eén platform<br />voor jouw volledige ISO-traject
      </h2>
      <p class="mt-4 text-lg text-primary-900/60">
        Van de eerste gap analyse tot aan de certificeringsaudit: Control One dekt elk onderdeel van ISO-compliance, zonder dat je specialist hoeft te zijn.
      </p>
    </div>

    <!-- Tabbed interface -->
    <div class="flex items-center gap-3">

      <!-- Prev arrow -->
      <button id="features-prev" disabled aria-label="Vorig tabblad" class="hidden lg:flex shrink-0 w-10 h-10 rounded-full bg-white border border-primary-200 shadow-sm items-center justify-center text-primary-500 hover:text-primary-800 hover:shadow-md transition-all disabled:opacity-25 disabled:pointer-events-none">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
      </button>

      <div class="rounded-3xl border border-primary-100 overflow-hidden shadow-sm bg-white flex-1 min-w-0">

      <!-- Tab bar -->
      <div class="border-b border-primary-100 bg-primary-50/40">
        <div class="overflow-x-auto scrollbar-none" id="features-tab-bar">
          <div class="flex min-w-max">
          {features.map((f, i) => (
            <button
              data-tab-idx={i}
              class:list={[
                'features-tab group flex items-center gap-2 px-5 py-4 text-sm font-medium border-b-2 transition-all duration-200 whitespace-nowrap',
                i === 0
                  ? `${f.borderActive} ${f.textActive} bg-white`
                  : 'border-transparent text-primary-900/50 hover:text-primary-800 hover:bg-white/70',
              ]}
            >
              <span class:list={[
                'w-7 h-7 rounded-lg flex items-center justify-center transition-colors duration-200',
                i === 0 ? f.iconBg : 'bg-primary-100/60 group-hover:bg-primary-100',
              ]}>
                <span class:list={[i === 0 ? f.iconColor : 'text-primary-400 group-hover:text-primary-600']}>
                  <Fragment set:html={f.tabIcon} />
                </span>
              </span>
              {f.title}
            </button>
          ))}
          </div>
        </div>
      </div>

      <!-- Content panels -->
      <div id="features-panels">
        {features.map((f, i) => (
          <div
            data-panel-idx={i}
            class:list={['features-panel', i !== 0 && 'hidden']}
          >
            <div class="grid lg:grid-cols-[1fr_1.1fr] items-stretch min-h-[420px]">

              <!-- Left: text content -->
              <div class="p-5 sm:p-8 lg:p-12 flex flex-col justify-center border-r border-primary-50">
                <div class="flex items-center gap-3 mb-5">
                  <div class:list={['w-10 h-10 rounded-xl flex items-center justify-center shrink-0', f.iconBg, f.iconColor]}>
                    <Fragment set:html={f.icon} />
                  </div>
                  <span class="text-xs font-bold uppercase tracking-widest text-primary-400">
                    Functie {String(i + 1).padStart(2, '0')}
                  </span>
                </div>
                <h3 class="text-2xl font-bold text-primary-950 tracking-tight mb-3">{f.title}</h3>
                <p class="text-base text-primary-900/60 leading-relaxed mb-6">{f.description}</p>
                <ul class="space-y-2.5 mb-7">
                  {f.bullets.map(b => (
                    <li class="flex items-start gap-3">
                      <svg class:list={['w-5 h-5 shrink-0 mt-0.5', f.iconColor]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      <span class="text-sm text-primary-900/70 leading-relaxed">{b}</span>
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5 mb-7">
                  {f.tags.map(tag => (
                    <span class:list={['text-xs font-semibold px-2.5 py-1 rounded-full border', f.tagStyle]}>{tag}</span>
                  ))}
                </div>
                <a href={(f as any).pageHref ?? '/features'} class:list={['inline-flex items-center gap-1.5 text-sm font-semibold transition-colors group/link', f.iconColor]}>
                  Meer over {f.title}
                  <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                  </svg>
                </a>
              </div>

              <!-- Right: mockup -->
              <div class:list={['flex items-center justify-center p-5 sm:p-8 lg:p-12', f.bgActive]}>
                <!-- Coach mockup -->
                {i === 0 && (
                  <div class="w-full max-w-sm">
                    <div class="bg-white rounded-2xl shadow-md border border-primary-100 overflow-hidden">
                      <div class="px-4 py-3 bg-primary-50 border-b border-primary-100 flex items-center justify-between">
                        <span class="text-xs font-semibold text-primary-700">Implementatiecoach: Stap 3 van 28</span>
                        <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-semibold">11% gereed</span>
                      </div>
                      <div class="p-4 space-y-2">
                        {[
                          { num: 1, label: 'Context van de organisatie', done: true },
                          { num: 2, label: 'Scopebepaling', done: true },
                          { num: 3, label: 'Gap analyse uitvoeren', done: false, active: true },
                          { num: 4, label: 'Risicobeoordeling opzetten', done: false },
                          { num: 5, label: 'Behandelingsplan opstellen', done: false },
                          { num: 6, label: 'VvT invullen', done: false },
                        ].map(step => (
                          <div class:list={[
                            'flex items-center gap-3 p-2.5 rounded-lg text-sm',
                            step.done ? 'opacity-60' : step.active ? 'bg-blue-50 border border-blue-200' : 'bg-primary-50/50',
                          ]}>
                            <div class:list={[
                              'w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0',
                              step.done ? 'bg-blue-500 text-white' : step.active ? 'bg-blue-500 text-white' : 'bg-primary-200 text-primary-600',
                            ]}>
                              {step.done
                                ? <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                : step.num
                              }
                            </div>
                            <span class:list={['leading-tight', step.active ? 'font-semibold text-primary-950' : 'text-primary-700']}>{step.label}</span>
                            {step.active && <span class="ml-auto text-xs font-semibold text-blue-600 shrink-0">Actief</span>}
                          </div>
                        ))}
                      </div>
                      <div class="px-4 pb-4">
                        <div class="w-full bg-primary-100 rounded-full h-1.5">
                          <div class="bg-blue-500 h-1.5 rounded-full" style="width: 11%"></div>
                        </div>
                        <p class="text-xs text-primary-500 mt-1.5">3 van 28 stappen afgerond</p>
                      </div>
                    </div>
                  </div>
                )}
                <!-- Risicoanalyse mockup -->
                {i === 1 && (
                  <div class="w-full max-w-sm">
                    <div class="bg-white rounded-2xl shadow-md border border-primary-100 overflow-hidden">
                      <div class="px-4 py-3 bg-primary-50 border-b border-primary-100 flex items-center justify-between">
                        <span class="text-xs font-semibold text-primary-700">Risicomatrix: 18 risico's</span>
                        <span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full font-semibold">3 hoog</span>
                      </div>
                      <div class="p-4">
                        <div class="grid grid-cols-[auto_1fr_1fr_1fr_1fr_1fr] gap-1 mb-1">
                          <div class="w-5"></div>
                          {['1','2','3','4','5'].map(n => <div class="text-center text-[10px] text-primary-400 font-medium">{n}</div>)}
                        </div>
                        {[
                          { label:'5', cells:['bg-amber-200','bg-orange-300','bg-red-300','bg-red-400','bg-red-500'], counts:[null,null,2,null,null] },
                          { label:'4', cells:['bg-green-200','bg-amber-200','bg-amber-300','bg-orange-300','bg-red-400'], counts:[null,null,5,3,null] },
                          { label:'3', cells:['bg-green-100','bg-green-200','bg-amber-200','bg-amber-300','bg-orange-300'], counts:[null,null,null,4,null] },
                          { label:'2', cells:['bg-green-100','bg-green-100','bg-green-200','bg-amber-200','bg-amber-300'], counts:[null,null,null,null,null] },
                          { label:'1', cells:['bg-green-100','bg-green-100','bg-green-100','bg-green-200','bg-amber-200'], counts:[null,null,null,null,null] },
                        ].map(row => (
                          <div class="grid grid-cols-[auto_1fr_1fr_1fr_1fr_1fr] gap-1 mb-1">
                            <div class="w-5 text-right text-[10px] text-primary-400 font-medium flex items-center justify-end pr-1">{row.label}</div>
                            {row.cells.map((bg, ci) => (
                              <div class:list={['h-8 rounded flex items-center justify-center', bg]}>
                                {row.counts[ci] && <span class="text-[11px] font-bold text-white drop-shadow-sm">{row.counts[ci]}</span>}
                              </div>
                            ))}
                          </div>
                        ))}
                        <div class="flex items-center justify-between mt-3 pt-3 border-t border-primary-50">
                          <div class="flex gap-3">
                            <span class="flex items-center gap-1 text-[11px] text-primary-500"><span class="w-2.5 h-2.5 rounded-sm bg-green-200 inline-block"></span>Laag</span>
                            <span class="flex items-center gap-1 text-[11px] text-primary-500"><span class="w-2.5 h-2.5 rounded-sm bg-amber-300 inline-block"></span>Midden</span>
                            <span class="flex items-center gap-1 text-[11px] text-primary-500"><span class="w-2.5 h-2.5 rounded-sm bg-red-400 inline-block"></span>Hoog</span>
                          </div>
                          <span class="text-xs text-primary-400">Kans →</span>
                        </div>
                      </div>
                    </div>
                  </div>
                )}
                <!-- Documentbeheer mockup -->
                {i === 2 && (
                  <div class="w-full max-w-sm">
                    <div class="bg-white rounded-2xl shadow-md border border-primary-100 overflow-hidden">
                      <div class="px-4 py-3 bg-primary-50 border-b border-primary-100 flex items-center justify-between">
                        <span class="text-xs font-semibold text-primary-700">Documenten: 24 bestanden</span>
                        <button class="text-xs bg-violet-600 text-white px-2.5 py-1 rounded-lg font-semibold">+ Nieuw</button>
                      </div>
                      <div class="divide-y divide-primary-50">
                        {[
                          { name: 'Informatiebeveiligingsbeleid', version: 'v2.1', status: 'Goedgekeurd', statusBg: 'bg-green-100 text-green-700' },
                          { name: 'Risicobeoordelingsprocedure', version: 'v1.3', status: 'Goedgekeurd', statusBg: 'bg-green-100 text-green-700' },
                          { name: 'Toegangsbeleid', version: 'v3.0', status: 'Concept', statusBg: 'bg-amber-100 text-amber-700' },
                          { name: 'Incidentresponse procedure', version: 'v1.1', status: 'Review', statusBg: 'bg-blue-100 text-blue-700' },
                          { name: 'Business Continuity Plan', version: 'v2.0', status: 'Goedgekeurd', statusBg: 'bg-green-100 text-green-700' },
                        ].map(doc => (
                          <div class="flex items-center gap-3 px-4 py-3">
                            <svg class="w-4 h-4 text-violet-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                            <div class="flex-1 min-w-0">
                              <p class="text-xs font-semibold text-primary-900 truncate">{doc.name}</p>
                              <p class="text-[11px] text-primary-400">{doc.version}</p>
                            </div>
                            <span class:list={['text-[11px] font-semibold px-2 py-0.5 rounded-full shrink-0', doc.statusBg]}>{doc.status}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                )}
                <!-- VvT mockup -->
                {i === 3 && (
                  <div class="w-full max-w-sm">
                    <div class="bg-white rounded-2xl shadow-md border border-primary-100 overflow-hidden">
                      <div class="px-4 py-3 bg-primary-50 border-b border-primary-100 flex items-center justify-between">
                        <span class="text-xs font-semibold text-primary-700">VvT: Annex A overzicht</span>
                        <button class="text-xs bg-indigo-600 text-white px-2.5 py-1 rounded-lg font-semibold">PDF export</button>
                      </div>
                      <div class="p-4 space-y-2">
                        {[
                          { code: 'A5', name: 'Organisatorische maatregelen', total: 37, done: 37, pct: 100 },
                          { code: 'A6', name: 'Personeelsmaatregelen', total: 8, done: 6, pct: 75 },
                          { code: 'A7', name: 'Fysieke maatregelen', total: 14, done: 9, pct: 64 },
                          { code: 'A8', name: 'Technische maatregelen', total: 34, done: 18, pct: 53 },
                        ].map(cat => (
                          <div class="p-3 rounded-xl bg-primary-50/60 border border-primary-100">
                            <div class="flex items-center justify-between mb-2">
                              <div class="flex items-center gap-2">
                                <span class="text-xs font-bold text-indigo-600 bg-indigo-50 px-1.5 py-0.5 rounded">{cat.code}</span>
                                <span class="text-xs font-semibold text-primary-950">{cat.name}</span>
                              </div>
                              <span class="text-xs text-primary-500">{cat.done}/{cat.total}</span>
                            </div>
                            <div class="w-full bg-primary-100 rounded-full h-1.5">
                              <div class:list={['h-1.5 rounded-full', cat.pct === 100 ? 'bg-green-500' : 'bg-indigo-500']} style={`width: ${cat.pct}%`}></div>
                            </div>
                          </div>
                        ))}
                        <div class="flex items-center justify-between pt-1">
                          <span class="text-xs text-primary-500">Totaal: 70 van 93 maatregelen</span>
                          <span class="text-xs font-bold text-indigo-600">75%</span>
                        </div>
                      </div>
                    </div>
                  </div>
                )}
                <!-- Gap Analyse mockup -->
                {i === 4 && (
                  <div class="w-full max-w-sm">
                    <div class="bg-white rounded-2xl shadow-md border border-primary-100 overflow-hidden">
                      <div class="px-4 py-3 bg-primary-50 border-b border-primary-100 flex items-center justify-between">
                        <span class="text-xs font-semibold text-primary-700">Gap Analyse: Nulmeting</span>
                        <span class="text-xs bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full font-semibold">62% compliant</span>
                      </div>
                      <div class="p-4 space-y-3">
                        {[
                          { label: 'H4 Context', pct: 80, color: 'bg-emerald-500' },
                          { label: 'H5 Leiderschap', pct: 90, color: 'bg-emerald-500' },
                          { label: 'H6 Planning', pct: 55, color: 'bg-amber-500' },
                          { label: 'H7 Ondersteuning', pct: 70, color: 'bg-emerald-400' },
                          { label: 'H8 Uitvoering', pct: 40, color: 'bg-red-400' },
                          { label: 'H9 Evaluatie', pct: 60, color: 'bg-amber-400' },
                          { label: 'H10 Verbetering', pct: 45, color: 'bg-amber-500' },
                        ].map(item => (
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-xs font-medium text-primary-700">{item.label}</span>
                              <span class="text-xs text-primary-500">{item.pct}%</span>
                            </div>
                            <div class="w-full bg-primary-100 rounded-full h-2">
                              <div class:list={['h-2 rounded-full', item.color]} style={`width: ${item.pct}%`}></div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                )}
                <!-- Audit mockup -->
                {i === 5 && (
                  <div class="w-full max-w-sm">
                    <div class="bg-white rounded-2xl shadow-md border border-primary-100 overflow-hidden">
                      <div class="px-4 py-3 bg-primary-50 border-b border-primary-100 flex items-center justify-between">
                        <span class="text-xs font-semibold text-primary-700">Audits: 2025</span>
                        <button class="text-xs bg-teal-600 text-white px-2.5 py-1 rounded-lg font-semibold">+ Audit plannen</button>
                      </div>
                      <div class="divide-y divide-primary-50">
                        {[
                          { name: 'Interne audit H4-H6', date: '15 jan 2025', status: 'Afgerond', statusBg: 'bg-green-100 text-green-700', findings: 3 },
                          { name: 'Interne audit H7-H10', date: '28 feb 2025', status: 'Actief', statusBg: 'bg-blue-100 text-blue-700', findings: 1 },
                          { name: 'Pre-audit certificering', date: '20 apr 2025', status: 'Gepland', statusBg: 'bg-amber-100 text-amber-700', findings: 0 },
                          { name: 'Certificeringsaudit', date: '12 mei 2025', status: 'Gepland', statusBg: 'bg-amber-100 text-amber-700', findings: 0 },
                        ].map(audit => (
