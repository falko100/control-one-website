---
const navItems = [
  { label: 'Coach', icon: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  { label: "Risico's", icon: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z' },
  { label: 'Documenten', icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z' },
  { label: 'Audits', icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z' },
  { label: 'Leveranciers', icon: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z' },
];

const coachSteps = [
  { label: 'Scope bepalen', done: true },
  { label: 'Risicoanalyse', done: true },
  { label: 'Maatregelenplan', done: true },
  { label: 'Beleidsdocumenten', done: false, active: true },
  { label: 'Interne audit', done: false },
];

const auditItems = [
  { label: 'A.5 Beleid & org.', status: 'Voldaan', badgeClass: 'bg-green-100 text-green-700' },
  { label: 'A.8 Beheer activa', status: 'Deels', badgeClass: 'bg-amber-100 text-amber-700' },
  { label: 'A.9 Toegangsbeheer', status: 'Open', badgeClass: 'bg-red-100 text-red-600' },
  { label: 'A.12 Beveiliging', status: 'Voldaan', badgeClass: 'bg-green-100 text-green-700' },
];

const riskCells = Array.from({ length: 25 }, (_, i) => {
  const row = Math.floor(i / 5);
  const col = i % 5;
  const score = (row + 1) * (col + 1);
  return score >= 16 ? 'bg-red-400' : score >= 9 ? 'bg-amber-400' : score >= 4 ? 'bg-yellow-300' : 'bg-emerald-300';
});

const recentActivity = [
  { text: 'Beleid goedgekeurd', dot: 'bg-green-400', time: '2u' },
  { text: "3 risico's bijgewerkt", dot: 'bg-primary-400', time: 'Gist.' },
  { text: 'Audit gepland: 15 jan', dot: 'bg-amber-400', time: '2d' },
];
---

<div class="relative select-none w-full" style="height: 490px;">

  <!-- ══ MAIN DASHBOARD CARD ══ -->
  <div class="absolute rounded-xl overflow-hidden shadow-2xl shadow-primary-950/40 border border-white/10 bg-white"
       style="left: 44px; right: 0; top: 0; bottom: 30px;">

    <!-- Browser chrome -->
    <div class="flex items-center gap-3 px-3 py-2 bg-slate-100 border-b border-slate-200 shrink-0">
      <div class="flex gap-1.5 shrink-0">
        <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-amber-400"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-emerald-400"></div>
      </div>
      <div class="flex-1 flex items-center gap-1.5 px-2 py-0.5 bg-white rounded text-[10px] text-slate-400 font-mono border border-slate-200">
        <svg class="w-2.5 h-2.5 text-slate-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
        </svg>
        app.control-one.nl
      </div>
    </div>

    <!-- App layout -->
    <div class="flex" style="height: calc(100% - 37px);">

      <!-- Sidebar -->
      <div class="w-36 shrink-0 bg-primary-950 flex flex-col overflow-hidden">
        <div class="px-3 py-2.5 border-b border-white/10">
          <div class="text-white font-bold text-xs tracking-tight">Control One</div>
        </div>
        <div class="px-2.5 py-2 border-b border-white/10">
          <div class="flex items-center gap-1.5 px-2 py-1 bg-white/10 rounded-md">
            <div class="w-1 h-1 rounded-full bg-primary-400 shrink-0"></div>
            <span class="text-[10px] text-white/80">ISO 27001</span>
          </div>
        </div>
        <nav class="flex-1 px-1.5 py-2 space-y-0.5 overflow-hidden">
          <div class="flex items-center gap-2 px-2 py-1.5 rounded-md bg-white/15">
            <svg class="w-3 h-3 text-white shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
            <span class="text-[10px] text-white font-semibold">Dashboard</span>
          </div>
          {navItems.map(item => (
            <div class="flex items-center gap-2 px-2 py-1.5 rounded-md">
              <svg class="w-3 h-3 text-white/40 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon}></path>
              </svg>
              <span class="text-[10px] text-white/50">{item.label}</span>
            </div>
          ))}
        </nav>
      </div>

      <!-- Main content -->
      <div class="flex-1 flex flex-col bg-slate-50 overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2 bg-white border-b border-slate-100 shrink-0">
          <div>
            <div class="text-xs font-semibold text-slate-800">Dashboard</div>
            <div class="text-[10px] text-slate-400">ISO 27001: Informatiebeveiliging</div>
          </div>
          <div class="px-2 py-0.5 bg-primary-600 text-white text-[10px] font-semibold rounded-full">Actief</div>
        </div>

        <div class="flex-1 p-3 overflow-hidden space-y-2.5">

          <!-- Stat cards -->
          <div class="grid grid-cols-4 gap-1.5">
            <div class="bg-white rounded-lg border border-slate-100 p-2">
              <div class="text-[9px] text-slate-400">Coach</div>
              <div class="text-sm font-bold text-primary-700 leading-tight">14<span class="text-[9px] font-normal text-slate-400">/28</span></div>
            </div>
            <div class="bg-white rounded-lg border border-slate-100 p-2">
              <div class="text-[9px] text-slate-400">Risico's</div>
              <div class="text-sm font-bold text-amber-600 leading-tight">12</div>
            </div>
            <div class="bg-white rounded-lg border border-slate-100 p-2">
              <div class="text-[9px] text-slate-400">CPAR's</div>
              <div class="text-sm font-bold text-red-500 leading-tight">3</div>
            </div>
            <div class="bg-white rounded-lg border border-slate-100 p-2">
              <div class="text-[9px] text-slate-400">Maatregelen</div>
              <div class="text-sm font-bold text-primary-600 leading-tight">67<span class="text-[9px] font-normal text-slate-400">/93</span></div>
            </div>
          </div>

          <!-- Progress bar -->
          <div class="bg-white rounded-lg border border-slate-100 p-2.5">
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-[10px] font-medium text-slate-600">Implementatievoortgang</span>
              <span class="text-[10px] font-bold text-primary-700">52%</span>
            </div>
            <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-primary-500 to-primary-700 rounded-full" style="width: 52%"></div>
            </div>
            <div class="mt-1 flex justify-between text-[9px] text-slate-400">
              <span>Start</span>
              <span>Certificering</span>
            </div>
          </div>

          <!-- Bottom row -->
          <div class="grid grid-cols-2 gap-2">

            <!-- Risk heatmap -->
            <div class="bg-white rounded-lg border border-slate-100 p-2.5">
              <div class="text-[10px] font-medium text-slate-600 mb-1.5">Risicomatrix (5×5)</div>
              <div class="grid gap-0.5" style="grid-template-columns: repeat(5, 1fr);">
                {riskCells.map(color => (
                  <div class:list={['aspect-square rounded-sm', color]}></div>
                ))}
              </div>
              <div class="mt-1.5 flex gap-2 text-[9px] text-slate-400">
                <span class="flex items-center gap-0.5"><span class="w-1.5 h-1.5 rounded-sm bg-emerald-300 inline-block"></span>Laag</span>
                <span class="flex items-center gap-0.5"><span class="w-1.5 h-1.5 rounded-sm bg-amber-400 inline-block"></span>Mid</span>
                <span class="flex items-center gap-0.5"><span class="w-1.5 h-1.5 rounded-sm bg-red-400 inline-block"></span>Hoog</span>
              </div>
            </div>

            <!-- Recent activity -->
            <div class="bg-white rounded-lg border border-slate-100 p-2.5 overflow-hidden">
              <div class="text-[10px] font-medium text-slate-600 mb-1.5">Recente activiteit</div>
              <div class="space-y-1.5">
                {recentActivity.map(item => (
                  <div class="flex gap-1.5 items-start">
                    <div class:list={['w-1.5 h-1.5 rounded-full shrink-0 mt-0.5', item.dot]}></div>
                    <div>
                      <div class="text-[9px] text-slate-600 leading-tight">{item.text}</div>
                      <div class="text-[9px] text-slate-400">{item.time}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ FLOATING CARD: IMPLEMENTATIECOACH ══ -->
  <div class="absolute bg-white rounded-2xl overflow-hidden border border-slate-200"
       style="left: 0; top: 60px; width: 178px; z-index: 20; transform: rotate(-3.5deg); box-shadow: 0 20px 40px rgba(2,9,90,0.30), 0 4px 12px rgba(0,0,0,0.12);">
    <div class="px-3 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded-md bg-white/20 flex items-center justify-center shrink-0">
          <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div>
          <div class="text-white font-bold text-[10px] leading-tight">Implementatiecoach</div>
          <div class="text-blue-200 text-[9px]">Stap 14 van 28</div>
        </div>
      </div>
    </div>
    <div class="p-2.5 space-y-1">
      {coachSteps.map(step => (
        <div class:list={['flex items-center gap-2 px-1.5 py-1 rounded-lg', step.active && 'bg-blue-50']}>
          <div class:list={[
            'w-4 h-4 rounded-full flex items-center justify-center shrink-0',
            step.done ? 'bg-blue-500' : step.active ? 'border-2 border-blue-400' : 'border border-slate-200',
          ]}>
            {step.done && (
              <svg class="w-2.5 h-2.5 text-white" viewBox="0 0 10 10" fill="none">
                <path d="M2 5l2.5 2.5 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            )}
          </div>
          <span class:list={[
            'text-[9px] leading-tight',
            step.done ? 'text-slate-400 line-through' : step.active ? 'text-blue-700 font-semibold' : 'text-slate-500',
          ]}>{step.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ══ FLOATING CARD: AUDITBEHEER ══ -->
  <div class="absolute bg-white rounded-2xl overflow-hidden border border-slate-200"
       style="right: 4px; bottom: 0; width: 192px; z-index: 20; transform: rotate(2deg); box-shadow: 0 20px 40px rgba(2,9,90,0.30), 0 4px 12px rgba(0,0,0,0.12);">
    <div class="px-3 py-2.5 bg-gradient-to-r from-primary-800 to-primary-900">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded-md bg-white/20 flex items-center justify-center shrink-0">
          <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path>
          </svg>
        </div>
        <div>
          <div class="text-white font-bold text-[10px] leading-tight">Auditbeheer</div>
          <div class="text-primary-300 text-[9px]">Interne audit · Jan 2025</div>
        </div>
      </div>
    </div>
    <div class="p-2.5 space-y-1.5">
      {auditItems.map(item => (
        <div class="flex items-center justify-between gap-2">
          <span class="text-[9px] text-slate-600 truncate">{item.label}</span>
          <span class:list={['text-[9px] font-semibold px-1.5 py-0.5 rounded-full shrink-0', item.badgeClass]}>{item.status}</span>
        </div>
      ))}
    </div>
  </div>

</div>
