---

<section id="hoe-het-werkt" class="py-24" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-14">
      <p class="text-sm font-semibold uppercase tracking-widest text-accent-400 mb-3">Hoe het werkt</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight leading-tight">
        Jouw Organisatie,<br />ons Stappenplan
      </h2>
      <p class="mt-4 text-lg text-white/90 leading-relaxed">
        Control One structureert het volledige ISO-traject, zodat je altijd weet waar je staat en wat de volgende stap is.
      </p>
    </div>

    <!-- Verticale zigzag-tijdlijn -->
    <div class="relative">

      <!-- Gradient-lijn: mobiel links, desktop gecentreerd -->
      <div class="absolute left-5 lg:left-1/2 lg:-translate-x-1/2 top-3 bottom-3 w-[3px] rounded-full pointer-events-none" style="background: linear-gradient(180deg, #6fd0f0 0%, #01a2e8 72%, #34d399 100%); opacity: 0.55;"></div>

      <div>
        {steps.map((step, i) => (
          <div class={`hiw-row relative pl-14 lg:pl-0 ${i > 0 ? 'mt-8 lg:-mt-10' : ''} ${i % 2 === 1 ? 'hiw-rechts' : 'hiw-links'}`}>

            <!-- Genummerde bol op de lijn -->
            <div
              class="absolute left-5 -translate-x-1/2 top-6 lg:left-1/2 lg:top-1/2 lg:-translate-y-1/2 w-11 h-11 rounded-full flex items-center justify-center text-white text-base font-bold shadow-lg ring-4 ring-white/15 z-10"
              style={`background: ${step.numBg};`}
            >
              {i + 1}
            </div>

            <!-- Glass-kaart, afwisselend links en rechts van de lijn -->
            <div class={`lg:w-[calc(50%-3.5rem)] ${i % 2 === 1 ? 'lg:ml-auto' : ''}`}>
              <div class="bg-white/[0.07] border border-white/15 rounded-2xl p-5 sm:p-6 backdrop-blur hover:border-white/30 hover:bg-white/[0.1] transition-colors duration-300">
                <a href={step.href} class="group flex items-center gap-3.5 mb-2.5">
                  <div
                    class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 shadow-sm transition-transform duration-300 group-hover:scale-105"
                    style={`background: ${step.iconBg}; color: ${step.iconStroke};`}
                  >
                    <Fragment set:html={step.icon} />
                  </div>
                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-widest text-accent-400">Stap {step.number}</p>
                    <h3 class="text-lg font-bold text-white leading-snug group-hover:text-accent-400 transition-colors inline-flex items-center gap-1.5">
                      {step.title}
                      <svg class="w-4 h-4 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                    </h3>
                  </div>
                </a>
                <p class="text-sm text-primary-100/85 leading-relaxed">{step.description}</p>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {step.tags.map(tag => (
                    <a
                      href={tag.href}
                      class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold border transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-md"
                      style={`background: ${step.tagBg}; color: ${step.tagText}; border-color: ${step.tagBorder};`}
                    >
                      {tag.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="mt-12 pt-8 border-t border-white/20 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 text-sm text-white/55">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-blue-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Gemiddeld 3 tot 5 maanden naar certificering
      </div>
      <div class="hidden sm:block w-1 h-1 rounded-full bg-white/30"></div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-blue-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Geen consultant nodig
      </div>
      <div class="hidden sm:block w-1 h-1 rounded-full bg-white/30"></div>
      <a href="/demo" class="flex items-center gap-1.5 font-semibold text-white hover:text-blue-200 transition-colors">
        Bekijk de live demo
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

  </div>
</section>


<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const sectie = document.getElementById('hoe-het-werkt');
    if (!sectie) return;
    const rijen = Array.from(sectie.querySelectorAll<HTMLElement>('.hiw-row'));
    if (!rijen.length) return;

    // Initial state en reveal via inline styles: onafhankelijk van CSS-scoping, werkt in dev en prod
    const desktop = window.matchMedia('(min-width: 1024px)').matches;
    rijen.forEach((rij, i) => {
      rij.style.opacity = '0';
      rij.style.transform = desktop
        ? (rij.classList.contains('hiw-rechts') ? 'translateX(28px)' : 'translateX(-28px)')
        : 'translateY(24px)';
      rij.style.transition = `opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1) ${i * 130}ms, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1) ${i * 130}ms`;
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const rij = entry.target as HTMLElement;
          rij.style.opacity = '1';
          rij.style.transform = 'none';
          observer.unobserve(rij);
        }
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -10% 0px' });

    rijen.forEach(rij => observer.observe(rij));
  })();
</script>
