---

<section id="hoe-het-werkt" class="py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-20">
      <p class="text-sm font-semibold tracking-widest uppercase text-primary-600 mb-4">Hoe het werkt</p>
      <h2 class="text-4xl sm:text-5xl font-bold text-primary-950 tracking-tight leading-[1.1]">
        Van nul tot<br />gecertificeerd
      </h2>
      <p class="mt-5 text-lg text-primary-900/55 leading-relaxed">
        Control One structureert het volledige ISO-traject, zodat je altijd weet waar je staat en wat de volgende stap is.
      </p>
    </div>

    <!-- Timeline grid -->
    <div class="relative">

      <!-- Connecting line (desktop only) -->
      <div class="hidden lg:block absolute left-[10%] right-[10%] h-px bg-gradient-to-r from-blue-200 via-violet-200 via-orange-200 via-emerald-200 to-amber-200 pointer-events-none" style="top: 44px;"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-4">
        {steps.map((step, i) => (
          <div class="flex flex-col items-center text-center group">

            <!-- Icon node (sits on the line) -->
            <div class="relative mb-7 z-10">
              <!-- Step number badge -->
              <div
                class="absolute -top-2.5 -right-2.5 w-6 h-6 rounded-full flex items-center justify-center text-white text-[10px] font-bold shadow-md z-10 ring-2 ring-white"
                style={`background: ${step.numBg};`}
              >
                {step.number}
              </div>
              <!-- Icon circle -->
              <div
                class="w-[88px] h-[88px] rounded-3xl flex items-center justify-center shadow-sm transition-transform duration-300 group-hover:scale-105 group-hover:shadow-md"
                style={`background: ${step.iconBg}; color: ${step.iconStroke};`}
              >
                <Fragment set:html={step.icon} />
              </div>
            </div>

            <!-- Title -->
            <h3 class="text-lg font-bold text-primary-950 mb-3 leading-snug">{step.title}</h3>

            <!-- Description -->
            <p class="text-sm text-primary-900/55 leading-relaxed mb-5">{step.description}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 justify-center mt-auto">
              {step.tags.map(tag => (
                <span
                  class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold border"
                  style={`background: ${step.tagBg}; color: ${step.tagText}; border-color: ${step.tagBorder};`}
                >
                  {tag}
                </span>
              ))}
            </div>

          </div>
        ))}
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="mt-16 pt-10 border-t border-primary-100 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 text-sm text-primary-900/50">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Gemiddeld 3–5 maanden naar certificering
      </div>
      <div class="hidden sm:block w-1 h-1 rounded-full bg-primary-200"></div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Geen consultant nodig
      </div>
      <div class="hidden sm:block w-1 h-1 rounded-full bg-primary-200"></div>
      <a href="/demo" class="flex items-center gap-1.5 font-semibold text-primary-700 hover:text-primary-900 transition-colors">
        Bekijk de live demo
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

  </div>
</section>
