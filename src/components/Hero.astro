---
---

<section class="relative overflow-hidden" style="background: linear-gradient(160deg, #3468b8 0%, #4080cc 50%, #5090d8 100%);">

  <!-- Ambient glow orbs -->
  <div class="absolute top-0 left-1/2 w-[700px] h-[700px] bg-white/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/3 right-1/4 w-[400px] h-[400px] bg-accent-400/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6">

    <!-- ── Centered text + CTA block ── -->
    <div class="text-center pt-28 sm:pt-36 pb-12 max-w-3xl mx-auto">

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl xl:text-7xl font-bold tracking-tight text-white leading-[1.05]">
        Werken aan impact
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-primary-300">Control One Portal</span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-8 text-lg sm:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">
        Van risicoanalyse tot certificering: Control One begeleidt jouw organisatie stap voor stap. Alles op één plek, voor iedereen begrijpelijk.
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://app.control-one.nl/register" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-primary-950 bg-white hover:bg-primary-50 rounded-full transition-all shadow-xl shadow-black/25">
          Gratis starten · 14 dagen
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a href="/demo" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white border border-white/35 hover:border-white/60 hover:bg-white/10 rounded-full transition-all">
          Live Demo
        </a>
      </div>

      <!-- ISO norm badges (producten) -->
      <div class="mt-9 flex flex-wrap items-center justify-center gap-2">
        <a href="/iso-27001" class="px-3 py-1 text-[11px] font-bold tracking-widest rounded-full border border-white/60 bg-white/20 text-white hover:bg-white/30 hover:border-white transition-colors">ISO 27001</a>
        <a href="/iso-9001" class="px-3 py-1 text-[11px] font-bold tracking-widest rounded-full border border-white/60 bg-white/20 text-white hover:bg-white/30 hover:border-white transition-colors">ISO 9001</a>
        <a href="/iso-14001" class="px-3 py-1 text-[11px] font-bold tracking-widest rounded-full border border-white/60 bg-white/20 text-white hover:bg-white/30 hover:border-white transition-colors">ISO 14001</a>
        <a href="/iso-45001" class="px-3 py-1 text-[11px] font-bold tracking-widest rounded-full border border-white/60 bg-white/20 text-white hover:bg-white/30 hover:border-white transition-colors">ISO 45001</a>
      </div>

      <!-- Scheidingslijn -->
      <div class="mt-6 flex items-center justify-center gap-3">
        <div class="w-12 border-t border-white/30"></div>
        <div class="w-1 h-1 rounded-full bg-white/40"></div>
        <div class="w-12 border-t border-white/30"></div>
      </div>

      <!-- USPs -->
      <div class="mt-5 flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-sm text-white/85">
        <!-- Nederlands bedrijf -->
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-white/65 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Nederlands bedrijf · EU-hosting
        </div>
        <!-- Chat consultancy -->
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-white/65 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          5 uur gratis ISO-consultancy inbegrepen
        </div>
        <!-- Geen consultant nodig -->
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-white/65 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          Zelf implementeren, geen dure consultant
        </div>
        <!-- Talen -->
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-white/65 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802"/>
          </svg>
          Platform en templates in het Nederlands en Engels
        </div>
      </div>

    </div><!-- end text/CTA block -->

    <!-- ── Logo marquee ── -->
    <div class="mt-10 pb-14">
      <p class="text-center text-xs font-semibold uppercase tracking-widest text-white/55 mb-7">Vertrouwd door organisaties in heel Nederland</p>
      <div class="relative overflow-hidden">

        <div class="logo-marquee-track flex items-center gap-14">
          <!-- Set 1 -->
          <img src="/logos/clients/Bidfood.png" alt="Bidfood" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/unica_1_Wzps3Y.png" alt="Unica" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Logo_Moore_DRV.png" alt="Moore DRV" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Logo-inQdo-nieuw.png" alt="inQdo" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/waterschap-rivierenland-logo1.png" alt="Waterschap Rivierenland" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/hofberger-logo-langwerpig-1920w-1920w.png" alt="Hofberger" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/OminesLogoBlue.png" alt="Omines" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/logo_innvolve@2x.png" alt="Innvolve" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Caredate.png" alt="Caredate" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/jdn-logo.png" alt="JDN" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/1280px-AVROTROS_logo_2020.svg_.png" alt="AVROTROS" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Actabyte-logo-op-wit.png" alt="Actabyte" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/De-Kenniskamers.png" alt="De Kenniskamers" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Logo-IQPS3-2-met-wit-1.png" alt="IQPS" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/horizontal-for-white-background.png" alt="Klant" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <!-- Set 2 (duplicate for seamless loop) -->
          <img src="/logos/clients/Bidfood.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/unica_1_Wzps3Y.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Logo_Moore_DRV.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Logo-inQdo-nieuw.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/waterschap-rivierenland-logo1.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/hofberger-logo-langwerpig-1920w-1920w.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/OminesLogoBlue.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/logo_innvolve@2x.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Caredate.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/jdn-logo.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/1280px-AVROTROS_logo_2020.svg_.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Actabyte-logo-op-wit.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/De-Kenniskamers.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Logo-IQPS3-2-met-wit-1.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/horizontal-for-white-background.png" alt="" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .logo-marquee-track {
    width: max-content;
    animation: logo-scroll 45s linear infinite;
  }
  .logo-marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes logo-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .logo-item {
    filter: brightness(0) invert(1);
    opacity: 0.9;
    transition: opacity 0.3s ease;
    flex-shrink: 0;
  }
  .logo-item:hover {
    opacity: 1;
  }
</style>
