---
---

<section class="relative overflow-hidden bg-white pb-0">

  <!-- Subtle background tint -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary-50/50 to-primary-50/10 pointer-events-none"></div>

  <!-- Bottom gradient: bridges into the dark InteractiveShowcase below -->
  <div class="absolute bottom-0 left-0 right-0 h-40 pointer-events-none" style="background: linear-gradient(to bottom, transparent 0%, #1a3d6e 100%);"></div>

  <!-- Ambient glow orbs -->
  <div class="absolute top-0 left-1/2 w-[700px] h-[700px] bg-accent-400/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] bg-primary-100/60 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/3 right-1/4 w-[350px] h-[350px] bg-accent-400/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6">

    <!-- ── Centered text block ── -->
    <div class="text-center pt-28 sm:pt-32 max-w-3xl mx-auto">

      <!-- Badges -->

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-6xl xl:text-7xl font-bold tracking-tight text-primary-950 leading-[1.05]">
        Werken aan impact
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-accent-500 to-primary-600">Control One Portal</span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-lg sm:text-xl text-primary-700/70 max-w-2xl mx-auto leading-relaxed">
        Van risicoanalyse tot certificering: Control One begeleidt jouw organisatie stap voor stap. Alles op één plek, voor iedereen begrijpelijk.
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://app.control-one.nl/register" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-primary-950 hover:bg-primary-900 rounded-full transition-all shadow-lg shadow-primary-950/20">
          Gratis starten · 14 dagen
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a href="/demo" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-primary-800 border border-primary-200 hover:border-primary-400 hover:bg-primary-50 rounded-full transition-all">
          Live Demo
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4 sm:gap-6 text-sm text-primary-500">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          ISO 27001 &amp; 9001
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          ISO 14001 &amp; 45001
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Nederlands bedrijf · EU-hosting
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          5 uur gratis chat consultancy inbegrepen
        </div>
      </div>

    </div>

    <!-- ── Logo marquee ── -->
    <div class="mt-14 pb-44 relative z-10">
      <p class="text-center text-xs font-semibold uppercase tracking-widest text-primary-300 mb-8">Vertrouwd door organisaties in heel Nederland</p>
      <div class="relative overflow-hidden">
        <!-- Edge fades -->
        <div class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to right, white, transparent);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to left, white, transparent);"></div>

        <div class="logo-marquee-track flex items-center gap-14">
          <!-- Set 1 -->
          <img src="/logos/clients/Bidfood.png" alt="Bidfood" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/unica_1_Wzps3Y.png" alt="Unica" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Logo_Moore_DRV.png" alt="Moore DRV" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Logo-inQdo-nieuw.png" alt="inQdo" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/waterschap-rivierenland-logo1.jpg" alt="Waterschap Rivierenland" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/hofberger-logo-langwerpig-1920w-1920w.png" alt="Hofberger" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/OminesLogoBlue.png" alt="Omines" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/logo_innvolve@2x.png" alt="Innvolve" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Caredate.png" alt="Caredate" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/jdn-logo.jpeg" alt="JDN" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/1280px-AVROTROS_logo_2020.svg_.png" alt="AVROTROS" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Actabyte-logo-op-wit.png" alt="Actabyte" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/De-Kenniskamers.png" alt="De Kenniskamers" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/Logo-IQPS3-2-met-wit-1.png" alt="IQPS" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <img src="/logos/clients/horizontal-for-white-background.png" alt="Klant" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" />
          <!-- Set 2 (duplicate for seamless loop) -->
          <img src="/logos/clients/Bidfood.png" alt="Bidfood" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/unica_1_Wzps3Y.png" alt="Unica" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Logo_Moore_DRV.png" alt="Moore DRV" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Logo-inQdo-nieuw.png" alt="inQdo" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/waterschap-rivierenland-logo1.jpg" alt="Waterschap Rivierenland" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/hofberger-logo-langwerpig-1920w-1920w.png" alt="Hofberger" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/OminesLogoBlue.png" alt="Omines" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/logo_innvolve@2x.png" alt="Innvolve" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Caredate.png" alt="Caredate" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/jdn-logo.jpeg" alt="JDN" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/1280px-AVROTROS_logo_2020.svg_.png" alt="AVROTROS" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Actabyte-logo-op-wit.png" alt="Actabyte" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/De-Kenniskamers.png" alt="De Kenniskamers" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Logo-IQPS3-2-met-wit-1.png" alt="IQPS" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/horizontal-for-white-background.png" alt="Klant" class="logo-item h-9 w-auto object-contain max-w-[140px]" loading="lazy" aria-hidden="true" />
        </div>
      </div>
    </div>

<style>
  .logo-marquee-track {
    width: max-content;
    animation: logo-scroll 35s linear infinite;
  }
  .logo-marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes logo-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .logo-item {
    filter: grayscale(100%) opacity(0.5);
    mix-blend-mode: multiply;
    transition: filter 0.3s ease;
    flex-shrink: 0;
  }
  .logo-item:hover {
    filter: grayscale(0%) opacity(0.85);
  }
</style>


  </div>
</section>
