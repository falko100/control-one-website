---
---

<section class="relative overflow-hidden" style="background: linear-gradient(160deg, #132d5e 0%, #1b418a 50%, #2554a0 100%);">

  <!-- Ambient glow orbs -->
  <div class="absolute top-0 left-1/2 w-[700px] h-[700px] bg-white/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/3 right-1/4 w-[400px] h-[400px] bg-accent-400/15 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6">

    <!-- ── Centered text block ── -->
    <div class="text-center pt-28 sm:pt-36 pb-24 sm:pb-32 max-w-3xl mx-auto">

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl xl:text-7xl font-bold tracking-tight text-white leading-[1.05]">
        Werken aan impact
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-primary-300">Control One Portal</span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-lg sm:text-xl text-white/55 max-w-2xl mx-auto leading-relaxed">
        Van risicoanalyse tot certificering: Control One begeleidt jouw organisatie stap voor stap. Alles op één plek, voor iedereen begrijpelijk.
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://app.control-one.nl/register" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-primary-950 bg-white hover:bg-primary-50 rounded-full transition-all shadow-xl shadow-black/25">
          Gratis starten · 14 dagen
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a href="/demo" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white/85 border border-white/20 hover:border-white/40 hover:bg-white/8 rounded-full transition-all">
          Live Demo
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4 sm:gap-6 text-sm text-white/40">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          ISO 27001 &amp; 9001
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          ISO 14001 &amp; 45001
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Nederlands bedrijf · EU-hosting
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          5 uur gratis chat consultancy inbegrepen
        </div>
      </div>

    </div>

    <!-- ── Logo marquee ── -->
    <div class="mt-12 pb-14">
      <p class="text-center text-xs font-semibold uppercase tracking-widest text-white/30 mb-8">Vertrouwd door organisaties in heel Nederland</p>
      <div class="relative overflow-hidden">
        <div class="absolute left-0 top-0 bottom-0 w-20 z-10 pointer-events-none" style="background: linear-gradient(to right, #1b418a, transparent);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-20 z-10 pointer-events-none" style="background: linear-gradient(to left, #1b418a, transparent);"></div>

        <div class="logo-marquee-track flex items-center gap-14">
          <!-- Set 1 -->
          <img src="/logos/clients/Bidfood.png" alt="Bidfood" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/unica_1_Wzps3Y.png" alt="Unica" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/Logo_Moore_DRV.png" alt="Moore DRV" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/Logo-inQdo-nieuw.png" alt="inQdo" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/waterschap-rivierenland-logo1.jpg" alt="Waterschap Rivierenland" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/hofberger-logo-langwerpig-1920w-1920w.png" alt="Hofberger" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/OminesLogoBlue.png" alt="Omines" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/logo_innvolve@2x.png" alt="Innvolve" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/Caredate.png" alt="Caredate" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/jdn-logo.jpeg" alt="JDN" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/1280px-AVROTROS_logo_2020.svg_.png" alt="AVROTROS" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/Actabyte-logo-op-wit.png" alt="Actabyte" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/De-Kenniskamers.png" alt="De Kenniskamers" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/Logo-IQPS3-2-met-wit-1.png" alt="IQPS" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <img src="/logos/clients/horizontal-for-white-background.png" alt="Klant" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" />
          <!-- Set 2 (duplicate for seamless loop) -->
          <img src="/logos/clients/Bidfood.png" alt="Bidfood" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/unica_1_Wzps3Y.png" alt="Unica" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Logo_Moore_DRV.png" alt="Moore DRV" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Logo-inQdo-nieuw.png" alt="inQdo" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/waterschap-rivierenland-logo1.jpg" alt="Waterschap Rivierenland" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/hofberger-logo-langwerpig-1920w-1920w.png" alt="Hofberger" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/OminesLogoBlue.png" alt="Omines" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/logo_innvolve@2x.png" alt="Innvolve" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Caredate.png" alt="Caredate" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/jdn-logo.jpeg" alt="JDN" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/1280px-AVROTROS_logo_2020.svg_.png" alt="AVROTROS" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Actabyte-logo-op-wit.png" alt="Actabyte" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/De-Kenniskamers.png" alt="De Kenniskamers" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/Logo-IQPS3-2-met-wit-1.png" alt="IQPS" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
          <img src="/logos/clients/horizontal-for-white-background.png" alt="Klant" class="logo-item h-8 w-auto object-contain max-w-[130px]" loading="lazy" aria-hidden="true" />
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .logo-marquee-track {
    width: max-content;
    animation: logo-scroll 40s linear infinite;
  }
  .logo-marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes logo-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .logo-item {
    filter: grayscale(1) invert(1);
    mix-blend-mode: screen;
    opacity: 0.8;
    transition: opacity 0.3s ease;
    flex-shrink: 0;
  }
  .logo-item:hover {
    opacity: 1;
  }
</style>
