<section class="relative overflow-hidden bg-white" style="min-height: 88vh;">

  <!-- Subtle background tint -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary-50/50 to-primary-50/10 pointer-events-none"></div>

  <!-- Ambient glow orbs -->
  <div class="absolute top-0 left-1/2 w-[700px] h-[700px] bg-accent-400/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] bg-primary-100/60 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/3 right-1/4 w-[350px] h-[350px] bg-accent-400/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6">

    <!-- ── Centered text block ── -->
    <div class="text-center pt-28 sm:pt-32 max-w-3xl mx-auto">

      <!-- Badges -->

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-6xl xl:text-7xl font-bold tracking-tight text-primary-950 leading-[1.05]">
        Werken aan impact
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-accent-500 to-primary-600">Control One Portal</span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-lg sm:text-xl text-primary-700/70 max-w-2xl mx-auto leading-relaxed">
        Van risicoanalyse tot certificering: Control One begeleidt jouw organisatie stap voor stap. Alles op één plek, voor iedereen begrijpelijk.
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://app.control-one.nl/register" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-primary-950 hover:bg-primary-900 rounded-full transition-all shadow-lg shadow-primary-950/20">
          Gratis starten · 14 dagen
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a href="/demo" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-primary-800 border border-primary-200 hover:border-primary-400 hover:bg-primary-50 rounded-full transition-all">
          Live Demo
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4 sm:gap-6 text-sm text-primary-500">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          ISO 27001 &amp; 9001
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          ISO 14001 &amp; 45001
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Nederlands bedrijf · EU-hosting
        </div>
      </div>

    </div>

    <!-- ── Screenshot fan (desktop) ── -->
    <div class="hidden lg:flex items-end justify-center mt-10 relative" style="height: 420px; gap: 10px;">

      <!-- Card 1: left outer -->
      <div class="hero-card hero-card-1 shrink-0 rounded-2xl overflow-hidden shadow-xl border border-black/8" style="width: 205px;"
           data-src="/screenshots/portal-vendors.png" data-alt="Leveranciersbeheer portal">
        <img src="/screenshots/portal-vendors.png" alt="Leveranciersbeheer portal"
             class="w-full" style="height: 290px; object-fit: cover; object-position: 0% 8%;" loading="eager" />
      </div>

      <!-- Card 2: left inner -->
      <div class="hero-card hero-card-2 shrink-0 rounded-2xl overflow-hidden shadow-xl border border-black/8" style="width: 240px;"
           data-src="/screenshots/portal-risks.png" data-alt="Risicoanalyse portal">
        <img src="/screenshots/portal-risks.png" alt="Risicoanalyse portal"
             class="w-full" style="height: 312px; object-fit: cover; object-position: 0% 8%;" loading="eager" />
      </div>

      <!-- Card 3: center (featured) -->
      <div class="hero-card hero-card-3 shrink-0 rounded-2xl overflow-hidden relative z-10" style="width: 300px;"
           data-src="/screenshots/portal-dashboard.png" data-alt="Control One dashboard">
        <img src="/screenshots/portal-dashboard.png" alt="Control One dashboard"
             class="w-full" style="height: 348px; object-fit: cover; object-position: 0% 8%;" loading="eager" />
      </div>

      <!-- Card 4: right inner -->
      <div class="hero-card hero-card-4 shrink-0 rounded-2xl overflow-hidden shadow-xl border border-black/8" style="width: 240px;"
           data-src="/screenshots/portal-documents.png" data-alt="Documentbeheer portal">
        <img src="/screenshots/portal-documents.png" alt="Documentbeheer portal"
             class="w-full" style="height: 312px; object-fit: cover; object-position: 0% 8%;" loading="eager" />
      </div>

      <!-- Card 5: right outer -->
      <div class="hero-card hero-card-5 shrink-0 rounded-2xl overflow-hidden shadow-xl border border-black/8" style="width: 205px;"
           data-src="/screenshots/portal-coach.png" data-alt="Implementatiecoach portal">
        <img src="/screenshots/portal-coach.png" alt="Implementatiecoach portal"
             class="w-full" style="height: 290px; object-fit: cover; object-position: 0% 8%;" loading="eager" />
      </div>


    </div>

<!-- ── Lightbox ── -->
<div id="hero-lightbox" class="hero-lightbox" aria-hidden="true">
  <button class="hero-lightbox-close" id="hero-lightbox-close" aria-label="Sluiten">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>
  <div class="hero-lightbox-backdrop" id="hero-lightbox-backdrop"></div>
  <div class="hero-lightbox-content">
    <img id="hero-lightbox-img" src="" alt="" />
  </div>
</div>

<style>
  /* ── Lightbox ── */
  .hero-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .hero-lightbox.is-open {
    opacity: 1;
    pointer-events: all;
  }
  .hero-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(2, 9, 90, 0.75);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .hero-lightbox-content {
    position: relative;
    z-index: 1;
    max-width: min(90vw, 1200px);
    max-height: 85vh;
    transform: scale(0.92);
    transition: transform 0.35s cubic-bezier(0.34, 1.3, 0.64, 1);
  }
  .hero-lightbox.is-open .hero-lightbox-content {
    transform: scale(1);
  }
  .hero-lightbox-content img {
    width: 100%;
    height: auto;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 16px;
    box-shadow: 0 0 0 1px rgba(111,208,240,0.2), 0 32px 80px rgba(2,9,90,0.5);
  }
  .hero-lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 2;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .hero-lightbox-close:hover {
    background: rgba(255,255,255,0.28);
  }

  /* ── Hero cards ── */
  .hero-card {
    transform-origin: bottom center;
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.4s ease,
      filter 0.4s ease;
    cursor: pointer;
    position: relative;
  }

  .hero-card-1 { transform: rotate(-10deg) translateY(30px); }
  .hero-card-2 { transform: rotate(-5deg) translateY(14px); }
  .hero-card-3 {
    transform: rotate(0deg);
    box-shadow: 0 0 0 1px rgba(1,162,232,0.25), 0 25px 50px rgba(2,9,90,0.15);
  }
  .hero-card-4 { transform: rotate(5deg) translateY(14px); }
  .hero-card-5 { transform: rotate(10deg) translateY(30px); }

  .hero-card-1:hover { transform: rotate(-10deg) translateY(10px) scale(1.07); z-index: 20; }
  .hero-card-2:hover { transform: rotate(-5deg) translateY(-4px) scale(1.07); z-index: 20; }
  .hero-card-3:hover { transform: rotate(0deg) translateY(-10px) scale(1.08); z-index: 20; }
  .hero-card-4:hover { transform: rotate(5deg) translateY(-4px) scale(1.07); z-index: 20; }
  .hero-card-5:hover { transform: rotate(10deg) translateY(10px) scale(1.07); z-index: 20; }

  .hero-card:hover {
    filter: brightness(1.06) drop-shadow(0 8px 24px rgba(1,162,232,0.20));
    box-shadow: 0 0 0 1.5px rgba(1,162,232,0.35), 0 20px 48px rgba(2,9,90,0.18);
  }

  .hero-card.is-active {
    box-shadow: 0 0 0 2.5px rgba(1,162,232,0.7), 0 20px 48px rgba(2,9,90,0.22);
    filter: brightness(1.08);
  }

  /* ── Round-robin auto-highlight (mirrors hover transforms per card) ── */
  .hero-card.is-lit {
    filter: brightness(1.06) drop-shadow(0 8px 24px rgba(1,162,232,0.20));
    box-shadow: 0 0 0 1.5px rgba(1,162,232,0.35), 0 20px 48px rgba(2,9,90,0.18);
    z-index: 20;
  }
  .hero-card-1.is-lit { transform: rotate(-10deg) translateY(10px) scale(1.07); }
  .hero-card-2.is-lit { transform: rotate(-5deg) translateY(-4px) scale(1.07); }
  .hero-card-3.is-lit { transform: rotate(0deg) translateY(-10px) scale(1.08); }
  .hero-card-4.is-lit { transform: rotate(5deg) translateY(-4px) scale(1.07); }
  .hero-card-5.is-lit { transform: rotate(10deg) translateY(10px) scale(1.07); }
</style>

<script>
  const lightbox = document.getElementById('hero-lightbox');
  const lightboxImg = document.getElementById('hero-lightbox-img');
  const lightboxClose = document.getElementById('hero-lightbox-close');
  const lightboxBackdrop = document.getElementById('hero-lightbox-backdrop');

  function openLightbox(src, alt) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    document.querySelectorAll('.hero-card.is-active').forEach(c => c.classList.remove('is-active'));
  }

  document.querySelectorAll('.hero-card[data-src]').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.hero-card.is-active').forEach(c => c.classList.remove('is-active'));
      card.classList.add('is-active');
      openLightbox(card.dataset.src, card.dataset.alt);
    });
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBackdrop.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

  // ── Round-robin auto-highlight ──────────────────────────
  const cards = Array.from(document.querySelectorAll('.hero-card'));
  const fan   = document.querySelector('.hero-card')?.closest('div[style*="height: 420px"]');
  let litIndex = 2; // start at center card
  let autoTimer: ReturnType<typeof setInterval> | null = null;
  let isHovered = false;

  function setLit(index: number) {
    cards.forEach((c, i) => c.classList.toggle('is-lit', i === index));
  }

  function startAuto() {
    if (autoTimer) return;
    autoTimer = setInterval(() => {
      litIndex = (litIndex + 1) % cards.length;
      setLit(litIndex);
    }, 1800);
  }

  function stopAuto() {
    if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
    cards.forEach(c => c.classList.remove('is-lit'));
  }

  // Pause when user hovers any card
  cards.forEach(card => {
    card.addEventListener('mouseenter', () => { isHovered = true; stopAuto(); });
    card.addEventListener('mouseleave', () => { isHovered = false; startAuto(); });
  });

  // Start immediately
  setLit(litIndex);
  startAuto();
</script>


  </div>
</section>
