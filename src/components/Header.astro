---
const navLinks = [
  { label: 'Functies', href: '/features' },
  { label: 'Hoe het werkt', href: '/#hoe-het-werkt' },
  { label: 'Prijzen', href: '/pricing' },
  { label: 'FAQ', href: '/#faq' },
];

const frameworkLinks = [
  { label: 'ISO 27001', href: '/iso-27001' },
  { label: 'ISO 9001', href: '/iso-9001' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-primary-100">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/logo.svg" alt="Control One" class="h-7" />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={link.href} class="text-sm font-medium text-primary-900/70 hover:text-primary-700 transition-colors">
          {link.label}
        </a>
      ))}
      <div class="relative group">
        <button class="text-sm font-medium text-primary-900/70 hover:text-primary-700 transition-colors flex items-center gap-1">
          Frameworks
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 hidden group-hover:block">
          <div class="bg-white border border-primary-100 rounded-lg shadow-lg py-2 min-w-[160px]">
            {frameworkLinks.map(link => (
              <a href={link.href} class="block px-4 py-2 text-sm text-primary-900/70 hover:bg-primary-50 hover:text-primary-700 transition-colors">
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-3">
      <a href="#" class="hidden sm:inline-flex text-sm font-medium text-primary-900/70 hover:text-primary-700 transition-colors">
        Inloggen
      </a>
      <a href="/demo" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-primary-700 hover:bg-primary-800 rounded-lg transition-colors shadow-sm">
        Gratis Proberen
      </a>
    </div>
  </div>
</header>
