---
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-primary-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/logo.svg" alt="Control One" class="h-8" />
    </a>

    <nav class="hidden lg:flex items-center gap-7">

      <!-- ── Portal mega-dropdown ── -->
      <div class="relative group">
        <button class="text-sm font-medium text-primary-900/70 hover:text-primary-700 transition-colors flex items-center gap-1">
          Portal
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 hidden group-hover:block z-50">
          <div class="bg-white border border-primary-100 rounded-xl shadow-xl overflow-hidden w-[500px]">

            <!-- Panel header -->
            <div class="px-4 py-2.5 bg-primary-50/80 border-b border-primary-100">
              <p class="text-[11px] font-semibold text-primary-500 uppercase tracking-widest">Control One Portal</p>
            </div>

            <!-- 2-column item grid -->
            <div class="p-3 grid grid-cols-2 gap-0.5">

              <!-- Portal overzicht -->
              <a href="/features" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-primary-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-primary-100 flex items-center justify-center shrink-0 text-primary-600 group-hover/item:bg-primary-200 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Portal overzicht</p>
                  <p class="text-xs text-primary-900/50">Alles wat de portal biedt</p>
                </div>
              </a>

              <!-- Templates -->
              <a href="/templates" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-emerald-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-emerald-50 flex items-center justify-center shrink-0 text-emerald-600 group-hover/item:bg-emerald-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 004.5 9v.878m13.5-3A2.25 2.25 0 0119.5 9v.878m0 0a2.246 2.246 0 00-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0121 12v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6c0-.98.626-1.813 1.5-2.122"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Templates</p>
                  <p class="text-xs text-primary-900/50">120+ vooraf ingevulde documenten</p>
                </div>
              </a>

              <!-- Maatregelen -->
              <a href="/maatregelen" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-blue-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 text-blue-600 group-hover/item:bg-blue-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Maatregelen</p>
                  <p class="text-xs text-primary-900/50">93 Annex A beheersmaatregelen</p>
                </div>
              </a>

              <!-- Documentbeheer -->
              <a href="/documenten" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-violet-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-violet-50 flex items-center justify-center shrink-0 text-violet-600 group-hover/item:bg-violet-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Documentbeheer</p>
                  <p class="text-xs text-primary-900/50">Beleid & procedures beheren</p>
                </div>
              </a>

              <!-- Coach -->
              <a href="/coach" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-amber-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center shrink-0 text-amber-600 group-hover/item:bg-amber-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Coach</p>
                  <p class="text-xs text-primary-900/50">Stapsgewijze implementatiegids</p>
                </div>
              </a>

              <!-- Kennisbank -->
              <a href="/kennisbank" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-teal-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-teal-50 flex items-center justify-center shrink-0 text-teal-600 group-hover/item:bg-teal-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Kennisbank</p>
                  <p class="text-xs text-primary-900/50">ISO kennis direct beschikbaar</p>
                </div>
              </a>

              <!-- Risicoanalyse -->
              <a href="/risicoanalyse" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-red-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-red-50 flex items-center justify-center shrink-0 text-red-600 group-hover/item:bg-red-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Risicoanalyse</p>
                  <p class="text-xs text-primary-900/50">Risicoregister & risicomatrix</p>
                </div>
              </a>

              <!-- Audits -->
              <a href="/audits" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-orange-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-orange-50 flex items-center justify-center shrink-0 text-orange-600 group-hover/item:bg-orange-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0118 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3l1.5 1.5 3-3.75"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Audits</p>
                  <p class="text-xs text-primary-900/50">Intern & extern auditbeheer</p>
                </div>
              </a>

              <!-- Leveranciers -->
              <a href="/leveranciers" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-cyan-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-cyan-50 flex items-center justify-center shrink-0 text-cyan-600 group-hover/item:bg-cyan-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Leveranciers</p>
                  <p class="text-xs text-primary-900/50">Vendor management & beoordeling</p>
                </div>
              </a>

              <!-- Directiebeoordeling -->
              <a href="/directiebeoordeling" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-indigo-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-indigo-50 flex items-center justify-center shrink-0 text-indigo-600 group-hover/item:bg-indigo-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">Directiebeoordeling</p>
                  <p class="text-xs text-primary-900/50">Management reviews & verslagen</p>
                </div>
              </a>

            </div>

            <!-- Footer: demo link -->
            <div class="px-3 pb-3 pt-1">
              <a href="/demo" class="flex items-center justify-between px-3 py-2 rounded-lg bg-primary-50 hover:bg-primary-100 transition-colors group/demo">
                <span class="text-xs font-semibold text-primary-700">Bekijk de live demo →</span>
                <svg class="w-3.5 h-3.5 text-primary-500 group-hover/demo:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
            </div>

          </div>
        </div>
      </div>

      <!-- ── Frameworks dropdown ── -->
      <div class="relative group">
        <button class="text-sm font-medium text-primary-900/70 hover:text-primary-700 transition-colors flex items-center gap-1">
          Frameworks
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 hidden group-hover:block z-50">
          <div class="bg-white border border-primary-100 rounded-xl shadow-xl overflow-hidden w-[320px]">

            <!-- Panel header -->
            <div class="px-4 py-2.5 bg-primary-50/80 border-b border-primary-100">
              <p class="text-[11px] font-semibold text-primary-500 uppercase tracking-widest">Ondersteunde normen</p>
            </div>

            <!-- Items -->
            <div class="p-3 flex flex-col gap-0.5">

              <!-- ISO 27001 -->
              <a href="/iso-27001" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-blue-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 text-blue-600 group-hover/item:bg-blue-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">ISO 27001</p>
                  <p class="text-xs text-primary-900/50">Informatiebeveiliging</p>
                </div>
              </a>

              <!-- ISO 9001 -->
              <a href="/iso-9001" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-emerald-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-emerald-50 flex items-center justify-center shrink-0 text-emerald-600 group-hover/item:bg-emerald-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">ISO 9001</p>
                  <p class="text-xs text-primary-900/50">Kwaliteitsmanagement</p>
                </div>
              </a>

              <!-- ISO 14001 -->
              <a href="/iso-14001" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-green-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-green-50 flex items-center justify-center shrink-0 text-green-600 group-hover/item:bg-green-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253M3.157 7.582A8.959 8.959 0 003 12c0 .778.099 1.533.284 2.253"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">ISO 14001</p>
                  <p class="text-xs text-primary-900/50">Milieumanagement</p>
                </div>
              </a>

              <!-- ISO 45001 -->
              <a href="/iso-45001" class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg hover:bg-amber-50 transition-colors group/item">
                <div class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center shrink-0 text-amber-600 group-hover/item:bg-amber-100 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-primary-950">ISO 45001</p>
                  <p class="text-xs text-primary-900/50">Arbo & Veiligheid</p>
                </div>
              </a>

            </div>

            <!-- Footer: alle frameworks -->
            <div class="px-3 pb-3 pt-1">
              <a href="/frameworks" class="flex items-center justify-between px-3 py-2 rounded-lg bg-primary-50 hover:bg-primary-100 transition-colors group/fw">
                <span class="text-xs font-semibold text-primary-700">Bekijk alle frameworks →</span>
                <svg class="w-3.5 h-3.5 text-primary-500 group-hover/fw:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
            </div>

          </div>
        </div>
      </div>

      <!-- Prijzen -->
      <a href="/pricing" class="text-sm font-medium text-primary-900/70 hover:text-primary-700 transition-colors">Prijzen</a>

      <a href="/over-ons" class="text-sm font-medium text-primary-900/70 hover:text-primary-700 transition-colors">Over ons</a>
      <a href="/faq" class="text-sm font-medium text-primary-900/70 hover:text-primary-700 transition-colors">FAQ</a>
      <a href="/contact" class="text-sm font-medium text-primary-900/70 hover:text-primary-700 transition-colors">Contact</a>
    </nav>

    <div class="flex items-center gap-3">
      <a href="/demo" class="hidden lg:inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold text-primary-700 bg-primary-50 hover:bg-primary-100 border border-primary-200 rounded-lg transition-colors">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        Demo
      </a>
      <a href="https://app.control-one.nl/register" class="hidden lg:inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-primary-700 hover:bg-primary-800 rounded-lg transition-colors shadow-sm">
        Gratis Starten
      </a>
      <!-- Hamburger button (mobile + tablet only) -->
