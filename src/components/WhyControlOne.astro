---
---

<section class="py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 mb-4">Waarom Control One</p>
      <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-primary-950 leading-[1.1]">
        ISO voor iedereen,<br />van starten tot doorgroeien
      </h2>
      <p class="mt-5 text-lg text-primary-900/55 leading-relaxed">
        De meeste tools geven je een lege omgeving. Control One geeft je een volledig pad — van nulmeting tot certificaat.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

      <!-- Card 1: De Coach – 2 cols, dark -->
      <div class="lg:col-span-2 rounded-3xl overflow-hidden text-white relative" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);">
        <div class="absolute top-0 right-0 w-96 h-96 bg-accent-400/6 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-300/6 rounded-full blur-3xl pointer-events-none"></div>

        <div class="flex flex-col lg:flex-row h-full">

          <!-- Left: copy + stats -->
          <div class="relative z-10 flex flex-col justify-center p-6 lg:p-10 lg:w-[44%] shrink-0">
            <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 rounded-full px-3 py-1.5 mb-7 w-fit">
              <svg class="w-3.5 h-3.5 text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c-.317-.159.69-.159 1.006 0l4.994 2.497z"/>
              </svg>
              <span class="text-xs font-bold uppercase tracking-widest text-white/75">Implementatiecoach</span>
            </div>

            <h3 class="text-3xl lg:text-4xl font-bold leading-tight mb-5">
              28 stappen.<br />Nul twijfel.
            </h3>
            <p class="text-white/60 text-sm leading-relaxed mb-8">
              Elke stap vertelt je wat ISO vereist, waarom het belangrijk is en wat jij vandaag concreet moet doen. Geen raden, geen consultant nodig.
            </p>

            <!-- Stats -->
            <div class="flex items-center gap-5 mb-8 pb-8 border-b border-white/10">
              <div class="text-center">
                <div class="text-3xl font-black text-white">28</div>
                <div class="text-[10px] font-semibold uppercase tracking-wide text-white/40 mt-0.5">stappen</div>
              </div>
              <div class="w-px h-10 bg-white/15"></div>
              <div class="text-center">
                <div class="text-3xl font-black text-white">4</div>
                <div class="text-[10px] font-semibold uppercase tracking-wide text-white/40 mt-0.5">fasen</div>
              </div>
              <div class="w-px h-10 bg-white/15"></div>
              <div class="text-center">
                <div class="text-3xl font-black text-accent-400">100%</div>
                <div class="text-[10px] font-semibold uppercase tracking-wide text-white/40 mt-0.5">ISO gedekt</div>
              </div>
            </div>

            <!-- Feature list -->
            <div class="space-y-2.5">
              {[
                'Stap-voor-stap begeleiding met ISO-uitleg',
                'Gap analyse en PDCA-cyclus ingebouwd',
                'Voortgang zichtbaar voor je hele team',
              ].map(item => (
                <div class="flex items-center gap-2.5 text-sm text-white/70">
                  <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {item}
                </div>
              ))}
            </div>
          </div>

          <!-- Right: UI mockup of a coach step -->
          <div class="relative hidden lg:flex flex-1 items-center justify-center p-8">
            <div class="w-full max-w-sm bg-white/10 backdrop-blur-sm border border-white/15 rounded-2xl overflow-hidden shadow-2xl">

              <!-- Header: phase + step -->
              <div class="px-5 py-4 border-b border-white/10 flex items-center justify-between">
                <div class="flex items-center gap-2.5">
                  <div class="w-7 h-7 rounded-lg bg-accent-400 flex items-center justify-center shrink-0">
                    <svg class="w-3.5 h-3.5 text-primary-950" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 6.75V15m6-6v8.25"/></svg>
                  </div>
                  <div>
                    <div class="text-[10px] font-bold uppercase tracking-widest text-white/40">Fase 01 · Voorbereiding</div>
                    <div class="text-xs font-semibold text-white">Stap 7 van 28</div>
                  </div>
                </div>
                <span class="text-[10px] font-bold bg-emerald-400/20 text-emerald-300 border border-emerald-400/30 px-2 py-1 rounded-lg">In uitvoering</span>
              </div>

              <!-- Progress bar -->
              <div class="px-5 pt-4 pb-1">
                <div class="flex justify-between text-[10px] text-white/40 mb-1.5">
                  <span>Voortgang</span><span>25%</span>
                </div>
                <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-accent-400 to-emerald-400 rounded-full" style="width: 25%"></div>
                </div>
              </div>

              <!-- Step content -->
              <div class="px-5 py-4">
                <h4 class="text-base font-bold text-white mb-2">Scope en toepassingsgebied bepalen</h4>
                <p class="text-xs text-white/55 leading-relaxed mb-4">
                  Definieer welke onderdelen van je organisatie onder het ISMS vallen. ISO 27001 cl. 4.3 vereist een gedocumenteerde scope.
                </p>
                <div class="inline-flex items-center gap-1.5 bg-white/8 border border-white/12 rounded-lg px-2.5 py-1.5 text-[10px] font-semibold text-white/60 mb-4">
                  <svg class="w-3 h-3 text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15"/></svg>
                  ISO 27001:2022 · Clausule 4.3
                </div>
                <button class="w-full flex items-center justify-center gap-2 bg-accent-400 hover:bg-accent-300 text-primary-950 font-semibold text-xs py-2.5 rounded-xl transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4"/></svg>
                  Stap afronden
                </button>
              </div>

              <!-- Dot navigation -->
              <div class="px-5 pb-4 flex items-center justify-center gap-1">
                {Array.from({length: 7}).map((_, i) => (
                  <div class={`rounded-full ${i === 6 ? 'w-4 h-1.5 bg-accent-400' : 'w-1.5 h-1.5 bg-white/20'}`}></div>
                ))}
              </div>

            </div>
          </div>

        </div>
      </div>

      <!-- Card 2: Sjablonen – split into two stacked cards -->
      <div class="flex flex-col gap-5">

        <!-- Card 2a: Documenten -->
        <div class="flex-1 rounded-3xl border border-primary-100 bg-gradient-to-br from-violet-50 to-white p-7 flex flex-col">
          <div class="w-11 h-11 rounded-2xl bg-violet-100 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
            </svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-widest text-violet-600 mb-2">Sjablonen</p>
          <h3 class="text-lg font-bold text-primary-950 mb-2 leading-snug">Start niet met een lege pagina</h3>
          <p class="text-primary-900/55 text-sm leading-relaxed mb-4">
            Alle benodigde documenten zijn vooraf ingevuld en direct bewerkbaar.
          </p>
          <div class="mt-auto space-y-2">
            {[
              'ISMS-handboek conform ISO 27001:2022',
              'Beleid voor alle 93 Annex A-clausules',
            ].map(item => (
              <div class="flex items-center gap-2.5 text-sm text-primary-800">
                <div class="w-4 h-4 rounded-full bg-violet-100 flex items-center justify-center shrink-0">
                  <svg class="w-2.5 h-2.5 text-violet-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                </div>
                {item}
              </div>
            ))}
          </div>
        </div>

        <!-- Card 2b: Templates -->
        <div class="flex-1 rounded-3xl border border-primary-100 bg-gradient-to-br from-violet-50/60 to-white p-7 flex flex-col">
          <div class="w-11 h-11 rounded-2xl bg-violet-100 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/>
            </svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-widest text-violet-600 mb-2">Templates</p>
          <h3 class="text-lg font-bold text-primary-950 mb-2 leading-snug">200+ sjablonen direct beschikbaar</h3>
          <p class="text-primary-900/55 text-sm leading-relaxed mb-4">
            Van risicoanalyse tot auditplan — elk sjabloon is ISO-conform en direct aanpasbaar.
          </p>
          <div class="mt-auto space-y-2">
            {[
              'Risicoanalyse- en audittemplates',
              'Directiebeoordeling template',
            ].map(item => (
              <div class="flex items-center gap-2.5 text-sm text-primary-800">
                <div class="w-4 h-4 rounded-full bg-violet-100 flex items-center justify-center shrink-0">
                  <svg class="w-2.5 h-2.5 text-violet-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                </div>
                {item}
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Card 3: Alles verbonden -->
      <div class="rounded-3xl border border-primary-100 bg-gradient-to-br from-teal-50 to-white p-8 flex flex-col">
        <div class="w-11 h-11 rounded-2xl bg-teal-100 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z"/>
          </svg>
        </div>
        <p class="text-xs font-semibold uppercase tracking-widest text-teal-600 mb-2">Alles verbonden</p>
        <h3 class="text-xl font-bold text-primary-950 mb-3">Eén platform, geen losse eilanden</h3>
        <p class="text-primary-900/55 text-sm leading-relaxed mb-5">
          Een bevinding uit een audit leidt direct tot een CPAR. Een risico koppelt automatisch aan de juiste maatregelen.
        </p>
        <div class="mt-auto grid grid-cols-2 gap-2">
          {[
            { label: "Risico's", svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>' },
            { label: 'Documenten', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>' },
            { label: 'Audits', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>' },
            { label: "CPAR's", svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>' },
            { label: 'Leveranciers', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>' },
            { label: 'Incidenten', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>' },
          ].map(item => (
            <div class="flex items-center gap-2 text-xs font-medium text-primary-700 bg-white border border-primary-100 rounded-xl px-3 py-2 shadow-sm">
              <svg class="w-3.5 h-3.5 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.svg}></svg>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Card 4: Multi-framework -->
      <div class="rounded-3xl border border-primary-100 bg-gradient-to-br from-blue-50 to-white p-8 flex flex-col">
        <div class="w-11 h-11 rounded-2xl bg-blue-100 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>
          </svg>
        </div>
        <p class="text-xs font-semibold uppercase tracking-widest text-blue-600 mb-2">Multi-framework</p>
        <h3 class="text-xl font-bold text-primary-950 mb-3">Meerdere normen, één platform</h3>
        <p class="text-primary-900/55 text-sm leading-relaxed mb-6">
          Beheer ISO 27001, 9001, 14001 en 45001 vanuit dezelfde omgeving. Documenten en risico's zijn herbruikbaar over frameworks, zonder dubbel werk.
        </p>
        <div class="mt-auto grid grid-cols-2 gap-2">
          {[
            { label: 'ISO 27001', sub: 'Informatiebeveiliging', color: 'bg-blue-50 border-blue-200 text-blue-700' },
            { label: 'ISO 9001', sub: 'Kwaliteit', color: 'bg-indigo-50 border-indigo-200 text-indigo-700' },
            { label: 'ISO 14001', sub: 'Milieu', color: 'bg-emerald-50 border-emerald-200 text-emerald-700' },
            { label: 'ISO 45001', sub: 'Arbo & Veiligheid', color: 'bg-amber-50 border-amber-200 text-amber-700' },
          ].map(fw => (
            <div class={`rounded-xl border px-3 py-2 ${fw.color}`}>
              <div class="text-xs font-bold">{fw.label}</div>
              <div class="text-[10px] opacity-70 leading-snug">{fw.sub}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Card 5: Direct starten -->
      <div class="rounded-3xl border border-amber-200/60 bg-gradient-to-br from-amber-50 to-orange-50/30 p-8 flex flex-col relative overflow-hidden">
        <div class="absolute -top-6 -right-6 w-32 h-32 bg-amber-300/20 rounded-full blur-2xl pointer-events-none"></div>
        <div class="relative z-10 w-11 h-11 rounded-2xl bg-amber-100 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="relative z-10">
          <div class="text-5xl font-black text-amber-600 tracking-tight leading-none mb-2">&lt;&nbsp;5 min</div>
          <p class="text-xs font-semibold uppercase tracking-widest text-amber-600 mb-3">Direct aan de slag</p>
          <p class="text-primary-900/55 text-sm leading-relaxed mb-6">
            Geen installatie, geen IT-afdeling. Maak een account aan en start vandaag nog met je ISO-traject.
          </p>
          <div class="space-y-2">
            {[
              'Geen creditcard bij aanmelding',
              'Geen installatie of IT-setup',
              'Direct toegang tot alle modules',
            ].map(item => (
              <div class="flex items-center gap-2 text-sm text-primary-800">
                <svg class="w-3.5 h-3.5 text-amber-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Card 6: Vergelijking – 3 cols full width -->
      <div class="lg:col-span-3 rounded-3xl border border-primary-100 bg-white p-5 sm:p-10">
        <div class="flex items-center gap-3 mb-8">
