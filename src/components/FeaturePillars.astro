// Accent color tokens for each pillar (hex for inline styles, Tailwind classes for JIT-safe usage)
const accentMap: Record<
  Pillar['accent'],
  { soft: string; strong: string; ring: string; text: string; hover: string; border: string }
> = {
  blue: {
    soft: 'bg-blue-50',
    strong: 'bg-blue-100',
    ring: 'ring-blue-200',
    text: 'text-blue-700',
    hover: 'hover:bg-blue-50',
    border: 'border-blue-200/70',
  },
  amber: {
    soft: 'bg-amber-50',
    strong: 'bg-amber-100',
    ring: 'ring-amber-200',
    text: 'text-amber-700',
    hover: 'hover:bg-amber-50',
    border: 'border-amber-200/70',
  },
  violet: {
    soft: 'bg-violet-50',
    strong: 'bg-violet-100',
    ring: 'ring-violet-200',
    text: 'text-violet-700',
    hover: 'hover:bg-violet-50',
    border: 'border-violet-200/70',
  },
  emerald: {
    soft: 'bg-emerald-50',
    strong: 'bg-emerald-100',
    ring: 'ring-emerald-200',
    text: 'text-emerald-700',
    hover: 'hover:bg-emerald-50',
    border: 'border-emerald-200/70',
  },
};
---

<section class="relative py-20 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-12 sm:mb-16">
      <p class="text-xs sm:text-sm font-semibold tracking-widest uppercase text-primary-600 mb-3">
        Functies per pijler
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-primary-950 tracking-tight leading-[1.1]">
        Twaalf functies,<br />vier logische pijlers
      </h2>
      <p class="mt-5 text-base sm:text-lg text-primary-900/65 leading-relaxed">
        Ga direct naar de functie die je nodig hebt. Elke pijler bundelt samenhangende tools die onderling data uitwisselen, zodat werk dat je eenmaal doet overal automatisch doorwerkt.
      </p>
    </div>

    <!-- Pillars grid: 1 / 2 / 2 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 sm:gap-6">
      {pillars.map(p => {
        const a = accentMap[p.accent];
        return (
          <article
            class={`group relative rounded-2xl sm:rounded-3xl border ${a.border} bg-white p-6 sm:p-8 shadow-sm hover:shadow-lg transition-shadow duration-300`}
          >
            <!-- Pillar header -->
            <header class="flex items-start gap-4 mb-5 sm:mb-6">
              <div
                class={`shrink-0 w-12 h-12 sm:w-14 sm:h-14 rounded-2xl ${a.strong} ${a.text} flex items-center justify-center shadow-sm`}
              >
                <Fragment set:html={p.icon} />
              </div>
              <div class="min-w-0 flex-1">
                <p class={`text-[11px] sm:text-xs font-bold uppercase tracking-[0.12em] ${a.text} mb-1`}>
                  {p.label}
                </p>
                <h3 class="text-lg sm:text-xl font-bold text-primary-950 leading-snug">
                  {p.title}
                </h3>
              </div>
            </header>

            <p class="text-sm sm:text-[15px] text-primary-900/65 leading-relaxed mb-5 sm:mb-6">
              {p.description}
            </p>

            <!-- Feature links -->
            <ul class="space-y-1.5">
              {p.items.map(item => (
                <li>
                  <a
                    href={item.href}
                    class={`flex items-center gap-3 sm:gap-4 rounded-xl p-3 sm:p-3.5 -mx-2 sm:-mx-3 transition-colors duration-200 ${a.hover} focus:outline-none focus-visible:ring-2 ${a.ring}`}
                  >
                    <span
                      class={`shrink-0 w-10 h-10 rounded-xl ${a.soft} ${a.text} flex items-center justify-center transition-transform duration-200 group-hover:scale-[1.02]`}
                    >
                      <Fragment set:html={item.icon} />
                    </span>
                    <span class="min-w-0 flex-1">
                      <span class="block text-sm sm:text-[15px] font-semibold text-primary-950 group-hover:text-primary-900">
                        {item.title}
                      </span>
                      <span class="block text-xs sm:text-[13px] text-primary-900/55 leading-snug mt-0.5">
                        {item.tagline}
                      </span>
                    </span>
                    <svg
                      class={`shrink-0 w-4 h-4 sm:w-4.5 sm:h-4.5 ${a.text} opacity-60 transition-transform duration-200 group-hover:translate-x-0.5`}
                      fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </article>
        );
      })}
    </div>

    <!-- Subtle helper below grid -->
    <p class="mt-10 sm:mt-12 text-center text-sm text-primary-900/55">
      Liever alles in één oogopslag?
      <a href="#constellation" class="font-semibold text-primary-700 hover:underline">Bekijk de constellatie bovenaan</a>
      of
      <a href="/pricing" class="font-semibold text-primary-700 hover:underline">vergelijk de pakketten</a>.
    </p>
  </div>
</section>
