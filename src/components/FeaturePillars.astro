---
// ── Features grouped into 4 thematic pillars with deep links ──
// Alternative to the interactive constellation: a scannable, SEO-friendly
// index of every feature page. Each pillar collects 3 related features.

type FeatureLink = {
  id: string;
  title: string;
  tagline: string;
  href: string;
  icon: string;
};

type Pillar = {
  id: string;
  label: string;
  title: string;
  description: string;
  accent: 'blue' | 'amber' | 'violet' | 'emerald';
  icon: string;
  items: FeatureLink[];
};

