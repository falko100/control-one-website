<section class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="relative rounded-3xl bg-gradient-to-br from-primary-700 via-primary-800 to-primary-950 px-8 py-16 sm:px-16 sm:py-20 overflow-hidden">
      <div class="absolute top-0 right-0 w-96 h-96 bg-accent-400/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary-400/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>

      <div class="relative max-w-2xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
          Klaar om uw ISO-compliance te vereenvoudigen?
        </h2>
        <p class="mt-4 text-lg text-primary-200/80">
          Sluit u aan bij honderden bedrijven die Control One vertrouwen voor hun compliance-traject. Start vandaag nog uw gratis proefperiode.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/demo" class="inline-flex items-center px-6 py-3 text-base font-semibold text-primary-900 bg-white hover:bg-primary-50 rounded-lg transition-all shadow-lg">
            Gratis Proberen
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
          <a href="/demo" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white/90 hover:text-white border border-white/20 hover:border-white/40 rounded-lg transition-all">
            Neem Contact Op
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
