// ── Accent color mapping (avoids Tailwind purge issues with dynamic classes) ──
const accents: Record<string, { iconBg: string; iconColor: string }> = {
  blue:    { iconBg: 'bg-blue-50',    iconColor: 'text-blue-600' },
  amber:   { iconBg: 'bg-amber-50',   iconColor: 'text-amber-600' },
  indigo:  { iconBg: 'bg-indigo-50',  iconColor: 'text-indigo-600' },
  violet:  { iconBg: 'bg-violet-50',  iconColor: 'text-violet-600' },
  green:   { iconBg: 'bg-green-50',   iconColor: 'text-green-600' },
  emerald: { iconBg: 'bg-emerald-50', iconColor: 'text-emerald-600' },
  teal:    { iconBg: 'bg-teal-50',    iconColor: 'text-teal-600' },
  cyan:    { iconBg: 'bg-cyan-50',    iconColor: 'text-cyan-600' },
  rose:    { iconBg: 'bg-rose-50',    iconColor: 'text-rose-600' },
  primary: { iconBg: 'bg-primary-50', iconColor: 'text-primary-600' },
  sky:     { iconBg: 'bg-sky-50',     iconColor: 'text-sky-600' },
  fuchsia: { iconBg: 'bg-fuchsia-50', iconColor: 'text-fuchsia-600' },
};

// ── Polar → percent coords for absolute positioning ──
const polar = (r: number, deg: number) => {
  const rad = (deg * Math.PI) / 180;
  return {
    x: +(50 + r * Math.cos(rad)).toFixed(2),
    y: +(50 + r * Math.sin(rad)).toFixed(2),
  };
};

// ── Bubble positions around the center (5 inner + 6 outer = 11) ──
// Inner ring r=36, outer ring r=50 — gives ≥ 20px edge-to-edge clearance
// between neighbouring inner/outer bubbles even with the float animation.
const constellation = [
  { f: features[1],  pos: polar(36, -90) },   // risico
  { f: features[2],  pos: polar(36, -18) },   // vvt
  { f: features[3],  pos: polar(36,  54) },   // documenten
  { f: features[4],  pos: polar(36, 126) },   // templates
  { f: features[5],  pos: polar(36, 198) },   // gap
  { f: features[6],  pos: polar(50, -60) },   // audit
  { f: features[7],  pos: polar(50,   0) },   // leveranciers
  { f: features[8],  pos: polar(50,  60) },   // incidenten
  { f: features[9],  pos: polar(50, 120) },   // dashboard
  { f: features[10], pos: polar(50, 180) },   // kennisbank
  { f: features[11], pos: polar(50, 240) },   // directie
];

// Hex stroke colors per accent, for line highlighting
const accentStroke: Record<string, string> = {
  blue: '#3b82f6', amber: '#f59e0b', indigo: '#6366f1', violet: '#8b5cf6',
  green: '#22c55e', emerald: '#10b981', teal: '#14b8a6', cyan: '#06b6d4',
  rose: '#f43f5e', primary: '#2563eb', sky: '#0ea5e9', fuchsia: '#d946ef',
};
---

<section
  id="constellation"
  class="relative flex flex-col items-center justify-center overflow-hidden px-4 sm:px-6 pt-24 pb-8 bg-gradient-to-b from-slate-50 via-white to-slate-50"
  style="min-height: 100vh;"
>

  <!-- Twinkling stars -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <div class="constellation-star absolute top-[14%] left-[10%] w-1 h-1 rounded-full bg-blue-400" style="--delay: 0s;"></div>
    <div class="constellation-star absolute top-[22%] right-[16%] w-1 h-1 rounded-full bg-violet-400" style="--delay: 1.2s;"></div>
    <div class="constellation-star absolute top-[55%] left-[5%] w-1.5 h-1.5 rounded-full bg-indigo-300" style="--delay: 2.4s;"></div>
    <div class="constellation-star absolute top-[48%] right-[6%] w-1 h-1 rounded-full bg-sky-400" style="--delay: 0.8s;"></div>
    <div class="constellation-star absolute bottom-[24%] left-[22%] w-1 h-1 rounded-full bg-primary-400" style="--delay: 3s;"></div>
    <div class="constellation-star absolute bottom-[16%] right-[28%] w-1.5 h-1.5 rounded-full bg-blue-300" style="--delay: 1.8s;"></div>
    <div class="constellation-star absolute top-[70%] left-[12%] w-1 h-1 rounded-full bg-fuchsia-300" style="--delay: 2.1s;"></div>
    <div class="constellation-star absolute top-[30%] right-[30%] w-0.5 h-0.5 rounded-full bg-blue-500" style="--delay: 0.4s;"></div>
  </div>

  <!-- Compact header -->
  <div class="relative text-center mb-8 sm:mb-12">
    <p class="text-[11px] sm:text-sm font-semibold tracking-widest uppercase text-primary-600 mb-2">Alles wat je nodig hebt</p>
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-primary-950 tracking-tight leading-tight">
      Eén platform,<br /><span
        class="bg-clip-text text-transparent"
        style="background-image: linear-gradient(90deg, #0e2470 0%, #196bd7 50%, #01a2e8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
      >oneindig</span> veel functies
    </h2>
  </div>

  <!-- Constellation container: fits within viewport, stays square -->
  <div
    class="relative w-full aspect-square"
    style="max-width: min(680px, calc(100vh - 240px), 92vw);"
  >

    <!-- Orbital rings -->
    <svg class="absolute inset-0 w-full h-full constellation-ring-inner" viewBox="0 0 100 100" aria-hidden="true">
      <circle cx="50" cy="50" r="36" fill="none" stroke="#cbd5e1" stroke-width="0.15" stroke-dasharray="0.6 0.9" />
    </svg>
    <svg class="absolute inset-0 w-full h-full constellation-ring-outer" viewBox="0 0 100 100" aria-hidden="true">
      <circle cx="50" cy="50" r="50" fill="none" stroke="#cbd5e1" stroke-width="0.15" stroke-dasharray="0.6 0.9" />
    </svg>

    <!-- Connecting lines (center → each bubble) -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 100 100" aria-hidden="true">
      {constellation.map(({ f, pos }) => (
        <line
          x1="50" y1="50" x2={pos.x} y2={pos.y}
          stroke="#e2e8f0" stroke-width="0.08" stroke-dasharray="0.4 0.6"
          class="constellation-line"
          data-line={f.id}
          data-stroke={accentStroke[f.accent]}
        />
      ))}
    </svg>

    <!-- Center hub wrapper (zero-sized anchor point) -->
    <div id="hub-wrap" class="hub-wrap absolute left-1/2 top-1/2 z-20">
      <!-- Pulsing halos: hide when hub expands.
           Centering is handled by the pulse keyframe's translate(-50%, -50%);
           do NOT add Tailwind -translate-x/y-1/2 here (Tailwind 4 uses the
           `translate` CSS property which would stack with the animation's
           `transform` and double-shift the halos off-center). -->
      <div class="hub-halos absolute top-0 left-0 pointer-events-none">
        <div class="w-[210px] h-[210px] sm:w-[220px] sm:h-[220px] rounded-full bg-blue-400/15 constellation-pulse absolute"></div>
        <div class="w-[180px] h-[180px] sm:w-[190px] sm:h-[190px] rounded-full bg-blue-400/25 constellation-pulse absolute" style="animation-delay: 1.2s;"></div>
      </div>

      <!-- Hub (morphs from circle → rounded rectangle on hover) -->
      <div
        id="hub"
        class="hub absolute -translate-x-1/2 -translate-y-1/2 bg-white shadow-2xl overflow-hidden"
      >
        <!-- Default panel: Control One favicon -->
        <div class="hub-panel absolute inset-0 flex flex-col items-center justify-center opacity-100 transition-opacity duration-300" data-panel="default">
          <img src="/favicon.svg" alt="Control One" class="w-16 h-16 sm:w-20 sm:h-20 select-none drop-shadow-sm" draggable="false" />
          <p
            class="mt-2 text-[10px] sm:text-[11px] font-bold tracking-[0.15em] uppercase bg-clip-text text-transparent"
            style="background-image: linear-gradient(90deg, #0e2470 0%, #196bd7 50%, #01a2e8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
          >
            Control One
          </p>
        </div>

        <!-- Dynamic per-feature panels -->
        {features.map(f => (
          <div
            class="hub-panel absolute inset-0 flex flex-col opacity-0 pointer-events-none transition-opacity duration-300"
            data-panel={f.id}
          >
            <!-- Top accent bar (color per feature) -->
            <div
              class="absolute top-0 left-0 right-0 h-1 z-10"
              style={`background: linear-gradient(90deg, ${accentStroke[f.accent]} 0%, ${accentStroke[f.accent]}80 100%);`}
            ></div>

            <div class="relative flex flex-col h-full p-4 sm:p-5">
              <!-- Header: icon + category + title -->
              <div class="flex items-start gap-3 mb-2">
                <div class={`shrink-0 w-11 h-11 sm:w-12 sm:h-12 rounded-xl ${accents[f.accent].iconBg} ${accents[f.accent].iconColor} flex items-center justify-center shadow-sm`}>
                  <Fragment set:html={f.icon.replace('w-6 h-6', 'w-6 h-6 sm:w-7 sm:h-7')} />
                </div>
                <div class="min-w-0 flex-1 pt-0.5">
                  <div class={`text-[9px] sm:text-[10px] font-bold tracking-[0.1em] uppercase ${accents[f.accent].iconColor} mb-0.5 truncate`}>{f.category}</div>
                  <h4 class="text-sm sm:text-[15px] font-bold text-primary-950 leading-tight">{f.title}</h4>
                </div>
              </div>

              <!-- Description -->
              <p class="text-[11px] sm:text-[11.5px] text-primary-900/70 leading-snug mb-2.5">{f.short}</p>

              <!-- Bullets (4, two columns) -->
              <ul class="grid grid-cols-1 gap-x-3 gap-y-1 mb-2">
                {f.bullets.slice(0, 4).map(b => (
                  <li class="flex items-start gap-1.5 text-[11px] text-primary-900/90">
                    <span class={`shrink-0 w-3.5 h-3.5 rounded-full ${accents[f.accent].iconBg} flex items-center justify-center mt-[1px]`}>
                      <svg class={`w-2.5 h-2.5 ${accents[f.accent].iconColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7"/></svg>
                    </span>
                    <span class="leading-snug">{b}</span>
                  </li>
                ))}
              </ul>

              <!-- Divider + tags row -->
              <div class="mt-auto pt-2 border-t border-slate-100 flex items-center justify-between gap-2">
                <div class="flex flex-wrap gap-1">
                  {f.tags.map(t => (
                    <span class={`px-1.5 py-0.5 rounded-md text-[10px] font-semibold ${accents[f.accent].iconBg} ${accents[f.accent].iconColor}`}>{t}</span>
                  ))}
                </div>
                <a
                  href={f.href}
                  class={`shrink-0 inline-flex items-center gap-0.5 text-[10px] font-semibold ${accents[f.accent].iconColor} hover:underline`}
                  data-feature-link={f.id}
                >
                  Meer
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Feature bubbles -->
    {constellation.map(({ f, pos }, i) => (
      <button
        class="constellation-bubble absolute -translate-x-1/2 -translate-y-1/2 z-10 group focus:outline-none"
        style={`left: ${pos.x}%; top: ${pos.y}%;`}
        data-feature={f.id}
        data-accent={f.accent}
        aria-label={f.title}
      >
        <span
          class="constellation-bubble-inner flex flex-col items-center relative"
          style={`--delay: ${(i * 0.35).toFixed(2)}s; --duration: ${6 + (i % 3)}s;`}
        >
          <span class={`relative flex items-center justify-center w-[60px] h-[60px] sm:w-[68px] sm:h-[68px] rounded-full bg-white shadow-md border-2 border-white transition-all duration-300 group-hover:scale-110 group-hover:shadow-xl group-focus-visible:scale-110 ${accents[f.accent].iconColor}`}>
            <span class={`flex items-center justify-center w-10 h-10 sm:w-[46px] sm:h-[46px] rounded-xl ${accents[f.accent].iconBg} ${accents[f.accent].iconColor}`}>
              <Fragment set:html={f.icon.replace('w-6 h-6', 'w-7 h-7')} />
            </span>
          </span>
          <span class="constellation-bubble-title mt-1.5 text-[10px] sm:text-[11px] font-semibold leading-tight text-primary-800 text-center max-w-[110px] whitespace-normal transition-colors duration-200">
            {f.title}
          </span>
        </span>
      </button>
    ))}
  </div>

  <!-- SEO-friendly feature list (hidden, for crawlers & screen readers) -->
  <div
    style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;"
  >
    <h3>Alle functies van Control One</h3>
    <ul>
      {features.map(f => (
        <li><strong>{f.title}:</strong> {f.short}</li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* ── Twinkling stars ── */
  @keyframes twinkle {
    0%, 100% { opacity: 0.25; transform: scale(1); }
    50%      { opacity: 0.9;  transform: scale(1.4); }
  }
  .constellation-star {
    animation: twinkle 3.2s ease-in-out infinite;
    animation-delay: var(--delay, 0s);
    opacity: 0.3;
  }

  /* ── Sparkle icon ── */
  @keyframes sparkle {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.7; }
    50%      { transform: scale(1.2) rotate(15deg); opacity: 1; }
  }
  .constellation-sparkle {
    animation: sparkle 2.2s ease-in-out infinite;
    display: inline-block;
  }

  /* ── Bubble float (gentle bob) ──
     Static min edge gap is ~15px (68px bubbles, inner r=36 / outer r=50),
     so ±5px per bubble still leaves ~5px clearance worst-case — visible
     movement without neighbours drifting into each other. */
  @keyframes constellation-float {
    0%, 100% { transform: translateY(0)    translateX(0); }
    25%      { transform: translateY(-5px) translateX(2px); }
    50%      { transform: translateY(-3px) translateX(-3px); }
    75%      { transform: translateY(3px)  translateX(2px); }
  }
  .constellation-bubble-inner {
    animation: constellation-float var(--duration, 6s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  /* ── Orbital rings slowly rotate ── */
  @keyframes spin-cw  { from { transform: rotate(0); } to { transform: rotate(360deg); } }
  @keyframes spin-ccw { from { transform: rotate(0); } to { transform: rotate(-360deg); } }
  .constellation-ring-inner { animation: spin-cw  80s linear infinite; transform-origin: center; }
  .constellation-ring-outer { animation: spin-ccw 120s linear infinite; transform-origin: center; }

  /* ── Central pulsing halos ── */
  @keyframes constellation-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1);    opacity: 0.55; }
    50%      { transform: translate(-50%, -50%) scale(1.18); opacity: 0.08; }
  }
  .constellation-pulse {
    /* Default centered state — also used during animation-delay and
       when prefers-reduced-motion disables the animation. */
    transform: translate(-50%, -50%) scale(1);
    animation: constellation-pulse 3.5s ease-in-out infinite;
  }

  /* ── Hub: morphs from circle (default, favicon) to rectangle (hover, info) ── */
  .hub {
    width: 160px;
    height: 160px;
    border-radius: 9999px;
    transition:
      width 0.45s cubic-bezier(0.4, 0, 0.2, 1),
      height 0.45s cubic-bezier(0.4, 0, 0.2, 1),
      border-radius 0.45s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.3s ease;
  }
  .hub-wrap.expanded .hub {
    width: 340px;
    height: 290px;
    border-radius: 20px;
  }
  .hub-halos {
    transition: opacity 0.3s ease;
    opacity: 1;
  }
  .hub-wrap.expanded .hub-halos {
    opacity: 0;
  }

  /* Smaller hub on narrow screens so it still fits */
  @media (max-width: 640px) {
    .hub { width: 130px; height: 130px; }
    .hub-wrap.expanded .hub { width: 280px; height: 250px; }
  }

  /* ── Connecting line transitions ── */
  .constellation-line {
    transition: stroke 0.25s ease, stroke-width 0.25s ease, stroke-dasharray 0.25s ease;
  }

  /* ── Dim sibling bubbles when one is focused ── */
  .constellation-bubble.dimmed .constellation-bubble-inner {
    opacity: 0.35;
    transition: opacity 0.3s;
  }

  /* ── Respect reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .constellation-star,
    .constellation-sparkle,
    .constellation-bubble-inner,
    .constellation-ring-inner,
    .constellation-ring-outer,
    .constellation-pulse {
      animation: none !important;
    }
    .constellation-star { opacity: 0.6; }
    .hub { transition: none; }
  }
</style>

<script>
  const hubWrap = document.getElementById('hub-wrap');
  const hubPanels = document.querySelectorAll<HTMLElement>('.hub-panel');
  const bubbles = document.querySelectorAll<HTMLElement>('.constellation-bubble');
  const lines = document.querySelectorAll<SVGLineElement>('.constellation-line');

  const showPanel = (id: string) => {
    hubPanels.forEach(p => {
      const active = p.dataset.panel === id;
      p.classList.toggle('opacity-100', active);
      p.classList.toggle('opacity-0', !active);
      p.classList.toggle('pointer-events-none', !active);
    });
  };

  const setExpanded = (expanded: boolean) => {
    if (!hubWrap) return;
    hubWrap.classList.toggle('expanded', expanded);
  };

  const setActiveLine = (id: string | null) => {
    lines.forEach(l => {
      if (id && l.dataset.line === id) {
        const hex = l.dataset.stroke || '#2563eb';
        l.setAttribute('stroke', hex);
        l.setAttribute('stroke-width', '0.25');
        l.setAttribute('stroke-dasharray', '0');
      } else {
        l.setAttribute('stroke', '#e2e8f0');
        l.setAttribute('stroke-width', '0.08');
        l.setAttribute('stroke-dasharray', '0.4 0.6');
      }
    });
  };

  const dimOthers = (id: string | null) => {
    bubbles.forEach(b => {
      if (id && b.dataset.feature !== id) b.classList.add('dimmed');
      else b.classList.remove('dimmed');
    });
  };

  const resetState = () => {
    showPanel('default');
    setExpanded(false);
    setActiveLine(null);
    dimOthers(null);
  };

  const activateBubble = (id: string) => {
    showPanel(id);
    setExpanded(true);
    setActiveLine(id);
    dimOthers(id);
  };

  let selected: string | null = null;
  let hovered: string | null = null;
  let collapseTimer: number | null = null;

  const cancelCollapse = () => {
    if (collapseTimer !== null) {
      clearTimeout(collapseTimer);
      collapseTimer = null;
    }
  };

  const scheduleCollapse = () => {
    cancelCollapse();
    collapseTimer = window.setTimeout(() => {
      if (!selected && !hovered) resetState();
    }, 120);
  };

  bubbles.forEach(b => {
    const id = b.dataset.feature!;

    b.addEventListener('mouseenter', () => {
      cancelCollapse();
      hovered = id;
      if (!selected) activateBubble(id);
    });
    b.addEventListener('mouseleave', () => {
      if (hovered === id) hovered = null;
      if (!selected) scheduleCollapse();
    });
    b.addEventListener('focus', () => {
      if (!selected) activateBubble(id);
    });
    b.addEventListener('blur', () => {
      if (!selected) resetState();
    });
    b.addEventListener('click', (e) => {
      e.stopPropagation();
      if (selected === id) {
        selected = null;
        resetState();
      } else {
        selected = id;
        activateBubble(id);
      }
    });
  });

  // Keep the hub expanded while the mouse is inside it (so the user can click Meer)
  const hub = document.getElementById('hub');
  if (hub) {
    hub.addEventListener('mouseenter', () => {
      cancelCollapse();
      hovered = hovered ?? '__hub__';
    });
    hub.addEventListener('mouseleave', () => {
      if (hovered === '__hub__') hovered = null;
      if (!selected) scheduleCollapse();
    });
  }

  // Click outside the constellation clears any pinned selection
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.constellation-bubble') && !target.closest('#hub')) {
      if (selected) {
        selected = null;
        resetState();
      }
    }
  });
</script>
