---
const plans = [
  {
    name: 'Starter',
    price: '49',
    description: 'Voor kleine teams die beginnen met hun compliance-traject.',
    features: [
      '1 ISO-framework',
      'Tot 5 teamleden',
      'Begeleide implementatiecoach',
      'Documentbeheer',
      'Basis risicoregister',
      'E-mail support',
    ],
    cta: 'Gratis Proberen',
    popular: false,
  },
  {
    name: 'Professional',
    price: '99',
    description: 'Voor groeiende bedrijven die volledige compliance-dekking nodig hebben.',
    features: [
      'Tot 3 ISO-frameworks',
      'Tot 25 teamleden',
      'Alles in Starter',
      'Interne audit workflows',
      'Leveranciersbeheer',
      'Directiebeoordelingen',
      'Verklaring van Toepasselijkheid',
      'Prioriteit support',
    ],
    cta: 'Gratis Proberen',
    popular: true,
  },
  {
    name: 'Enterprise',
    price: 'Op maat',
    description: 'Voor organisaties met geavanceerde compliance-behoeften.',
    features: [
      'Onbeperkt frameworks',
      'Onbeperkt teamleden',
      'Alles in Professional',
      'Aangepaste integraties',
      'Dedicated accountmanager',
      'SSO / SAML authenticatie',
      'SLA-garantie',
    ],
    cta: 'Neem Contact Op',
    popular: false,
  },
];
---

<section id="prijzen" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-16">
      <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Prijzen</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
        Eenvoudige, transparante prijzen
      </h2>
      <p class="mt-4 text-lg text-primary-900/60">
        Start 14 dagen gratis. Geen creditcard nodig. Schaal mee naarmate uw compliance-behoeften groeien.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {plans.map(plan => (
        <div class:list={[
          'relative rounded-2xl border p-8 flex flex-col',
          plan.popular
            ? 'border-primary-600 shadow-xl shadow-primary-100/50 scale-105'
            : 'border-primary-100',
        ]}>
          {plan.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 text-xs font-semibold text-white bg-primary-600 rounded-full">
              Populairst
            </div>
          )}

          <div class="mb-6">
            <h3 class="text-lg font-semibold text-primary-950">{plan.name}</h3>
            <p class="mt-1 text-sm text-primary-900/60">{plan.description}</p>
          </div>

          <div class="mb-6">
            {plan.price === 'Op maat' ? (
              <span class="text-4xl font-bold text-primary-950">Op maat</span>
            ) : (
              <div class="flex items-baseline gap-1">
                <span class="text-sm font-medium text-primary-900/60">&euro;</span>
                <span class="text-4xl font-bold text-primary-950">{plan.price}</span>
                <span class="text-sm font-medium text-primary-900/60">/maand</span>
              </div>
            )}
          </div>

          <ul class="space-y-3 mb-8 flex-1">
            {plan.features.map(feature => (
              <li class="flex items-start gap-3 text-sm text-primary-900/70">
                <svg class="w-5 h-5 text-primary-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                {feature}
              </li>
            ))}
          </ul>

          <a href="/demo" class:list={[
            'inline-flex items-center justify-center px-6 py-3 text-sm font-semibold rounded-lg transition-all',
            plan.popular
              ? 'text-white bg-primary-700 hover:bg-primary-800 shadow-lg shadow-primary-700/25'
              : 'text-primary-700 bg-primary-50 hover:bg-primary-100',
          ]}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
