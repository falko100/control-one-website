---

<section id="prijzen" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header + billing toggle -->
    <div class="max-w-2xl mx-auto text-center mb-12">
      <p class="text-sm font-semibold tracking-widest uppercase text-primary-600 mb-3">Prijzen</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight mb-4">
        Eén platform, ontelbare functies.<br />Kies je teamgrootte.
      </h2>
      <p class="text-base text-primary-900/55 leading-relaxed mb-8">
        Elk plan geeft volledige toegang tot het Control One platform, inclusief 1 ISO-framework.
      </p>

      <!-- Billing toggle -->
      <div class="inline-flex items-center gap-1 p-1 bg-primary-50 border border-primary-200 rounded-xl">
        <button
          id="toggle-monthly"
          class="billing-toggle px-5 py-2 text-sm font-semibold rounded-lg transition-all bg-white text-primary-900 shadow-sm border border-primary-200"
          onclick="setBilling('monthly')"
        >
          Per maand
        </button>
        <button
          id="toggle-yearly"
          class="billing-toggle px-5 py-2 text-sm font-semibold rounded-lg transition-all text-primary-600"
          onclick="setBilling('yearly')"
        >
          Per jaar
          <span class="ml-1.5 text-[10px] font-bold bg-emerald-100 text-emerald-700 border border-emerald-200 px-1.5 py-0.5 rounded-full">−10%</span>
        </button>
      </div>
      <p id="billing-note" class="text-xs text-primary-900/40 mt-2 h-4"></p>
    </div>

    <!-- Pricing cards -->
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {plans.map(plan => (
        <div class:list={[
          'relative rounded-2xl flex flex-col',
          plan.highlight
            ? 'border-2 border-primary-600 shadow-2xl shadow-primary-200/40 bg-white'
            : 'border border-primary-200 bg-white shadow-sm hover:shadow-md transition-shadow',
        ]}>

          {plan.badge && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 inline-flex items-center gap-1.5 px-4 py-1 text-xs font-bold text-white bg-primary-600 rounded-full shadow-lg whitespace-nowrap">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              {plan.badge}
            </div>
          )}

          <!-- Plan header -->
          <div class:list={['p-7 rounded-t-2xl', plan.highlight ? 'bg-gradient-to-br from-primary-50 to-white' : '']}>
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="text-xl font-bold text-primary-950">{plan.name}</h3>
                <p class="text-sm text-primary-900/50 mt-0.5 leading-snug">{plan.description}</p>
              </div>
              <span class:list={[
                'text-xs font-semibold px-2.5 py-1 rounded-lg whitespace-nowrap ml-3 mt-0.5 shrink-0',
                plan.highlight ? 'bg-primary-100 text-primary-700' : 'bg-primary-50 text-primary-600 border border-primary-200',
              ]}>
                {plan.seats}
              </span>
            </div>

            <!-- Price display -->
            <div class="mt-5 mb-1">
              <div class="flex items-baseline gap-1">
                <span class="text-2xl font-semibold text-primary-900/40">&euro;</span>
                <span class="price-display text-5xl font-black text-primary-950 tabular-nums" data-monthly={plan.priceMonthly} data-yearly={plan.priceYearly}>
                  {plan.priceMonthly}
                </span>
                <span class="text-sm font-medium text-primary-900/40 ml-0.5">/maand</span>
              </div>
              <p class="yearly-note text-xs text-emerald-600 font-semibold mt-1 h-4 hidden">
                Jaarlijks gefactureerd · je bespaart €{(plan.priceMonthly - plan.priceYearly) * 12}
              </p>
              <p class="monthly-note text-xs text-primary-900/35 mt-1">excl. BTW · maandelijks opzegbaar</p>
            </div>
          </div>

          <!-- CTA button -->
          <div class="px-7 py-4">
            <a href={plan.ctaHref} class:list={[
              'flex items-center justify-center w-full px-5 py-3 text-sm font-semibold rounded-xl transition-all',
              plan.highlight
                ? 'bg-primary-700 hover:bg-primary-800 text-white shadow-lg shadow-primary-700/20'
                : 'bg-primary-50 hover:bg-primary-100 text-primary-700 border border-primary-200',
            ]}>
              {plan.cta}
              <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>

          <!-- Divider -->
          <div class:list={['h-px mx-7', plan.highlight ? 'bg-primary-200/70' : 'bg-primary-100']}></div>

          <!-- Support -->
          <div class="px-7 py-5 space-y-2.5">
            <p class="text-[10px] font-bold uppercase tracking-widest text-primary-400 mb-3">Support</p>
            {[
              { icon: 'M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z', label: plan.support },
              { icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z', label: `Reactietijd: ${plan.responseTime}` },
              ...(plan.sla ? [{ icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z', label: 'SLA 99.9% uptime garantie' }] : []),
            ].map(item => (
              <div class="flex items-center gap-2.5">
                <svg class:list={['w-4 h-4 shrink-0', plan.highlight ? 'text-primary-600' : 'text-primary-400']} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon}></path>
                </svg>
                <span class="text-sm text-primary-800/65">{item.label}</span>
              </div>
            ))}
          </div>

          <!-- Divider -->
          <div class:list={['h-px mx-7', plan.highlight ? 'bg-primary-200/70' : 'bg-primary-100']}></div>

          <!-- All features -->
          <div class="px-7 py-5 flex-1">
            <p class="text-[10px] font-bold uppercase tracking-widest text-primary-400 mb-3.5">Alles inbegrepen</p>
            <div class="space-y-2">
              {includedFeatures.map(f => (
                <div class="flex items-center gap-2.5">
                  <svg class:list={['w-4 h-4 shrink-0', plan.highlight ? 'text-primary-600' : 'text-primary-400']} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={f.icon}></path>
                  </svg>
                  <span class="text-sm text-primary-800/70">{f.label}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="h-7"></div>

        </div>
      ))}
    </div>

    <!-- Add-on block -->
    <div class="max-w-5xl mx-auto mt-8">
      <div class="rounded-2xl border border-dashed border-primary-300 bg-primary-50/50 p-6 flex flex-col sm:flex-row items-center gap-6">
        <div class="w-11 h-11 rounded-2xl bg-white border border-primary-200 shadow-sm flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v6m3-3H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="flex-1 text-center sm:text-left">
          <div class="flex items-center gap-2 justify-center sm:justify-start mb-1">
            <span class="text-xs font-bold uppercase tracking-widest text-primary-600">Uitbreiding</span>
            <span class="text-xs bg-white text-primary-600 font-semibold border border-primary-200 px-2 py-0.5 rounded-full">Add-on</span>
          </div>
          <h3 class="text-base font-bold text-primary-950">Extra ISO-framework toevoegen</h3>
          <p class="text-sm text-primary-900/55 mt-0.5">Voeg een tweede, derde of vierde framework toe aan je abonnement. Direct toegang tot alle functies voor dat framework.</p>
        </div>
        <div class="flex items-center gap-4 shrink-0">
          <div class="text-right">
            <div class="flex items-baseline gap-0.5 justify-end">
              <span class="text-sm text-primary-900/40">&euro;</span>
              <span class="text-3xl font-black text-primary-950">39</span>
              <span class="text-sm text-primary-900/40">/mnd</span>
            </div>
            <p class="text-xs text-primary-900/35">per extra framework</p>
          </div>
          <a href="/contact" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-primary-700 bg-white hover:bg-primary-50 border border-primary-300 rounded-xl transition-all whitespace-nowrap shadow-sm">
            Meer info
          </a>
        </div>
      </div>
    </div>

    <!-- Garantie balk -->
    <div class="max-w-5xl mx-auto mt-5">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-5 sm:gap-8 py-4 px-6 rounded-2xl bg-primary-50/40 border border-primary-100 text-sm">
        {[
          { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: '14 dagen gratis uitproberen' },
          { icon: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z', label: 'iDEAL & creditcard' },
          { icon: 'M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3', label: 'Maandelijks opzegbaar' },
          { icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0zM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z', label: 'EU-hosting · AVG-compliant' },
        ].map((item, i) => (
          <>
            {i > 0 && <div class="hidden sm:block w-px h-4 bg-primary-200"></div>}
            <div class="flex items-center gap-2 text-primary-700/70">
              <svg class="w-4 h-4 text-primary-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon}></path>
              </svg>
              <span class="text-sm">{item.label}</span>
            </div>
          </>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  function setBilling(type: 'monthly' | 'yearly') {
    const isYearly = type === 'yearly';

    // Toggle button styles
    const monthlyBtn = document.getElementById('toggle-monthly')!;
    const yearlyBtn = document.getElementById('toggle-yearly')!;
    if (isYearly) {
      monthlyBtn.classList.remove('bg-white', 'text-primary-900', 'shadow-sm', 'border', 'border-primary-200');
      monthlyBtn.classList.add('text-primary-600');
      yearlyBtn.classList.add('bg-white', 'text-primary-900', 'shadow-sm', 'border', 'border-primary-200');
      yearlyBtn.classList.remove('text-primary-600');
    } else {
      yearlyBtn.classList.remove('bg-white', 'text-primary-900', 'shadow-sm', 'border', 'border-primary-200');
      yearlyBtn.classList.add('text-primary-600');
      monthlyBtn.classList.add('bg-white', 'text-primary-900', 'shadow-sm', 'border', 'border-primary-200');
      monthlyBtn.classList.remove('text-primary-600');
    }

    // Update prices
    document.querySelectorAll<HTMLElement>('.price-display').forEach(el => {
      el.textContent = String(isYearly ? el.dataset.yearly : el.dataset.monthly);
    });

    // Toggle notes
    document.querySelectorAll<HTMLElement>('.yearly-note').forEach(el => {
      el.classList.toggle('hidden', !isYearly);
    });
    document.querySelectorAll<HTMLElement>('.monthly-note').forEach(el => {
      el.classList.toggle('hidden', isYearly);
    });
  }

  // Make globally accessible
  (window as any).setBilling = setBilling;
</script>
