---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Documentbeheer — ISO-documenten centraal beheren | Control One" description="Beheer al je ISO-documenten op één plek. Versiebeheer, goedkeuringsworkflows en kant-en-klare sjablonen per ISO-clausule. Exporteer als PDF voor je auditor.">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-violet-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-violet-400 bg-violet-400/10 rounded-full border border-violet-400/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
            Documentbeheer
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Alle beleid & procedures<br/><span class="text-violet-400">op één plek beheerd</span>
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-xl leading-relaxed">
            Control One bevat een volledig documentenregister met 22+ vooraf ingevulde beleidsdocumenten en procedures. Bewerk, goedkeur en exporteer direct vanuit de portal.
          </p>
          <div class="mt-8 flex gap-4">
            <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
              Gratis uitproberen
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/templates" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Bekijk alle templates</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-0 bg-white">
      <div class="max-w-5xl mx-auto px-6 -mt-8">
        <div class="rounded-2xl overflow-hidden border border-primary-100 shadow-2xl shadow-primary-200/30">
          <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
            <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
            <div class="flex-1 max-w-[220px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center">app.control-one.nl/documenten</div></div>
          </div>
          <img src="/screenshots/portal-documents.png" alt="Documentbeheer in Control One" class="w-full" />
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {[
            { title: '22+ templates vooraf ingevuld', desc: 'Van ISMS-handboek tot leveranciersbeleid: alles staat klaar, geschreven door ISO-experts.' },
            { title: 'Bewerken in de portal', desc: 'Pas documenten direct aan in de ingebouwde editor. Geen Word, geen e-mailen. Gewoon inloggen en bewerken.' },
            { title: 'PDF export voor auditors', desc: 'Exporteer elk document als PDF, klaar voor inlevering bij uw certificerende instelling.' },
            { title: 'Versie- en goedkeuringshistorie', desc: 'Houd bij wie wat wanneer heeft gewijzigd. Elke versie is traceerbaar en aantoonbaar.' },
            { title: 'Koppeling met Coach & VvT', desc: 'Documenten zijn gekoppeld aan de implementatiestappen en de Verklaring van Toepasselijkheid.' },
            { title: 'Filter op categorie en status', desc: 'Zoek direct op documenttype, status (concept / goedgekeurd) of ISO-clausule.' },
          ].map(f => (
            <div class="p-6 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center text-violet-600 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h3 class="text-sm font-bold text-primary-950 mb-2">{f.title}</h3>
              <p class="text-sm text-primary-900/55 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
