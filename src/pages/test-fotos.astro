---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Test: Foto-opties" noindex={true}>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════════════
         PAGE HEADER
    ════════════════════════════════════════════════════ -->
    <section class="pt-32 pb-10 bg-primary-950">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-5 text-xs font-bold tracking-widest uppercase text-amber-300 bg-amber-400/10 rounded-full border border-amber-400/20">
          <span class="w-1.5 h-1.5 bg-amber-300 rounded-full animate-pulse"></span>
          Tijdelijke testpagina
        </div>
        <h1 class="text-4xl font-bold text-white tracking-tight">Foto-opties homepage</h1>
        <p class="mt-3 text-primary-300/70 text-lg">Vier uitwerkingen — kies welke richting aansluit</p>
        <!-- Quick nav -->
        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          {['Optie 1 · Tussensectie', 'Optie 2 · Hero accent', 'Optie 3 · Collage strip', 'Optie 4 · Testimonials', 'Optie 5 · 3-foto blok'].map((label, i) => (
            <a href={`#optie-${i + 1}`} class="px-4 py-2 text-sm font-semibold text-white bg-white/10 hover:bg-white/20 border border-white/15 rounded-lg transition-all">
              {label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         OPTIE 1 — "Gebouwd in Twente" Tussensectie
    ════════════════════════════════════════════════════ -->
    <div id="optie-1" class="bg-primary-50 py-8 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-8 h-8 rounded-full bg-primary-700 text-white text-sm font-bold flex items-center justify-center shrink-0">1</span>
          <div>
            <p class="font-bold text-primary-950 text-lg">"Gebouwd in Twente" Tussensectie</p>
            <p class="text-sm text-primary-600">Tussen Testimonials en WhyControlOne · Full-bleed kantoorfoto met overlay + portretcollage</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Optie 1: Variant A — Donkere overlay + portret-rij -->
    <section class="relative overflow-hidden" style="min-height: 520px;">
      <!-- Background office photo -->
      <img
        src="/team/office-2.webp"
        alt="Control One kantoor"
        class="absolute inset-0 w-full h-full object-cover"
        style="object-position: center 40%;"
      />
      <!-- Gradient overlay -->
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(26,63,122,0.92) 0%, rgba(15,40,90,0.85) 60%, rgba(26,63,122,0.75) 100%);"></div>
      <!-- Subtle noise/grain texture overlay -->
      <div class="absolute inset-0 opacity-20" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 stitchTiles=%22stitch%22/></filter><rect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22 opacity=%221%22/></svg>');"></div>

      <div class="relative max-w-7xl mx-auto px-6 py-20 lg:py-28">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">

          <!-- Left: text -->
          <div class="lg:w-1/2">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-5 text-xs font-bold tracking-widest uppercase text-accent-400 bg-white/10 rounded-full border border-white/15">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
              Enschede, Twente
            </div>
            <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight leading-[1.15]">
              Gebouwd door mensen<br />die ISO <em class="not-italic text-accent-400">kennen</em>
            </h2>
            <p class="mt-5 text-lg text-blue-100/80 leading-relaxed max-w-lg">
              Control One is gemaakt door een team van compliance-professionals en software-ontwikkelaars uit Twente. Geen consultants, geen tussenpersonen — gewoon een platform dat werkt.
            </p>

            <!-- Stats -->
            <div class="mt-8 grid grid-cols-3 gap-6">
              <div>
                <p class="text-3xl font-bold text-white">4+</p>
                <p class="text-sm text-blue-200/70 mt-0.5">ISO-frameworks</p>
              </div>
              <div class="border-l border-white/15 pl-6">
                <p class="text-3xl font-bold text-white">28</p>
                <p class="text-sm text-blue-200/70 mt-0.5">Coaching-stappen</p>
              </div>
              <div class="border-l border-white/15 pl-6">
                <p class="text-3xl font-bold text-accent-400">100%</p>
                <p class="text-sm text-blue-200/70 mt-0.5">Nederlands team</p>
              </div>
            </div>

            <!-- CTA -->
            <div class="mt-10">
              <a href="/over-ons" class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg shadow-accent-400/25">
                Leer ons kennen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
              </a>
            </div>
          </div>

          <!-- Right: portrait grid -->
          <div class="lg:w-1/2 flex flex-col gap-4">
            <!-- 2 large + 1 small layout -->
            <div class="grid grid-cols-2 gap-4">
              <div class="rounded-2xl overflow-hidden aspect-[4/3] shadow-xl shadow-black/30 ring-1 ring-white/10">
                <img src="/team/office-1.webp" alt="Control One team" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="rounded-2xl overflow-hidden aspect-[4/3] shadow-xl shadow-black/30 ring-1 ring-white/10">
                <img src="/team/office-3.webp" alt="Control One kantoor" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" style="object-position: center 30%;" />
              </div>
            </div>
            <!-- Portrait strip -->
            <div class="flex items-center gap-3">
              <div class="flex -space-x-3">
                {[1,2,3,4,5,6].map(n => (
                  <img src={`/team/portrait-${n}.webp`} alt="Teamlid" class="w-10 h-10 rounded-full object-cover border-2 border-white/30 shadow-md" style="object-position: center 15%;" />
                ))}
              </div>
              <p class="text-sm text-white/70">+ ons hele team</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- 1B: Variant met horizontale brede foto + tekst eronder -->
    <div class="bg-primary-50 py-4 px-6">
      <div class="max-w-5xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary-400">Optie 1B — Alternatiefe layout: breed beeld + tekst eronder</p>
      </div>
    </div>

    <section class="bg-white py-20">
      <div class="max-w-7xl mx-auto px-6">
        <!-- Full-width photo with overlay text -->
        <div class="relative rounded-3xl overflow-hidden shadow-2xl shadow-primary-900/20" style="min-height: 400px;">
          <img src="/team/office-4.webp" alt="Control One kantoor" class="absolute inset-0 w-full h-full object-cover" style="object-position: center 35%;" />
          <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(26,63,122,0.90) 0%, rgba(26,63,122,0.60) 50%, rgba(26,63,122,0.10) 100%);"></div>
          <div class="relative p-10 sm:p-14 flex flex-col justify-end h-full" style="min-height: 400px;">
            <p class="text-xs font-bold tracking-widest uppercase text-accent-400 mb-3">📍 Enschede, Twente</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight max-w-xl leading-snug">
              Een Twents team dat ISO toegankelijk maakt voor iedereen
            </h2>
            <p class="mt-4 text-blue-100/80 max-w-lg">Van idee tot certificering — wij begrijpen het traject omdat we het zelf hebben doorlopen.</p>
            <div class="mt-7 flex items-center gap-4">
              <div class="flex -space-x-3">
                {[1,2,3,4].map(n => (
                  <img src={`/team/portrait-${n}.webp`} alt="Teamlid" class="w-10 h-10 rounded-full object-cover border-2 border-white/40" style="object-position: center 15%;" />
                ))}
              </div>
              <a href="/over-ons" class="text-sm font-semibold text-white underline underline-offset-4 hover:text-accent-400 transition-colors">Leer ons kennen →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         OPTIE 2 — Hero accent (foto naast screenshot-fan)
    ════════════════════════════════════════════════════ -->
    <div id="optie-2" class="bg-primary-50 py-8 px-6 border-t-4 border-primary-100">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center gap-3 mb-2">
          <span class="w-8 h-8 rounded-full bg-primary-700 text-white text-sm font-bold flex items-center justify-center shrink-0">2</span>
          <div>
            <p class="font-bold text-primary-950 text-lg">Hero accent — Kantoorsfeer in de Hero</p>
            <p class="text-sm text-primary-600">Kantoor- of teamfoto als visueel accent ín de Hero, naast of boven de screenshot-fan</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 2A: Hero met foto als rechter kolom -->
    <div class="bg-primary-50/30 py-4 px-6">
      <div class="max-w-5xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary-400">Optie 2A — Tekst links, kantoor/team foto rechts (split hero)</p>
      </div>
    </div>

    <section class="relative overflow-hidden bg-white" style="min-height: 80vh;">
      <div class="absolute inset-0 bg-gradient-to-b from-primary-50/50 to-primary-50/10 pointer-events-none"></div>
      <div class="absolute top-0 left-1/2 w-[700px] h-[700px] bg-accent-400/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

      <div class="relative max-w-7xl mx-auto px-6 py-28">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

          <!-- Left: text (same as current hero) -->
          <div class="lg:w-1/2 text-center lg:text-left">
            <div class="flex flex-wrap items-center justify-center lg:justify-start gap-2 mb-7">
              <div class="inline-flex items-center gap-2 px-3 py-1 text-xs font-semibold tracking-wide uppercase text-primary-700 bg-primary-50 rounded-full border border-primary-200">
                <span class="w-1.5 h-1.5 bg-accent-500 rounded-full animate-pulse"></span>
                ISO Compliance Platform
              </div>
            </div>
            <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-primary-950 leading-[1.05]">
              Werken aan impact
              <span class="block text-transparent bg-clip-text bg-gradient-to-r from-accent-500 to-primary-600">Control One Portal</span>
            </h1>
            <p class="mt-6 text-lg sm:text-xl text-primary-700/70 max-w-xl leading-relaxed">
              Van risicoanalyse tot certificering: Control One begeleidt jouw organisatie stap voor stap. Alles op één plek, voor iedereen begrijpelijk.
            </p>
            <div class="mt-10 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
              <a href="#" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-primary-950 hover:bg-primary-900 rounded-full transition-all shadow-lg shadow-primary-950/20">
                Gratis starten · 14 dagen
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
              </a>
              <a href="#" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-primary-800 border border-primary-200 hover:border-primary-400 hover:bg-primary-50 rounded-full transition-all">
                Bekijk een demo
              </a>
            </div>
            <!-- Trust -->
            <div class="mt-8 flex flex-wrap items-center justify-center lg:justify-start gap-4 sm:gap-6 text-sm text-primary-500">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                ISO 27001 &amp; 9001
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                Nederlands bedrijf · EU-hosting
              </div>
            </div>
          </div>

          <!-- Right: office/team photo with frame -->
          <div class="lg:w-1/2 relative">
            <!-- Main photo card -->
            <div class="relative rounded-3xl overflow-hidden shadow-2xl shadow-primary-900/15 ring-1 ring-primary-100">
              <img
                src="/team/office-1.webp"
                alt="Control One team aan het werk"
                class="w-full object-cover"
                style="height: 440px; object-position: center 30%;"
              />
              <!-- Subtle gradient bottom -->
              <div class="absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to top, rgba(248,250,252,0.8), transparent);"></div>
              <!-- Team badge overlay -->
              <div class="absolute bottom-5 left-5 right-5 flex items-center gap-3 bg-white/90 backdrop-blur-sm rounded-2xl px-4 py-3 shadow-lg">
                <div class="flex -space-x-2.5">
                  {[1,2,3,4].map(n => (
                    <img src={`/team/portrait-${n}.webp`} alt="Teamlid" class="w-8 h-8 rounded-full object-cover border-2 border-white" style="object-position: center 15%;" />
                  ))}
                </div>
                <div>
                  <p class="text-xs font-semibold text-primary-950">Ons team staat voor je klaar</p>
                  <p class="text-[11px] text-primary-500">Reactie binnen 1 werkdag · Enschede</p>
                </div>
              </div>
            </div>

            <!-- Floating accent card (top-right) -->
            <div class="absolute -top-4 -right-4 bg-white rounded-2xl shadow-xl border border-primary-100 px-4 py-3 flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center">
                <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <div>
                <p class="text-xs font-bold text-primary-950">Nederlands bedrijf</p>
                <p class="text-[11px] text-primary-500">100% eigen team</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- 2B: Hero met team-fotostrook bovenin als menselijk element -->
    <div class="bg-primary-50/30 py-4 px-6 border-t border-primary-100">
      <div class="max-w-5xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary-400">Optie 2B — Subtiele team-foto strip bovenaan de hero (boven de headline)</p>
      </div>
    </div>

    <section class="relative overflow-hidden bg-white pt-24 pb-16">
      <div class="absolute inset-0 bg-gradient-to-b from-primary-50/50 to-primary-50/10 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">

        <!-- Team photo strip ABOVE headline -->
        <div class="max-w-3xl mx-auto text-center mb-8">
          <!-- Overlapping portraits + badge -->
          <div class="flex items-center justify-center gap-3 mb-6">
            <div class="flex -space-x-3">
              {[1,2,3,4,5].map(n => (
                <img src={`/team/portrait-${n}.webp`} alt="Teamlid" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md" style="object-position: center 15%;" />
              ))}
            </div>
            <div class="flex items-center gap-2 px-3 py-1 text-xs font-semibold text-primary-700 bg-primary-50 rounded-full border border-primary-200">
              <span class="w-1.5 h-1.5 bg-accent-500 rounded-full animate-pulse"></span>
              ISO Compliance Platform · Twente
            </div>
          </div>

          <h1 class="text-5xl sm:text-6xl lg:text-6xl xl:text-7xl font-bold tracking-tight text-primary-950 leading-[1.05]">
            Werken aan impact
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-accent-500 to-primary-600">Control One Portal</span>
          </h1>
          <p class="mt-6 text-lg sm:text-xl text-primary-700/70 max-w-2xl mx-auto leading-relaxed">
            Van risicoanalyse tot certificering: Control One begeleidt jouw organisatie stap voor stap.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="#" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-primary-950 hover:bg-primary-900 rounded-full transition-all shadow-lg shadow-primary-950/20">
              Gratis starten · 14 dagen
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </a>
            <a href="#" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-primary-800 border border-primary-200 hover:border-primary-400 hover:bg-primary-50 rounded-full transition-all">
              Bekijk een demo
            </a>
          </div>
        </div>

        <!-- Office photo below CTA buttons, above screenshot fan -->
        <div class="mt-10 grid grid-cols-3 gap-3 max-w-2xl mx-auto">
          <div class="rounded-2xl overflow-hidden aspect-[3/2] shadow-lg ring-1 ring-primary-100">
            <img src="/team/office-3.webp" alt="Kantoor" class="w-full h-full object-cover" style="object-position: center 35%;" />
          </div>
          <div class="rounded-2xl overflow-hidden aspect-[3/2] shadow-lg ring-1 ring-primary-100">
            <img src="/team/office-1.webp" alt="Team" class="w-full h-full object-cover" style="object-position: center 30%;" />
          </div>
          <div class="rounded-2xl overflow-hidden aspect-[3/2] shadow-lg ring-1 ring-primary-100">
            <img src="/team/office-4.webp" alt="Kantoor" class="w-full h-full object-cover" style="object-position: center 35%;" />
          </div>
        </div>
        <p class="text-center text-xs text-primary-400 mt-3">📍 Control One HQ · Enschede, Twente</p>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         OPTIE 3 — Collage strip (3 foto's naast elkaar)
    ════════════════════════════════════════════════════ -->
    <div id="optie-3" class="bg-primary-50 py-8 px-6 border-t-4 border-primary-100">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center gap-3 mb-2">
          <span class="w-8 h-8 rounded-full bg-primary-700 text-white text-sm font-bold flex items-center justify-center shrink-0">3</span>
          <div>
            <p class="font-bold text-primary-950 text-lg">Compacte fotocollage strip</p>
            <p class="text-sm text-primary-600">Lichte sectie met 3–4 foto's naast elkaar · past goed boven of onder de CTA</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 3A: RADICAAL NIEUWE versie — Editoriaal portret-split -->
    <div class="bg-primary-50/30 py-4 px-6">
      <div class="max-w-5xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary-400">Optie 3A — Editoriaal portret-split (nieuw) ✦</p>
      </div>
    </div>

    <section class="overflow-hidden bg-white">
      <div class="flex flex-col lg:flex-row" style="min-height: 580px;">

        <!-- Left: Donker content panel -->
        <div class="relative flex flex-col justify-between px-10 sm:px-14 py-14 lg:py-16 lg:w-[44%] shrink-0" style="background: linear-gradient(160deg, #2d5fa8 0%, #2554a0 100%);">
          <!-- Decoratief stippelpatroon -->
          <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 22px 22px;"></div>

          <!-- Bovenkant content -->
          <div class="relative z-10">
            <!-- Location badge -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-8 text-xs font-bold tracking-widest uppercase text-blue-200 bg-white/10 rounded-full border border-white/20 w-fit">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
              Enschede, Twente
            </div>

            <!-- Headline -->
            <h2 class="text-3xl sm:text-4xl xl:text-[2.6rem] font-bold text-white tracking-tight leading-[1.1]">
              Gebouwd in Twente.<br />
              Ingezet door<br />
              <em class="not-italic text-accent-400">heel Nederland.</em>
            </h2>

            <!-- Subtiele lijn -->
            <div class="mt-8 w-10 h-0.5 rounded-full bg-white/20"></div>

            <!-- Omschrijving -->
            <p class="mt-6 text-blue-100/70 leading-relaxed max-w-sm text-[15px]">
              Een team van compliance-professionals en software-ontwikkelaars. Geen consultants, geen tussenpersonen — gewoon software die werkt.
            </p>

            <!-- Feature bullets -->
            <ul class="mt-7 space-y-2.5">
              {['100% Nederlands eigendom', 'EU-hosting · AVG-compliant', 'Opgericht vanuit eigen ISO-ervaring'].map(item => (
                <li class="flex items-center gap-2.5 text-sm text-white/75">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent-400 shrink-0 mt-px"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Onderkant: stats + teamstrip -->
          <div class="relative z-10 mt-12">
            <!-- Stats row -->
            <div class="flex gap-7 mb-9 pb-9 border-b border-white/10">
              <div>
                <p class="text-2xl font-bold text-white leading-none">28</p>
