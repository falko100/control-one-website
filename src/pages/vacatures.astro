---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const perks = [
  { title: 'Remote-first', description: 'Werk vanuit huis of waar je maar wilt in Nederland.' },
  { title: 'Flexibele uren', description: 'We meten output, niet aanwezigheid.' },
  { title: 'Leerbudget', description: 'Jaarlijks budget voor cursussen, conferenties en boeken.' },
  { title: 'Moderne stack', description: 'Laravel, Filament, Tailwind CSS en meer.' },
];

const vacatures = [
  {
    title: 'Full-stack Developer (Laravel)',
    type: 'Fulltime',
    location: 'Enschede / Remote',
    department: 'Engineering',
    description: 'Je werkt aan het hart van ons platform: van nieuwe features voor de implementatiecoach tot risicoanalyse-modules en documentbeheer. Je bouwt mee aan een product dat dagelijks gebruikt wordt door organisaties die ISO-certificering nastreven.',
    requirements: [
      'Sterke kennis van Laravel en PHP',
      'Ervaring met Vue.js of Livewire',
      'Affiniteit met clean code en testbaar schrijven',
      'Zelfstandig en resultaatgericht',
    ],
  },
  {
    title: 'ISO-consultant (Parttime)',
    type: 'Parttime · 16–24 uur',
    location: 'Enschede / Remote',
    department: 'Consultancy',
    description: 'Je bent de expert achter onze chat consultancy. Klanten stellen gerichte vragen over hun ISO-traject en jij geeft praktische, heldere antwoorden. Daarnaast draag je bij aan het verbeteren van onze kennisbank, sjablonen en coachstappen.',
    requirements: [
      'Aantoonbare ervaring met ISO 27001, 9001, 14001 of 45001',
      'Sterke schriftelijke communicatie in het Nederlands',
      'In staat om complexe normen helder uit te leggen',
      'Bij voorkeur ervaring als lead auditor of implementatieconsultant',
    ],
  },
  {
    title: 'Sales Development Representative',
    type: 'Fulltime',
    location: 'Enschede / Remote',
    department: 'Sales',
    description: 'Jij bent het eerste aanspreekpunt voor potentiële klanten. Je kwalificeert leads, voert kennismakingsgesprekken en helpt organisaties begrijpen hoe Control One hen naar certificering brengt. Je werkt nauw samen met marketing en product.',
    requirements: [
      'Minimaal 1 jaar ervaring in sales of accountmanagement',
      'Interesse in compliance, SaaS of B2B-software',
      'Proactief en communicatief sterk',
      'Ervaring met een CRM-systeem is een pré',
    ],
  },
];

const today = new Date().toISOString().split('T')[0];
const validThroughDate = new Date();
validThroughDate.setMonth(validThroughDate.getMonth() + 3);
const validThrough = validThroughDate.toISOString().split('T')[0];

const jobSchemas = vacatures.map(v => ({
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: v.title,
  description: `${v.description}\n\nWat we van je vragen:\n${v.requirements.map(r => `- ${r}`).join('\n')}`,
  datePosted: today,
  validThrough,
  employmentType: v.type.toLowerCase().includes('parttime') ? 'PART_TIME' : 'FULL_TIME',
  hiringOrganization: {
    '@type': 'Organization',
    name: 'Control One',
    sameAs: 'https://control-one.nl',
    logo: 'https://control-one.nl/logo.svg',
  },
  jobLocation: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Twekkeler Es 42',
      postalCode: '7547 SM',
      addressLocality: 'Enschede',
      addressRegion: 'Overijssel',
      addressCountry: 'NL',
    },
  },
  applicantLocationRequirements: { '@type': 'Country', name: 'Netherlands' },
  jobLocationType: 'TELECOMMUTE',
  industry: 'Software / Compliance',
  occupationalCategory: v.department,
  inLanguage: 'nl-NL',
}));

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
    { '@type': 'ListItem', position: 2, name: 'Vacatures', item: 'https://control-one.nl/vacatures' },
  ],
};
---

<Layout
  title="Vacatures — Werk bij Control One"
  description="Bekijk onze openstaande vacatures. Bouw mee aan de toekomst van ISO-compliance bij Control One in Enschede. Remote-first, flexibele uren en een moderne tech stack."
  jsonLd={[...jobSchemas, breadcrumbSchema]}
>
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-accent-400 bg-white/10 rounded-full">
            <span class="w-1.5 h-1.5 bg-accent-400 rounded-full"></span>
            Vacatures
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Bouw mee aan de toekomst van
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-primary-300">compliance</span>
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-2xl mx-auto leading-relaxed">
            We zijn een klein team vanuit Enschede met grote ambities. Wij zoeken mensen die willen bouwen, leren en impact maken.
          </p>
        </div>
      </div>
    </section>

    <!-- Perks -->
    <section class="py-20 bg-white border-b border-primary-100">
      <div class="max-w-4xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Waarom Control One?</p>
          <h2 class="text-3xl font-bold text-primary-950 tracking-tight">Werken bij ons</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-6">
          {perks.map(p => (
            <div class="p-6 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <h3 class="font-semibold text-primary-950 mb-2">{p.title}</h3>
              <p class="text-sm text-primary-900/60 leading-relaxed">{p.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Open vacatures -->
    <section class="py-24 bg-primary-50/40">
      <div class="max-w-4xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Nu beschikbaar</p>
          <h2 class="text-3xl font-bold text-primary-950 tracking-tight">Openstaande vacatures</h2>
          <p class="mt-3 text-primary-900/75">{vacatures.length} posities beschikbaar</p>
        </div>

        <div class="space-y-5">
          {vacatures.map(v => (
            <div class="bg-white rounded-2xl border border-primary-100 shadow-sm p-8 hover:shadow-md hover:border-primary-200 transition-all">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-5">
                <div>
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-primary-500 bg-primary-50 border border-primary-200 px-2.5 py-1 rounded-full">{v.department}</span>
                    <span class="text-xs font-semibold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2.5 py-1 rounded-full">{v.type}</span>
                  </div>
                  <h3 class="text-xl font-bold text-primary-950">{v.title}</h3>
                  <p class="text-sm text-primary-500 mt-1 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    {v.location}
                  </p>
                </div>
                <a href={`/contact?vacature=${encodeURIComponent(v.title)}`} class="shrink-0 inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-primary-700 hover:bg-primary-800 rounded-xl transition-all shadow-sm shadow-primary-700/20 whitespace-nowrap">
                  Solliciteer
                  <svg class="ml-1.5 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </a>
              </div>

              <p class="text-sm text-primary-900/65 leading-relaxed mb-5">{v.description}</p>

              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-primary-400 mb-3">Wat we zoeken</p>
                <ul class="space-y-2">
                  {v.requirements.map(r => (
                    <li class="flex items-start gap-2.5 text-sm text-primary-800/70">
                      <svg class="w-4 h-4 text-primary-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                      {r}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>

        <!-- Open sollicitatie -->
        <div class="mt-10 p-8 sm:p-10 rounded-3xl bg-white border border-primary-100 text-center">
          <h2 class="text-xl font-bold text-primary-950 mb-3">Staat jouw rol er niet bij?</h2>
          <p class="text-primary-900/60 leading-relaxed max-w-lg mx-auto mb-6 text-sm">
            Stuur een open sollicitatie. We zijn altijd geïnteresseerd in mensen die passen bij onze missie, ook als er geen specifieke vacature voor is.
          </p>
          <a href="/contact" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-primary-700 bg-primary-50 hover:bg-primary-100 border border-primary-200 rounded-xl transition-all">
            Open sollicitatie sturen
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
