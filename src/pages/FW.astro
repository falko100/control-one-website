---
// 🎂 Geheim verjaardagspagina — niet te serieus nemen
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>🎂 GEFELICITEERD FALKO 🎂</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: #0d0d1a;
      color: white;
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* ── Confetti canvas ── */
    #confetti-canvas {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    .page {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 60px 24px 100px;
      text-align: center;
    }

    /* ── Badge ── */
    .badge {
      display: inline-block;
      background: linear-gradient(135deg, #f59e0b, #ef4444);
      color: white;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 999px;
      margin-bottom: 28px;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }

    /* ── Hero title ── */
    .hero-title {
      font-size: clamp(3rem, 10vw, 6rem);
      font-weight: 900;
      line-height: 1;
      background: linear-gradient(135deg, #f59e0b 0%, #ef4444 30%, #a855f7 60%, #3b82f6 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: rainbow 4s linear infinite;
      background-size: 200% 200%;
    }
    @keyframes rainbow {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .hero-name {
      font-size: clamp(2rem, 7vw, 4.5rem);
      font-weight: 900;
      color: white;
      margin-top: 8px;
      text-shadow: 0 0 40px rgba(168, 85, 247, 0.5);
    }

    /* ── Photo ── */
    .photo-wrap {
      position: relative;
      display: inline-block;
      margin-bottom: 28px;
    }
    .photo-wrap img {
      width: 130px;
      height: 130px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      border: 4px solid transparent;
      background: linear-gradient(#0d0d1a, #0d0d1a) padding-box,
                  linear-gradient(135deg, #f59e0b, #ef4444, #a855f7, #3b82f6) border-box;
      box-shadow: 0 0 40px rgba(168, 85, 247, 0.4), 0 0 80px rgba(245, 158, 11, 0.15);
      animation: photoglow 3s ease-in-out infinite alternate;
    }
    @keyframes photoglow {
      from { box-shadow: 0 0 30px rgba(168, 85, 247, 0.4), 0 0 60px rgba(245, 158, 11, 0.15); }
      to   { box-shadow: 0 0 50px rgba(59, 130, 246, 0.5), 0 0 90px rgba(239, 68, 68, 0.2); }
    }
    /* Party hat on top */
    .photo-hat {
      position: absolute;
      top: -28px;
      left: 50%;
      transform: translateX(-40%) rotate(-15deg);
      font-size: 2.2rem;
      animation: hatbounce 1.2s ease-in-out infinite;
      filter: drop-shadow(0 2px 6px rgba(0,0,0,0.5));
    }
    @keyframes hatbounce {
      0%, 100% { transform: translateX(-40%) rotate(-15deg) translateY(0); }
      50%       { transform: translateX(-40%) rotate(-15deg) translateY(-6px); }
    }

    /* ── Tagline ── */
    .tagline {
      margin-top: 20px;
      font-size: 1.2rem;
      color: #94a3b8;
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.6;
    }

    /* ── GIF grid ── */
    .gif-section {
      margin-top: 52px;
    }
    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #64748b;
      margin-bottom: 20px;
    }
    .gif-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .gif-grid .big {
      grid-column: span 2;
    }
    .gif-wrap {
      border-radius: 20px;
      overflow: hidden;
      border: 2px solid rgba(255,255,255,0.08);
      background: #1e1e2e;
      position: relative;
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    }
    .gif-wrap:hover {
      transform: scale(1.03) rotate(-1deg);
      box-shadow: 0 20px 60px rgba(168, 85, 247, 0.25);
    }
    .gif-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      min-height: 200px;
    }
    .gif-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 8px 12px;
      background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
      font-size: 12px;
      font-weight: 600;
      color: white;
      text-align: left;
    }

    /* ── Fun facts ── */
    .facts-section {
      margin-top: 56px;
      padding: 40px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 28px;
      text-align: left;
    }
    .facts-title {
      font-size: 1.4rem;
      font-weight: 800;
      color: white;
      margin-bottom: 24px;
      text-align: center;
    }
    .fact-item {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 16px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .fact-item:last-child { border-bottom: none; }
    .fact-emoji {
      font-size: 1.6rem;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .fact-text {
      font-size: 1rem;
      color: #cbd5e1;
      line-height: 1.5;
    }
    .fact-text strong { color: white; }

    /* ── Second GIF row ── */
    .gif-row-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 16px;
    }

    /* ── Sign-off ── */
    .signoff {
      margin-top: 56px;
      padding: 40px;
      background: linear-gradient(135deg, rgba(168,85,247,0.12), rgba(59,130,246,0.12));
      border: 1px solid rgba(168,85,247,0.25);
      border-radius: 28px;
    }
    .signoff-emoji {
      font-size: 3rem;
      display: block;
      margin-bottom: 16px;
      animation: wobble 1s ease-in-out infinite;
    }
    @keyframes wobble {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(-8deg); }
      75% { transform: rotate(8deg); }
    }
    .signoff-text {
      font-size: 1.1rem;
      color: #cbd5e1;
      line-height: 1.7;
    }
    .signoff-team {
      margin-top: 20px;
      font-size: 1.4rem;
      font-weight: 900;
      background: linear-gradient(135deg, #f59e0b, #ef4444);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Big center GIF ── */
    .gif-center {
      margin-top: 16px;
      border-radius: 20px;
      overflow: hidden;
      border: 2px solid rgba(255,255,255,0.08);
      max-height: 340px;
    }
    .gif-center img {
      width: 100%;
      height: 340px;
      object-fit: cover;
      display: block;
    }

    @media (max-width: 640px) {
      .gif-grid { grid-template-columns: 1fr; }
      .gif-grid .big { grid-column: span 1; }
      .gif-row-2 { grid-template-columns: 1fr; }
      .facts-section { padding: 24px; }
    }
  </style>
</head>
<body>

  <canvas id="confetti-canvas"></canvas>

  <div class="page">

    <!-- Hero -->
    <div class="badge">🎂 Vandaag is het zover 🎂</div>

    <!-- Photo -->
    <div class="photo-wrap">
      <span class="photo-hat">🎉</span>
      <img src="/falko.jpg" alt="Falko" />
    </div>

    <div class="hero-title">GEFELICITEERD!</div>
    <div class="hero-name">Falko 🎂</div>
    <p class="tagline">
      De man. De mythe. De legende. Vandaag officieel een versienummer hoger.
      We weten niet zeker of dat een feature of een bug is, maar het voelt goed.
    </p>

    <!-- GIF grid row 1 -->
    <div class="gif-section">
      <div class="section-label">🎊 Geanimeerde felicitaties 🎊</div>
      <div class="gif-grid">
        <div class="gif-wrap big">
          <img src="https://media.giphy.com/media/l0MYt5jPR6QX5pnqM/giphy.gif" alt="Party time!" loading="eager" />
          <div class="gif-caption">🥳 De werkvloer op jouw verjaardag</div>
        </div>
        <div class="gif-wrap">
          <img src="https://media.giphy.com/media/3oEjHBa34dVLv0jnoc/giphy.gif" alt="Birthday cake" loading="eager" />
          <div class="gif-caption">🎂 Taart ≠ calorieën op je verjaardag</div>
        </div>
      </div>

      <div class="gif-row-2">
        <div class="gif-wrap">
          <img src="https://media.giphy.com/media/artj92V8o75VPL7AeQ/giphy.gif" alt="Celebration" loading="eager" />
          <div class="gif-caption">🕺 Jij als je klokslag 09:00</div>
        </div>
        <div class="gif-wrap">
          <img src="https://media.giphy.com/media/g9582DNuQppxC/giphy.gif" alt="Confetti" loading="eager" />
          <div class="gif-caption">🎉 Het hele kantoor voor jou</div>
        </div>
      </div>
    </div>

    <!-- Fun facts -->
    <div class="facts-section">
      <div class="facts-title">📋 Officieel Verjaardagsrapport: Falko</div>

      <div class="fact-item">
        <span class="fact-emoji">🧓</span>
        <div class="fact-text">
          <strong>Leeftijd in software-jaren:</strong> Als Falko een framework was, zou hij al drie major versies achter lopen en staan er overal deprecated-warnings. Gelukkig is hij geen framework. Hij is een mens. <em>Waarschijnlijk.</em>
        </div>
      </div>

      <div class="fact-item">
        <span class="fact-emoji">☕</span>
        <div class="fact-text">
          <strong>Koffieconsumptie Q1-Q4:</strong> Statistisch gezien heeft Falko dit jaar genoeg koffie gedronken om een middelgrote database te vullen. De exacte hoeveelheid wordt niet gelogd. Dat is waarschijnlijk met opzet.
        </div>
      </div>

      <div class="fact-item">
        <span class="fact-emoji">🤌</span>
        <div class="fact-text">
          <strong>Communicatiestijl:</strong> Legt technische problemen uit op een manier die iedereen laat knikken alsof ze het begrijpen. Niemand begrijpt het. Falko weet dit. Hij knikt vriendelijk terug.
        </div>
      </div>

      <div class="fact-item">
        <span class="fact-emoji">⚡</span>
        <div class="fact-text">
          <strong>Laravel-expertise (gecertificeerd door niemand, betwist door niemand):</strong> Kan een Laravel-fout debuggen die hij zelf heeft veroorzaakt met een snelheid die suggereert dat hij hem expres heeft aangemaakt, alleen om daarna indrukwekkend te zijn. We hebben dit nooit kunnen bewijzen. We proberen het ook niet meer.
        </div>
      </div>

      <div class="fact-item">
        <span class="fact-emoji">📱</span>
        <div class="fact-text">
          <strong>Reactiesnelheid op berichten:</strong> Reageert op technische vragen binnen 4 minuten. Op "kun je even bellen?" gemiddeld 3 werkdagen. Het systeem werkt. Niemand klaagt.
        </div>
      </div>

      <div class="fact-item">
        <span class="fact-emoji">🎂</span>
        <div class="fact-text">
          <strong>Verwachting voor vandaag:</strong> Zal minimaal eenmaal zeggen dat hij "niet zo'n verjaardagspersoon" is, terwijl hij stiekem hoopt op taart, aandacht en een vroeg naar huis. Volledig begrijpelijk. Volledig doorzien.
        </div>
      </div>
    </div>

    <!-- Center GIF -->
    <div class="gif-center" style="margin-top: 40px;">
      <img src="https://media.giphy.com/media/YTbZzCkRQCEJa/giphy.gif" alt="Office celebration" loading="lazy" />
    </div>


  </div>

  <script>
    // ── Confetti ──────────────────────────────────────────
    const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    let W = canvas.width  = window.innerWidth;
    let H = canvas.height = window.innerHeight;
    window.addEventListener('resize', () => { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; });

    const colors = ['#f59e0b','#ef4444','#a855f7','#3b82f6','#10b981','#f472b6','#facc15'];

    interface Particle {
      x: number; y: number;
      w: number; h: number;
      color: string;
      rotation: number;
      rotSpeed: number;
      speedX: number;
      speedY: number;
      opacity: number;
    }

    const particles: Particle[] = Array.from({ length: 140 }, () => ({
      x: Math.random() * window.innerWidth,
      y: Math.random() * -window.innerHeight,
      w: Math.random() * 10 + 5,
      h: Math.random() * 6 + 3,
      color: colors[Math.floor(Math.random() * colors.length)],
      rotation: Math.random() * Math.PI * 2,
      rotSpeed: (Math.random() - 0.5) * 0.1,
      speedX: (Math.random() - 0.5) * 1.5,
      speedY: Math.random() * 2 + 1.2,
      opacity: Math.random() * 0.7 + 0.3,
    }));

    function draw() {
      ctx.clearRect(0, 0, W, H);
      particles.forEach(p => {
        ctx.save();
        ctx.globalAlpha = p.opacity;
        ctx.translate(p.x + p.w / 2, p.y + p.h / 2);
        ctx.rotate(p.rotation);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
        ctx.restore();

        p.x += p.speedX;
        p.y += p.speedY;
        p.rotation += p.rotSpeed;

        if (p.y > H + 20) {
          p.y = -20;
          p.x = Math.random() * W;
        }
      });
      requestAnimationFrame(draw);
    }
    draw();
  </script>

</body>
</html>
