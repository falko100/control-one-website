---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Bericht verzonden — Bedankt! | Control One"
  description="Bedankt voor je bericht. We nemen zo snel mogelijk contact met je op."
  noindex={true}
>
  <Header />
  <main class="bg-gradient-to-b from-white to-primary-50/30 min-h-[70vh] flex items-center">
    <section class="max-w-3xl mx-auto px-6 py-24 text-center">
      <div class="inline-flex w-16 h-16 items-center justify-center rounded-full bg-gradient-to-br from-primary-500 to-primary-700 shadow-lg shadow-primary-500/20 mb-8">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-primary-950 leading-tight">Bedankt voor je bericht!</h1>
      <p class="mt-5 text-lg text-primary-600 leading-relaxed">
        We hebben je bericht in goede orde ontvangen en nemen zo snel mogelijk — meestal binnen één werkdag — contact met je op.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white rounded-xl shadow-lg transition-all"
          style="background: linear-gradient(135deg, #2d5fa8, #2554a0);"
        >
          Terug naar home
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-700 bg-white border border-primary-200 rounded-xl hover:border-primary-400 transition-all"
        >
          Lees onze kennisbank
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
