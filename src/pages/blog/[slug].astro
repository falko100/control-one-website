---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  // Voeg 1 dag toe zodat posts op de publicatiedatum zelf altijd zichtbaar zijn (tijdzone-correctie)
  const now = new Date(new Date().getTime() + 24 * 60 * 60 * 1000);
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.publishDate <= now);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const { title, description, publishDate, category, readTime, author, image, imageAlt, keywords } = post.data;

const formattedDate = publishDate.toLocaleDateString('nl-NL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `https://control-one.nl/blog/${post.slug}#article`,
  headline: title,
  description: description,
  image: image ? `https://control-one.nl${image}` : 'https://control-one.nl/og-image.png',
  datePublished: publishDate.toISOString(),
  dateModified: publishDate.toISOString(),
  inLanguage: 'nl-NL',
  articleSection: category,
  author: {
    '@type': 'Organization',
    '@id': 'https://control-one.nl/#organization',
    name: author || 'Control One Redactie',
    url: 'https://control-one.nl/over-ons',
    description: 'De redactie van Control One bestaat uit ISO-specialisten met ervaring in het implementeren van ISO 27001, 9001, 14001 en 45001 bij Nederlandse MKB-organisaties.',
    knowsAbout: ['ISO 27001', 'ISO 9001', 'ISO 14001', 'ISO 45001', 'AVG', 'NIS2', 'Informatiebeveiliging', 'Compliance'],
  },
  publisher: {
    '@type': 'Organization',
    '@id': 'https://control-one.nl/#organization',
    name: 'Control One',
    url: 'https://control-one.nl',
    logo: {
      '@type': 'ImageObject',
      url: 'https://control-one.nl/logo.svg',
      width: 512,
      height: 512,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://control-one.nl/blog/${post.slug}`,
  },
  isPartOf: {
    '@type': 'Blog',
    '@id': 'https://control-one.nl/blog#blog',
    name: 'Control One Blog',
  },
  keywords: keywords?.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://control-one.nl/blog' },
    { '@type': 'ListItem', position: 3, name: title, item: `https://control-one.nl/blog/${post.slug}` },
  ],
};
---

<Layout
  title={`${title} | Control One Blog`}
  description={description}
  image={image ?? '/og-image.png'}
  ogType="article"
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-16 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-accent-400/8 rounded-full blur-3xl -translate-y-1/4 translate-x-1/4"></div>

      <div class="relative max-w-4xl mx-auto px-6">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-primary-400/70 mb-8">
          <a href="/" class="hover:text-primary-300 transition-colors">Home</a>
          <span>/</span>
          <a href="/blog" class="hover:text-primary-300 transition-colors">Blog</a>
          <span>/</span>
          <span class="text-primary-300">{category}</span>
        </nav>

        <!-- Category & meta -->
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="inline-flex px-3 py-1 text-xs font-semibold tracking-wide uppercase text-accent-400 bg-white/10 rounded-full">
            {category}
          </span>
          <span class="text-primary-400/60 text-sm">{formattedDate}</span>
          <span class="text-primary-400/40 text-sm">·</span>
          <span class="text-primary-400/60 text-sm">{readTime} leestijd</span>
          <span class="text-primary-400/40 text-sm">·</span>
          <span class="text-primary-400/60 text-sm">{author}</span>
        </div>

        <!-- Title -->
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white leading-[1.15] mb-6">
          {title}
        </h1>

        <!-- Description -->
        <p class="text-lg text-primary-300/80 leading-relaxed max-w-2xl">
          {description}
        </p>
      </div>
    </section>

    <!-- Hero image -->
    {image && (
      <div class="max-w-4xl mx-auto px-6 -mt-4">
        <div class="rounded-2xl overflow-hidden shadow-2xl shadow-primary-950/50">
          <img
            src={image}
            alt={imageAlt ?? title}
            class="w-full"
            width="1200"
            height="630"
            loading="eager"
          />
        </div>
      </div>
    )}

    <!-- Article content + sidebar -->
    <div class="max-w-7xl mx-auto px-6 py-16">
      <div class="flex flex-col lg:flex-row gap-12">

        <!-- Main content -->
        <article class="flex-1 min-w-0">
          <div class="prose prose-lg prose-primary max-w-none
            prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-primary-950
            prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:pt-8 prose-h2:border-t prose-h2:border-primary-100
            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-primary-800
            prose-p:text-primary-900/75 prose-p:leading-relaxed
            prose-a:text-primary-600 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
            prose-strong:text-primary-950 prose-strong:font-semibold
            prose-blockquote:border-l-4 prose-blockquote:border-accent-400 prose-blockquote:bg-primary-50 prose-blockquote:rounded-r-xl prose-blockquote:py-1 prose-blockquote:px-6 prose-blockquote:not-italic prose-blockquote:text-primary-700
            prose-table:text-sm
            prose-thead:bg-primary-50
            prose-th:text-primary-700 prose-th:font-semibold prose-th:px-4 prose-th:py-3
            prose-td:px-4 prose-td:py-3 prose-td:text-primary-900/70
            prose-tr:border-b prose-tr:border-primary-100
            prose-code:text-accent-700 prose-code:bg-primary-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-mono prose-code:text-sm
            prose-ul:text-primary-900/75 prose-li:my-1
            prose-hr:border-primary-200 prose-hr:my-12
          ">
            <Content />
          </div>

          <!-- CTA at bottom of article -->
          <div class="mt-16 p-8 rounded-2xl bg-gradient-to-br from-primary-950 to-primary-800 text-white">
            <div class="flex items-start gap-4 mb-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-accent-400/20 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Klaar om te starten met ISO 27001?</h3>
                <p class="text-primary-300/80 leading-relaxed">
                  Control One begeleidt je stap voor stap door het volledige implementatieproces. Van gap-analyse tot certificeringsaudit — inclusief alle templates en werkstromen.
                </p>
              </div>
            </div>
            <div class="flex flex-col sm:flex-row gap-3 mt-6">
              <a
                href="/prijzen"
                class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent-400 text-primary-950 font-semibold rounded-xl hover:bg-accent-300 transition-colors"
              >
                Gratis starten
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
              <a
                href="/iso-27001"
                class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/10 text-white font-medium rounded-xl hover:bg-white/20 transition-colors"
              >
                Meer over ISO 27001
              </a>
            </div>
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="lg:w-72 flex-shrink-0">
          <div class="sticky top-28 space-y-6">

            <!-- Table of contents -->
            <div class="p-5 rounded-2xl border border-primary-100 bg-primary-50/50">
              <h3 class="text-sm font-semibold text-primary-950 uppercase tracking-wide mb-4">Inhoudsopgave</h3>
              <nav class="space-y-1" id="toc">
                <!-- JS fills this -->
              </nav>
            </div>

            <!-- Quick facts -->
            <div class="p-5 rounded-2xl border border-primary-100">
              <h3 class="text-sm font-semibold text-primary-950 uppercase tracking-wide mb-4">Snel overzicht</h3>
              <dl class="space-y-3 text-sm">
                <div>
                  <dt class="text-primary-900/50 mb-0.5">Doorlooptijd</dt>
                  <dd class="font-medium text-primary-950">5–9 maanden</dd>
                </div>
                <div>
                  <dt class="text-primary-900/50 mb-0.5">Kosten (consultant)</dt>
                  <dd class="font-medium text-primary-950">€18.000–€25.000</dd>
                </div>
                <div>
                  <dt class="text-primary-900/50 mb-0.5">Kosten (zelf)</dt>
                  <dd class="font-medium text-green-700">€500–€2.000/jaar</dd>
                </div>
                <div>
                  <dt class="text-primary-900/50 mb-0.5">Certificaat geldig</dt>
                  <dd class="font-medium text-primary-950">3 jaar</dd>
                </div>
                <div>
                  <dt class="text-primary-900/50 mb-0.5">Bewijsperiode</dt>
                  <dd class="font-medium text-primary-950">min. 3 maanden</dd>
                </div>
              </dl>
            </div>

            <!-- Related links -->
            <div class="p-5 rounded-2xl border border-primary-100">
              <h3 class="text-sm font-semibold text-primary-950 uppercase tracking-wide mb-4">Gerelateerd</h3>
              <ul class="space-y-2 text-sm">
                <li>
                  <a href="/iso-27001" class="text-primary-600 hover:text-primary-800 transition-colors flex items-center gap-2">
                    <span class="text-primary-300">→</span>
                    ISO 27001 module in Control One
                  </a>
                </li>
                <li>
                  <a href="/iso-9001" class="text-primary-600 hover:text-primary-800 transition-colors flex items-center gap-2">
                    <span class="text-primary-300">→</span>
                    ISO 9001 combineren
                  </a>
                </li>
                <li>
                  <a href="/faq" class="text-primary-600 hover:text-primary-800 transition-colors flex items-center gap-2">
                    <span class="text-primary-300">→</span>
                    Veelgestelde vragen
                  </a>
                </li>
                <li>
                  <a href="/prijzen" class="text-primary-600 hover:text-primary-800 transition-colors flex items-center gap-2">
                    <span class="text-primary-300">→</span>
                    Bekijk prijzen
                  </a>
                </li>
              </ul>
            </div>

          </div>
        </aside>

      </div>
    </div>

  </main>
  <Footer />
</Layout>

<script>
  // Build table of contents from h2/h3 headings in the article
  const article = document.querySelector('article .prose');
  const toc = document.getElementById('toc');
  if (article && toc) {
    const headings = article.querySelectorAll('h2, h3');
    headings.forEach((heading, i) => {
      const id = `heading-${i}`;
      heading.id = id;
      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = heading.textContent ?? '';
      a.className = heading.tagName === 'H2'
        ? 'block text-sm text-primary-700 hover:text-primary-950 transition-colors py-0.5'
        : 'block text-sm text-primary-500 hover:text-primary-700 transition-colors py-0.5 pl-3';
      toc.appendChild(a);
    });
  }
</script>

<style>
  /* Table styling inside prose */
  .prose table {
    width: 100%;
    border-collapse: collapse;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.06);
  }
  .prose table thead {
    background-color: rgb(var(--color-primary-50));
  }
  .prose table th,
  .prose table td {
    text-align: left;
  }
  .prose table tr:last-child td {
    border-bottom: none;
  }
</style>
