    items: [
      { num: '6.1', title: 'Screening' },
      { num: '6.2', title: 'Arbeidsvoorwaarden' },
      { num: '6.3', title: 'Bewustwording, opleiding en training op het gebied van informatiebeveiliging' },
      { num: '6.4', title: 'Disciplinair proces' },
