---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const chapters = [
  { number: '4', title: 'Context van de organisatie', description: 'Begrijp uw organisatie, belanghebbenden en het toepassingsgebied van uw ISMS.' },
  { number: '5', title: 'Leiderschap', description: 'Zorg voor betrokkenheid van het management, beleid en rollen & verantwoordelijkheden.' },
  { number: '6', title: 'Planning', description: 'Pak risico\'s en kansen aan, stel doelen en plan wijzigingen.' },
  { number: '7', title: 'Ondersteuning', description: 'Beheer middelen, competenties, bewustzijn, communicatie en gedocumenteerde informatie.' },
  { number: '8', title: 'Uitvoering', description: 'Implementeer uw informatiebeveiligingsprocessen en beheersmaatregelen.' },
  { number: '9', title: 'Evaluatie van prestaties', description: 'Monitor, meet, analyseer en evalueer uw ISMS-prestaties.' },
  { number: '10', title: 'Verbetering', description: 'Pak afwijkingen aan en streef naar continue verbetering van uw ISMS.' },
];

const annexCategories = [
  { name: 'Organisatorische beheersmaatregelen', count: '37', icon: '🏢' },
  { name: 'Beheersmaatregelen voor mensen', count: '8', icon: '👥' },
  { name: 'Fysieke beheersmaatregelen', count: '14', icon: '🔒' },
  { name: 'Technologische beheersmaatregelen', count: '34', icon: '💻' },
];

const benefits = [
  { title: 'Bescherm gevoelige data', description: 'Systematische aanpak voor het beschermen van vertrouwelijke informatie tegen datalekken en cyberaanvallen.' },
  { title: 'Voldoe aan wet- en regelgeving', description: 'Demonstreer compliance met AVG, NIS2 en andere regelgeving via een erkend framework.' },
  { title: 'Win het vertrouwen van klanten', description: 'ISO 27001-certificering is wereldwijd erkend en geeft klanten vertrouwen in uw informatiebeveiliging.' },
  { title: 'Verminder beveiligingsincidenten', description: 'Proactieve risicobeoordeling en beheersmaatregelen verminderen de kans op kostbare incidenten.' },
];
---

<Layout title="ISO 27001 Informatiebeveiliging — Control One">
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary-400/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-accent-400 bg-white/10 rounded-full backdrop-blur-sm">
            <span class="w-1.5 h-1.5 bg-accent-400 rounded-full"></span>
            Informatiebeveiliging
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-[1.1]">
            ISO 27001
          </h1>
          <p class="mt-2 text-xl sm:text-2xl font-medium text-primary-200">
            Information Security Management System
          </p>
          <p class="mt-6 text-lg text-primary-300/80 max-w-2xl leading-relaxed">
            Implementeer een ISMS volgens de internationale norm voor informatiebeveiliging. Control One begeleidt u van risicobeoordeling tot Annex A — stap voor stap.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="/demo" class="inline-flex items-center px-6 py-3 text-base font-semibold text-primary-900 bg-white hover:bg-primary-50 rounded-lg transition-all shadow-lg">
              Start met ISO 27001
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </a>
            <a href="/features" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white/90 hover:text-white border border-white/20 hover:border-white/40 rounded-lg transition-all">
              Bekijk alle functies
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- What is ISO 27001 -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Wat is ISO 27001?</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight mb-6">
              De internationale norm voor informatiebeveiliging
            </h2>
            <div class="text-primary-900/60 leading-relaxed space-y-4">
              <p>
                ISO 27001 is de meest erkende norm voor het beheren van gevoelige bedrijfsinformatie. Het biedt een systematische aanpak die mensen, processen en IT-systemen omvat via een risicomanagementproces.
              </p>
              <p>
                Certificering toont aan klanten, partners en toezichthouders dat uw organisatie informatiebeveiliging serieus neemt en internationaal erkende best practices volgt.
              </p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {benefits.map(b => (
              <div class="p-5 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100">
                <h3 class="font-semibold text-primary-950 mb-2 text-sm">{b.title}</h3>
                <p class="text-xs text-primary-900/50 leading-relaxed">{b.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Chapters -->
    <section class="py-24 bg-gradient-to-b from-primary-50/50 to-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Normstructuur</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Hoofdstukken 4–10
          </h2>
          <p class="mt-4 text-lg text-primary-900/60">
            Control One begeleidt u door elk hoofdstuk met een stapsgewijze coach, voortgangsregistratie en directe koppeling naar uw documenten.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {chapters.map((ch, i) => (
            <div class:list={[
              'group relative p-6 rounded-2xl border bg-white hover:shadow-lg hover:shadow-primary-100/50 transition-all',
              i === 0 ? 'border-primary-200 shadow-md' : 'border-primary-100',
            ]}>
              <div class:list={[
                'w-10 h-10 rounded-xl flex items-center justify-center font-bold text-sm mb-4',
                i === 0 ? 'bg-primary-600 text-white' : 'bg-primary-50 text-primary-600',
              ]}>
                {ch.number}
              </div>
              <h3 class="font-semibold text-primary-950 mb-2">{ch.title}</h3>
              <p class="text-sm text-primary-900/50 leading-relaxed">{ch.description}</p>
            </div>
          ))}
          <!-- Extra card: your journey -->
          <div class="relative p-6 rounded-2xl bg-gradient-to-br from-primary-700 to-primary-900 text-white overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
            <div class="relative">
              <div class="text-3xl font-bold mb-2">100%</div>
              <div class="text-primary-200 text-sm font-medium mb-4">Normdekkking</div>
              <p class="text-primary-300/80 text-sm leading-relaxed">
                Control One dekt alle hoofdstukken en beheersmaatregelen van ISO 27001:2022.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Annex A -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Annex A</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            93 beheersmaatregelen, 4 categorieën
          </h2>
          <p class="mt-4 text-lg text-primary-900/60">
            ISO 27001:2022 Annex A bevat 93 beheersmaatregelen. Control One helpt u bij het beoordelen, implementeren en documenteren van elke maatregel via de Verklaring van Toepasselijkheid.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
          {annexCategories.map(cat => (
            <div class="relative p-6 rounded-2xl border border-primary-100 bg-gradient-to-b from-white to-primary-50/30 text-center hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="text-4xl mb-4">{cat.icon}</div>
              <div class="text-3xl font-bold text-primary-700 mb-1">{cat.count}</div>
              <div class="text-sm text-primary-900/60 font-medium">{cat.name}</div>
            </div>
          ))}
        </div>

        <!-- SOA callout -->
        <div class="mt-16 max-w-4xl mx-auto p-8 rounded-3xl bg-gradient-to-r from-primary-50 to-accent-400/10 border border-primary-100">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
            <div class="w-14 h-14 rounded-2xl bg-primary-600 text-white flex items-center justify-center shrink-0">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"></path></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-primary-950 mb-1">Verklaring van Toepasselijkheid (VvT)</h3>
              <p class="text-primary-900/60">
                Genereer automatisch uw Statement of Applicability op basis van uw risicobeoordeling en geïmplementeerde beheersmaatregelen. Exporteer als PDF voor uw auditor.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
