      { num: '7.10', title: 'Opslagmedia' },
      { num: '7.11', title: 'Ondersteunende Voorzieningen' },
      { num: '7.12', title: 'Beveiliging van Bekabeling' },
      { num: '7.13', title: 'Onderhoud van de apparatuur' },
