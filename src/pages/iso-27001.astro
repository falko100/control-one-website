---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const chapters = [
  {
    number: '4',
    title: 'Context van de organisatie',
    description: 'Breng de interne en externe context van je organisatie in kaart en identificeer de eisen van belanghebbenden. Stel de scope van je ISMS helder vast, inclusief grenzen, toepasselijkheid en interfaces.',
    vereist: 'Inzicht in interne en externe context, identificatie van belanghebbenden en hun eisen, en een helder gedefinieerd toepassingsgebied voor het ISMS.',
    documenten: ['Scope document', 'Contextanalyse', 'Register van belanghebbenden'],
    platform: 'Interactieve scopebepaling wizard, contextanalyse template en automatisch gegenereerd scope document dat aansluit op auditorsverwachtingen.',
  },
  {
    number: '5',
    title: 'Leiderschap',
    description: 'Zorg voor aantoonbare betrokkenheid van het management bij informatiebeveiliging. Stel een formeel informatiebeveiligingsbeleid vast en wijs rollen en verantwoordelijkheden duidelijk toe.',
    vereist: 'Managementcommitment aantonen, een informatiebeveiligingsbeleid vaststellen en rollen, verantwoordelijkheden en bevoegdheden toewijzen.',
    documenten: ['Informatiebeveiligingsbeleid', 'Functiebeschrijvingen', 'Verantwoordelijkheidsmatrix'],
    platform: 'Beleidsgenerator met goedkeuringsworkflow, verantwoordelijkheidsmatrix en rollenregister voor je ISMS-team.',
  },
  {
    number: '6',
    title: 'Planning',
    description: 'Pak risico\'s en kansen aan, stel doelen en plan wijzigingen.',
    vereist: 'Risico\'s en kansen identificeren, een risicobeoordelingsproces uitvoeren, doelstellingen vaststellen en wijzigingsplanning inrichten.',
    documenten: ['Risicobeoordelingsrapport', 'Risicobewerkingsplan', 'Doelstellingenregister'],
    platform: 'Geïntegreerde risico-engine met behandelingsplan, rapportage en voortgangsregistratie van IS-doelstellingen.',
  },
  {
    number: '7',
    title: 'Ondersteuning',
    description: 'Beheer middelen, competenties, bewustzijn, communicatie en gedocumenteerde informatie.',
    vereist: 'Voldoende middelen beschikbaar stellen, competenties borgen, beveiligingsbewustzijn creëren en gedocumenteerde informatie beheersen.',
    documenten: ['Competentiematrix', 'Bewustwordingsprogramma', 'Documentbeheerbeleid'],
    platform: 'Centraal documentbeheer systeem, bewustwordings- en trainingsmodule en competentieregister voor je medewerkers.',
  },
  {
    number: '8',
    title: 'Uitvoering',
    description: 'Implementeer je informatiebeveiligingsprocessen en beheersmaatregelen.',
    vereist: 'Operationele planning en beheersing, uitvoering van het risicobewerkingsplan en implementatie van de 93 Annex A beheersmaatregelen.',
    documenten: ['Verklaring van Toepasselijkheid', 'Risicobehandelprocedures', 'Beleidsdocumenten per maatregel'],
    platform: 'Interactieve VvT builder, procedures bibliotheek en directe koppeling tussen geïmplementeerde maatregelen en je risicoregister.',
  },
  {
    number: '9',
    title: 'Evaluatie van prestaties',
    description: 'Monitor, meet, analyseer en evalueer je ISMS-prestaties.',
    vereist: 'Monitoren en meten van ISMS-prestaties, een intern auditprogramma uitvoeren en management reviews houden.',
    documenten: ['Auditplan & auditrapport', 'KPI-register', 'Directiebeoordelingsverslag'],
    platform: 'Gestructureerde auditworkflow met geautomatiseerde reminders, directiebeoordelingstemplates en KPI-tracking dashboard.',
  },
  {
    number: '10',
    title: 'Verbetering',
    description: 'Pak afwijkingen aan en streef naar continue verbetering van je ISMS.',
    vereist: 'Non-conformiteiten identificeren en corrigeren, corrigerende maatregelen treffen en continue verbetering van het ISMS documenteren.',
    documenten: ['Non-conformiteitenregister', 'Corrigerende maatregelenplan', 'Verbeterregister'],
    platform: 'Non-conformiteiten tracker, corrigerende maatregelenbeheer en verbeterdashboard voor structurele ISMS-groei.',
