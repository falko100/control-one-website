---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const contactOptions = [
  {
    title: 'Verkoop',
    description: 'Vragen over prijzen, demo\'s of enterprise-licenties.',
    email: 'sales@control-one.nl',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"></path></svg>`,
  },
  {
    title: 'Support',
    description: 'Hulp nodig met het platform? Ons supportteam staat klaar.',
    email: 'support@control-one.nl',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.712 4.33a9.027 9.027 0 011.652 1.306c.51.51.944 1.064 1.306 1.652M16.712 4.33l-3.448 4.138m3.448-4.138a9.014 9.014 0 00-9.424 0M19.67 7.288l-4.138 3.448m4.138-3.448a9.014 9.014 0 010 9.424m-4.138-5.976a3.736 3.736 0 00-.88-1.388 3.737 3.737 0 00-1.388-.88m2.268 2.268a3.765 3.765 0 010 2.528m-2.268-4.796a3.765 3.765 0 00-2.528 0m4.796 4.796c-.181.506-.475.982-.88 1.388a3.736 3.736 0 01-1.388.88m2.268-2.268l4.138 3.448m0 0a9.027 9.027 0 01-1.306 1.652c-.51.51-1.064.944-1.652 1.306m0 0l-3.448-4.138m3.448 4.138a9.014 9.014 0 01-9.424 0m5.976-4.138a3.765 3.765 0 01-2.528 0m0 0a3.736 3.736 0 01-1.388-.88 3.737 3.737 0 01-.88-1.388m0 0a3.765 3.765 0 010-2.528m2.268 4.796l-4.138 3.448M7.288 19.67a9.014 9.014 0 010-9.424m4.138 5.976l-3.448 4.138m0 0a9.027 9.027 0 01-1.652-1.306 9.027 9.027 0 01-1.306-1.652m0 0l4.138-3.448M4.33 16.712a9.014 9.014 0 010-9.424m4.138 5.976a3.765 3.765 0 010-2.528m0 0c.181-.506.475-.982.88-1.388a3.736 3.736 0 011.388-.88m-2.268 2.268L4.33 7.288m6.406 1.18L7.288 4.33m0 0a9.024 9.024 0 00-1.652 1.306A9.025 9.025 0 004.33 7.288"></path></svg>`,
  },
  {
    title: 'Partnerships',
    description: 'Interesse in een partnerschap of integratie? Laten we praten.',
    email: 'partners@control-one.nl',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"></path></svg>`,
  },
];
---

<Layout title="Contact — Neem contact op met Control One" description="Heb je een vraag over ISO-compliance of wil je een demo? Neem contact op met het Control One team. We reageren binnen één werkdag.">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-accent-400 bg-white/10 rounded-full">
            <span class="w-1.5 h-1.5 bg-accent-400 rounded-full"></span>
            Contact
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Neem
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-primary-300">contact</span> op
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-2xl mx-auto leading-relaxed">
            Heb je een vraag, wil je een demo of ben je benieuwd hoe Control One jouw organisatie kan helpen? We horen graag van je.
          </p>
        </div>
      </div>
    </section>

    <!-- Meeting foto -->
    <section class="py-0 bg-white">
      <div class="max-w-5xl mx-auto px-6 pt-12 pb-0">
        <div class="relative rounded-2xl overflow-hidden shadow-xl shadow-primary-100/50">
          <img src="/team/office-4.webp" alt="Control One team in gesprek" class="w-full object-cover" style="height: 260px; object-position: center 30%;" />
          <div class="absolute inset-0 bg-gradient-to-r from-primary-950/70 via-primary-900/30 to-transparent"></div>
          <div class="absolute inset-0 flex items-center px-10">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-accent-400 mb-2">Persoonlijk contact</p>
              <h2 class="text-2xl font-bold text-white">We denken graag met je mee</h2>
              <p class="text-primary-200/80 text-sm mt-1 max-w-sm">Van snelle vraag tot uitgebreide demo: ons team staat voor je klaar.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid lg:grid-cols-3 gap-8 mb-20">
          {contactOptions.map(opt => (
            <div class="p-6 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-12 h-12 rounded-xl bg-primary-50 text-primary-600 flex items-center justify-center mb-4">
                <Fragment set:html={opt.icon} />
              </div>
              <h3 class="text-lg font-semibold text-primary-950 mb-2">{opt.title}</h3>
              <p class="text-sm text-primary-900/60 leading-relaxed mb-4">{opt.description}</p>
              <a href={`mailto:${opt.email}`} class="text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
                {opt.email}
              </a>
            </div>
          ))}
        </div>

        <!-- Contact form: 2-column layout -->
        <div class="mb-20 rounded-3xl overflow-hidden border border-primary-100 shadow-xl shadow-primary-100/30" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);">
          <div class="grid lg:grid-cols-5">

            <!-- Left: info panel -->
            <div class="lg:col-span-2 px-10 py-12 flex flex-col justify-between gap-8">
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-blue-300/70 mb-3">Direct contact</p>
                <h2 class="text-2xl sm:text-3xl font-bold text-white leading-snug">
                  Stuur een bericht
                </h2>
                <p class="mt-4 text-sm text-blue-100/70 leading-relaxed">
                  We lezen elk bericht zorgvuldig en reageren doorgaans binnen één werkdag.
                </p>
              </div>

              <div class="space-y-5">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-4 h-4 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                  </div>
                  <div>
                    <p class="text-xs text-blue-300/60 uppercase tracking-wide font-semibold mb-0.5">E-mail</p>
                    <a href="mailto:info@control-one.nl" class="text-sm text-white hover:text-blue-200 transition-colors font-medium">info@control-one.nl</a>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-4 h-4 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </div>
                  <div>
                    <p class="text-xs text-blue-300/60 uppercase tracking-wide font-semibold mb-0.5">Reactietijd</p>
                    <p class="text-sm text-white font-medium">Binnen 1 werkdag</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-4 h-4 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                  </div>
                  <div>
                    <p class="text-xs text-blue-300/60 uppercase tracking-wide font-semibold mb-0.5">Locatie</p>
                    <p class="text-sm text-white font-medium">Enschede, Nederland</p>
                  </div>
                </div>
              </div>

              <div class="pt-6 border-t border-white/10">
                <p class="text-xs text-blue-200/50 leading-relaxed">
                  Liever direct bellen of een demo plannen? Kies dan Sales hierboven.
                </p>
              </div>
            </div>

            <!-- Right: form -->
            <div class="lg:col-span-3 bg-white px-10 py-12">
              <form class="space-y-5">
                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="name" class="block text-xs font-semibold uppercase tracking-wide text-primary-500 mb-2">Naam</label>
                    <input type="text" id="name" name="name" required placeholder="Jan de Vries" class="w-full px-4 py-3 rounded-xl border border-primary-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/15 outline-none transition-all text-sm bg-primary-50/30 placeholder-primary-300" />
                  </div>
                  <div>
                    <label for="email" class="block text-xs font-semibold uppercase tracking-wide text-primary-500 mb-2">E-mailadres</label>
                    <input type="email" id="email" name="email" required placeholder="jan@bedrijf.nl" class="w-full px-4 py-3 rounded-xl border border-primary-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/15 outline-none transition-all text-sm bg-primary-50/30 placeholder-primary-300" />
                  </div>
                </div>
                <div>
                  <label for="company" class="block text-xs font-semibold uppercase tracking-wide text-primary-500 mb-2">Bedrijf</label>
                  <input type="text" id="company" name="company" placeholder="Bedrijfsnaam" class="w-full px-4 py-3 rounded-xl border border-primary-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/15 outline-none transition-all text-sm bg-primary-50/30 placeholder-primary-300" />
                </div>
                <div>
                  <label for="subject" class="block text-xs font-semibold uppercase tracking-wide text-primary-500 mb-2">Onderwerp</label>
                  <select id="subject" name="subject" class="w-full px-4 py-3 rounded-xl border border-primary-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/15 outline-none transition-all text-sm bg-primary-50/30 text-primary-700">
                    <option value="">Selecteer een onderwerp</option>
                    <option>Demo aanvragen</option>
                    <option>Vraag over functies</option>
                    <option>Prijzen & abonnementen</option>
                    <option>Technische ondersteuning</option>
                    <option>Partnership</option>
                    <option>Anders</option>
                  </select>
                </div>
                <div>
                  <label for="message" class="block text-xs font-semibold uppercase tracking-wide text-primary-500 mb-2">Bericht</label>
                  <textarea id="message" name="message" rows="5" required placeholder="Vertel ons hoe we je kunnen helpen..." class="w-full px-4 py-3 rounded-xl border border-primary-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/15 outline-none transition-all text-sm bg-primary-50/30 placeholder-primary-300 resize-none"></textarea>
                </div>
                <button type="submit" class="w-full flex items-center justify-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded-xl transition-all shadow-lg" style="background: linear-gradient(135deg, #2d5fa8, #2554a0);">
                  Verstuur bericht
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </button>
              </form>
            </div>

          </div>
        </div>

        <!-- Kantoor -->
        <div class="mb-20">
          <div class="grid lg:grid-cols-2 gap-0 rounded-3xl overflow-hidden shadow-xl shadow-primary-100/50 border border-primary-100">
            <!-- Foto buitenkant -->
            <div class="relative">
              <img
                src="/kantoor.jpg"
                alt="Control One kantoor Enschede, Twekkeler Es 42"
                class="w-full h-full object-cover"
                style="min-height: 320px; object-position: center 40%;"
              />
            </div>
            <!-- Adres & info -->
            <div class="flex flex-col justify-center px-10 py-12 gap-6" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%)">
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-accent-400 mb-3">Ons kantoor</p>
                <h2 class="text-2xl sm:text-3xl font-bold text-white leading-snug">
                  Bezoek ons in Enschede
                </h2>
                <p class="mt-3 text-primary-300/70 text-sm leading-relaxed">
                  Control One is gevestigd in het bruisende tech-hart van Twente. Altijd welkom voor een kop koffie en een gesprek over je ISO-traject.
                </p>
              </div>

              <div class="space-y-4 text-sm">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"></path></svg>
                  </div>
                  <div>
                    <p class="text-white font-semibold">Control One B.V.</p>
                    <p class="text-primary-300/70">Twekkeler Es 42</p>
                    <p class="text-primary-300/70">7547 SM Enschede</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path></svg>
                  </div>
                  <div>
                    <p class="text-white/50 text-xs">KvK-nummer</p>
                    <p class="text-primary-200">99763877</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"></path></svg>
                  </div>
                  <div>
                    <p class="text-white/50 text-xs">BTW-nummer</p>
                    <p class="text-primary-200">NL869122927B01</p>
                  </div>
                </div>
              </div>

              <a
                href="https://maps.google.com/?q=Twekkeler+Es+42,+7547+SM+Enschede"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-colors self-start mt-2"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497z"></path></svg>
                Bekijk op de kaart
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
