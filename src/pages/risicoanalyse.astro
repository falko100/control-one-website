---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import DemoCta from '../components/DemoCta.astro';
import Footer from '../components/Footer.astro';

// Risk matrix data for inline visual (5x5)
const matrixColors = [
  // impact 1 → 5 (rows), probability 1 → 5 (cols)
  ['low', 'low', 'low', 'med', 'med'],
  ['low', 'low', 'med', 'med', 'high'],
  ['low', 'med', 'med', 'high', 'high'],
  ['med', 'med', 'high', 'high', 'crit'],
  ['med', 'high', 'high', 'crit', 'crit'],
];
const colorMap = {
  low: 'bg-emerald-100 text-emerald-800',
  med: 'bg-amber-100 text-amber-800',
  high: 'bg-orange-100 text-orange-800',
  crit: 'bg-red-100 text-red-800',
};
// Real-ish risk counts per cell (plotted risks)
const counts = [
  [2, 0, 1, 0, 1],
  [0, 1, 1, 2, 1],
  [1, 0, 1, 1, 0],
  [0, 0, 0, 2, 0],
  [0, 0, 0, 0, 0],
];

// Realistische risico-register rijen
const riskRegister = [
  { context: 'Mensen', dreiging: 'Phishing-aanval op medewerker', gevolgen: 'Datalek, financieel verlies', kans: 4, impact: 4, score: 16, scoreColor: 'bg-red-100 text-red-800', maatregel: true },
  { context: 'Systemen', dreiging: 'Ransomware op productieserver', gevolgen: 'Volledige uitval, recovery 5+ dagen', kans: 3, impact: 5, score: 15, scoreColor: 'bg-orange-100 text-orange-800', maatregel: true },
  { context: 'Leveranciers', dreiging: 'Cloudprovider valt langer dan 24h uit', gevolgen: 'Klantapplicatie offline', kans: 2, impact: 4, score: 8, scoreColor: 'bg-amber-100 text-amber-800', maatregel: true },
  { context: 'Fysiek', dreiging: 'Ongeautoriseerde toegang serverruimte', gevolgen: 'Hardware-diefstal of -manipulatie', kans: 1, impact: 4, score: 4, scoreColor: 'bg-emerald-100 text-emerald-800', maatregel: true },
  { context: 'Processen', dreiging: 'Onjuiste change in productie zonder review', gevolgen: 'Service-degradatie', kans: 3, impact: 3, score: 9, scoreColor: 'bg-amber-100 text-amber-800', maatregel: false },
];

// Risico → CPAR flow steps
const riskToCparFlow = [
  { step: '1', label: 'Risico geïdentificeerd', desc: 'Dreiging "Ransomware op productieserver" geregistreerd in het register, score 15 (hoog).', color: 'bg-red-50 border-red-200 text-red-700' },
  { step: '2', label: 'Behandelstrategie gekozen', desc: 'Mitigeren via Annex A.8.13 (Back-up) en A.8.7 (Bescherming tegen malware).', color: 'bg-blue-50 border-blue-200 text-blue-700' },
  { step: '3', label: 'CPAR aangemaakt', desc: 'CPAR-RA-0034 — implementatie immutable backups + EDR uitrol op alle endpoints.', color: 'bg-orange-50 border-orange-200 text-orange-700' },
  { step: '4', label: 'Residueel risico', desc: 'Na implementatie: kans 1 × impact 4 = score 4 (laag). Geaccepteerd door directie.', color: 'bg-emerald-50 border-emerald-200 text-emerald-700' },
];
---

<Layout
  title="Risicoanalyse — ISO Risicobeheer Software | Control One"
  description="Voer risicoanalyses uit met Control One. Configureerbare 5×5 risicomatrix, inherente en residuele risico's, behandelstrategieën, snapshots en directe koppeling met Annex A."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
      { '@type': 'ListItem', position: 2, name: 'Portal', item: 'https://control-one.nl/features' },
      { '@type': 'ListItem', position: 3, name: 'Risicoanalyse', item: 'https://control-one.nl/risicoanalyse' },
    ],
  }}
>
  <Header />
  <main>
    <section class="relative pt-32 pb-20 lg:pb-28 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-red-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="lg:grid lg:grid-cols-[1fr_1.15fr] lg:gap-12 lg:items-center">
          <div class="max-w-xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-red-400 bg-red-400/10 rounded-full border border-red-400/20">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
              Risicoanalyse
            </div>
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
              Risico's identificeren,<br/><span class="text-red-400">beoordelen & beheersen</span>
            </h1>
            <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
              Plot risico's op een configureerbare 5×5 matrix, bepaal kans × impact, kies een behandelstrategie en koppel elke bevinding aan de juiste Annex A-maatregel. Inherente en residuele risico's worden automatisch berekend en vastgelegd.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3 text-xs font-medium text-white/80">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-red-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Inherent &amp; residueel
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-red-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                4 behandelstrategieën
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-red-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Snapshots &amp; trend
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-red-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Clausule 6.1 &amp; 6.2
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
                Gratis uitproberen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href="/features" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Alle features</a>
            </div>
          </div>

          <!-- Hero afbeelding rechts -->
          <div class="mt-12 lg:mt-0">
            <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40">
              <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
                <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
                <div class="flex-1 min-w-0 max-w-[220px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center truncate">app.control-one.nl/risicoanalyse</div></div>
              </div>
              <img src="/screenshots/portal-risks.png" alt="Risicoanalyse in Control One" class="w-full" loading="eager" data-lightbox />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Inline 5x5 matrix visual -->
    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sm font-semibold tracking-wide uppercase text-red-600 mb-3">5×5 risicomatrix</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Van diffuse zorg<br/>naar concrete score</h2>
            <p class="mt-4 text-lg text-primary-900/60 leading-relaxed">Elk risico krijgt een kans (1 = zeer onwaarschijnlijk tot 5 = zeer waarschijnlijk) en een impact (1 = zeer laag tot 5 = zeer hoog). De portal berekent de indexatie automatisch en plot het risico op de matrix — zowel het inherente als het residuele risico na behandeling.</p>
            <div class="mt-6 flex flex-wrap gap-2">
              <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-100">Laag</span>
              <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-amber-50 text-amber-700 border border-amber-100">Gemiddeld</span>
              <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-orange-50 text-orange-700 border border-orange-100">Hoog</span>
              <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-red-50 text-red-700 border border-red-100">Kritiek</span>
            </div>
            <div class="mt-8 grid grid-cols-3 gap-3">
              <div class="p-3 rounded-xl bg-primary-50 border border-primary-100 text-center">
                <p class="text-2xl font-bold text-primary-950">13</p>
                <p class="text-[10px] font-semibold uppercase tracking-wide text-primary-500 mt-1">Actieve risico's</p>
              </div>
              <div class="p-3 rounded-xl bg-primary-50 border border-primary-100 text-center">
                <p class="text-2xl font-bold text-primary-950">38%</p>
                <p class="text-[10px] font-semibold uppercase tracking-wide text-primary-500 mt-1">Afgerond</p>
              </div>
              <div class="p-3 rounded-xl bg-primary-50 border border-primary-100 text-center">
                <p class="text-2xl font-bold text-primary-950">4</p>
                <p class="text-[10px] font-semibold uppercase tracking-wide text-primary-500 mt-1">Top-risico's</p>
              </div>
            </div>
          </div>
          <div class="rounded-2xl border border-primary-100 bg-gradient-to-b from-primary-50/40 to-white p-6">
            <div class="flex items-end justify-between mb-4">
              <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500">Matrix</p>
                <p class="text-sm font-bold text-primary-950">Residuele risico's</p>
              </div>
              <span class="text-[10px] font-semibold text-primary-400">Totaal: 13</span>
            </div>
            <div class="flex gap-2">
              <div class="flex flex-col justify-between text-[9px] font-semibold text-primary-400 py-2">
                <span>Zeer hoog</span>
                <span>Hoog</span>
                <span>Gem.</span>
                <span>Laag</span>
                <span>Zeer laag</span>
              </div>
              <div class="flex-1">
                <div class="grid grid-cols-5 gap-1">
                  {matrixColors.slice().reverse().map((row, ri) => (
                    row.map((c, ci) => (
                      <div class:list={['aspect-square rounded flex items-center justify-center text-xs font-bold', colorMap[c]]}>
                        {counts[4 - ri][ci] > 0 ? counts[4 - ri][ci] : ''}
                      </div>
                    ))
                  ))}
                </div>
                <div class="grid grid-cols-5 gap-1 mt-1 text-[9px] font-semibold text-primary-400 text-center">
                  <span>Zeer&nbsp;onw.</span>
                  <span>Onw.</span>
                  <span>Mog.</span>
                  <span>Waar.</span>
                  <span>Zeer&nbsp;waar.</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Risk categories -->
    <section class="py-20 bg-primary-50/30">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-10">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Categorieën</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Risico's georganiseerd per domein</h2>
          <p class="mt-4 text-lg text-primary-900/75">Control One start met een voorbeeld-risicoregister in zes domeinen. Pas aan, voeg toe en verwijder wat voor je niet relevant is.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
          {[
            { name: 'Mensen', icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z', desc: 'Phishing, insider threats, social engineering.' },
            { name: 'Systemen & Software', icon: 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5', desc: 'Ransomware, verouderde software, back-up.' },
            { name: 'Netwerk', icon: 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5', desc: 'DDoS, monitoring, segmentatie.' },
            { name: 'Fysieke & org. beveiliging', icon: 'M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z', desc: 'Datacenters, diefstal, toegangscontrole.' },
            { name: 'Ontwikkeling & acceptatie', icon: 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5', desc: 'Broncode, CI/CD, veilig programmeren.' },
            { name: 'Leveranciers & cloud', icon: 'M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z', desc: 'Cloud, uitbesteding, ketenrisico.' },
          ].map(cat => (
            <div class="p-5 rounded-2xl bg-white border border-primary-100">
              <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center text-red-600 mb-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={cat.icon}/></svg>
              </div>
              <h3 class="text-sm font-bold text-primary-950 mb-1">{cat.name}</h3>
              <p class="text-xs text-primary-900/75 leading-relaxed">{cat.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Mid-page Demo CTA -->
    <DemoCta
      module="Risicoanalyse"
      title="Benieuwd hoe je risico's beoordeelt in de portal?"
      description="Stap door een interactieve rondleiding en zie hoe je dreigingen scoort op de 5x5 matrix, behandelstrategieën kiest en risico's koppelt aan maatregelen en CPAR's."
      ctaText="Bekijk de live demo"
      urlPath="risico / matrix"
      accentBg="bg-red-500"
      accentText="text-red-300"
      variant="risico"
    />

    <!-- 4 treatment strategies -->
    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-red-600 mb-3">Risicobehandeling</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Vier strategieën, één keuze per risico</h2>
          <p class="mt-4 text-lg text-primary-900/75">Per risico kies je een behandelstrategie. De portal rekent de verwachte nieuwe kans en impact om naar het residuele risico en toont inherente en nieuwe score naast elkaar.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
          {[
            { name: 'Mitigeren', desc: 'Kans of impact verlagen door maatregelen uit Annex A toe te passen.', color: 'bg-blue-50 border-blue-100 text-blue-700' },
            { name: 'Vermijden', desc: 'Het risico wegnemen door de activiteit niet uit te voeren of anders in te richten.', color: 'bg-emerald-50 border-emerald-100 text-emerald-700' },
            { name: 'Overdragen', desc: 'Het risico beleggen bij een derde partij, bijvoorbeeld via verzekering of contractclausule.', color: 'bg-amber-50 border-amber-100 text-amber-700' },
            { name: 'Accepteren', desc: 'Restrisico expliciet aanvaarden door topmanagement, inclusief onderbouwing.', color: 'bg-violet-50 border-violet-100 text-violet-700' },
          ].map(s => (
            <div class:list={['p-5 rounded-2xl border', s.color]}>
              <h3 class="text-sm font-bold mb-1">{s.name}</h3>
              <p class="text-xs leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Risicoregister voorbeeld -->
    <section class="py-24 bg-gradient-to-b from-primary-50/40 to-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-red-600 mb-3">Het register</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Eén rij per risico, alle context op zijn plek</h2>
          <p class="mt-4 text-lg text-primary-900/75">Het risicoregister geeft per dreiging direct inzicht: context, gevolgen, kans- en impactscore, plus of er al een maatregel aan gekoppeld is.</p>
        </div>

        <div class="max-w-6xl mx-auto rounded-2xl overflow-hidden border border-primary-100 bg-white shadow-2xl shadow-primary-100/40">
          <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
            <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
            <div class="flex-1 flex justify-center"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 truncate max-w-[280px]">app.control-one.nl / risicoanalyse / register</div></div>
            <div class="w-14"></div>
          </div>
          <!-- Tab strip -->
          <div class="flex gap-2 px-5 py-3 bg-primary-50/60 border-b border-primary-100 text-xs font-semibold">
            <span class="px-3 py-1.5 rounded-md text-primary-500">Beleid</span>
            <span class="px-3 py-1.5 rounded-md text-primary-500">Definitie</span>
            <span class="px-3 py-1.5 rounded-md bg-red-100 text-red-700">Register</span>
            <span class="px-3 py-1.5 rounded-md text-primary-500">Snapshots</span>
          </div>
          <!-- Table -->
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-primary-50/50 border-b border-primary-100">
                <tr class="text-left">
                  <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-primary-500">Context</th>
                  <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-primary-500">Dreiging</th>
                  <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-primary-500 hidden md:table-cell">Mogelijke gevolgen</th>
                  <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-primary-500 text-center w-12">Kans</th>
                  <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-primary-500 text-center w-14">Impact</th>
                  <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-primary-500 text-center w-14">Score</th>
                  <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-primary-500 text-center w-20">Maatregel</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-primary-100">
                {riskRegister.map(r => (
                  <tr class="hover:bg-primary-50/40 transition-colors">
                    <td class="px-4 py-3.5 text-xs font-semibold text-primary-700">{r.context}</td>
                    <td class="px-4 py-3.5 text-xs font-medium text-primary-900">{r.dreiging}</td>
                    <td class="px-4 py-3.5 text-xs text-primary-900/65 hidden md:table-cell">{r.gevolgen}</td>
                    <td class="px-4 py-3.5 text-xs font-bold text-center text-primary-700">{r.kans}</td>
                    <td class="px-4 py-3.5 text-xs font-bold text-center text-primary-700">{r.impact}</td>
                    <td class="px-4 py-3.5 text-center"><span class:list={['inline-flex items-center justify-center w-9 h-7 rounded-md text-xs font-bold', r.scoreColor]}>{r.score}</span></td>
                    <td class="px-4 py-3.5 text-center">
                      {r.maatregel ? (
                        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-emerald-100 text-emerald-700">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        </span>
                      ) : (
                        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-red-100 text-red-700">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>
                        </span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="px-5 py-3 bg-primary-50/40 border-t border-primary-100 flex items-center justify-between text-[11px] text-primary-500 flex-wrap gap-2">
            <span>Voorbeeld · 5 risico's getoond. Een gemiddeld register telt 30–60 risico's.</span>
            <span class="font-semibold">Score = Kans × Impact (max 25)</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Risico → CPAR flow -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-red-600 mb-3">Van risico naar actie</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Eén risico, vier stappen tot residueel</h2>
          <p class="mt-4 text-lg text-primary-900/75">Een hoog inherent risico wordt in vier stappen omgezet naar een geaccepteerd residueel risico — automatisch gekoppeld aan Annex A en CPAR.</p>
        </div>

        <div class="max-w-5xl mx-auto grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {riskToCparFlow.map((s, i) => (
            <div class:list={['relative p-5 rounded-2xl border', s.color]}>
              <p class="text-[10px] font-bold uppercase tracking-widest opacity-80">Stap {s.step}</p>
              <h3 class="text-base font-bold mt-1 mb-2">{s.label}</h3>
              <p class="text-xs leading-relaxed opacity-90">{s.desc}</p>
              {i < 3 && (
                <svg class="hidden lg:block absolute top-1/2 -right-3 w-6 h-6 text-primary-400 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              )}
            </div>
          ))}
        </div>

        <!-- Score before/after -->
        <div class="mt-12 max-w-3xl mx-auto p-6 rounded-2xl bg-gradient-to-br from-primary-950 to-primary-900 text-white">
          <p class="text-xs font-bold uppercase tracking-widest text-red-300/80 mb-4">Score-vergelijking · CPAR-RA-0034</p>
          <div class="grid grid-cols-2 gap-6">
            <div>
              <p class="text-[10px] font-semibold text-primary-300/70 uppercase tracking-widest mb-2">Inherent (vóór)</p>
              <div class="flex items-baseline gap-2">
                <span class="text-4xl font-bold">15</span>
                <span class="text-xs text-primary-300/80">3 × 5</span>
              </div>
              <span class="inline-block mt-2 px-2 py-0.5 rounded text-[10px] font-bold bg-red-100 text-red-800">Hoog</span>
            </div>
            <div class="border-l border-white/10 pl-6">
              <p class="text-[10px] font-semibold text-emerald-300/80 uppercase tracking-widest mb-2">Residueel (na)</p>
              <div class="flex items-baseline gap-2">
                <span class="text-4xl font-bold">4</span>
                <span class="text-xs text-emerald-200/80">1 × 4</span>
              </div>
              <span class="inline-block mt-2 px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-100 text-emerald-800">Laag — geaccepteerd</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature grid -->
    <section class="py-24 bg-primary-50/30">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Wat de portal voor je doet</h2>
          <p class="mt-4 text-lg text-primary-900/75">Van eerste risico tot directiebeoordeling — alle stappen worden gestructureerd vastgelegd en automatisch gekoppeld.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {[
            { title: 'Inherent én residueel risico', desc: 'Leg eerst het risico vast zonder maatregelen, en daarna het restrisico na behandeling. Beide worden visueel getoond.' },
            { title: 'Directe koppeling aan Annex A', desc: 'Vanuit een risico selecteert je direct de Annex A-maatregelen die het risico afdekken. Je VvT-tabel toont deze koppeling meteen.' },
            { title: 'Snapshots voor audits', desc: 'Bewaar de volledige staat van je risicoregister op ieder moment — ideaal als bewijs tijdens interne en externe audits.' },
            { title: 'Risicobeleid kant-en-klaar', desc: 'Inclusief een uitgeschreven risicobeleid met referenties, rollen, werkwijze en periodieke herbeoordeling — volledig aanpasbaar.' },
            { title: 'Risico-eigenaren & status', desc: 'Wijs per risico een eigenaar toe, volg de status (open, incompleet, afgerond) en zie direct wie verantwoordelijk is.' },
            { title: 'Top-risico\'s dashboard', desc: 'Een apart overzicht met de hoogste risico\'s, per categorie en met impact- en kansscore — perfect voor management-rapportage.' },
            { title: 'Trendgrafiek', desc: 'Zie hoe je risicopositie zich door de tijd ontwikkelt en toon vooruitgang in directiebeoordelingen en externe audits.' },
            { title: 'Restrisico-acceptatie', desc: 'Leg expliciete acceptatie van restrisico\'s door topmanagement vast, inclusief onderbouwing — direct auditklaar.' },
            { title: 'Voldoet aan clausule 6.1 & 6.2', desc: 'De methode, werkwijze en documentatie voldoen volledig aan ISO 27001:2022 en de richtlijnen van ISO 27005.' },
          ].map(f => (
            <div class="p-6 rounded-2xl border border-primary-100 bg-white hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center text-red-600 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h3 class="text-sm font-bold text-primary-950 mb-2">{f.title}</h3>
              <p class="text-sm text-primary-900/75 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
