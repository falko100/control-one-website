---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Vragen met opties. Elke optie heeft een key die in de scoring gebruikt wordt.
const vragen = [
  {
    id: 'norm',
    vraag: 'Welke norm wil je behalen?',
    toelichting: 'Twijfel je? Kies dan "Weet ik nog niet", de scan helpt je verder.',
    opties: [
      { key: '27001', label: 'ISO 27001', sub: 'Informatiebeveiliging' },
      { key: '9001', label: 'ISO 9001', sub: 'Kwaliteitsmanagement' },
      { key: '14001', label: 'ISO 14001', sub: 'Milieumanagement' },
      { key: '45001', label: 'ISO 45001', sub: 'Arbo & veiligheid' },
      { key: 'meerdere', label: 'Meerdere normen', sub: 'Bijvoorbeeld 27001 + 9001' },
      { key: 'onbekend', label: 'Weet ik nog niet', sub: 'Ik oriënteer me nog' },
    ],
  },
  {
    id: 'aanleiding',
    vraag: 'Wat is de belangrijkste aanleiding?',
    toelichting: 'Kies wat het meest speelt. Dit bepaalt mede het advies.',
    opties: [
      { key: 'klant', label: 'Klanten of tenders vragen erom', sub: 'Zonder certificaat doe ik niet mee' },
      { key: 'wetgeving', label: 'Wet- en regelgeving', sub: 'Zoals NIS2 of contractuele eisen' },
      { key: 'professionaliseren', label: 'Professionaliseren en groeien', sub: 'Meer grip op processen en risico\'s' },
      { key: 'onderhoud', label: 'Bestaand certificaat onderhouden', sub: 'Of overstappen van huidige tooling' },
      { key: 'orientatie', label: 'Ik oriënteer me breed', sub: 'Nog geen concrete verplichting' },
    ],
  },
  {
    id: 'deadline',
    vraag: 'Wanneer wil je gecertificeerd zijn?',
    toelichting: 'Een realistische deadline bepaalt het tempo van je traject.',
    opties: [
      { key: 'kort', label: 'Binnen 3 maanden', sub: 'Er is haast bij' },
      { key: 'middel', label: 'Binnen 3 tot 6 maanden', sub: 'Het meest gekozen tempo' },
      { key: 'lang', label: 'Binnen 6 tot 12 maanden', sub: 'Ruim de tijd' },
      { key: 'geen', label: 'Geen harde deadline', sub: 'Zorgvuldigheid boven snelheid' },
    ],
  },
  {
    id: 'grootte',
    vraag: 'Hoe groot is je organisatie?',
    toelichting: 'Aantal medewerkers binnen de beoogde scope.',
    opties: [
      { key: 'xs', label: '1 tot 10 medewerkers', sub: '' },
      { key: 's', label: '11 tot 50 medewerkers', sub: '' },
      { key: 'm', label: '51 tot 100 medewerkers', sub: '' },
      { key: 'l', label: 'Meer dan 100 medewerkers', sub: '' },
    ],
  },
  {
    id: 'status',
    vraag: 'Waar sta je nu?',
    toelichting: 'Wees eerlijk, dit is je nulmeting.',
    opties: [
      { key: 'niets', label: 'We beginnen bij nul', sub: 'Nog geen beleid of documentatie' },
      { key: 'los', label: 'Losse documenten en afspraken', sub: 'Maar geen samenhangend systeem' },
      { key: 'deels', label: 'Deels ingericht systeem', sub: 'Beleid en processen staan er grotendeels' },
      { key: 'cert', label: 'Al gecertificeerd', sub: 'Onderhoud of overstap van tooling' },
    ],
  },
  {
    id: 'maatregelen',
    vraag: 'In hoeverre zijn er al concrete maatregelen genomen?',
    toelichting: 'Denk aan afspraken en maatregelen rond kwaliteit, veiligheid of informatiebeveiliging.',
    opties: [
      { key: 'nauwelijks', label: 'Nog nauwelijks', sub: 'We doen het vooral op gevoel' },
      { key: 'basis', label: 'De basis staat', sub: 'Een aantal maatregelen is geregeld, maar niet vastgelegd' },
      { key: 'groot', label: 'Grotendeels ingericht', sub: 'Maatregelen zijn bewust gekozen en gedocumenteerd' },
      { key: 'volwassen', label: 'Volwassen en geborgd', sub: 'We evalueren en verbeteren periodiek' },
    ],
  },
  {
    id: 'bewustwording',
    vraag: 'Hoe leeft het onderwerp bij je collega\'s?',
    toelichting: 'Certificering slaagt alleen als het team meedoet, niet alleen de trekker.',
    opties: [
      { key: 'nauwelijks', label: 'Nauwelijks', sub: 'Het speelt vooral bij het management' },
      { key: 'klein', label: 'Bij een kleine groep', sub: 'Enkele direct betrokkenen kennen het belang' },
      { key: 'breed', label: 'Redelijk breed', sub: 'De meeste collega\'s kennen de basisafspraken' },
      { key: 'sterk', label: 'Sterk', sub: 'Het is onderdeel van hoe we werken' },
    ],
  },
  {
    id: 'procesmatig',
    vraag: 'Hoe gestructureerd werken jullie met processen?',
    toelichting: 'Elke ISO-norm draait om procesmatig werken: vastleggen, meten en verbeteren.',
    opties: [
      { key: 'weinig', label: 'Weinig vastgelegd', sub: 'Kennis zit vooral in de hoofden van collega\'s' },
      { key: 'deels', label: 'Deels beschreven', sub: 'De belangrijkste processen staan op papier, maar niet actueel' },
      { key: 'gevolgd', label: 'Beschreven en nageleefd', sub: 'Processen zijn vastgelegd en worden gevolgd' },
      { key: 'continu', label: 'We verbeteren continu', sub: 'We meten, evalueren en stellen processen bij' },
    ],
  },
  {
    id: 'verantwoordelijke',
    vraag: 'Is er iemand verantwoordelijk voor het traject?',
    toelichting: 'Elke succesvolle implementatie heeft een duidelijke trekker.',
    opties: [
      { key: 'ja_tijd', label: 'Ja, met voldoende tijd', sub: 'Het traject is een van de hoofdtaken' },
      { key: 'ja_erbij', label: 'Ja, naast andere taken', sub: 'Het moet er tussendoor' },
      { key: 'nee', label: 'Nog niet', sub: 'Dat moeten we nog beleggen' },
    ],
  },
  {
    id: 'tijd',
    vraag: 'Hoeveel tijd kan je team per week vrijmaken?',
    toelichting: 'Gemiddeld, voor de duur van het traject.',
    opties: [
      { key: 'min', label: 'Minder dan 2 uur', sub: '' },
      { key: 'laag', label: '2 tot 4 uur', sub: '' },
      { key: 'mid', label: '4 tot 8 uur', sub: '' },
      { key: 'hoog', label: 'Meer dan 8 uur', sub: '' },
    ],
  },
  {
    id: 'aanpak',
    vraag: 'Hoe wil je het traject het liefst aanpakken?',
    toelichting: 'Er is geen fout antwoord, elke route leidt naar certificering.',
    opties: [
      { key: 'zelf', label: 'Volledig zelf', sub: 'Met een goed platform als basis' },
      { key: 'vangnet', label: 'Zelf, met hulp op afroep', sub: 'Een expert kunnen inschakelen als het nodig is' },
      { key: 'begeleid', label: 'Het liefst begeleid', sub: 'Samen met een consultant door het traject' },
      { key: 'weetniet', label: 'Weet ik nog niet', sub: 'Daarvoor doe ik deze scan' },
    ],
  },
  {
    id: 'ervaring',
    vraag: 'Hoeveel ISO-ervaring heeft je team?',
    toelichting: 'Ervaring versnelt, maar is geen voorwaarde.',
    opties: [
      { key: 'geen', label: 'Geen ervaring', sub: 'ISO is nieuw voor ons' },
      { key: 'beetje', label: 'Een beetje', sub: 'We kennen de basis of hebben ermee gewerkt' },
      { key: 'veel', label: 'Ervaren', sub: 'We hebben eerder een norm geïmplementeerd' },
    ],
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
    { '@type': 'ListItem', position: 2, name: 'Quickscan', item: 'https://control-one.nl/quickscan' },
  ],
};
---

<Layout
  title="Gratis ISO Quickscan — In 2 minuten weten waar je staat | Control One"
  description="Doe de gratis ISO quickscan: 12 vragen, direct resultaat. Ontdek welke aanpak past bij jouw organisatie, hoe lang certificering duurt en wat het kost. Voor ISO 27001, 9001, 14001 en 45001."
  jsonLd={[breadcrumbSchema]}
>
  <Header />
  <main>

    <!-- ===== HERO / INTRO ===== -->
    <section id="qs-intro" class="relative pt-32 pb-20 lg:pb-28 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="lg:grid lg:grid-cols-[1.1fr_1fr] lg:gap-14 lg:items-center">
          <div class="max-w-xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-accent-400 bg-accent-400/10 rounded-full border border-accent-400/20">
              <span class="w-1.5 h-1.5 bg-accent-400 rounded-full animate-pulse"></span>
              Gratis quickscan · 3 minuten
            </div>
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
              Waar sta jij op weg<br/><span class="text-accent-400">naar ISO-certificering?</span>
            </h1>
            <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
              Beantwoord 12 korte vragen en ontvang direct een persoonlijk advies: welke aanpak past bij jouw organisatie, welk abonnement, hoe lang het traject duurt en waar je moet beginnen.
            </p>
            <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3.5 text-base font-medium text-white/90 max-w-xl">
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-accent-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Direct resultaat op je scherm
              </div>
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-accent-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Gratis ISO Startgids (pdf)
              </div>
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-accent-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Voor alle vier de ISO-normen
              </div>
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-accent-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Geen account nodig
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <button id="qs-start" class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-xl transition-all shadow-lg cursor-pointer">
                Start de quickscan
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </button>
            </div>
          </div>

          <!-- Preview-kaart rechts -->
          <div class="mt-12 lg:mt-0 hidden lg:block">
            <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40 bg-white">
              <div class="px-6 py-4 bg-primary-50 border-b border-primary-100 flex items-center justify-between">
                <p class="text-xs font-bold uppercase tracking-widest text-primary-500">Voorbeeld resultaat</p>
                <span class="text-[10px] font-semibold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">Persoonlijk advies</span>
              </div>
              <div class="p-6">
                <div class="flex items-center justify-between mb-1">
                  <p class="text-sm font-bold text-primary-950">Jouw startpositie</p>
                  <p class="text-xs font-semibold text-primary-500">42% staat al</p>
                </div>
                <div class="h-3 rounded-full bg-primary-100 overflow-hidden mb-4">
                  <div class="h-full rounded-full" style="width: 42%; background: linear-gradient(90deg, #196bd7, #01a2e8);"></div>
                </div>
                <div class="space-y-2.5">
                  <div class="flex items-center justify-between text-sm"><span class="text-primary-500">Aanbevolen route</span><span class="font-semibold text-primary-950">Zelfstandig met vangnet</span></div>
                  <div class="flex items-center justify-between text-sm"><span class="text-primary-500">Passend abonnement</span><span class="font-semibold text-primary-950">Team · € 199/mnd</span></div>
                  <div class="flex items-center justify-between text-sm"><span class="text-primary-500">Verwachte doorlooptijd</span><span class="font-semibold text-primary-950">3 tot 5 maanden</span></div>
                  <div class="flex items-center justify-between text-sm"><span class="text-primary-500">Tijdsinvestering</span><span class="font-semibold text-primary-950">4 tot 8 uur per week</span></div>
                </div>
                <div class="mt-5 pt-5 border-t border-primary-100">
                  <p class="text-xs font-bold uppercase tracking-widest text-primary-500 mb-3">Aanbevelingen</p>
                  <ul class="space-y-2.5">
                    <li class="flex items-start gap-2.5 text-[13px] text-primary-900/75 leading-snug">
                      <span class="w-5 h-5 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      </span>
                      Start met de gap-analyse als nulmeting
                    </li>
                    <li class="flex items-start gap-2.5 text-[13px] text-primary-900/75 leading-snug">
                      <span class="w-5 h-5 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      </span>
                      Beschrijf eerst je vijf belangrijkste processen
                    </li>
                    <li class="flex items-start gap-2.5 text-[13px] text-primary-900/75 leading-snug">
                      <span class="w-5 h-5 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      </span>
                      Plan de interne audit als los begeleidingsmoment
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WIZARD ===== -->
    <section id="qs-wizard" class="hidden pt-36 pb-20 bg-primary-50/40 min-h-[70vh]">
      <div class="max-w-3xl mx-auto px-6">

        <!-- Progress -->
        <div class="mb-8">
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs font-bold uppercase tracking-widest text-primary-500">Vraag <span id="qs-stepnr">1</span> van {vragen.length}</p>
            <p class="text-xs font-semibold text-primary-400"><span id="qs-pct">0</span>% compleet</p>
          </div>
          <div class="h-2 rounded-full bg-primary-100 overflow-hidden">
            <div id="qs-bar" class="h-full rounded-full transition-all duration-500" style="width: 4%; background: linear-gradient(90deg, #196bd7, #01a2e8);"></div>
          </div>
        </div>

        <!-- Vraag-panels -->
        {vragen.map((v, i) => (
          <div class="qs-panel bg-white rounded-3xl border border-primary-100 shadow-xl shadow-primary-100/40 p-8 sm:p-10" data-step={i} data-qid={v.id} style={i === 0 ? '' : 'display:none'}>
            <h2 class="text-2xl sm:text-3xl font-bold text-primary-950 tracking-tight">{v.vraag}</h2>
            <p id={v.id === 'maatregelen' ? 'qs-toel-maatregelen' : undefined} class="mt-2 text-sm text-primary-500">{v.toelichting}</p>
            <div class="mt-7 grid sm:grid-cols-2 gap-3">
              {v.opties.map(o => (
                <button
                  class="qs-optie text-left p-5 rounded-2xl border-2 border-primary-100 hover:border-primary-400 hover:bg-primary-50/50 transition-all cursor-pointer group"
                  data-key={o.key}
                >
                  <span class="flex items-start gap-3">
                    <span class="qs-radio w-5 h-5 rounded-full border-2 border-primary-300 shrink-0 mt-0.5 flex items-center justify-center transition-all">
                      <span class="qs-dot w-2.5 h-2.5 rounded-full bg-primary-600 opacity-0 transition-opacity"></span>
                    </span>
                    <span>
                      <span class="block text-sm font-bold text-primary-950">{o.label}</span>
                      {o.sub && <span class="block text-xs text-primary-500 mt-0.5">{o.sub}</span>}
                    </span>
                  </span>
                </button>
              ))}
            </div>
            <div class="mt-8 flex items-center justify-between">
              <button class="qs-prev inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-primary-600 hover:text-primary-800 transition-colors cursor-pointer" style={i === 0 ? 'visibility:hidden' : ''}>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Vorige
              </button>
              <button class="qs-next inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-primary-700 hover:bg-primary-800 rounded-xl transition-all shadow-sm disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer" disabled>
                {i === vragen.length - 1 ? 'Bekijk mijn resultaat' : 'Volgende'}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== RESULTAAT ===== -->
    <section id="qs-result" class="hidden pt-36 pb-20 bg-primary-50/40">
      <div class="max-w-4xl mx-auto px-6">

        <div class="text-center mb-10 r-anim">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 mb-4 text-xs font-semibold tracking-widest uppercase text-emerald-700 bg-emerald-50 rounded-full border border-emerald-200">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            Scan afgerond · jouw resultaat
          </div>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Dit past bij <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #0e2470 0%, #196bd7 50%, #01a2e8 100%);">jouw organisatie</span></h2>
        </div>

        <!-- Route-badge + readiness -->
        <div class="relative bg-white rounded-3xl border border-primary-100 shadow-xl shadow-primary-100/40 overflow-hidden mb-8 r-anim" style="animation-delay: .08s">
          <div class="absolute top-0 left-0 right-0 h-1.5" style="background: linear-gradient(90deg, #0e2470 0%, #196bd7 50%, #01a2e8 100%);"></div>
          <div class="p-8 sm:p-10 flex flex-col sm:flex-row sm:items-center gap-8 sm:gap-10">
            <div class="flex-1">
              <p class="text-xs font-bold uppercase tracking-widest text-primary-500 mb-3">Aanbevolen route</p>
              <div class="flex items-center gap-3.5">
                <div class="w-12 h-12 rounded-2xl flex items-center justify-center shrink-0 text-white shadow-lg shadow-primary-500/25" style="background: linear-gradient(135deg, #196bd7, #01a2e8);">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path id="r-route-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <p id="r-route" class="text-2xl font-bold text-primary-950"></p>
              </div>
              <p id="r-route-uitleg" class="mt-4 text-sm text-primary-900/70 leading-relaxed"></p>
            </div>
            <div class="shrink-0 flex flex-col items-center self-center">
              <p class="text-xs font-bold uppercase tracking-widest text-primary-500 mb-3">Jouw startpositie</p>
              <div class="relative w-36 h-36">
                <svg class="w-36 h-36 -rotate-90" viewBox="0 0 120 120">
                  <defs>
                    <linearGradient id="qs-donut-grad" x1="0" y1="0" x2="1" y2="1">
                      <stop offset="0%" stop-color="#196bd7"/>
                      <stop offset="100%" stop-color="#01a2e8"/>
                    </linearGradient>
                  </defs>
                  <circle cx="60" cy="60" r="52" fill="none" stroke="#e9effb" stroke-width="11"/>
                  <circle id="r-donut" cx="60" cy="60" r="52" fill="none" stroke="url(#qs-donut-grad)" stroke-width="11" stroke-linecap="round" stroke-dasharray="326.7" stroke-dashoffset="326.7" style="transition: stroke-dashoffset 1.2s cubic-bezier(.22, 1, .36, 1);"/>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                  <p class="text-3xl font-bold text-primary-950 leading-none"><span id="r-readiness">0</span>%</p>
                  <p class="mt-1 text-[10px] font-bold uppercase tracking-widest text-primary-400">staat al</p>
                </div>
              </div>
              <p id="r-readiness-label" class="mt-2.5 text-xs font-semibold text-primary-700 text-center max-w-[190px]"></p>
              <p class="mt-1 text-[11px] text-primary-400 text-center max-w-[190px] leading-relaxed">Zoveel van een certificeerbaar managementsysteem heb je al staan. De rest bouw je op tijdens het traject.</p>
            </div>
          </div>
        </div>

        <!-- Advies-grid -->
        <div class="grid sm:grid-cols-3 gap-5 mb-8 r-anim" style="animation-delay: .16s">
          <div class="bg-white rounded-2xl border border-primary-100 p-6 shadow-sm">
            <div class="w-9 h-9 rounded-xl bg-primary-50 text-primary-600 flex items-center justify-center mb-3">
              <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
            </div>
