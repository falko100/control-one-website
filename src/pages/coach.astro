---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const steps = [
  { num: '01', title: 'Context van de organisatie', desc: 'Scope, context en belanghebbenden definiëren.' },
  { num: '02', title: 'Leiderschap & commitment', desc: 'Managementbetrokkenheid vastleggen en beleid opstellen.' },
  { num: '03', title: 'Planning & risicoanalyse', desc: 'Risico\'s identificeren, beoordelen en behandelen.' },
  { num: '04', title: 'Doelstellingen & maatregelen', desc: 'IS-doelstellingen definiëren en Annex A koppelen.' },
  { num: '05', title: 'Ondersteuning & middelen', desc: 'Competenties, bewustwording en communicatie borgen.' },
  { num: '06', title: 'Uitvoering', desc: 'Processen implementeren en bewijs verzamelen.' },
  { num: '07', title: 'Prestatiebeoordeling', desc: 'Monitoren, meten en interne audits uitvoeren.' },
  { num: '08', title: 'Verbetering & certificering', desc: 'Non-conformiteiten oplossen en certificering behalen.' },
];
---

<Layout title="Coach: Stapsgewijze ISO-implementatie - Control One">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-950 via-primary-900 to-amber-900/30"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-amber-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-amber-400 bg-amber-400/10 rounded-full border border-amber-400/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497z"/></svg>
            Coach
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Uw persoonlijke<br/><span class="text-amber-400">ISO-implementatiegids</span>
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-xl leading-relaxed">
            De Coach begeleidt u stap voor stap door alle 28 implementatiestappen van ISO 27001. U weet altijd precies waar u staat, wat er nog moet gebeuren en waarom.
          </p>
          <div class="mt-8 flex gap-4">
            <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
              Gratis uitproberen
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/features" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Alle features</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Screenshot -->
    <section class="py-0 bg-white">
      <div class="max-w-5xl mx-auto px-6 -mt-8">
        <div class="rounded-2xl overflow-hidden border border-primary-100 shadow-2xl shadow-primary-200/30">
          <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
            <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
            <div class="flex-1 max-w-[200px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center">app.control-one.nl/coach</div></div>
          </div>
          <img src="/screenshots/portal-coach.png" alt="Coach in Control One" class="w-full" />
        </div>
      </div>
    </section>

    <!-- Implementation steps -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">28 stappen</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Van start tot certificering</h2>
          <p class="mt-4 text-lg text-primary-900/55">Elke stap bevat concrete instructies, sjablonen en een checklist om voortgang bij te houden.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
          {steps.map(s => (
            <div class="p-5 rounded-2xl border border-primary-100 bg-gradient-to-b from-white to-primary-50/30 hover:shadow-md hover:shadow-primary-100/50 transition-all">
              <span class="text-xs font-bold text-primary-400 font-mono">{s.num}</span>
              <h3 class="text-sm font-bold text-primary-950 mt-2 mb-1">{s.title}</h3>
              <p class="text-xs text-primary-900/55 leading-relaxed">{s.desc}</p>
            </div>
          ))}
          <div class="p-5 rounded-2xl border border-primary-100 bg-primary-50/60 flex items-center justify-center col-span-1 sm:col-span-2 lg:col-span-4 lg:w-48 lg:mx-auto">
            <p class="text-xs text-primary-500 font-semibold text-center">+ 20 meer stappen in de portal</p>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
