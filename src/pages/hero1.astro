---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const screens = [
  { src: '/screenshots/portal-dashboard.png', label: 'Dashboard',           color: 'bg-accent-500',   textColor: 'text-accent-700',   bg: 'bg-accent-50',   border: 'border-accent-200'   },
  { src: '/screenshots/portal-risks.png',     label: 'Risicobeheer',        color: 'bg-rose-500',     textColor: 'text-rose-700',     bg: 'bg-rose-50',     border: 'border-rose-200'     },
  { src: '/screenshots/portal-documents.png', label: 'Documenten',          color: 'bg-violet-500',   textColor: 'text-violet-700',   bg: 'bg-violet-50',   border: 'border-violet-200'   },
  { src: '/screenshots/portal-vendors.png',   label: 'Leveranciersbeheer',  color: 'bg-emerald-500',  textColor: 'text-emerald-700',  bg: 'bg-emerald-50',  border: 'border-emerald-200'  },
  { src: '/screenshots/portal-coach.png',     label: 'Implementatiecoach',  color: 'bg-amber-500',    textColor: 'text-amber-700',    bg: 'bg-amber-50',    border: 'border-amber-200'    },
];
---

<Layout title="Hero Test — Verbeterde Fan" noindex={true}>
  <Header />
  <main>

    <section class="relative overflow-hidden bg-white pb-0" style="min-height: 96vh;">

      <!-- Background -->
      <div class="absolute inset-0 bg-gradient-to-b from-primary-50/60 via-white to-white pointer-events-none"></div>
      <div class="absolute top-0 left-1/2 w-[900px] h-[600px] bg-accent-400/8 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/3 pointer-events-none"></div>

      <div class="relative max-w-6xl mx-auto px-6">

        <!-- ── Centered text block ── -->
        <div class="text-center pt-24 sm:pt-28 max-w-3xl mx-auto">

          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-primary-600 bg-primary-50 rounded-full border border-primary-200">
            <span class="w-1.5 h-1.5 rounded-full bg-accent-500 animate-pulse"></span>
            ISO Compliance Platform
          </div>

          <h1 class="text-5xl sm:text-6xl lg:text-[4rem] xl:text-[4.5rem] font-bold tracking-tight text-primary-950 leading-[1.05]">
            ISO-certificering
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-accent-500 to-primary-600">zonder gedoe</span>
          </h1>

          <p class="mt-6 text-lg sm:text-xl text-primary-700/65 max-w-2xl mx-auto leading-relaxed">
            Van risicoanalyse tot certificering: Control One begeleidt jouw organisatie stap voor stap. Alles op één plek, voor iedereen begrijpelijk.
          </p>

          <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="https://app.control-one.nl/register" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-primary-950 hover:bg-primary-900 rounded-full transition-all shadow-lg shadow-primary-950/20">
              Gratis starten · 14 dagen
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
            <a href="/demo" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-primary-800 border border-primary-200 hover:border-primary-400 hover:bg-primary-50 rounded-full transition-all">
              Live Demo
            </a>
          </div>

          <div class="mt-7 flex flex-wrap items-center justify-center gap-4 sm:gap-6 text-sm text-primary-500">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              ISO 27001 &amp; 9001
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              ISO 14001 &amp; 45001
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Nederlands bedrijf · EU-hosting
            </span>
          </div>
        </div>

        <!-- ── Large browser mockup ── -->
        <div class="mt-14 relative">

          <!-- Glow beneath the mockup -->
          <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 w-[80%] h-24 bg-primary-300/20 rounded-full blur-3xl pointer-events-none"></div>

          <!-- Browser window -->
          <div id="main-mockup" class="relative rounded-2xl overflow-hidden shadow-[0_32px_80px_rgba(2,9,90,0.18)] border border-primary-200/60 transition-all duration-500">

            <!-- Chrome bar -->
            <div class="flex items-center gap-3 px-5 py-3.5 bg-primary-50 border-b border-primary-200/60">
              <div class="flex gap-1.5">
                <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
                <span class="w-3 h-3 rounded-full bg-amber-400/80"></span>
                <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
              </div>
              <!-- Nav arrows -->
              <div class="flex gap-1.5">
                <span class="w-6 h-5 rounded flex items-center justify-center text-primary-300">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><path d="M6.5 2L3.5 5l3 3"/></svg>
                </span>
                <span class="w-6 h-5 rounded flex items-center justify-center text-primary-300">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><path d="M3.5 2l3 3-3 3"/></svg>
                </span>
              </div>
              <!-- URL bar -->
              <div class="flex-1 bg-white rounded-lg px-4 py-1.5 text-sm text-primary-400 border border-primary-200/60 flex items-center gap-2 max-w-sm">
                <svg class="w-3.5 h-3.5 text-emerald-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                <span class="text-xs truncate">app.control-one.nl</span>
              </div>
            </div>

            <!-- Screenshot (crossfade) -->
            <div class="relative overflow-hidden bg-primary-50" style="height: 460px;">
              {screens.map((s, i) => (
                <img
                  id={`screen-${i}`}
                  src={s.src}
                  alt={s.label}
                  class="absolute inset-0 w-full h-full object-cover object-top transition-opacity duration-500"
                  style={i === 0 ? 'opacity:1;' : 'opacity:0;'}
                  loading="eager"
                />
              ))}
            </div>
          </div>

          <!-- ── Thumbnail strip ── -->
          <div class="mt-5 flex items-stretch justify-center gap-3 flex-wrap">
            {screens.map((s, i) => (
              <button
                id={`thumb-${i}`}
                data-index={i}
                class:list={[
                  'thumb-btn group flex items-center gap-2.5 px-4 py-2.5 rounded-xl border text-sm font-medium transition-all duration-200',
                  i === 0
                    ? `${s.bg} ${s.border} ${s.textColor} shadow-sm`
                    : 'bg-white border-primary-100 text-primary-500 hover:border-primary-300 hover:text-primary-700 hover:bg-primary-50/60'
                ]}
                data-activebg={s.bg}
                data-activeborder={s.border}
                data-activetext={s.textColor}
              >
                <span class:list={['w-2 h-2 rounded-full shrink-0', s.color]}></span>
                {s.label}
              </button>
            ))}
          </div>

        </div><!-- /mockup block -->

      </div><!-- /container -->

      <!-- Bottom gradient fade into white -->
      <div class="h-16 bg-gradient-to-b from-transparent to-white mt-8"></div>

    </section>

  </main>
  <Footer />
</Layout>

<script>
  const thumbBtns = Array.from(document.querySelectorAll('.thumb-btn')) as HTMLElement[];
  const screenImgs = document.querySelectorAll('[id^="screen-"]') as NodeListOf<HTMLElement>;
  let current = 0;
  let timer: ReturnType<typeof setInterval> | null = null;
  let paused = false;

  function activate(index: number) {
    // fade screens
    screenImgs.forEach((img, i) => {
      (img as HTMLElement).style.opacity = i === index ? '1' : '0';
    });

    // update thumbnails
    thumbBtns.forEach((btn, i) => {
      const isActive = i === index;
      const ab = btn.dataset.activebg!;
      const aborder = btn.dataset.activeborder!;
      const atext = btn.dataset.activetext!;

      // remove all possible active classes first
      btn.classList.remove(
        'bg-white', 'border-primary-100', 'text-primary-500',
        'hover:border-primary-300', 'hover:text-primary-700', 'hover:bg-primary-50/60',
        'shadow-sm',
        ...ab.split(' '), ...aborder.split(' '), ...atext.split(' ')
      );

      if (isActive) {
        btn.classList.add(...ab.split(' '), ...aborder.split(' '), ...atext.split(' '), 'shadow-sm');
      } else {
        btn.classList.add('bg-white', 'border-primary-100', 'text-primary-500',
          'hover:border-primary-300', 'hover:text-primary-700', 'hover:bg-primary-50/60');
      }
    });

    current = index;
  }

  function next() {
    activate((current + 1) % thumbBtns.length);
  }

  function startAuto() {
    if (timer) return;
    timer = setInterval(next, 2800);
  }

  function stopAuto() {
    if (timer) { clearInterval(timer); timer = null; }
  }

  // Click handlers
  thumbBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      stopAuto();
      paused = true;
      activate(i);
      // resume after 6s
      setTimeout(() => { paused = false; startAuto(); }, 6000);
    });
  });

  // Pause on hover over mockup
  const mockup = document.getElementById('main-mockup');
  mockup?.addEventListener('mouseenter', () => { stopAuto(); paused = true; });
  mockup?.addEventListener('mouseleave', () => { paused = false; startAuto(); });

  // Start
  startAuto();
</script>
