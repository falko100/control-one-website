---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const chapters = [
  {
    number: '4',
    title: 'Context van de organisatie',
    description: 'Breng je organisatie in kaart: analyseer de interne en externe context, identificeer belanghebbenden en hun eisen. Bepaal de scope van je QMS en begrijp de wisselwerking tussen processen.',
    vereist: 'Interne en externe context analyseren, belanghebbenden identificeren, scope van het QMS vaststellen en de wisselwerking tussen processen begrijpen.',
    documenten: ['Scope document', 'Contextanalyse', 'Register van belanghebbenden', 'Processenkaart'],
    platform: 'Interactieve scopebepaling wizard, SWOT/PESTLE-analysetemplate, contextanalyse en automatisch gegenereerd scope document.',
  },
  {
    number: '5',
    title: 'Leiderschap',
    description: 'Zorg voor aantoonbare betrokkenheid van het management bij kwaliteit en stel een helder kwaliteitsbeleid vast. Wijs rollen en verantwoordelijkheden toe en bevorder klantgerichtheid in de hele organisatie.',
    vereist: 'Kwaliteitsbeleid vaststellen en communiceren, rollen en verantwoordelijkheden toewijzen, klantgerichtheid bevorderen.',
    documenten: ['Kwaliteitsbeleid', 'Verantwoordelijkheidsmatrix', 'Functiebeschrijvingen'],
    platform: 'Beleidsgenerator met goedkeuringsworkflow, verantwoordelijkheidsmatrix en rollenregister voor je QMS-team.',
  },
  {
    number: '6',
    title: 'Planning',
    description: "Identificeer risico's en kansen die van invloed zijn op het behalen van je kwaliteitsdoelstellingen. Stel meetbare doelstellingen vast, maak concrete actieplannen en wijs de benodigde resources toe.",
    vereist: "Risico's en kansen identificeren, kwaliteitsdoelstellingen vaststellen en wijzigingen plannen.",
    documenten: ['Risicoregister', 'CPAR-formulier', 'Doelstellingenregister'],
    platform: 'Risicobeheermodule met behandelingsplan, CPAR-workflow en voortgangsregistratie van kwaliteitsdoelstellingen.',
  },
  {
    number: '7',
    title: 'Ondersteuning',
    description: 'Stel de juiste middelen beschikbaar, borg competenties en stimuleer kwaliteitsbewustzijn in de organisatie. Beheer alle gedocumenteerde informatie centraal en regel interne en externe communicatie.',
    vereist: 'Middelen beschikbaar stellen, competenties borgen, bewustzijn creëren, gedocumenteerde informatie beheren en communicatie regelen.',
    documenten: ['Competentiematrix', 'Bewustwordingsprogramma', 'Kalibratielog', 'Documentbeheerbeleid'],
    platform: 'Centraal documentbeheer, competentieregister, kalibratie- en onderhoudsmodule en trainingsregistratie.',
  },
  {
    number: '8',
    title: 'Uitvoering',
    description: 'Plan en beheer operationele processen, eisen voor producten/diensten.',
    vereist: 'Operationele processen plannen en beheersen, klanteisen vastleggen, ontwerp en ontwikkeling beheersen, leveranciers beoordelen, productie vrijgeven en non-conforme outputs beheersen.',
    documenten: ['Klanteisenregister', 'Leveranciersevaluatie', 'Ontvangstinspectielog', 'Non-conformiteitsrapport'],
    platform: 'Leveranciersbeheer met evaluatiecyclus, non-conformiteitsregistratie, ontvangstinspectie en vrijgaveworkflow.',
  },
  {
    number: '9',
    title: 'Evaluatie van prestaties',
    description: 'Monitor, meet, analyseer en evalueer de prestaties van je QMS.',
    vereist: 'Klanttevredenheid meten, interne audits uitvoeren en directiebeoordelingen houden.',
    documenten: ['Klanttevredenheidsrapport', 'Auditplan & auditrapport', 'Directiebeoordelingsverslag'],
    platform: 'Auditworkflow met geautomatiseerde reminders, directiebeoordelingstemplates en KPI-dashboard voor kwaliteitsprestaties.',
  },
  {
    number: '10',
    title: 'Verbetering',
    description: 'Pak afwijkingen aan en streef naar continue verbetering van je QMS.',
    vereist: 'Non-conformiteiten identificeren, corrigerende maatregelen treffen en continue verbetering documenteren.',
    documenten: ['Non-conformiteitenregister', 'Corrigerende maatregelenplan', 'Klantfeedbackformulier'],
    platform: 'CPAR-beheer met vierstaps-verbeterproces, klantfeedbackregistratie en verbeterdashboard.',
  },
];

const qmsGroups = [
  {
    name: 'Handboek',
    dot: 'bg-blue-500',
    countStyle: 'text-blue-700 bg-blue-50',
    items: [
      { name: 'Kwaliteitshandboek', sub: 'ISO 9001:2015' },
      { name: 'Documentatie Matrix', sub: 'Overzicht' },
      { name: 'Scope & toepassingsgebied', sub: 'H4 conform' },
    ],
  },
  {
    name: 'Beleid',
    dot: 'bg-emerald-500',
    countStyle: 'text-emerald-700 bg-emerald-50',
    items: [
      { name: 'Kwaliteitsbeleid', sub: 'H5.2' },
      { name: 'Documentbeheerbeleid', sub: 'H7.5' },
      { name: 'Bewustwordingsprogramma', sub: 'H7.3' },
      { name: 'Overzicht Verantwoordelijkheden', sub: 'H5.3' },
    ],
  },
  {
    name: 'Procedures',
    dot: 'bg-amber-500',
    countStyle: 'text-amber-700 bg-amber-50',
    items: [
      { name: 'Beheer MS Documentatie Procedure', sub: 'H7.5' },
      { name: 'Beheer MS Gegevens Procedure', sub: 'H7.5' },
      { name: 'Project Planning', sub: 'Template' },
      { name: 'ISO Checklist', sub: 'Pre-audit' },
    ],
  },
  {
    name: 'Registers & Analyses',
    dot: 'bg-indigo-500',
    countStyle: 'text-indigo-700 bg-indigo-50',
    items: [
      { name: 'Contextanalyse', sub: 'H4.1' },
      { name: 'Register van belanghebbenden', sub: 'H4.2' },
      { name: 'Scope document', sub: 'H4.3' },
      { name: 'Processenkaart', sub: 'H4.4' },
      { name: 'Risicoregister', sub: 'H6.1' },
      { name: 'Doelstellingenregister', sub: 'H6.2' },
      { name: 'Competentiematrix', sub: 'H7.2' },
      { name: 'Klanteisenregister', sub: 'H8.2' },
      { name: 'QMS Beheerd Gegevens Register', sub: 'Bijlage' },
      { name: 'QMS Beheerd Documenten Register', sub: 'Bijlage' },
    ],
  },
  {
    name: 'Formulieren & Rapporten',
    dot: 'bg-violet-500',
    countStyle: 'text-violet-700 bg-violet-50',
    items: [
      { name: 'Verantwoordelijkheidsmatrix', sub: 'H5.3' },
      { name: 'Functiebeschrijvingen', sub: 'H5.3' },
      { name: 'CPAR-formulier', sub: 'H10' },
      { name: 'Document Wijziging Verzoek Formulier', sub: 'Template' },
      { name: 'Klanttevredenheidsrapport', sub: 'H9.1' },
      { name: 'Non-conformiteitsrapport', sub: 'H8.7' },
      { name: 'Non-conformiteitenregister', sub: 'H10.2' },
      { name: 'Corrigerende maatregelenplan', sub: 'H10.2' },
      { name: 'Klantfeedbackformulier', sub: 'H10' },
      { name: 'Directiebeoordelingsverslag', sub: 'H9.3' },
      { name: 'Kalibratielog', sub: 'H7.1.5' },
      { name: 'Leveranciersevaluatie', sub: 'H8.4' },
      { name: 'Ontvangstinspectielog', sub: 'H8.4' },
    ],
  },
  {
    name: 'Interne Audit',
    dot: 'bg-teal-500',
    countStyle: 'text-teal-700 bg-teal-50',
    items: [
      { name: 'Auditplan & auditrapport', sub: 'H9.2' },
      { name: 'Auditeren Stap-voor-Stap', sub: 'Handleiding' },
      { name: 'Gedragscode voor Interne Auditors', sub: 'Procedure' },
      { name: 'Interne Audit Feedback Formulier', sub: 'Template' },
      { name: 'Interne Audit Rapport Template', sub: 'Template' },
      { name: 'IA Checklist – Leverancier', sub: 'Checklist' },
      { name: 'IA Checklist – Proces', sub: 'Checklist' },
      { name: 'IA Checklist – QMS', sub: 'Checklist' },
      { name: 'Kennis Vereisten QMS Auditoren', sub: 'Template' },
    ],
  },
];

const benefits = [
  { title: 'Verbeter klanttevredenheid', description: 'Aantoon dat je consequent voldoet aan klanteneisen en toepasselijke wet- en regelgeving.' },
  { title: 'Verhoog operationele efficiëntie', description: 'Identificeer en verbeter processen, verminder fouten en verspilling.' },
  { title: 'Win nieuwe opdrachten', description: 'ISO 9001-certificering is een vereiste bij steeds meer aanbestedingen en inkoopprocessen.' },
  { title: 'Continue verbetering', description: 'Gebruik de PDCA-cyclus om je kwaliteitsmanagementsysteem voortdurend te verbeteren.' },
];
---

<Layout title="ISO 9001 Certificering — Kwaliteitsmanagement Software | Control One" description="Behaal ISO 9001:2015 certificering met Control One. Stapsgewijze begeleiding door alle hoofdstukken, PDCA-cyclus, documentbeheer en interne audits in één platform.">
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary-400/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

          <!-- Left: text content -->
          <div class="flex-1 max-w-2xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-emerald-400 bg-white/10 rounded-full backdrop-blur-sm">
              <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>
              Kwaliteitsmanagement
            </div>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-[1.1]">
              ISO 9001
            </h1>
            <p class="mt-2 text-xl sm:text-2xl font-medium text-primary-200">
              Quality Management System
            </p>
            <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
              Implementeer een QMS volgens de internationale norm voor kwaliteitsmanagement. Control One begeleidt je van contextanalyse tot continue verbetering, stap voor stap.
            </p>
            <div class="mt-10 flex flex-col sm:flex-row gap-4">
              <a href="https://app.control-one.nl/register" class="inline-flex items-center px-6 py-3 text-base font-semibold text-primary-900 bg-white hover:bg-primary-50 rounded-lg transition-all shadow-lg">
                Start met ISO 9001
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
              </a>
              <a href="/features" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white/90 hover:text-white border border-white/20 hover:border-white/40 rounded-lg transition-all">
                Bekijk alle functies
              </a>
            </div>
          </div>

          <!-- Right: iMac mockup -->
          <div class="hidden lg:block flex-shrink-0">
            <img src="/images/imac-mockup.png" alt="Control One platform op iMac" style="width: 560px; max-width: 100%;" loading="eager" />
          </div>

        </div>
      </div>
    </section>

    <!-- What is ISO 9001 -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Wat is ISO 9001?</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight mb-6">
              De internationale norm voor kwaliteitsmanagement
            </h2>
            <div class="text-primary-900/60 leading-relaxed space-y-4">
              <p>
                ISO 9001 is de meest toegepaste norm voor kwaliteitsmanagementsystemen wereldwijd. Het biedt een systematische aanpak voor het beheersen van processen, het voldoen aan klanteisen en het aantonen van consistente productkwaliteit.
              </p>
              <p>
                Certificering toont aan klanten, partners en aanbestedende diensten dat je organisatie kwaliteit serieus neemt en internationaal erkende best practices volgt via de PDCA-cyclus.
              </p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {benefits.map(b => (
              <div class="p-5 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100">
                <h3 class="font-semibold text-primary-950 mb-2 text-sm">{b.title}</h3>
                <p class="text-xs text-primary-900/50 leading-relaxed">{b.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Team element -->
    <section class="py-20 overflow-hidden" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-14">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-5 text-xs font-bold tracking-widest uppercase text-blue-200 bg-white/10 rounded-full border border-white/20">
            <span class="w-1.5 h-1.5 bg-accent-400 rounded-full animate-pulse"></span>
            Enschede, Twente
          </div>
          <h2 class="text-3xl sm:text-4xl xl:text-5xl font-bold text-white tracking-tight leading-[1.1]">
            Een team met een missie
          </h2>
          <p class="mt-5 text-blue-100/55 max-w-lg mx-auto">
            Wij geloven dat compliance eenvoudig moet zijn. Niet als obstakel, maar als fundament voor groei van je organisatie.
          </p>
        </div>
        <div class="relative flex justify-center items-center" style="height: 420px;">
          <div class="absolute shadow-2xl" style="left: 3%; top: 50%; transform: translateY(-42%) rotate(-6deg); width: 40%; z-index: 1;">
            <div class="rounded-2xl overflow-hidden ring-2 ring-white/15" style="aspect-ratio: 4/3;">
              <img src="/team/office-8.jpg" alt="Vergadering" class="w-full h-full object-cover" style="object-position: center 40%; transform: scale(1.4); transform-origin: center center;" />
            </div>
          </div>
          <div class="relative shadow-2xl" style="width: 28%; z-index: 3;">
            <div class="rounded-2xl overflow-hidden ring-4 ring-accent-400/25" style="aspect-ratio: 3/4;">
              <img src="/team/office-6.webp" alt="Teamlid" class="w-full h-full object-cover" style="object-position: center 15%;" />
            </div>
          </div>
          <div class="absolute shadow-2xl" style="right: 3%; top: 50%; transform: translateY(-42%) rotate(6deg); width: 40%; z-index: 1;">
            <div class="rounded-2xl overflow-hidden ring-2 ring-white/15" style="aspect-ratio: 4/3;">
              <img src="/team/office-7.webp" alt="Developer" class="w-full h-full object-cover" style="object-position: center 30%;" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Chapters -->
    <section class="py-24 bg-gradient-to-b from-primary-50/50 to-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Normstructuur</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Hoofdstukken 1–10
          </h2>
          <p class="mt-4 text-lg text-primary-900/60">
            Control One begeleidt je door elk hoofdstuk met een stapsgewijze coach, voortgangsregistratie en directe koppeling naar je documenten.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">

          <!-- Hoofdstukken 1–3: inleiding -->
          <div class="relative rounded-2xl border border-dashed border-primary-200 bg-primary-50/50 p-6 flex flex-col gap-4">
            <div class="flex items-start justify-between">
              <div class="w-10 h-10 rounded-xl bg-primary-100 text-primary-500 flex items-center justify-center font-bold text-sm shrink-0">
                1–3
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest text-primary-400 bg-primary-100 px-2 py-1 rounded-full">Inleiding</span>
            </div>
            <div>
              <h3 class="font-semibold text-primary-950 mb-1 leading-snug">Inleiding van de norm</h3>
              <p class="text-sm text-primary-900/50 leading-relaxed">Hoofdstukken 1 t/m 3 vormen de algemene inleiding van de norm en bevatten geen implementatievereisten.</p>
            </div>
            <ul class="space-y-2 pt-1 border-t border-primary-100">
              <li class="flex items-start gap-2 text-xs text-primary-900/60">
                <span class="w-5 h-5 rounded-md bg-primary-100 text-primary-500 flex items-center justify-center font-bold shrink-0 mt-0.5">1</span>
                <span><strong class="text-primary-800">Toepassingsgebied</strong> — De scope en het doel van de norm.</span>
              </li>
              <li class="flex items-start gap-2 text-xs text-primary-900/60">
                <span class="w-5 h-5 rounded-md bg-primary-100 text-primary-500 flex items-center justify-center font-bold shrink-0 mt-0.5">2</span>
                <span><strong class="text-primary-800">Normatieve verwijzingen</strong> — Verwijzingen naar andere normen.</span>
              </li>
              <li class="flex items-start gap-2 text-xs text-primary-900/60">
                <span class="w-5 h-5 rounded-md bg-primary-100 text-primary-500 flex items-center justify-center font-bold shrink-0 mt-0.5">3</span>
                <span><strong class="text-primary-800">Termen en definities</strong> — Verklaringen van gebruikte begrippen.</span>
              </li>
            </ul>
          </div>

          {chapters.map((ch, i) => (
            <div
              class:list={[
                'chapter-card group relative rounded-2xl border bg-white transition-all duration-200 cursor-pointer overflow-hidden',
                i === 0 ? 'border-primary-200 shadow-md' : 'border-primary-100 hover:border-primary-200 hover:shadow-md hover:shadow-primary-100/50',
              ]}
              data-chapter={ch.number}
            >
              <!-- Card trigger (always visible) -->
              <div class="chapter-trigger p-6 flex flex-col">
                <div class="flex items-start justify-between mb-4">
                  <div class:list={[
                    'w-10 h-10 rounded-xl flex items-center justify-center font-bold text-sm shrink-0',
                    i === 0 ? 'bg-primary-600 text-white' : 'bg-primary-50 text-primary-600 group-hover:bg-primary-100 transition-colors',
                  ]}>
                    {ch.number}
                  </div>
                  <span class="chapter-expand-icon w-7 h-7 rounded-full bg-primary-50 flex items-center justify-center shrink-0 transition-all duration-300 group-hover:bg-primary-100">
                    <svg class="w-3.5 h-3.5 text-primary-500 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 5v14M5 12h14" class="chapter-plus"></path>
                    </svg>
                  </span>
                </div>
                <h3 class="font-semibold text-primary-950 mb-2 leading-snug">{ch.title}</h3>
                <p class="text-sm text-primary-900/50 leading-relaxed">{ch.description}</p>
              </div>

              <!-- Expandable details -->
              <div class="chapter-body" style="max-height: 0; overflow: hidden; transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1);">
                <div class="px-6 pb-6 border-t border-primary-100 space-y-4 pt-4">
                  <!-- What the norm requires -->
                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-widest text-primary-500 mb-1.5">Wat de norm vereist</p>
                    <p class="text-xs text-primary-900/65 leading-relaxed">{ch.vereist}</p>
                  </div>
                  <!-- Key documents -->
                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-widest text-primary-500 mb-1.5">Sleuteldocumenten</p>
                    <ul class="space-y-1">
                      {ch.documenten.map(doc => (
                        <li class="flex items-center gap-2 text-xs text-primary-900/65">
                          <svg class="w-3.5 h-3.5 text-primary-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                          {doc}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <!-- In Control One -->
                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-widest text-primary-500 mb-1.5">In Control One</p>
                    <p class="text-xs text-primary-900/65 leading-relaxed">{ch.platform}</p>
                  </div>
                  <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-1 text-xs font-semibold text-primary-700 hover:text-primary-900 transition-colors mt-1">
                    Start met dit hoofdstuk
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                  </a>
                </div>
              </div>
            </div>
          ))}
          <!-- Extra card: 100% coverage -->
          <div class="relative p-6 rounded-2xl bg-gradient-to-br from-emerald-700 to-emerald-900 text-white overflow-hidden flex flex-col justify-between">
            <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full blur-2xl pointer-events-none"></div>
            <div class="relative">
              <div class="text-4xl font-bold mb-1">100%</div>
              <div class="text-emerald-200 text-sm font-semibold mb-4">Normdekking</div>
              <p class="text-emerald-300/80 text-sm leading-relaxed">
                Control One dekt alle 7 hoofdstukken en alle vereisten van ISO 9001:2015, inclusief CPAR-beheer en klanttevredenheidsmeting.
              </p>
            </div>
            <a href="/demo" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-white/90 hover:text-white transition-colors">
              Bekijk het platform
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- QMS Documents -->
    <section class="py-24 bg-gradient-to-b from-primary-50/40 to-white">
      <div class="max-w-7xl mx-auto px-6">

        <!-- Header -->
        <div class="max-w-3xl mx-auto text-center mb-12">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-5 text-xs font-semibold tracking-widest uppercase text-emerald-700 bg-emerald-50 rounded-full border border-emerald-100">
            QMS Documentatie: ISO 9001:2015
          </div>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Alle QMS-documenten in één overzicht
          </h2>
          <p class="mt-4 text-lg text-primary-900/55 max-w-xl mx-auto leading-relaxed">
