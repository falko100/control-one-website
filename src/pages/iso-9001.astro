---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const chapters = [
  { number: '4', title: 'Context van de organisatie', description: 'Bepaal de interne en externe factoren, belanghebbenden en het toepassingsgebied van uw QMS.' },
  { number: '5', title: 'Leiderschap', description: 'Zorg voor betrokkenheid van de directie, kwaliteitsbeleid en organisatorische rollen.' },
  { number: '6', title: 'Planning', description: 'Adresseer risico\'s en kansen, stel kwaliteitsdoelstellingen en plan wijzigingen.' },
  { number: '7', title: 'Ondersteuning', description: 'Beheer middelen, competenties, bewustzijn, communicatie en gedocumenteerde informatie.' },
  { number: '8', title: 'Uitvoering', description: 'Plan en beheers processen voor producten en diensten, inclusief ontwerp, productie en levering.' },
  { number: '9', title: 'Evaluatie van prestaties', description: 'Monitor klanttevredenheid, voer interne audits uit en houd directiebeoordelingen.' },
  { number: '10', title: 'Verbetering', description: 'Pak afwijkingen aan, neem corrigerende maatregelen en streef naar continue verbetering.' },
];

const benefits = [
  {
    title: 'Klanttevredenheid',
    description: 'Verbeter klanttevredenheid door consistent kwalitatieve producten en diensten te leveren.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"></path></svg>`,
    gradient: 'from-emerald-500 to-teal-600',
  },
  {
    title: 'Procesoptimalisatie',
    description: 'Stroomlijn bedrijfsprocessen, verminder verspilling en verhoog de operationele efficiëntie.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"></path></svg>`,
    gradient: 'from-primary-500 to-primary-700',
  },
  {
    title: 'Marktvoordeel',
    description: 'Versterk uw marktpositie met een internationaal erkend kwaliteitskeurmerk.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.023 6.023 0 01-7.54 0"></path></svg>`,
    gradient: 'from-amber-500 to-orange-600',
  },
  {
    title: 'Risicovermindering',
    description: 'Identificeer en beheer risico\'s voordat ze problemen worden, met een proactieve aanpak.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path></svg>`,
    gradient: 'from-violet-500 to-purple-600',
  },
];

const pdcaCycle = [
  { phase: 'Plan', description: 'Bepaal doelen, identificeer risico\'s en plan processen.', color: 'bg-primary-600' },
  { phase: 'Do', description: 'Implementeer de geplande processen en beheersmaatregelen.', color: 'bg-accent-500' },
  { phase: 'Check', description: 'Monitor en meet resultaten tegen beleid en doelen.', color: 'bg-emerald-500' },
  { phase: 'Act', description: 'Neem corrigerende maatregelen voor continue verbetering.', color: 'bg-amber-500' },
];
---

<Layout title="ISO 9001 Kwaliteitsmanagement — Control One">
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-900 via-emerald-800 to-teal-900"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-teal-400/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-emerald-300 bg-white/10 rounded-full backdrop-blur-sm">
            <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>
            Kwaliteitsmanagement
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-[1.1]">
            ISO 9001
          </h1>
          <p class="mt-2 text-xl sm:text-2xl font-medium text-emerald-200">
            Quality Management System
          </p>
          <p class="mt-6 text-lg text-emerald-300/80 max-w-2xl leading-relaxed">
            Implementeer een QMS dat uw processen stroomlijnt, klanttevredenheid verhoogt en continue verbetering stimuleert — begeleid door Control One.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="/demo" class="inline-flex items-center px-6 py-3 text-base font-semibold text-emerald-900 bg-white hover:bg-emerald-50 rounded-lg transition-all shadow-lg">
              Start met ISO 9001
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </a>
            <a href="/features" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white/90 hover:text-white border border-white/20 hover:border-white/40 rounded-lg transition-all">
              Bekijk alle functies
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Voordelen</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Waarom ISO 9001 certificering?
          </h2>
          <p class="mt-4 text-lg text-primary-900/60">
            Een kwaliteitsmanagementsysteem volgens ISO 9001 levert meetbare voordelen voor uw organisatie.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {benefits.map(b => (
            <div class="group relative rounded-2xl overflow-hidden">
              <div class:list={['absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-300', b.gradient]}></div>
              <div class="relative p-6 rounded-2xl border border-primary-100 group-hover:border-transparent transition-colors bg-white group-hover:bg-transparent">
                <div class="w-12 h-12 rounded-xl bg-primary-50 group-hover:bg-white/20 text-primary-600 group-hover:text-white flex items-center justify-center mb-4 transition-colors">
                  <Fragment set:html={b.icon} />
                </div>
                <h3 class="font-semibold text-primary-950 group-hover:text-white mb-2 transition-colors">{b.title}</h3>
                <p class="text-sm text-primary-900/60 group-hover:text-white/80 leading-relaxed transition-colors">{b.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PDCA Cycle -->
    <section class="py-24 bg-gradient-to-b from-primary-50/50 to-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Methodiek</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Plan-Do-Check-Act cyclus
          </h2>
          <p class="mt-4 text-lg text-primary-900/60">
            ISO 9001 is gebouwd op de PDCA-cyclus voor continue verbetering. Control One structureert elke fase.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-4xl mx-auto">
          {pdcaCycle.map((step, i) => (
            <div class="relative text-center">
              {i < pdcaCycle.length - 1 && (
                <div class="hidden lg:block absolute top-10 left-full w-full h-px bg-gradient-to-r from-primary-300 to-primary-100 -translate-x-6 z-0"></div>
              )}
              <div class:list={['relative z-10 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-xl font-bold', step.color]}>
                {step.phase}
              </div>
              <p class="text-sm text-primary-900/60 leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Chapters -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Normstructuur</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Hoofdstukken 4–10
          </h2>
          <p class="mt-4 text-lg text-primary-900/60">
            Control One begeleidt u door elk hoofdstuk met voortgangsregistratie en directe koppeling naar uw documenten.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {chapters.map((ch, i) => (
            <div class:list={[
              'group relative p-6 rounded-2xl border bg-white hover:shadow-lg hover:shadow-primary-100/50 transition-all',
              i === 0 ? 'border-emerald-200 shadow-md' : 'border-primary-100',
            ]}>
              <div class:list={[
                'w-10 h-10 rounded-xl flex items-center justify-center font-bold text-sm mb-4',
                i === 0 ? 'bg-emerald-500 text-white' : 'bg-primary-50 text-primary-600',
              ]}>
                {ch.number}
              </div>
              <h3 class="font-semibold text-primary-950 mb-2">{ch.title}</h3>
              <p class="text-sm text-primary-900/50 leading-relaxed">{ch.description}</p>
            </div>
          ))}
          <div class="relative p-6 rounded-2xl bg-gradient-to-br from-emerald-600 to-teal-700 text-white overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
            <div class="relative">
              <div class="text-3xl font-bold mb-2">PDCA</div>
              <div class="text-emerald-200 text-sm font-medium mb-4">Continue verbetering</div>
              <p class="text-emerald-100/80 text-sm leading-relaxed">
                Alle hoofdstukken volgen de Plan-Do-Check-Act cyclus voor continue procesverbetering.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
