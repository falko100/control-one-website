---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const features = [
  {
    title: 'Begeleide Implementatie',
    subtitle: 'Uw persoonlijke ISO-coach',
    description: 'Onze implementatiecoach leidt u stap voor stap door elk hoofdstuk van uw ISO-framework. U weet altijd precies waar u staat en wat de volgende stap is.',
    details: [
      'Volledige eisenstructuur per framework',
      'Voortgangspercentage per hoofdstuk',
      'Contextgevoelige hulp en uitleg',
      'Automatisch gekoppeld aan documenten en bewijs',
    ],
    gradient: 'from-primary-600 to-primary-800',
    iconBg: 'bg-primary-500',
    icon: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path></svg>`,
  },
  {
    title: 'Documentbeheer',
    subtitle: 'Alles op één plek',
    description: 'Centraal beheer van al uw compliance-documenten. Maak beleidsdocumenten, risicoverklaringen en sjablonen — allemaal met versiebeheer en goedkeuringsworkflows.',
    details: [
      'Versiecontrole met revisiebeheer',
      'Beoordelings- en goedkeuringsworkflows',
      'Sjabloonbibliotheek voor snelle opstart',
      'Automatische koppeling aan framework-eisen',
    ],
    gradient: 'from-accent-500 to-primary-600',
    iconBg: 'bg-accent-500',
    icon: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path></svg>`,
  },
  {
    title: 'Risicobeheer',
    subtitle: 'Inzicht in uw risicolandschap',
    description: 'Identificeer, beoordeel en bewaak risico\'s met een uitgebreid risicoregister. Scoor risico\'s op kans en impact, en houd het risicolandschap in de tijd bij.',
    details: [
      'Kans × impact risicoscoring',
      'Meerdere risicocontexten (mensen, systemen, netwerk, etc.)',
      'Periodieke risicobeoordelingen met besluitregistratie',
      'Historische snapshots voor trendanalyse',
    ],
    gradient: 'from-amber-500 to-orange-600',
    iconBg: 'bg-amber-500',
    icon: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"></path></svg>`,
  },
  {
    title: 'Interne Audits',
    subtitle: 'Van scope tot rapportage',
    description: 'Voer interne audits uit met een compleet audit-traject: van scopedefinitie tot rapportage. Volg afwijkingen en corrigerende maatregelen tot aan afsluiting.',
    details: [
      '7-stappen audit wizard',
      'Geïntegreerde vragenlijsten',
      'Afwijkingen- en CPAR-beheer',
      'PDF-rapportages voor auditors',
    ],
    gradient: 'from-emerald-500 to-teal-600',
    iconBg: 'bg-emerald-500',
    icon: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"></path></svg>`,
  },
  {
    title: 'Leveranciersbeheer',
    subtitle: 'Grip op externe partijen',
    description: 'Houd uw leveranciersrisico\'s onder controle. Beheer certificaten, compliance-documentatie en plan periodieke beoordelingen voor al uw externe partijen.',
    details: [
      'Leveranciersregister met contactinformatie',
      'Certificaatbeheer met verloopwaarschuwingen',
      'Periodieke leveranciersbeoordelingen',
      'Risicoclassificatie per leverancier',
    ],
    gradient: 'from-violet-500 to-purple-600',
    iconBg: 'bg-violet-500',
    icon: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path></svg>`,
  },
  {
    title: 'Directiebeoordelingen',
    subtitle: 'Gestructureerd reviewproces',
    description: 'Structureer uw management reviews met voorgedefinieerde agenda\'s, actiepunten en besluitregistratie. Betrek het hele team bij het compliance-proces.',
    details: [
      'Voorgedefinieerde beoordelingssecties',
      'Actiepunten met verantwoordelijken',
      'Besluitregistratie en opvolging',
      'Teamgebaseerde samenwerking',
    ],
    gradient: 'from-rose-500 to-pink-600',
    iconBg: 'bg-rose-500',
    icon: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"></path></svg>`,
  },
];

const stats = [
  { value: '50%', label: 'Snellere audit-voorbereiding' },
  { value: '100+', label: 'Bedrijven vertrouwen op ons' },
  { value: '3-6', label: 'Maanden tot certificering' },
  { value: '24/7', label: 'Toegang tot uw compliance-data' },
];
---

<Layout title="Functies — Control One">
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-white to-accent-400/10"></div>
      <div class="absolute top-20 right-0 w-96 h-96 bg-primary-200/30 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-accent-400/10 rounded-full blur-3xl"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-primary-700 bg-primary-100 rounded-full">
            <span class="w-1.5 h-1.5 bg-primary-500 rounded-full"></span>
            Platform Functies
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-primary-950 leading-[1.1]">
            Alles voor uw
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-accent-500">ISO-compliance</span>
          </h1>
          <p class="mt-6 text-lg sm:text-xl text-primary-900/60 max-w-2xl mx-auto leading-relaxed">
            Control One biedt een compleet pakket aan tools om uw ISO-implementatie te begeleiden, bewaken en beheren — van eerste stap tot certificering.
          </p>
        </div>

        <!-- Stats bar -->
        <div class="mt-16 grid grid-cols-2 lg:grid-cols-4 gap-6 max-w-4xl mx-auto">
          {stats.map(stat => (
            <div class="text-center p-6 rounded-2xl bg-white border border-primary-100 shadow-sm">
              <div class="text-3xl font-bold text-primary-700">{stat.value}</div>
              <div class="mt-1 text-sm text-primary-900/50">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Feature cards -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 space-y-16">
        {features.map((feature, i) => (
          <div class:list={['grid lg:grid-cols-5 gap-8 items-center', i % 2 === 1 && 'direction-rtl']}>
            <!-- Visual card -->
            <div class:list={['lg:col-span-2 direction-ltr']}>
              <div class:list={['relative rounded-3xl p-8 sm:p-10 overflow-hidden bg-gradient-to-br', feature.gradient]}>
                <div class="absolute top-0 right-0 w-40 h-40 bg-white/10 rounded-full blur-2xl -translate-y-1/2 translate-x-1/4"></div>
                <div class="absolute bottom-0 left-0 w-32 h-32 bg-black/10 rounded-full blur-2xl translate-y-1/2 -translate-x-1/4"></div>

                <div class="relative">
                  <div class:list={['w-14 h-14 rounded-2xl flex items-center justify-center mb-6', feature.iconBg]}>
                    <Fragment set:html={feature.icon} />
                  </div>
                  <div class="text-white/90 text-sm font-medium uppercase tracking-wider mb-2">{feature.subtitle}</div>
                  <div class="text-white text-2xl font-bold">{feature.title}</div>

                  <!-- Decorative dots -->
                  <div class="mt-8 grid grid-cols-6 gap-2">
                    {[...Array(18)].map((_, j) => (
                      <div class:list={['w-2 h-2 rounded-full', j < 12 ? 'bg-white/20' : 'bg-white/10']}></div>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Content -->
            <div class="lg:col-span-3 direction-ltr">
              <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-2">{feature.subtitle}</p>
              <h2 class="text-2xl sm:text-3xl font-bold text-primary-950 mb-4">{feature.title}</h2>
              <p class="text-primary-900/60 leading-relaxed mb-8">{feature.description}</p>
              <div class="grid sm:grid-cols-2 gap-4">
                {feature.details.map(detail => (
                  <div class="flex items-start gap-3 p-3 rounded-xl bg-primary-50/50">
                    <svg class="w-5 h-5 text-primary-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                    <span class="text-sm text-primary-900/70">{detail}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <Testimonials />
    <CTA />
  </main>
  <Footer />
</Layout>
