---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FeatureConstellation from '../components/FeatureConstellation.astro';
import FeaturePillars from '../components/FeaturePillars.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CompleetPakket from '../components/CompleetPakket.astro';
import CTA from '../components/CTA.astro';
import DemoCta from '../components/DemoCta.astro';
import Footer from '../components/Footer.astro';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Control One',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: 'https://control-one.nl/features',
  description: 'Compliance software voor ISO 27001, 9001, 14001 en 45001. Implementatiecoach, risicoanalyse, VvT-module, documentbeheer, auditmanagement en leveranciersbeheer in één platform.',
  featureList: [
    'Implementatiecoach met 28 stappen',
    '93 Annex A-beheersmaatregelen',
    'Configureerbare risicomatrix 5×5',
    'Verklaring van Toepasselijkheid (VvT)',
    'Interne & externe auditmodule',
    'Documentbeheer met versiebeheer',
    'Leveranciersrisicoanalyse',
    'Directiebeoordeling (management review)',
    'Kennisbank met 120+ artikelen',
    '22+ kant-en-klare sjablonen',
  ],
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: '134',
    highPrice: '249',
    offerCount: 3,
    url: 'https://control-one.nl/pricing',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
    { '@type': 'ListItem', position: 2, name: 'Functies', item: 'https://control-one.nl/features' },
  ],
};
---

<Layout
  title="Functies — Alles voor ISO-compliance | Control One"
  description="Ontdek alle functies van Control One: implementatiecoach, risicoanalyse, documentbeheer, audits, leveranciersbeheer, VvT-module en meer. Eén platform voor je hele ISO-traject."
  jsonLd={[softwareSchema, breadcrumbSchema]}
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="relative pt-32 pb-16 lg:pb-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-white to-accent-400/10"></div>
      <div class="absolute top-20 right-0 w-96 h-96 bg-primary-200/30 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-accent-400/10 rounded-full blur-3xl"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="lg:grid lg:grid-cols-[1fr_1.15fr] lg:gap-12 lg:items-center">
          <div class="max-w-xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-primary-700 bg-primary-100 rounded-full">
              <span class="w-1.5 h-1.5 bg-primary-500 rounded-full"></span>
              Platform Functies
            </div>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-primary-950 leading-[1.1]">
              Alles voor jouw
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-accent-500">ISO-compliance</span>
            </h1>
            <p class="mt-6 text-lg text-primary-900/60 leading-relaxed">
              Control One biedt een compleet pakket aan tools om je ISO-implementatie te begeleiden, bewaken en beheren. Control One dekt elk onderdeel van ISO-compliance, zonder dat je specialist hoeft te zijn.
            </p>
          </div>

          <!-- Hero afbeelding rechts -->
          <div class="mt-12 lg:mt-0">
            <div class="rounded-2xl overflow-hidden border border-primary-100 shadow-2xl shadow-primary-200/50">
              <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
                <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
                <div class="flex-1 min-w-0 max-w-[220px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center truncate">app.control-one.nl/dashboard</div></div>
              </div>
              <img src="/screenshots/portal-dashboard.png" alt="Control One portal dashboard" class="w-full" loading="eager" data-lightbox />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature constellation: interactive orbit met alle platformfuncties -->
    <FeatureConstellation />

    <!-- Scanbare index van 12 functies, gegroepeerd in 4 pijlers -->
    <FeaturePillars />

    <!-- 5-stappen implementatiepad -->
    <HowItWorks />

    <!-- Mid-page Demo CTA -->
    <DemoCta
      module="Portal"
      title="Benieuwd hoe het hele platform werkt?"
      description="Loop door een interactieve rondleiding en zie alle modules in actie: van risicoanalyse tot audits en directiebeoordeling. Geen account nodig."
      ctaText="Bekijk de live demo"
      urlPath="dashboard"
      accentBg="bg-primary-500"
      accentText="text-blue-300"
      variant="portal"
    />

    <!-- Wat krijg je naast de tools: coach, kennisbank, sjablonen, chat consultancy -->
    <CompleetPakket />

    <CTA />
  </main>
  <Footer />
</Layout>
