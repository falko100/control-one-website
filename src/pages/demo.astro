---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Demo Aanvragen — Control One">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-white to-accent-400/10"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-start">
          <!-- Left column -->
          <div class="pt-8">
            <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-primary-950 leading-[1.1]">
              Start uw gratis proefperiode of
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-accent-500">vraag een demo aan</span>
            </h1>
            <p class="mt-6 text-lg text-primary-900/60 leading-relaxed">
              Probeer Control One 14 dagen gratis uit, of plan een persoonlijke demo met ons team. Wij laten u graag zien hoe Control One uw compliance-traject kan vereenvoudigen.
            </p>

            <div class="mt-10 space-y-6">
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary-50 text-primary-600 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-primary-950">Binnen 5 minuten aan de slag</h3>
                  <p class="text-sm text-primary-900/60 mt-1">Geen installatie nodig. Maak een account aan en start direct met uw ISO-implementatie.</p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary-50 text-primary-600 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"></path></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-primary-950">Geen creditcard nodig</h3>
                  <p class="text-sm text-primary-900/60 mt-1">Uw proefperiode is volledig gratis. Geen verplichtingen, geen verborgen kosten.</p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary-50 text-primary-600 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-primary-950">Persoonlijke begeleiding</h3>
                  <p class="text-sm text-primary-900/60 mt-1">Ons team helpt u graag op weg met een persoonlijke introductie en demo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right column: Form -->
          <div class="bg-white rounded-2xl border border-primary-100 shadow-xl shadow-primary-100/30 p-8">
            <h2 class="text-xl font-bold text-primary-950 mb-6">Vul uw gegevens in</h2>
            <form class="space-y-5">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="firstName" class="block text-sm font-medium text-primary-900/70 mb-1.5">Voornaam</label>
                  <input type="text" id="firstName" name="firstName" required class="w-full px-4 py-2.5 rounded-lg border border-primary-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 transition" />
                </div>
                <div>
                  <label for="lastName" class="block text-sm font-medium text-primary-900/70 mb-1.5">Achternaam</label>
                  <input type="text" id="lastName" name="lastName" required class="w-full px-4 py-2.5 rounded-lg border border-primary-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 transition" />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-primary-900/70 mb-1.5">Zakelijk e-mailadres</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 rounded-lg border border-primary-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 transition" />
              </div>

              <div>
                <label for="company" class="block text-sm font-medium text-primary-900/70 mb-1.5">Bedrijfsnaam</label>
                <input type="text" id="company" name="company" required class="w-full px-4 py-2.5 rounded-lg border border-primary-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 transition" />
              </div>

              <div>
                <label for="framework" class="block text-sm font-medium text-primary-900/70 mb-1.5">Welk framework heeft uw interesse?</label>
                <select id="framework" name="framework" class="w-full px-4 py-2.5 rounded-lg border border-primary-200 text-sm text-primary-900/70 focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 transition bg-white">
                  <option value="">Selecteer een framework</option>
                  <option value="iso-27001">ISO 27001 — Informatiebeveiliging</option>
                  <option value="iso-9001">ISO 9001 — Kwaliteitsmanagement</option>
                  <option value="iso-14001">ISO 14001 — Milieubeheer</option>
                  <option value="multiple">Meerdere frameworks</option>
                  <option value="other">Anders</option>
                </select>
              </div>

              <div>
                <label for="type" class="block text-sm font-medium text-primary-900/70 mb-1.5">Wat wilt u?</label>
                <div class="grid sm:grid-cols-2 gap-3">
                  <label class="flex items-center gap-3 p-3 rounded-lg border border-primary-200 cursor-pointer hover:bg-primary-50/50 transition has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                    <input type="radio" name="type" value="trial" checked class="text-primary-600 focus:ring-primary-500" />
                    <span class="text-sm text-primary-900/70">Gratis proefperiode</span>
                  </label>
                  <label class="flex items-center gap-3 p-3 rounded-lg border border-primary-200 cursor-pointer hover:bg-primary-50/50 transition has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                    <input type="radio" name="type" value="demo" class="text-primary-600 focus:ring-primary-500" />
                    <span class="text-sm text-primary-900/70">Persoonlijke demo</span>
                  </label>
                </div>
              </div>

              <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white bg-primary-700 hover:bg-primary-800 rounded-lg transition-all shadow-lg shadow-primary-700/25 mt-2">
                Versturen
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
              </button>

              <p class="text-xs text-primary-900/40 text-center">
                Door te versturen gaat u akkoord met ons <a href="#" class="underline hover:text-primary-600">privacybeleid</a>.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
