---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

---

<Layout title="Gratis Demo Aanvragen — Bekijk Control One in actie" description="Vraag een gratis demo aan van Control One en ontdek hoe je ISO 27001, 9001, 14001 en 45001 eenvoudig zelf implementeert. Plan een persoonlijke rondleiding.">
  <Header />
  <main>

    <!-- HERO -->
    <section class="relative pt-32 pb-16 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>

      <div class="relative max-w-7xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-accent-400 bg-white/10 rounded-full border border-white/10">
          <span class="w-1.5 h-1.5 bg-accent-400 rounded-full animate-pulse"></span>
          Live Demo
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
          Bekijk het Control One portal<br class="hidden sm:block" /> in actie
        </h1>
        <p class="mt-5 text-lg text-primary-300/80 max-w-2xl mx-auto leading-relaxed">
          Plan een persoonlijke demo met ons team of start direct met je 14 dagen gratis proefperiode.
        </p>
      </div>
    </section>

    <!-- INTERACTIVE DEMO -->
    <section id="portal" class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 mb-3">Interactieve demo</p>
          <h2 class="text-3xl font-bold text-primary-950 tracking-tight">Probeer het zelf uit</h2>
          <p class="mt-3 text-primary-900/60">Klik door het platform en ontdek hoe Control One werkt, zonder account.</p>
        </div>

        <iframe
          src="https://controlone.navattic.com/5k490p0b"
          style="border: none; width: 100%; aspect-ratio: 16 / 10; display: block;"
          allow="fullscreen"
          title="Control One: Interactieve Demo"
        ></iframe>
      </div>
    </section>

    <CTA />

  </main>
  <Footer />
</Layout>

