---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const artikelen = (await getCollection('kennisbank', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const normen = [
  { key: 'iso-27001', label: 'ISO 27001', sub: 'Informatiebeveiliging', kleur: 'text-blue-700', bg: 'bg-blue-50', border: 'border-blue-200', hover: 'hover:border-blue-400' },
  { key: 'iso-9001', label: 'ISO 9001', sub: 'Kwaliteitsmanagement', kleur: 'text-indigo-700', bg: 'bg-indigo-50', border: 'border-indigo-200', hover: 'hover:border-indigo-400' },
  { key: 'iso-14001', label: 'ISO 14001', sub: 'Milieumanagement', kleur: 'text-emerald-700', bg: 'bg-emerald-50', border: 'border-emerald-200', hover: 'hover:border-emerald-400' },
  { key: 'iso-45001', label: 'ISO 45001', sub: 'Arbo & veiligheid', kleur: 'text-amber-700', bg: 'bg-amber-50', border: 'border-amber-200', hover: 'hover:border-amber-400' },
  { key: 'algemeen', label: 'Algemeen', sub: 'Certificering, audits & begrippen', kleur: 'text-primary-700', bg: 'bg-primary-50', border: 'border-primary-200', hover: 'hover:border-primary-400' },
];

const categorieLabels: Record<string, string> = {
  normeisen: 'Normeisen', stappenplannen: 'Stappenplannen', begrippen: 'Begrippen',
  vragen: 'Veelgestelde vragen', vergelijkingen: 'Vergelijkingen', sjablonen: 'Documenten & sjablonen',
};

const perNorm = Object.fromEntries(normen.map(n => [n.key, artikelen.filter(a => a.data.norm === n.key)]));
const uitgelicht = artikelen.filter(a => a.data.categorie === 'vragen').slice(0, 6);
---

<Layout
  title="ISO Kennisbank — Alles over ISO 27001, 9001, 14001 en 45001 | Control One"
  description="De Nederlandstalige kennisbank over ISO-certificering: normeisen, stappenplannen, begrippen en veelgestelde vragen over ISO 27001, 9001, 14001 en 45001. Vrij toegankelijk."
>
  <Header />
  <main>

    <!-- HERO met zoekfunctie -->
    <section class="relative pt-32 pb-20 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-4xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-accent-400 bg-white/10 rounded-full border border-white/10">
          <span class="w-1.5 h-1.5 bg-accent-400 rounded-full animate-pulse"></span>
          Kennisbank
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
          Alles over ISO,<br /><span class="text-accent-400">in gewone taal</span>
        </h1>
        <p class="mt-5 text-lg text-white/90 max-w-2xl mx-auto leading-relaxed">
          Normeisen, stappenplannen en begrippen voor ISO 27001, 9001, 14001 en 45001. Voor wie begint én als naslagwerk tijdens de implementatie.
        </p>

        <!-- Zoekbalk -->
        <div class="relative mt-9 max-w-xl mx-auto" id="kb-zoek-wrap">
          <div class="relative">
            <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-primary-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 10a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input
              id="kb-zoek"
              type="search"
              placeholder="Zoek op onderwerp, norm of vraag..."
              autocomplete="off"
              class="w-full pl-13 pr-5 py-4 rounded-2xl bg-white text-primary-950 placeholder-primary-400 shadow-2xl shadow-black/20 outline-none focus:ring-4 focus:ring-accent-400/40 text-base"
              style="padding-left: 3.25rem;"
            />
          </div>
          <div id="kb-resultaten" class="hidden absolute left-0 right-0 top-full mt-2 bg-white rounded-2xl shadow-2xl shadow-black/25 border border-primary-100 overflow-hidden text-left z-30 max-h-96 overflow-y-auto"></div>
        </div>
        <p class="mt-4 text-sm text-white/70">{artikelen.length} artikelen · gratis toegankelijk · wekelijks aangevuld</p>
      </div>
    </section>

    <!-- NORMEN -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
          {normen.map(n => (
            <a href={`/kennis/${n.key}/`} class={`group rounded-2xl border ${n.border} ${n.hover} ${n.bg} p-6 transition-all hover:shadow-lg hover:-translate-y-0.5`}>
              <p class={`text-lg font-bold ${n.kleur}`}>{n.label}</p>
              <p class="mt-1 text-sm text-primary-900/60">{n.sub}</p>
              <p class={`mt-4 text-sm font-semibold ${n.kleur} inline-flex items-center gap-1.5`}>
                {perNorm[n.key].length} artikelen
                <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- UITGELICHT -->
    <section class="py-16 border-t border-primary-100/60" style="background: linear-gradient(180deg, #eff8ff 0%, #f8fbff 100%);">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 mb-2">Meestgelezen</p>
            <h2 class="text-2xl sm:text-3xl font-bold text-primary-950 tracking-tight">Begin met deze vragen</h2>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {uitgelicht.map(a => (
            <a href={`/kennis/${a.data.norm}/${a.slug}/`} class="group bg-white rounded-2xl border border-primary-100 hover:border-primary-300 p-6 transition-all hover:shadow-lg flex flex-col">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-[11px] font-bold uppercase tracking-widest text-primary-500">{a.data.norm === 'algemeen' ? 'Algemeen' : a.data.norm.replace('iso-', 'ISO ')}</span>
                <span class="w-1 h-1 rounded-full bg-primary-200"></span>
                <span class="text-[11px] text-primary-400">{a.data.readTime}</span>
              </div>
              <h3 class="text-base font-bold text-primary-950 group-hover:text-primary-700 transition-colors leading-snug">{a.data.title}</h3>
              <p class="mt-2 text-sm text-primary-900/60 leading-relaxed line-clamp-3">{a.data.description}</p>
              <span class="mt-4 pt-1 text-sm font-semibold text-primary-600 inline-flex items-center gap-1.5 mt-auto">
                Lees artikel
                <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CATEGORIEËN -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 mb-2">Bladeren op type</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-primary-950 tracking-tight mb-8">Zes soorten artikelen</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {Object.entries(categorieLabels).map(([key, label]) => {
            const count = artikelen.filter(a => a.data.categorie === key).length;
            return (
              <a href={`/kennis/type/${key}/`} class="group rounded-2xl border border-primary-100 bg-primary-50/40 hover:bg-white hover:border-primary-300 p-5 flex items-center justify-between transition-all hover:shadow-md">
                <div>
                  <p class="font-bold text-primary-950 group-hover:text-primary-700 transition-colors">{label}</p>
                  <p class="text-sm text-primary-900/50">{count} artikelen</p>
                </div>
                <svg class="w-5 h-5 text-primary-300 group-hover:text-primary-500 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- CTA: quickscan -->
    <section class="py-16 border-t border-primary-100/60" style="background: linear-gradient(180deg, #eff8ff 0%, #f8fbff 100%);">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary-950 tracking-tight">Weten waar jouw organisatie staat?</h2>
        <p class="mt-3 text-lg text-primary-900/70">Doe de gratis quickscan: 12 vragen, direct een persoonlijk advies met route, abonnement en doorlooptijd.</p>
        <div class="mt-7 flex flex-wrap justify-center gap-4">
          <a href="/quickscan" class="inline-flex items-center gap-2 px-7 py-3.5 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-500 hover:text-white rounded-xl transition-all shadow-lg shadow-accent-500/25">
            Doe de gratis quickscan
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="https://app.control-one.nl/register" class="inline-flex items-center px-7 py-3.5 text-sm font-semibold text-primary-700 bg-white border border-primary-200 hover:border-primary-400 rounded-xl transition-all">
            Probeer de portal 14 dagen gratis
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  // Client-side zoekfunctie: index lazy laden bij eerste focus, daarna live filteren.
  (function () {
    const input = document.getElementById('kb-zoek') as HTMLInputElement;
    const paneel = document.getElementById('kb-resultaten') as HTMLElement;
    if (!input || !paneel) return;

    let index: { titel: string; beschrijving: string; url: string; norm: string; zoek: string }[] | null = null;
    let laden = false;

    async function laadIndex() {
      if (index || laden) return;
      laden = true;
      try {
        const res = await fetch('/kennis/zoekindex.json');
        index = await res.json();
      } catch { index = []; }
      laden = false;
    }

    function zoek(q: string) {
      if (!index) return [];
      const termen = q.toLowerCase().split(/\s+/).filter(Boolean);
      if (!termen.length) return [];
      return index
        .map(item => {
          let score = 0;
          for (const t of termen) {
            if (item.titel.toLowerCase().includes(t)) score += 3;
            if (item.zoek.includes(t)) score += 1;
          }
          return { item, score };
        })
        .filter(r => r.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 8)
        .map(r => r.item);
    }

    function render(resultaten: NonNullable<typeof index>) {
      if (!resultaten.length) {
        paneel.innerHTML = '<p class="px-5 py-4 text-sm text-primary-400">Geen artikelen gevonden. Probeer een andere zoekterm.</p>';
      } else {
        paneel.innerHTML = resultaten.map(r => `
          <a href="${r.url}" class="block px-5 py-3.5 hover:bg-primary-50 transition-colors border-b border-primary-50 last:border-0">
            <span class="block text-[10px] font-bold uppercase tracking-widest text-primary-400 mb-0.5">${r.norm}</span>
            <span class="block text-sm font-semibold text-primary-950">${r.titel}</span>
            <span class="block text-xs text-primary-900/50 mt-0.5 line-clamp-1">${r.beschrijving}</span>
          </a>`).join('');
      }
      paneel.classList.remove('hidden');
    }

    input.addEventListener('focus', laadIndex, { once: true });
    input.addEventListener('input', async () => {
      const q = input.value.trim();
      if (q.length < 2) { paneel.classList.add('hidden'); return; }
      await laadIndex();
      render(zoek(q));
    });
    document.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('#kb-zoek-wrap')) paneel.classList.add('hidden');
    });
    input.addEventListener('keydown', (e) => { if (e.key === 'Escape') paneel.classList.add('hidden'); });
  })();
</script>
