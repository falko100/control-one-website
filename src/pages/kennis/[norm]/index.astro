---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  return ['iso-27001', 'iso-9001', 'iso-14001', 'iso-45001', 'algemeen'].map(norm => ({ params: { norm } }));
}

const { norm } = Astro.params;

const normInfo: Record<string, { label: string; sub: string; intro: string }> = {
  'iso-27001': { label: 'ISO 27001', sub: 'Informatiebeveiliging', intro: 'Alles over de norm voor informatiebeveiliging: van de 93 Annex A-maatregelen tot risicoanalyse en de Verklaring van Toepasselijkheid.' },
  'iso-9001': { label: 'ISO 9001', sub: 'Kwaliteitsmanagement', intro: 'Alles over de norm voor kwaliteitsmanagement: normeisen per clausule, processen, audits en continue verbetering.' },
  'iso-14001': { label: 'ISO 14001', sub: 'Milieumanagement', intro: 'Alles over de norm voor milieumanagement: milieuaspecten, compliance en duurzaamheidseisen in tenders.' },
  'iso-45001': { label: 'ISO 45001', sub: 'Arbo & veiligheid', intro: 'Alles over de norm voor gezond en veilig werken: van RI&E tot participatie en incidentregistratie.' },
  'algemeen': { label: 'Algemeen', sub: 'Certificering, audits & begrippen', intro: 'Norm-overstijgende kennis: certificeringstrajecten, audits, begrippen en vergelijkingen tussen normen.' },
};

const categorieLabels: Record<string, string> = {
  normeisen: 'Normeisen', stappenplannen: 'Stappenplannen', begrippen: 'Begrippen',
  vragen: 'Veelgestelde vragen', vergelijkingen: 'Vergelijkingen', sjablonen: 'Documenten & sjablonen',
};

const info = normInfo[norm!];
const artikelen = (await getCollection('kennisbank', ({ data }) => !data.draft && data.norm === norm))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'nl'));

const perCategorie = Object.entries(categorieLabels)
  .map(([key, label]) => ({ key, label, items: artikelen.filter(a => a.data.categorie === key) }))
  .filter(c => c.items.length > 0);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Kennisbank', item: 'https://control-one.nl/kennis/' },
    { '@type': 'ListItem', position: 2, name: info.label, item: `https://control-one.nl/kennis/${norm}/` },
  ],
};
---

<Layout
  title={`${info.label} kennisbank — ${info.sub} | Control One`}
  description={`${info.intro} ${artikelen.length} vrij toegankelijke artikelen.`}
  jsonLd={breadcrumbSchema}
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="relative pt-32 pb-14 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <nav class="text-sm text-white/60 mb-5" aria-label="Breadcrumb">
          <a href="/kennis/" class="hover:text-white transition-colors">Kennisbank</a>
          <span class="mx-2">/</span>
          <span class="text-white/90">{info.label}</span>
        </nav>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-white leading-tight">{info.label} <span class="text-accent-400">kennisbank</span></h1>
        <p class="mt-4 text-lg text-white/90 max-w-2xl leading-relaxed">{info.intro}</p>
        <p class="mt-3 text-sm text-white/70">{artikelen.length} artikelen</p>
      </div>
    </section>

    <!-- ARTIKELEN PER CATEGORIE -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        {perCategorie.length === 0 && (
          <p class="text-primary-900/60">De eerste artikelen voor deze norm verschijnen binnenkort. Bekijk intussen de <a href="/kennis/" class="text-primary-600 font-semibold hover:underline">volledige kennisbank</a>.</p>
        )}
        <div class="space-y-14">
          {perCategorie.map(cat => (
            <div>
              <h2 class="text-xl font-bold text-primary-950 tracking-tight mb-5 flex items-center gap-3">
                {cat.label}
                <span class="text-xs font-semibold text-primary-400 bg-primary-50 border border-primary-100 rounded-full px-2.5 py-0.5">{cat.items.length}</span>
              </h2>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {cat.items.map(a => (
                  <a href={`/kennis/${a.data.norm}/${a.slug}/`} class="group bg-white rounded-2xl border border-primary-100 hover:border-primary-300 p-5 transition-all hover:shadow-md flex flex-col">
                    <h3 class="text-[15px] font-bold text-primary-950 group-hover:text-primary-700 transition-colors leading-snug">{a.data.title}</h3>
                    <p class="mt-1.5 text-sm text-primary-900/55 leading-relaxed line-clamp-2">{a.data.description}</p>
                    <span class="mt-3 text-xs text-primary-400 mt-auto pt-2">{a.data.readTime} leestijd</span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-14 border-t border-primary-100/60" style="background: linear-gradient(180deg, #eff8ff 0%, #f8fbff 100%);">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-2xl font-bold text-primary-950 tracking-tight">Zelf aan de slag met {info.label}?</h2>
        <p class="mt-2 text-primary-900/70">De portal begeleidt je stap voor stap, met alle sjablonen en de implementatiecoach.</p>
        <div class="mt-6 flex flex-wrap justify-center gap-4">
          <a href="/quickscan" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-500 hover:text-white rounded-xl transition-all shadow-md">Doe de gratis quickscan</a>
          <a href={norm === 'algemeen' ? '/frameworks' : `/${norm}`} class="inline-flex items-center px-6 py-3 text-sm font-semibold text-primary-700 bg-white border border-primary-200 hover:border-primary-400 rounded-xl transition-all">Meer over {info.label}</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
