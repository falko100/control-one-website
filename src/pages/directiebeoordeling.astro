---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Directiebeoordeling: Control One">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-indigo-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-indigo-400 bg-indigo-400/10 rounded-full border border-indigo-400/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>
            Directiebeoordeling
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Management reviews<br/><span class="text-indigo-400">gestructureerd & gedocumenteerd</span>
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-xl leading-relaxed">
            Bereid directiebeoordelingen voor met alle vereiste input, leg besluiten en actiepunten vast en genereer kant-en-klare verslagen conform ISO 27001 clausule 9.3.
          </p>
          <div class="mt-8 flex gap-4">
            <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
              Gratis uitproberen
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/features" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Alle features</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-0 bg-white">
      <div class="max-w-5xl mx-auto px-6 -mt-8">
        <div class="rounded-2xl overflow-hidden border border-primary-100 shadow-2xl shadow-primary-200/30">
          <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
            <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
            <div class="flex-1 max-w-[280px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center">app.control-one.nl/directiebeoordeling</div></div>
          </div>
          <!-- Directiebeoordeling inline mockup -->
          <div class="bg-white p-6">
            <!-- Review header -->
            <div class="flex items-center justify-between mb-5 pb-4 border-b border-primary-100">
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-widest text-indigo-500 mb-0.5">Directiebeoordeling</p>
                <p class="text-sm font-bold text-primary-950">Informatiebeveiliging: ISO 27001 · Q1 2024</p>
              </div>
              <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 border border-amber-100">In voorbereiding</span>
            </div>
            <!-- Input items -->
            <p class="text-[10px] font-semibold uppercase tracking-wide text-primary-400 mb-3">Verplichte inputpunten, clausule 9.3</p>
            <div class="grid grid-cols-2 gap-2 mb-5">
              {[
                { label: 'Status vorige actiepunten', done: true },
                { label: 'Resultaten interne audits', done: true },
                { label: 'Non-conformiteiten & CPAR\'s', done: true },
                { label: 'Prestaties en KPI\'s', done: false },
                { label: 'Risicobehandeling', done: false },
                { label: 'Kansen voor verbetering', done: false },
              ].map(item => (
                <div class:list={['flex items-center gap-2 px-3 py-2 rounded-lg border text-xs font-medium', item.done ? 'bg-indigo-50 border-indigo-100 text-indigo-800' : 'bg-primary-50/50 border-primary-100 text-primary-500']}>
                  <div class:list={['w-4 h-4 rounded-full flex items-center justify-center shrink-0', item.done ? 'bg-indigo-500' : 'border-2 border-primary-200']}>
                    {item.done && <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>}
                  </div>
                  <span class="truncate">{item.label}</span>
                </div>
              ))}
            </div>
            <!-- Action items -->
            <p class="text-[10px] font-semibold uppercase tracking-wide text-primary-400 mb-2">Actiepunten uit vorige beoordeling</p>
            <div class="space-y-1.5">
              {[
                { action: 'Leveranciersbeleid updaten', owner: 'J. Smit', due: '15 apr', done: true },
                { action: 'Intern audit Q1 afronden', owner: 'L. de Vries', due: '30 apr', done: false },
              ].map(a => (
                <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-primary-50/50">
                  <div class:list={['w-3.5 h-3.5 rounded-full shrink-0', a.done ? 'bg-emerald-500' : 'border-2 border-primary-300']}></div>
                  <span class:list={['flex-1 text-xs font-medium truncate', a.done ? 'line-through text-primary-400' : 'text-primary-900']}>{a.action}</span>
                  <span class="text-[10px] text-primary-400">{a.owner}</span>
                  <span class="text-[10px] font-semibold text-indigo-600">{a.due}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">

        <!-- Input items grid -->
        <div class="max-w-3xl mx-auto mb-16">
          <p class="text-xs font-semibold tracking-widest uppercase text-indigo-500 mb-3 text-center">Verplichte input ISO 27001:2022 clausule 9.3</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {[
              'Status vorige actiepunten',
              'Resultaten interne audits',
              'Resultaten externe audits',
              'Prestaties en doelstellingen',
              'Non-conformiteiten & CPAR\'s',
              'Risicobehandeling & risico\'s',
              'Leveranciersfeedback',
              'Resultaten monitoring KPI\'s',
              'Kansen voor verbetering',
            ].map(item => (
              <div class="flex items-center gap-2.5 p-3 rounded-xl bg-indigo-50 border border-indigo-100">
                <div class="w-4 h-4 rounded-full bg-indigo-500 flex items-center justify-center shrink-0">
                  <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-xs font-medium text-primary-800">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Feature cards -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {[
            { title: 'Gestructureerde voorbereiding', desc: 'De portal verzamelt automatisch alle vereiste inputpunten uit andere modules zoals audits, CPAR\'s en risico\'s.' },
            { title: 'Notulen & besluitenlijst', desc: 'Leg besluiten en actiepunten vast tijdens de vergadering en genereer direct een gestructureerd verslag.' },
            { title: 'Actiepunten opvolging', desc: 'Actiepunten worden omgezet in taken met eigenaar en deadline, zichtbaar in het dashboard.' },
            { title: 'Historisch overzicht', desc: 'Bewaar alle voorgaande directiebeoordelingen en volg de voortgang van besluiten door de tijd heen.' },
            { title: 'PDF-export voor auditor', desc: 'Exporteer het verslag als ondertekend PDF-document, klaar voor inzage door uw certificerende instantie.' },
            { title: 'KPI-dashboard als input', desc: 'Koppel uw KPI-resultaten direct als inputpunt en presenteer trends en doelrealisatie in de vergadering.' },
          ].map(f => (
            <div class="p-6 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h3 class="text-sm font-bold text-primary-950 mb-2">{f.title}</h3>
              <p class="text-sm text-primary-900/55 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>

        <!-- Callout -->
        <div class="mt-12 max-w-3xl mx-auto p-6 rounded-2xl bg-indigo-50 border border-indigo-100 flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-indigo-600 flex items-center justify-center text-white shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary-950 mb-1">Auditklaar in één klik</h3>
            <p class="text-sm text-primary-900/60 leading-relaxed">Exporteer het volledige verslag inclusief aanwezigenlijst, inputpunten, besluiten en actiepunten als ondertekend PDF-document. Je certificerende instantie heeft direct alles wat nodig is voor clausule 9.3.</p>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
