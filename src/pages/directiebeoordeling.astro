---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const exampleReviews = [
  { num: 'MR-0004', subject: 'Kwartaalbeoordeling ISMS — Q1 2026', date: '16 apr 2026', status: 'Ingepland', color: 'bg-amber-50 text-amber-700 border-amber-100' },
  { num: 'MR-0003', subject: 'Directiebeoordeling H1 2026', date: '13 apr 2026', status: 'In behandeling', color: 'bg-blue-50 text-blue-700 border-blue-100' },
  { num: 'MR-0002', subject: 'Directiebeoordeling Q4 2025', date: '16 feb 2026', status: 'Goedgekeurd', color: 'bg-emerald-50 text-emerald-700 border-emerald-100' },
  { num: 'MR-0001', subject: 'Eerste directiebeoordeling ISO 27001', date: '16 feb 2026', status: 'Uitgevoerd', color: 'bg-primary-50 text-primary-600 border-primary-100' },
];

// 17 standaard secties zoals in de portal (uit Control One database)
const reviewSections = [
  { num: 1, name: 'Acties vorige vergadering', desc: 'Status van besluiten en actiepunten uit de vorige directiebeoordeling.', group: 'input' },
  { num: 2, name: 'Wijzigingen externe/interne context', desc: 'Veranderingen in markt, regelgeving, organisatie en stakeholders sinds de laatste review.', group: 'input' },
  { num: 3, name: 'Prestaties ISMS', desc: 'Samenvatting van KPI\'s, doelstellingen en operationele resultaten.', group: 'input' },
  { num: 4, name: 'Risico-identificatie en behandeling', desc: 'Nieuwe risico\'s, behandelde risico\'s en restrisico\'s — direct uit het risicoregister.', group: 'input' },
  { num: 5, name: 'Interne en externe audits', desc: 'Resultaten van interne audits, surveillance-audits en externe certificeringsaudits.', group: 'input' },
  { num: 6, name: 'Corrigerende en preventieve maatregelen', desc: 'CPAR-status: openstaand, in behandeling, afgerond — automatisch gevuld.', group: 'input' },
  { num: 7, name: 'Informatiebeveiligingsincidenten', desc: 'Geregistreerde incidenten, lessons learned en patroonanalyse.', group: 'input' },
  { num: 8, name: 'Paraatheid en noodsituaties', desc: 'Resultaten van BCP/DR-tests en aanpassingen aan noodprocedures.', group: 'input' },
  { num: 9, name: 'Nalevingsverplichtingen', desc: 'Wettelijke en contractuele verplichtingen — actuele status en wijzigingen.', group: 'input' },
  { num: 10, name: 'Bewustzijn en communicatie', desc: 'Trainingen, awareness-campagnes en communicatie-effectiviteit.', group: 'input' },
  { num: 11, name: 'Wijzigingen ISMS', desc: 'Voorgestelde of doorgevoerde wijzigingen in scope, beleid of structuur.', group: 'output' },
  { num: 12, name: 'Training, ontwikkeling en middelen', desc: 'Beoordeling van capaciteit, kennis en budget voor het ISMS.', group: 'output' },
  { num: 13, name: 'Voortdurende verbetering', desc: 'Verbeterinitiatieven, lessons learned en innovatie-acties.', group: 'output' },
  { num: 14, name: 'Risico\'s en kansen', desc: 'Strategische risico\'s en kansen die uit de beoordeling naar voren komen.', group: 'output' },
  { num: 15, name: 'Beleid, doelstellingen en KPI\'s', desc: 'Bevestiging of aanpassing van beleid, doelstellingen en KPI\'s voor de komende periode.', group: 'output' },
  { num: 16, name: 'Bijzondere onderwerpen', desc: 'Specifieke agendapunten relevant voor deze beoordelingscyclus.', group: 'output' },
  { num: 17, name: 'W.v.t.t.k.', desc: 'Wat verder ter tafel komt — open ruimte voor inbreng buiten agenda.', group: 'output' },
];

// Auto-vulling van inputpunten uit andere portal-modules
const autoFillSources = [
  { section: 'Risico-identificatie', source: 'Risicoanalyse', icon: 'risk' },
  { section: 'Audits', source: 'Audits-module', icon: 'audit' },
  { section: 'CPAR\'s', source: 'CPAR-overzicht', icon: 'cpar' },
  { section: 'Incidenten', source: 'Beveiligingsincidenten', icon: 'incident' },
  { section: 'Maatregelen-status', source: 'Maatregelen + VvT', icon: 'control' },
  { section: 'Leveranciers', source: 'Leveranciersbeoordelingen', icon: 'vendor' },
];
---

<Layout
  title="Directiebeoordeling — Management Review Software | Control One"
  description="Leg directiebeoordelingen gestructureerd vast conform ISO-eisen. Automatische verzameling van inputpunten, besluitenlijst, actiepunten en PDF-rapport — volledig conform clausule 9.3."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
      { '@type': 'ListItem', position: 2, name: 'Portal', item: 'https://control-one.nl/features' },
      { '@type': 'ListItem', position: 3, name: 'Directiebeoordeling', item: 'https://control-one.nl/directiebeoordeling' },
    ],
  }}
>
  <Header />
  <main>
    <section class="relative pt-32 pb-20 lg:pb-28 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-indigo-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="lg:grid lg:grid-cols-[1fr_1.15fr] lg:gap-12 lg:items-center">
          <div class="max-w-xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-indigo-400 bg-indigo-400/10 rounded-full border border-indigo-400/20">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>
              Directiebeoordeling
            </div>
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
              Management reviews<br/><span class="text-indigo-400">gestructureerd & gedocumenteerd</span>
            </h1>
            <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
              Elke directiebeoordeling krijgt een eigen MR-nummer, verzamelt automatisch de verplichte inputpunten uit audits, CPAR's, risico's en leveranciers en levert een ondertekend PDF-verslag — volledig conform ISO 27001 clausule 9.3.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3 text-xs font-medium text-white/80">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Clausule 9.3 volledig
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Automatische inputverzameling
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Kwartaal- &amp; jaarreviews
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
                Gratis uitproberen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href="/features" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Alle features</a>
            </div>
          </div>

          <!-- Hero afbeelding rechts -->
          <div class="mt-12 lg:mt-0">
            <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40">
              <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
                <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
                <div class="flex-1 min-w-0 max-w-[280px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center truncate">app.control-one.nl/directiebeoordeling</div></div>
              </div>
              <!-- Directiebeoordeling inline mockup -->
              <div class="bg-white p-5">
                <!-- Review header -->
                <div class="flex items-center justify-between mb-4 pb-3 border-b border-primary-100">
                  <div>
                    <p class="text-[10px] font-semibold uppercase tracking-widest text-indigo-500 mb-0.5">MR-0004</p>
                    <p class="text-xs font-bold text-primary-950">Kwartaalbeoordeling ISMS — Q1 2026</p>
                  </div>
                  <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 border border-amber-100">Voorbereiding</span>
                </div>
                <!-- Input items -->
                <p class="text-[10px] font-semibold uppercase tracking-wide text-primary-400 mb-2">Inputpunten clausule 9.3</p>
                <div class="grid grid-cols-2 gap-1.5 mb-4">
                  {[
                    { label: 'Status vorige actiepunten', done: true },
                    { label: 'Resultaten interne audits', done: true },
                    { label: "Non-conformiteiten & CPAR's", done: true },
                    { label: "Prestaties en KPI's", done: false },
                    { label: 'Risicobehandeling', done: false },
                    { label: 'Kansen voor verbetering', done: false },
                  ].map(item => (
                    <div class:list={['flex items-center gap-2 px-2 py-1.5 rounded-lg border text-[10px] font-medium', item.done ? 'bg-indigo-50 border-indigo-100 text-indigo-800' : 'bg-primary-50/50 border-primary-100 text-primary-500']}>
                      <div class:list={['w-3.5 h-3.5 rounded-full flex items-center justify-center shrink-0', item.done ? 'bg-indigo-500' : 'border-2 border-primary-200']}>
                        {item.done && <svg class="w-2 h-2 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>}
                      </div>
                      <span class="truncate">{item.label}</span>
                    </div>
                  ))}
                </div>
                <!-- Action items -->
                <p class="text-[10px] font-semibold uppercase tracking-wide text-primary-400 mb-2">Actiepunten uit vorige beoordeling</p>
                <div class="space-y-1.5">
                  {[
                    { action: 'Leveranciersbeleid updaten', owner: 'J. Smit', due: '15 apr', done: true },
                    { action: 'Intern audit Q1 afronden', owner: 'L. de Vries', due: '30 apr', done: false },
                  ].map(a => (
                    <div class="flex items-center gap-2 px-2 py-1.5 rounded-lg bg-primary-50/50">
                      <div class:list={['w-3 h-3 rounded-full shrink-0', a.done ? 'bg-emerald-500' : 'border-2 border-primary-300']}></div>
                      <span class:list={['flex-1 text-[10px] font-medium truncate', a.done ? 'line-through text-primary-400' : 'text-primary-900']}>{a.action}</span>
                      <span class="text-[9px] text-primary-400">{a.owner}</span>
                      <span class="text-[9px] font-semibold text-indigo-600">{a.due}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Reviews list -->
    <section class="py-20 bg-primary-50/30">
      <div class="max-w-5xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-10">
          <p class="text-sm font-semibold tracking-wide uppercase text-indigo-600 mb-3">Historie</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Elke review genummerd en bewaard</h2>
          <p class="mt-4 text-lg text-primary-900/75">Van je eerste ISO-review tot kwartaalbeoordelingen: de portal geeft elke review een uniek MR-nummer, bewaart het volledige verslag en toont status en actiepunten.</p>
        </div>
        <div class="rounded-2xl overflow-hidden border border-primary-100 bg-white shadow-lg shadow-primary-100/40">
          <div class="flex items-center gap-3 px-5 py-3 bg-primary-50 border-b border-primary-100 text-[10px] font-bold uppercase tracking-wide text-primary-500">
            <span class="w-20 shrink-0">Nummer</span>
            <span class="flex-1">Onderwerp</span>
            <span class="w-28 shrink-0 hidden sm:block">Datum</span>
            <span class="w-32 shrink-0 text-right">Status</span>
          </div>
          <div class="divide-y divide-primary-100">
            {exampleReviews.map(r => (
              <div class="flex items-center gap-3 px-5 py-3 hover:bg-primary-50/40 transition-colors">
                <span class="w-20 shrink-0 text-xs font-bold font-mono text-primary-500">{r.num}</span>
                <p class="flex-1 text-sm font-semibold text-primary-900 truncate">{r.subject}</p>
                <span class="w-28 shrink-0 hidden sm:block text-xs text-primary-500">{r.date}</span>
                <div class="w-32 shrink-0 text-right">
                  <span class:list={['text-[10px] font-semibold px-2 py-0.5 rounded border', r.color]}>{r.status}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Input items grid -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto mb-16">
          <p class="text-xs font-semibold tracking-widest uppercase text-indigo-500 mb-3 text-center">Verplichte input ISO 27001:2022 clausule 9.3</p>
          <h2 class="text-center text-3xl font-bold text-primary-950 tracking-tight mb-10">9 inputpunten, automatisch verzameld</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {[
              'Status vorige actiepunten',
              'Resultaten interne audits',
              'Resultaten externe audits',
              'Prestaties en doelstellingen',
              'Non-conformiteiten & CPAR\'s',
              'Risicobehandeling & risico\'s',
              'Leveranciersfeedback',
              'Resultaten monitoring KPI\'s',
              'Kansen voor verbetering',
            ].map(item => (
              <div class="flex items-center gap-2.5 p-3 rounded-xl bg-indigo-50 border border-indigo-100">
                <div class="w-4 h-4 rounded-full bg-indigo-500 flex items-center justify-center shrink-0">
                  <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-xs font-medium text-primary-800">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- 17 standaard secties -->
        <div class="mt-24">
          <div class="max-w-2xl mx-auto text-center mb-12">
            <p class="text-sm font-semibold tracking-wide uppercase text-indigo-600 mb-3">Vaste structuur</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">17 secties, conform clausule 9.3</h2>
            <p class="mt-4 text-lg text-primary-900/75">Iedere directiebeoordeling in Control One volgt dezelfde gestandaardiseerde structuur. Tien input-secties (de stand van zaken) en zeven output-secties (besluiten en acties).</p>
          </div>

          <div class="grid lg:grid-cols-2 gap-6 max-w-6xl mx-auto">
            <!-- Input secties -->
            <div class="rounded-2xl border border-blue-100 bg-white overflow-hidden">
              <div class="px-5 py-3.5 bg-blue-50 border-b border-blue-100 flex items-center justify-between">
                <p class="text-sm font-bold text-blue-900">Input-secties (1–10)</p>
                <span class="text-[10px] font-bold text-blue-700 bg-white border border-blue-200 px-2 py-0.5 rounded-full">Stand van zaken</span>
              </div>
              <ul class="divide-y divide-primary-100">
                {reviewSections.filter(s => s.group === 'input').map(s => (
                  <li class="px-5 py-3.5 hover:bg-blue-50/30 transition-colors flex items-start gap-3">
                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-blue-100 text-blue-700 text-xs font-bold shrink-0">{s.num}</span>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-primary-950">{s.name}</p>
                      <p class="text-xs text-primary-900/60 mt-0.5 leading-relaxed">{s.desc}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Output secties -->
            <div class="rounded-2xl border border-emerald-100 bg-white overflow-hidden">
              <div class="px-5 py-3.5 bg-emerald-50 border-b border-emerald-100 flex items-center justify-between">
                <p class="text-sm font-bold text-emerald-900">Output-secties (11–17)</p>
                <span class="text-[10px] font-bold text-emerald-700 bg-white border border-emerald-200 px-2 py-0.5 rounded-full">Besluiten &amp; acties</span>
              </div>
              <ul class="divide-y divide-primary-100">
                {reviewSections.filter(s => s.group === 'output').map(s => (
                  <li class="px-5 py-3.5 hover:bg-emerald-50/30 transition-colors flex items-start gap-3">
                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-emerald-100 text-emerald-700 text-xs font-bold shrink-0">{s.num}</span>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-primary-950">{s.name}</p>
                      <p class="text-xs text-primary-900/60 mt-0.5 leading-relaxed">{s.desc}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- Auto-vulling -->
        <div class="mt-24 max-w-5xl mx-auto">
          <div class="max-w-2xl mx-auto text-center mb-10">
            <p class="text-sm font-semibold tracking-wide uppercase text-indigo-600 mb-3">Automatisch gevoed</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Inputpunten vullen zichzelf</h2>
            <p class="mt-4 text-lg text-primary-900/75">Geen losse Excel-sheets samenvoegen. Control One trekt de inputpunten direct uit de modules waar de data leeft.</p>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {autoFillSources.map(s => (
              <div class="p-5 rounded-2xl border border-primary-100 bg-gradient-to-br from-white to-indigo-50/40">
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-9 h-9 rounded-lg bg-indigo-100 text-indigo-700 flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-[10px] font-bold uppercase tracking-widest text-indigo-600">Sectie</p>
                    <p class="text-sm font-bold text-primary-950 truncate">{s.section}</p>
                  </div>
                </div>
                <p class="text-xs text-primary-900/65"><span class="text-indigo-700 font-semibold">Bron: </span>{s.source}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Feature cards -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {[
            { title: 'Eigen MR-nummer per review', desc: 'Elke directiebeoordeling krijgt automatisch een MR-nummer (MR-0001, MR-0002, …) en een vast sjabloon volgens clausule 9.3.' },
            { title: 'Gestructureerde voorbereiding', desc: 'De portal verzamelt automatisch alle inputpunten uit andere modules — audits, CPAR\'s, risico\'s, incidenten, leveranciers.' },
            { title: 'Status door de cyclus', desc: 'Volg elke review door statussen heen: Ingepland → In behandeling → Uitgevoerd → Goedgekeurd, met audit-trail.' },
            { title: 'Kwartaal- én jaarreviews', desc: 'Plan naast de verplichte jaarlijkse review ook kwartaalbeoordelingen in — zelfde structuur, lichtere bezetting.' },
            { title: 'Notulen & besluitenlijst', desc: 'Leg besluiten en actiepunten vast tijdens de vergadering en genereer direct een gestructureerd verslag.' },
            { title: 'Actiepunten opvolging', desc: 'Actiepunten worden omgezet in taken met eigenaar en deadline, zichtbaar in het dashboard — de volgende review toont automatisch de status.' },
            { title: 'Historisch overzicht', desc: 'Alle voorgaande directiebeoordelingen staan bewaard. Perfect voor het aantonen van continuïteit tijdens een externe audit.' },
            { title: 'PDF-export voor auditor', desc: 'Exporteer het verslag als ondertekend PDF-document, klaar voor inzage door je certificerende instantie.' },
            { title: 'KPI-dashboard als input', desc: 'Koppel je KPI-resultaten direct als inputpunt en presenteer trends en doelrealisatie live in de vergadering.' },
          ].map(f => (
            <div class="p-6 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h3 class="text-sm font-bold text-primary-950 mb-2">{f.title}</h3>
              <p class="text-sm text-primary-900/75 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>

        <!-- Callout -->
