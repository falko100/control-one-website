---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const categories = [
  { label: 'A.5', name: 'Organisatorisch', count: 37, color: 'bg-blue-50 text-blue-700 border-blue-100', subtitle: 'Beleid, governance, assets, leveranciers, incidenten, compliance.' },
  { label: 'A.6', name: 'Mensen', count: 8, color: 'bg-emerald-50 text-emerald-700 border-emerald-100', subtitle: 'Screening, training, werken op afstand, geheimhouding, gedrag.' },
  { label: 'A.7', name: 'Fysiek', count: 14, color: 'bg-orange-50 text-orange-700 border-orange-100', subtitle: 'Toegang, kabels, apparatuur, clear desk, veilige verwijdering.' },
  { label: 'A.8', name: 'Technologisch', count: 34, color: 'bg-violet-50 text-violet-700 border-violet-100', subtitle: 'Authenticatie, logging, malware, back-up, netwerk, crypto, SDLC.' },
];

const exampleControls = [
  { ref: 'A5.15', name: 'Toegangsbeveiliging', status: 'implemented' },
  { ref: 'A5.23', name: 'Cloud-beveiliging', status: 'implemented' },
  { ref: 'A6.3', name: 'Bewustwording &amp; training', status: 'in_progress' },
  { ref: 'A6.7', name: 'Werken op afstand', status: 'implemented' },
  { ref: 'A7.2', name: 'Fysieke toegangscontroles', status: 'implemented' },
  { ref: 'A8.7', name: 'Bescherming tegen malware', status: 'implemented' },
  { ref: 'A8.13', name: 'Informatie back-up', status: 'implemented' },
  { ref: 'A8.24', name: 'Gebruik van cryptografie', status: 'in_progress' },
];

const statusColor = {
  implemented: 'bg-emerald-50 text-emerald-700 border-emerald-100',
  in_progress: 'bg-amber-50 text-amber-700 border-amber-100',
  not_applicable: 'bg-primary-50 text-primary-500 border-primary-100',
};
const statusLabel = {
  implemented: 'Geïmplementeerd',
  in_progress: 'In behandeling',
  not_applicable: 'N.v.t.',
};

// Concreet voorbeeld van één Annex A maatregel zoals weergegeven in de portal
const sampleControl = {
  ref: 'A5.15',
  name: 'Toegangsbeveiliging',
  norm: 'ISO 27001:2022 Annex A',
  status: 'Geïmplementeerd',
  owner: { name: 'Mark de Vries', role: 'IT Manager' },
  reviewedAt: '12-03-2026',
  category: 'A5 — Organisatorisch',
  applies: true,
  rationale: 'Toegangsbeveiliging is een centrale control voor de bescherming van bedrijfsgegevens en klantdata. Wij hebben een toegangsbeleid opgesteld waarin per applicatie en omgeving wordt geregeld wie welke rechten krijgt op basis van het least-privilege principe en need-to-know.',
  documents: [
    { name: 'Beleid voor toegangsbeveiliging', type: 'Beleid', clause: 'A5.15' },
    { name: 'Procedure RBAC-rechten', type: 'Procedure', clause: 'A5.15' },
    { name: 'Toegangsmatrix', type: 'Register', clause: 'A5.15' },
  ],
  linkedRisks: [
    { id: 'R-2026-014', title: 'Ongeautoriseerde toegang productiedata', score: 12 },
    { id: 'R-2026-022', title: 'Misbruik admin-privileges', score: 16 },
  ],
};

// Status-flow per maatregel
const controlStatuses = [
  { code: 'open', label: 'Open', desc: 'Nog niet beoordeeld of in behandeling', color: 'bg-primary-50 text-primary-600 border-primary-100' },
  { code: 'in_progress', label: 'In behandeling', desc: 'Implementatie loopt, owner is actief', color: 'bg-amber-50 text-amber-700 border-amber-100' },
  { code: 'implemented', label: 'Geïmplementeerd', desc: 'Volledig actief en aantoonbaar', color: 'bg-emerald-50 text-emerald-700 border-emerald-100' },
  { code: 'not_applicable', label: 'N.v.t.', desc: 'Onderbouwd uitgesloten in VvT', color: 'bg-violet-50 text-violet-700 border-violet-100' },
];
---

<Layout
  title="Annex A Maatregelen — ISO 27001 Beheersmaatregelen | Control One"
  description="Beheer alle 93 Annex A-beheersmaatregelen van ISO 27001:2022. Wijs eigenaren toe, monitor implementatiestatus en vul je Verklaring van Toepasselijkheid per maatregel in."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
      { '@type': 'ListItem', position: 2, name: 'Portal', item: 'https://control-one.nl/features' },
      { '@type': 'ListItem', position: 3, name: 'Maatregelen', item: 'https://control-one.nl/maatregelen' },
    ],
  }}
>
  <Header />
  <main>
    <section class="relative pt-32 pb-20 lg:pb-28 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="lg:grid lg:grid-cols-[1fr_1.15fr] lg:gap-12 lg:items-center">
          <div class="max-w-xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-blue-400 bg-blue-400/10 rounded-full border border-blue-400/20">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              Annex A Maatregelen
            </div>
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
              Alle 93 maatregelen<br/><span class="text-blue-400">overzichtelijk beheerd</span>
            </h1>
            <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
              Elke ISO 27001:2022 Annex A-maatregel krijgt een eigen pagina met uitleg, status, eigenaar, onderbouwing en gekoppelde documenten. Je VvT-tabel toont dezelfde data per maatregel: één plek om in te vullen en te beheren.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3 text-xs font-medium text-white/80">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                93 controls
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Interactieve VvT-tabel
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Gekoppeld aan risico's &amp; documenten
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
                Gratis uitproberen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href="/iso-27001#annex-a" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Bekijk alle maatregelen</a>
            </div>
          </div>

          <!-- Hero afbeelding rechts -->
          <div class="mt-12 lg:mt-0">
            <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40">
              <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
                <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
                <div class="flex-1 min-w-0 max-w-[220px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center truncate">app.control-one.nl/maatregelen</div></div>
              </div>
              <img src="/screenshots/portal-maatregelen.png" alt="Maatregelen in Control One" class="w-full" loading="eager" data-lightbox />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 4 categories with more context -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">4 categorieën, 93 maatregelen</h2>
          <p class="mt-4 text-lg text-primary-900/75 leading-relaxed">De volledige set Annex A-maatregelen uit ISO 27001:2022 is ingedeeld in vier duidelijke thema's. Per maatregel leg je vast of deze van toepassing is, waarom (of waarom niet), en hoe je deze heeft geïmplementeerd.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
          {categories.map(cat => (
            <div class:list={['p-5 rounded-2xl border flex flex-col', cat.color]}>
              <p class="text-xs font-bold font-mono mb-3">{cat.label}</p>
              <p class="text-4xl font-bold mb-1">{cat.count}</p>
              <p class="text-sm font-semibold mb-2">{cat.name}</p>
              <p class="text-xs opacity-70 leading-relaxed">{cat.subtitle}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Inline control list mockup -->
    <section class="py-20 bg-primary-50/30">
      <div class="max-w-5xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-10">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Per maatregel</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Status, eigenaar en bewijs op één plek</h2>
          <p class="mt-4 text-lg text-primary-900/75">Elke maatregel is een eigen werkpagina waarop je de implementatiestatus, onderbouwing en gekoppelde documenten bijhoudt.</p>
        </div>
        <div class="rounded-2xl overflow-hidden border border-primary-100 bg-white shadow-lg shadow-primary-100/40">
          <div class="flex items-center justify-between px-5 py-3 bg-primary-50 border-b border-primary-100">
            <p class="text-xs font-semibold text-primary-700">A5 — Organisatorisch · 37 maatregelen</p>
            <span class="text-[10px] font-semibold text-primary-400">Voorbeeld</span>
          </div>
          <div class="divide-y divide-primary-100">
            {exampleControls.map(c => (
              <div class="flex items-center gap-4 px-5 py-3.5 hover:bg-primary-50/40 transition-colors">
                <span class="text-[11px] font-bold font-mono text-primary-500 w-14 shrink-0">{c.ref}</span>
                <p class="flex-1 text-sm font-medium text-primary-900 truncate" set:html={c.name}></p>
                <span class:list={['text-[10px] font-semibold px-2 py-0.5 rounded border', statusColor[c.status]]}>{statusLabel[c.status]}</span>
                <svg class="w-4 h-4 text-primary-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Concreet voorbeeld: A5.15 -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-blue-600 mb-3">Voorbeeld</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Eén control van dichtbij</h2>
          <p class="mt-4 text-lg text-primary-900/75">Dit is hoe één Annex A-maatregel eruit ziet in de portal: status, eigenaar, onderbouwing, gekoppelde documenten én de risico's die deze control afdekt.</p>
        </div>

        <div class="max-w-5xl mx-auto rounded-2xl overflow-hidden border border-primary-100 bg-white shadow-2xl shadow-primary-100/40">
          <!-- Header -->
          <div class="px-6 py-5 bg-gradient-to-r from-blue-50 to-primary-50/40 border-b border-primary-100 flex items-start justify-between gap-4 flex-wrap">
            <div class="flex items-center gap-4">
              <div class="px-3 py-2 rounded-xl bg-white border border-blue-100 font-mono">
                <p class="text-[10px] font-bold uppercase tracking-widest text-blue-600">Control</p>
                <p class="text-base font-bold text-primary-950">{sampleControl.ref}</p>
              </div>
              <div>
                <h3 class="text-lg font-bold text-primary-950">{sampleControl.name}</h3>
                <p class="text-xs text-primary-500 mt-0.5">{sampleControl.norm} · {sampleControl.category}</p>
              </div>
            </div>
            <div class="flex flex-col gap-1.5 items-end">
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200">
                <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                {sampleControl.status}
              </span>
              <span class="text-[10px] text-primary-500">VvT: van toepassing</span>
            </div>
          </div>

          <!-- Meta grid -->
          <div class="grid sm:grid-cols-3 gap-0 border-b border-primary-100 divide-y sm:divide-y-0 sm:divide-x divide-primary-100">
            <div class="px-6 py-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500 mb-1">Eigenaar</p>
              <p class="text-sm font-semibold text-primary-950">{sampleControl.owner.name}</p>
              <p class="text-xs text-primary-500">{sampleControl.owner.role}</p>
            </div>
            <div class="px-6 py-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500 mb-1">Laatst beoordeeld</p>
              <p class="text-sm font-semibold text-primary-950">{sampleControl.reviewedAt}</p>
              <p class="text-xs text-primary-500">Volgende: 12-03-2027</p>
            </div>
            <div class="px-6 py-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500 mb-1">In VvT</p>
              <p class="text-sm font-semibold text-primary-950">Inbegrepen</p>
              <p class="text-xs text-primary-500">Niet uitgesloten</p>
            </div>
          </div>

          <!-- Onderbouwing -->
          <div class="px-6 py-5 border-b border-primary-100">
            <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500 mb-2">Onderbouwing &amp; implementatie</p>
            <p class="text-sm text-primary-900/75 leading-relaxed">{sampleControl.rationale}</p>
          </div>

          <!-- Linked docs + risks -->
          <div class="grid lg:grid-cols-2 gap-0 divide-y lg:divide-y-0 lg:divide-x divide-primary-100">
            <div class="px-6 py-5">
              <div class="flex items-center justify-between mb-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500">Gekoppelde documenten</p>
                <span class="text-[10px] font-bold text-blue-700 bg-blue-50 border border-blue-100 px-2 py-0.5 rounded-full">{sampleControl.documents.length}</span>
              </div>
              <ul class="space-y-2">
                {sampleControl.documents.map(d => (
                  <li class="flex items-center gap-3 p-2.5 rounded-lg bg-primary-50/40 border border-primary-100">
                    <svg class="w-4 h-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-semibold text-primary-900 truncate">{d.name}</p>
                      <p class="text-[10px] text-primary-500">{d.type} · {d.clause}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
            <div class="px-6 py-5 bg-red-50/30">
              <div class="flex items-center justify-between mb-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-red-700">Afgedekte risico's</p>
                <span class="text-[10px] font-bold text-red-700 bg-white border border-red-200 px-2 py-0.5 rounded-full">{sampleControl.linkedRisks.length}</span>
              </div>
              <ul class="space-y-2">
                {sampleControl.linkedRisks.map(r => (
                  <li class="flex items-center gap-3 p-2.5 rounded-lg bg-white border border-red-100">
                    <span class:list={['inline-flex items-center justify-center w-9 h-7 rounded-md text-xs font-bold shrink-0', r.score >= 15 ? 'bg-red-100 text-red-800' : 'bg-amber-100 text-amber-800']}>{r.score}</span>
                    <div class="flex-1 min-w-0">
                      <p class="text-[10px] font-mono font-bold text-red-700">{r.id}</p>
                      <p class="text-xs text-primary-900/85 truncate">{r.title}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Status flow visualisatie -->
    <section class="py-20 bg-primary-50/40">
      <div class="max-w-5xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-10">
          <p class="text-sm font-semibold tracking-wide uppercase text-blue-600 mb-3">Implementatiestatus</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Vier statussen per control</h2>
          <p class="mt-4 text-lg text-primary-900/75">Iedere maatregel doorloopt dezelfde transparante levenscyclus — geen twijfel over waar je staat.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {controlStatuses.map(s => (
            <div class:list={['p-5 rounded-2xl border', s.color]}>
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-current opacity-70"></span>
                <h3 class="text-sm font-bold">{s.label}</h3>
              </div>
              <p class="text-xs leading-relaxed opacity-80">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Feature grid -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Maatregelen in de praktijk</h2>
          <p class="mt-4 text-lg text-primary-900/75">Geen losse checklists — elke maatregel is geïntegreerd met risico's, documenten, audits en de VvT.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {[
            { title: 'Uitleg per control', desc: 'Voor elke maatregel een korte toelichting: wat vraagt de norm, waarom en hoe toon je het aan?' },
            { title: 'Status & eigenaar', desc: 'Per maatregel leg je vast of deze van toepassing is, de implementatiestatus, wie verantwoordelijk is en wanneer de laatste review was.' },
            { title: 'Onderbouwing vastleggen', desc: 'Schrijf per control in de portal je motivatie en hoe je de maatregel heeft geïmplementeerd. Deze tekst is direct zichtbaar in je VvT-overzicht.' },
            { title: 'Direct gekoppeld aan documenten', desc: 'Policies, procedures en bewijsstukken zijn direct te koppelen aan een maatregel — één klik tussen beheersmaatregel en documentbeheer.' },
            { title: 'Gekoppeld aan risicoanalyse', desc: 'Risico\'s verwijzen naar de maatregelen die ze afdekken — je ziet per risico welke controls actief zijn.' },
            { title: 'Interactieve VvT-tabel', desc: 'De Verklaring van Toepasselijkheid is geen apart bestand: hij deelt dezelfde data als je maatregelenregister en is direct als PDF te exporteren.' },
            { title: 'Filter op chapter', desc: 'Spring met één klik tussen A5, A6, A7 en A8. Binnen elk hoofdstuk zijn alle sub-controls meteen zichtbaar.' },
            { title: 'Kennisbankartikelen per maatregel', desc: 'Elke maatregel heeft een bijbehorend kennisbankartikel met praktische uitleg — 93 artikelen in totaal.' },
            { title: 'Auditklaar', desc: 'Tijdens een audit krijgt de auditor één centraal overzicht met status, onderbouwing en bewijs per control.' },
          ].map(f => (
            <div class="p-6 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h3 class="text-sm font-bold text-primary-950 mb-2">{f.title}</h3>
              <p class="text-sm text-primary-900/75 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
        <div class="mt-12 max-w-3xl mx-auto p-6 rounded-2xl bg-primary-50 border border-primary-100 flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-primary-600 flex items-center justify-center text-white shrink-0">
