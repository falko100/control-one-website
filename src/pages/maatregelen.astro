---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const categories = [
  { label: 'A.5', name: 'Organisatorisch', count: 37, color: 'bg-blue-50 text-blue-700 border-blue-100' },
  { label: 'A.6', name: 'Mensen', count: 8, color: 'bg-emerald-50 text-emerald-700 border-emerald-100' },
  { label: 'A.7', name: 'Fysiek', count: 14, color: 'bg-orange-50 text-orange-700 border-orange-100' },
  { label: 'A.8', name: 'Technologisch', count: 34, color: 'bg-violet-50 text-violet-700 border-violet-100' },
];
---

<Layout title="Maatregelen: Annex A ISO 27001 - Control One">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-blue-400 bg-blue-400/10 rounded-full border border-blue-400/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            Annex A Maatregelen
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Alle 93 maatregelen<br/><span class="text-blue-400">overzichtelijk beheerd</span>
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-xl leading-relaxed">
            Control One geeft u een volledig overzicht van alle ISO 27001:2022 Annex A beheersmaatregelen. Documenteer per maatregel de implementatiestatus, verantwoordelijke en bewijs, direct gekoppeld aan uw Verklaring van Toepasselijkheid.
          </p>
          <div class="mt-8 flex gap-4">
            <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
              Gratis uitproberen
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/iso-27001#annex-a" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Bekijk alle maatregelen</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Screenshot -->
    <section class="py-0 bg-white">
      <div class="max-w-5xl mx-auto px-6 -mt-8">
        <div class="rounded-2xl overflow-hidden border border-primary-100 shadow-2xl shadow-primary-200/30">
          <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
            <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
            <div class="flex-1 max-w-[220px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center">app.control-one.nl/maatregelen</div></div>
          </div>
          <img src="/screenshots/portal-maatregelen.png" alt="Maatregelen in Control One" class="w-full" />
        </div>
      </div>
    </section>

    <!-- 4 categories -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">4 categorieën, 93 maatregelen</h2>
          <p class="mt-4 text-lg text-primary-900/55 leading-relaxed">Per maatregel legt u vast of deze van toepassing is, waarom (of waarom niet), en hoe u deze heeft geïmplementeerd.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-4xl mx-auto">
          {categories.map(cat => (
            <div class:list={['p-6 rounded-2xl border text-center', cat.color]}>
              <p class="text-xs font-bold font-mono mb-3">{cat.label}</p>
              <p class="text-4xl font-bold mb-2">{cat.count}</p>
              <p class="text-sm font-semibold">{cat.name}</p>
            </div>
          ))}
        </div>
        <div class="mt-12 max-w-3xl mx-auto p-6 rounded-2xl bg-primary-50 border border-primary-100 flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-primary-600 flex items-center justify-center text-white shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary-950 mb-1">Automatisch gekoppeld aan de VvT</h3>
            <p class="text-sm text-primary-900/60 leading-relaxed">Elke maatregel is direct gekoppeld aan uw Verklaring van Toepasselijkheid. Pas de status aan en de VvT wordt automatisch bijgewerkt.</p>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
