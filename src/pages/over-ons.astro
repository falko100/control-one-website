---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const values = [
  {
    title: 'Toegankelijkheid',
    description: 'ISO hoeft geen specialistenvak te zijn. We zorgen dat elke medewerker, van directeur tot kwaliteitscoördinator, begrijpt wat er van hen verwacht wordt.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path></svg>`,
  },
  {
    title: 'Zelf de regie',
    description: 'We geloven dat organisaties ISO zelf kunnen beheren. Onze coach, sjablonen en kennisbank geven je alle tools in handen, zonder afhankelijk te zijn van dure externe consultants.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"></path></svg>`,
  },
  {
    title: 'Betrouwbaarheid',
    description: 'We vragen onze klanten hun gevoelige compliancedata aan ons toe te vertrouwen. Die verantwoordelijkheid nemen we serieus, met encryptie, rolgebaseerde toegang en regelmatige beveiligingsaudits.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path></svg>`,
  },
  {
    title: 'Continue verbetering',
    description: 'We leven naar wat we prediken. Net als de PDCA-cyclus die centraal staat in ISO, verbeteren wij ons platform continu op basis van gebruikersfeedback en normwijzigingen.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"></path></svg>`,
  },
];

const features_highlights = [
  { label: 'ISO 27001', description: 'Informatiebeveiliging (ISMS)' },
  { label: 'ISO 9001', description: 'Kwaliteitsmanagement (QMS)' },
  { label: 'ISO 14001', description: 'Milieumanagement (EMS)' },
  { label: 'ISO 45001', description: 'Arbo & Veiligheid (OHSMS)' },
];
---

<Layout title="Over Control One — Het team achter de ISO-software" description="Leer het team achter Control One kennen. Gebouwd in Enschede met de missie om ISO-compliance toegankelijk te maken voor elke organisatie in Nederland.">
  <Header />
  <main>

    <!-- Hero -->
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>
      <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-primary-400/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-accent-400 bg-white/10 rounded-full">
            <span class="w-1.5 h-1.5 bg-accent-400 rounded-full"></span>
            Over Control One
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            ISO compliance<br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-primary-300">die iedereen begrijpt</span>
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-2xl mx-auto leading-relaxed">
            We bouwen het platform dat we zelf hadden willen hebben: een tool waarmee élke organisatie, ongeacht ISO-kennis, zelf haar certificeringstraject kan doorlopen.
          </p>
        </div>
      </div>
    </section>

    <!-- Missie -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Onze missie</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight mb-6">
              ISO zonder consultant. Zonder chaos.
            </h2>
            <div class="text-primary-900/60 leading-relaxed space-y-4 text-base">
              <p>
                ISO-certificering is voor veel organisaties een groeiende noodzaak: klanten vragen ernaar, aanbestedingen eisen het, en de risico's worden groter. Maar het traject staat bekend als complex, tijdrovend en duur.
              </p>
              <p>
                Dat hoeft niet zo te zijn. Control One is gebouwd vanuit de overtuiging dat een goede structuur, duidelijke begeleiding en de juiste tools meer waard zijn dan een externe consultant. Met onze implementatiecoach, kant-en-klare sjablonen, kennisbank en geïntegreerde tools doe je het gewoon zelf, op je eigen tempo.
              </p>
              <p>
                Van risicoanalyse tot Verklaring van Toepasselijkheid, van interne audit tot leveranciersbeoordeling: alles zit in één platform, logisch geordend langs de PDCA-cyclus.
              </p>
            </div>
          </div>

          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div class="p-6 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100 text-center">
                <div class="text-4xl font-bold text-primary-700 mb-1">2012</div>
                <div class="text-sm text-primary-900/50 leading-snug">Opgericht in Enschede</div>
              </div>
              <div class="p-6 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100 text-center">
                <div class="text-4xl font-bold text-primary-700 mb-1">4</div>
                <div class="text-sm text-primary-900/50 leading-snug">ISO-frameworks ondersteund</div>
              </div>
              <div class="p-6 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100 text-center">
                <div class="text-4xl font-bold text-primary-700 mb-1">100%</div>
                <div class="text-sm text-primary-900/50 leading-snug">Nederlands & AVG-compliant</div>
              </div>
              <div class="p-6 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100 text-center">
                <div class="text-4xl font-bold text-primary-700 mb-1">NL</div>
                <div class="text-sm text-primary-900/50 leading-snug">EU-hosting, geen Amerikaanse cloud</div>
              </div>
            </div>

            <!-- Frameworks -->
            <div class="p-6 rounded-2xl border border-primary-100 bg-primary-50/40">
              <p class="text-xs font-semibold uppercase tracking-wide text-primary-500 mb-4">Ondersteunde frameworks</p>
              <div class="space-y-3">
                {features_highlights.map(f => (
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
                      <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                      <span class="text-sm font-semibold text-primary-950">{f.label}</span>
                      <span class="text-sm text-primary-900/50">: {f.description}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Kantoor foto gallery -->
    <section class="py-0 bg-white overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 pb-16">
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
          <!-- Large main photo spanning 2 rows -->
          <div class="row-span-2 rounded-2xl overflow-hidden" style="min-height: 400px;">
            <img src="/team/office-1.webp" alt="Team Control One samenwerkt" class="w-full h-full object-cover" style="min-height: 400px;" />
          </div>
          <!-- Top right -->
          <div class="rounded-2xl overflow-hidden">
            <img src="/team/office-2.webp" alt="Ontwikkelaar Control One" class="w-full h-full object-cover" style="height: 196px;" />
          </div>
          <!-- Middle right -->
          <div class="rounded-2xl overflow-hidden hidden lg:block">
            <img src="/team/office-3.webp" alt="Team aan het werk" class="w-full h-full object-cover" style="height: 196px;" />
          </div>
          <!-- Bottom spanning - meeting photo with text overlay -->
          <div class="relative rounded-2xl overflow-hidden col-span-1 lg:col-span-2">
            <img src="/team/office-4.webp" alt="Overleg Control One" class="w-full object-cover" style="height: 196px;" />
            <div class="absolute inset-0 bg-gradient-to-r from-primary-950/80 via-primary-950/40 to-transparent"></div>
            <div class="absolute inset-0 flex items-center px-7">
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-accent-400 mb-1">Ons kantoor</p>
                <h2 class="text-lg sm:text-xl font-bold text-white leading-snug">Gebouwd in Twente,<br/>innovatie voor heel Nederland</h2>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team portretfoto's -->
    <section id="team" class="py-24 bg-gradient-to-b from-primary-50/30 to-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">De mensen achter Control One</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Maak kennis met ons team
          </h2>
          <p class="mt-4 text-lg text-primary-900/60">
            Een hecht team van developers, designers en ISO-specialisten, allemaal vanuit Enschede.
          </p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
          {[
            { src: '/team/portrait-1.webp', quote: 'ISO 27001 klinkt zwaar, maar het is gewoon heel veel gezond verstand op papier.' },
            { src: '/team/portrait-2.webp', quote: 'Als iemand na 28 stappen voor het eerst zijn certificaat haalt, weet ik weer precies waarom ik dit doe.' },
            { src: '/team/portrait-3.webp', quote: 'We bouwen geen software. We bouwen het zelfvertrouwen om ISO zelf aan te kunnen.' },
            { src: '/team/portrait-4.webp', quote: 'Een risicomatrix hoeft niet eng te zijn. Gewoon nadenken over wat er mis kan gaan, zodat het dat niet doet.' },
            { src: '/team/portrait-5.webp', quote: 'De VvT is het hart van je ISMS. Als dat klopt, klopt alles.' },
            { src: '/team/portrait-6.webp', quote: 'Code, koffie en compliance. Mijn dagelijkse routine, en ik zou het voor niets willen ruilen.' },
            { src: '/team/portrait-7.webp', quote: 'Wij lachen hier veel. Tussendoor bouwen we dan ook nog de beste ISO-software van Nederland.' },
            { src: '/team/portrait-8.webp', quote: 'Elk feature dat wij bouwen is één reden minder voor een dure externe consultant.' },
            { src: '/team/portrait-9.webp', quote: 'ISO zonder structuur is als navigeren zonder GPS. Wij zijn de GPS.' },
        { src: '/team/portrait-10.webp', quote: 'Complexe regelgeving hoeft niet complex te voelen. Dat is precies waar wij voor bouwen.' },
          ].map((member) => (
            <div class="group relative rounded-2xl overflow-hidden shadow-md hover:shadow-2xl hover:-translate-y-1.5 transition-all duration-300 cursor-default">
              <img
                src={member.src}
                alt="Teamlid Control One"
                class="w-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                style="aspect-ratio: 2/3;"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary-950 via-primary-900/80 to-primary-800/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4 sm:p-5">
                <svg class="w-6 h-6 text-accent-400/80 mb-2 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                <p class="text-white/95 text-xs sm:text-sm leading-relaxed font-medium translate-y-2 group-hover:translate-y-0 transition-transform duration-300 delay-75">
                  {member.quote}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Onze missie -->
    <section class="py-24 overflow-hidden relative" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%)">
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/3 -left-32 w-[500px] h-[500px] bg-accent-400/5 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-primary-800/30 rounded-full blur-[80px]"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-6">
        <!-- Header -->
        <div class="max-w-3xl mx-auto text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-accent-400 bg-accent-400/10 rounded-full border border-accent-400/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Onze missie
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight">
            Onze Twentse<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-blue-300">Motivatie</span>
          </h2>
          <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
            Wij bouwen compliance-software die slim, modern en eerlijk is. Toegankelijk voor iedere organisatie in Nederland, zonder consultants, zonder obstakels, zonder onnodige complexiteit.
          </p>
        </div>

        <!-- 8 values grid -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-14">
          <!-- Jong -->
          <div class="group p-6 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/[0.15] hover:border-white/35 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-yellow-400/15 flex items-center justify-center mb-4 group-hover:bg-yellow-400/25 transition-colors">
              <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            </div>
            <h3 class="text-base font-bold text-white mb-1.5">Jong</h3>
            <p class="text-sm text-white/65 leading-relaxed">Fris, energiek en zonder ballast. We denken buiten de kaders en omarmen nieuwe ideeën.</p>
          </div>

          <!-- Aantrekkelijk -->
          <div class="group p-6 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/[0.15] hover:border-white/35 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-pink-400/15 flex items-center justify-center mb-4 group-hover:bg-pink-400/25 transition-colors">
              <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="text-base font-bold text-white mb-1.5">Aantrekkelijk</h3>
            <p class="text-sm text-white/65 leading-relaxed">Design is geen bijzaak. Een mooi product dat prettig werkt maakt het verschil bij dagelijks gebruik.</p>
          </div>

          <!-- Makkelijk toegankelijk -->
          <div class="group p-6 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/[0.15] hover:border-white/35 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-green-400/15 flex items-center justify-center mb-4 group-hover:bg-green-400/25 transition-colors">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 10.5V6.75a4.5 4.5 0 119 0v3.75M3.75 21.75h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
            </div>
            <h3 class="text-base font-bold text-white mb-1.5">Makkelijk toegankelijk</h3>
            <p class="text-sm text-white/65 leading-relaxed">Geen consultants, geen drempel. Iedereen kan starten, van startup tot gevestigde onderneming.</p>
          </div>

          <!-- Innovatie -->
          <div class="group p-6 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/[0.15] hover:border-white/35 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-purple-400/15 flex items-center justify-center mb-4 group-hover:bg-purple-400/25 transition-colors">
              <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
            </div>
            <h3 class="text-base font-bold text-white mb-1.5">Innovatie</h3>
            <p class="text-sm text-white/65 leading-relaxed">We bouwen wat er nog niet is. Altijd op zoek naar slimmere oplossingen voor complexe compliance-vraagstukken.</p>
          </div>

          <!-- Nederlands -->
          <div class="group p-6 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/[0.15] hover:border-white/35 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-orange-400/15 flex items-center justify-center mb-4 group-hover:bg-orange-400/25 transition-colors">
              <svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            </div>
            <h3 class="text-base font-bold text-white mb-1.5">Nederlands</h3>
            <p class="text-sm text-white/65 leading-relaxed">Gebouwd in Twente, voor Nederland. Onze taal, onze normen, onze klanten. Thuis op de Nederlandse markt.</p>
          </div>

          <!-- Professioneel -->
          <div class="group p-6 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/[0.15] hover:border-white/35 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-blue-400/15 flex items-center justify-center mb-4 group-hover:bg-blue-400/25 transition-colors">
              <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            </div>
            <h3 class="text-base font-bold text-white mb-1.5">Professioneel</h3>
            <p class="text-sm text-white/65 leading-relaxed">Enterprise kwaliteit voor elk bedrijf. Geen compromissen op betrouwbaarheid, veiligheid of correctheid.</p>
          </div>

          <!-- Fris -->
          <div class="group p-6 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/[0.15] hover:border-white/35 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-teal-400/15 flex items-center justify-center mb-4 group-hover:bg-teal-400/25 transition-colors">
