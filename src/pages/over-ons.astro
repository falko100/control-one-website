---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const values = [
  {
    title: 'Transparantie',
    description: 'We zijn open over wat we doen, hoe we het doen en waarom. Van onze roadmap tot onze beveiligingsmaatregelen.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>`,
  },
  {
    title: 'Eenvoud',
    description: 'Compliance hoeft niet complex te zijn. We maken het begrijpelijk en toegankelijk voor elke organisatie.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"></path></svg>`,
  },
  {
    title: 'Betrouwbaarheid',
    description: 'Onze klanten vertrouwen ons met gevoelige gegevens. Die verantwoordelijkheid nemen we zeer serieus.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path></svg>`,
  },
  {
    title: 'Continue verbetering',
    description: 'Net als de frameworks die we ondersteunen, streven we continu naar verbetering van ons product en onze dienstverlening.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"></path></svg>`,
  },
];
---

<Layout title="Over ons — Control One">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-accent-400 bg-white/10 rounded-full">
            <span class="w-1.5 h-1.5 bg-accent-400 rounded-full"></span>
            Over ons
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Compliance moet
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-primary-300">eenvoudig</span> zijn
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-2xl mx-auto leading-relaxed">
            Control One is ontstaan vanuit de overtuiging dat ISO-compliance niet complex en duur hoeft te zijn. Wij bouwen het platform dat we zelf hadden willen hebben.
          </p>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Ons verhaal</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight mb-6">
              Geboren uit frustratie, gebouwd met passie
            </h2>
            <div class="text-primary-900/60 leading-relaxed space-y-4">
              <p>
                Als consultants zagen we keer op keer hetzelfde probleem: organisaties die worstelden met spreadsheets, verouderde documenten en eindeloze checklists om hun ISO-certificering te behalen en te behouden.
              </p>
              <p>
                Er moest een betere manier zijn. Daarom bouwden we Control One — een platform dat de complexiteit van compliance wegneemt en organisaties begeleidt van begin tot certificering.
              </p>
              <p>
                Ons team combineert diepgaande kennis van ISO-frameworks met moderne softwareontwikkeling. We begrijpen zowel de normvereisten als de dagelijkse praktijk van compliance managers.
              </p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-6">
            <div class="p-6 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100 text-center">
              <div class="text-4xl font-bold text-primary-700 mb-1">3</div>
              <div class="text-sm text-primary-900/50">Frameworks</div>
            </div>
            <div class="p-6 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100 text-center">
              <div class="text-4xl font-bold text-primary-700 mb-1">100%</div>
              <div class="text-sm text-primary-900/50">Normdekking</div>
            </div>
            <div class="p-6 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100 text-center">
              <div class="text-4xl font-bold text-primary-700 mb-1">EU</div>
              <div class="text-sm text-primary-900/50">Data-locatie</div>
            </div>
            <div class="p-6 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100 text-center">
              <div class="text-4xl font-bold text-primary-700 mb-1">NL</div>
              <div class="text-sm text-primary-900/50">Nederlands bedrijf</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-b from-primary-50/50 to-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Onze waarden</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Waar we voor staan
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {values.map(v => (
            <div class="p-6 rounded-2xl border border-primary-100 bg-white hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-12 h-12 rounded-xl bg-primary-50 text-primary-600 flex items-center justify-center mb-4">
                <Fragment set:html={v.icon} />
              </div>
              <h3 class="text-lg font-semibold text-primary-950 mb-2">{v.title}</h3>
              <p class="text-sm text-primary-900/60 leading-relaxed">{v.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
