---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import DemoCta from '../components/DemoCta.astro';
import Footer from '../components/Footer.astro';

const exampleVendors = [
  { name: 'AWS Cloud Services', cls: 'Hoog', iso: 'Ja', date: '8 okt 2025', clsColor: 'bg-red-50 text-red-700 border-red-100', isoColor: 'bg-emerald-50 text-emerald-700 border-emerald-100' },
  { name: 'Microsoft Azure', cls: 'Hoog', iso: 'Ja', date: '16 apr 2026', clsColor: 'bg-red-50 text-red-700 border-red-100', isoColor: 'bg-emerald-50 text-emerald-700 border-emerald-100' },
  { name: 'Salesforce NL B.V.', cls: 'Gemiddeld', iso: 'Ja', date: '16 apr 2026', clsColor: 'bg-amber-50 text-amber-700 border-amber-100', isoColor: 'bg-emerald-50 text-emerald-700 border-emerald-100' },
  { name: 'Fortinet Nederland', cls: 'Hoog', iso: 'Nee', date: '20 nov 2025', clsColor: 'bg-red-50 text-red-700 border-red-100', isoColor: 'bg-rose-50 text-rose-700 border-rose-100' },
  { name: 'KPN Business', cls: 'Gemiddeld', iso: 'Ja', date: '10 feb 2026', clsColor: 'bg-amber-50 text-amber-700 border-amber-100', isoColor: 'bg-emerald-50 text-emerald-700 border-emerald-100' },
  { name: 'AFAS Software', cls: 'Hoog', iso: 'Ja', date: '15 jan 2026', clsColor: 'bg-red-50 text-red-700 border-red-100', isoColor: 'bg-emerald-50 text-emerald-700 border-emerald-100' },
  { name: 'Alles Schoon BV', cls: 'Gemiddeld', iso: 'Onbekend', date: '13 apr 2026', clsColor: 'bg-amber-50 text-amber-700 border-amber-100', isoColor: 'bg-primary-50 text-primary-500 border-primary-100' },
];

// Concrete leverancier detail-card
const sampleVendor = {
  name: 'AWS Cloud Services',
  classification: 'Hoog',
  description: 'Cloud-infrastructuur voor productie- en testomgeving — IaaS, S3 storage, RDS databases, Lambda compute en CloudFront CDN.',
  iso: 'Ja',
  isoExclusion: 'Nee',
  contact: { person: 'Sarah van der Heijden', phone: '+31 20 555 1234', email: 'enterprise@aws.com' },
  notes: 'Strategische leverancier — opname in disaster recovery plan en jaarlijkse penetratietest verplicht.',
  lastReview: '8 okt 2025',
  nextReview: '8 okt 2026',
  certificates: [
    { name: 'ISO 27001:2022', valid: '2027-04-15' },
    { name: 'ISO 27017 — Cloud security', valid: '2027-04-15' },
    { name: 'SOC 2 Type II', valid: '2026-12-31' },
  ],
  documents: [
    { name: 'Verwerkersovereenkomst AWS', type: 'Contract' },
    { name: 'AWS Shared Responsibility Model', type: 'Bewijs' },
    { name: 'Penetratietest rapport 2025', type: 'Audit' },
  ],
};

// Classificatie flow
const classificationLevels = [
  { level: 'Hoog', desc: 'Toegang tot productiedata, bedrijfskritische systemen of grote financiële impact bij uitval. Jaarlijkse formele beoordeling, recente certificering vereist.', color: 'bg-red-50 border-red-200', textColor: 'text-red-700', percentage: '15–25%' },
  { level: 'Gemiddeld', desc: 'Toegang tot interne systemen of beperkte persoonsgegevens. Tweejaarlijkse review, certificaat aanbevolen.', color: 'bg-amber-50 border-amber-200', textColor: 'text-amber-700', percentage: '40–55%' },
  { level: 'Laag', desc: 'Geen toegang tot gevoelige data, lage operationele afhankelijkheid. Driejaarlijkse spotcheck volstaat.', color: 'bg-emerald-50 border-emerald-200', textColor: 'text-emerald-700', percentage: '25–40%' },
];

// 3 tabs uit de portal
const vendorTabs = [
  { name: 'Beoordelingen', desc: 'Periodieke leveranciersbeoordeling met scoringsformulier — onderwerpen: prestaties, naleving SLA, security incidents, audits, financiële stabiliteit.', icon: 'star' },
  { name: 'Documenten', desc: 'Verwerkersovereenkomsten, NDAs, SLA\'s, audit rapporten en penetratietest-resultaten centraal opgeslagen, gekoppeld aan deze leverancier.', icon: 'doc' },
  { name: 'Certificates', desc: 'ISO 27001-, ISO 9001-, SOC 2- en branche-specifieke certificaten met geldigheidsdatum. Automatische reminder zes weken vóór verloop.', icon: 'cert' },
];
---

<Layout
  title="Leveranciersbeheer — Leveranciersrisico's beheren | Control One"
  description="Beheer leveranciers en hun risico's met Control One. Classificeer op risiconiveau, volg ISO-certificering, plan beoordelingen en koppel maatregelen A5.19–5.23."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
      { '@type': 'ListItem', position: 2, name: 'Portal', item: 'https://control-one.nl/features' },
      { '@type': 'ListItem', position: 3, name: 'Leveranciers', item: 'https://control-one.nl/leveranciers' },
    ],
  }}
>
  <Header />
  <main>
    <section class="relative pt-32 pb-20 lg:pb-28 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-cyan-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="lg:grid lg:grid-cols-[1fr_1.15fr] lg:gap-12 lg:items-center">
          <div class="max-w-xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-cyan-400 bg-cyan-400/10 rounded-full border border-cyan-400/20">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z"/></svg>
              Leveranciersbeheer
            </div>
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
              Leveranciersrisico's<br/><span class="text-cyan-400">inzichtelijk & beheersbaar</span>
            </h1>
            <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
              Een centraal leveranciersregister met risicoclassificatie, ISO-certificaatstatus, datum laatste beoordeling en automatische planning voor de volgende beoordeling. Volledig conform ISO 27001:2022 clausule 5.19 tot 5.23.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3 text-xs font-medium text-white/80">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-cyan-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Classificatie hoog / gem. / laag
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-cyan-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Review-cyclus per leverancier
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-cyan-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Annex A 5.19 – 5.23
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
                Gratis uitproberen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href="/features" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Alle features</a>
            </div>
          </div>

          <!-- Hero afbeelding rechts -->
          <div class="mt-12 lg:mt-0">
            <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40">
              <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
                <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
                <div class="flex-1 min-w-0 max-w-[240px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center truncate">app.control-one.nl/leveranciers</div></div>
              </div>
              <img src="/screenshots/portal-vendors.png" alt="Leveranciersbeheer in Control One" class="w-full" loading="eager" data-lightbox />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Dashboard stats + list -->
    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-3 gap-6 mb-10">
          <div class="p-5 rounded-2xl bg-gradient-to-b from-red-50 to-white border border-red-100">
            <p class="text-[10px] font-bold uppercase tracking-widest text-red-600">Classificatie</p>
            <div class="mt-2 flex items-baseline gap-2">
              <p class="text-3xl font-bold text-primary-950">9</p>
              <p class="text-sm text-primary-500">actieve leveranciers</p>
            </div>
            <div class="mt-3 flex gap-1 text-[10px] font-semibold">
              <span class="flex-1 text-center py-1 rounded bg-red-100 text-red-700">5 hoog</span>
              <span class="flex-1 text-center py-1 rounded bg-amber-100 text-amber-700">4 gem.</span>
              <span class="flex-1 text-center py-1 rounded bg-emerald-100 text-emerald-700">0 laag</span>
            </div>
          </div>
          <div class="p-5 rounded-2xl bg-gradient-to-b from-emerald-50 to-white border border-emerald-100">
            <p class="text-[10px] font-bold uppercase tracking-widest text-emerald-600">Beoordelingen up-to-date</p>
            <div class="mt-2 flex items-baseline gap-2">
              <p class="text-3xl font-bold text-primary-950">9</p>
              <p class="text-sm text-primary-500">/ 9 beoordeeld</p>
            </div>
            <div class="mt-3 h-1.5 rounded-full bg-primary-100 overflow-hidden">
              <div class="h-full bg-emerald-500 rounded-full" style="width: 100%"></div>
            </div>
            <p class="text-[10px] text-primary-400 mt-2">Alle beoordelingen up-to-date</p>
          </div>
          <div class="p-5 rounded-2xl bg-gradient-to-b from-blue-50 to-white border border-blue-100">
            <p class="text-[10px] font-bold uppercase tracking-widest text-blue-600">ISO-certificaat</p>
            <div class="mt-2 flex items-baseline gap-2">
              <p class="text-3xl font-bold text-primary-950">7</p>
              <p class="text-sm text-primary-500">/ 9 gecertificeerd</p>
            </div>
            <p class="text-[10px] text-primary-400 mt-2">1 niet gecertificeerd · 1 onbekend</p>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden border border-primary-100 bg-white shadow-lg shadow-primary-100/40">
          <div class="flex items-center gap-3 px-5 py-3 bg-primary-50 border-b border-primary-100 text-[10px] font-bold uppercase tracking-wide text-primary-500">
            <span class="w-48 sm:w-56 shrink-0">Leverancier</span>
            <span class="w-24 shrink-0">Classificatie</span>
            <span class="w-20 shrink-0 hidden sm:block">ISO</span>
            <span class="flex-1 text-right">Laatste beoordeling</span>
          </div>
          <div class="divide-y divide-primary-100">
            {exampleVendors.map(v => (
              <div class="flex items-center gap-3 px-5 py-3 hover:bg-primary-50/40 transition-colors">
                <p class="w-48 sm:w-56 shrink-0 text-sm font-semibold text-primary-900 truncate">{v.name}</p>
                <span class:list={['w-24 shrink-0 text-[10px] font-semibold px-2 py-0.5 rounded border text-center', v.clsColor]}>{v.cls}</span>
                <span class:list={['w-20 shrink-0 hidden sm:block text-[10px] font-semibold px-2 py-0.5 rounded border text-center', v.isoColor]}>{v.iso}</span>
                <span class="flex-1 text-right text-xs text-primary-500">{v.date}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Mid-page Demo CTA -->
    <DemoCta
      module="Leveranciers"
      title="Benieuwd hoe je leveranciers beheert in de portal?"
      description="Stap door een interactieve rondleiding en zie hoe je leveranciers classificeert, certificaten bewaakt en risico's per partner koppelt aan je managementsysteem."
      ctaText="Bekijk de live demo"
      urlPath="leveranciers / register"
      accentBg="bg-cyan-500"
      accentText="text-cyan-300"
      variant="leveranciers"
    />

    <!-- Concrete leverancier voorbeeld -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-cyan-600 mb-3">Voorbeeld</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Eén leverancier van dichtbij</h2>
          <p class="mt-4 text-lg text-primary-900/75">Per leverancier leg je alle relevante details vast: classificatie, contactgegevens, certificaten en gekoppelde documenten — auditklaar.</p>
        </div>

        <div class="max-w-5xl mx-auto rounded-2xl overflow-hidden border border-primary-100 bg-white shadow-2xl shadow-primary-100/40">
          <!-- Header -->
          <div class="px-6 py-5 bg-gradient-to-r from-cyan-50 to-primary-50/40 border-b border-primary-100 flex items-start justify-between gap-4 flex-wrap">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white border border-cyan-100 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/></svg>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-cyan-600 mb-1">Leverancier</p>
                <h3 class="text-lg font-bold text-primary-950">{sampleVendor.name}</h3>
              </div>
            </div>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-semibold bg-red-50 text-red-700 border border-red-200">
              <span class="w-2 h-2 rounded-full bg-red-500"></span>
              Classificatie: {sampleVendor.classification}
            </span>
          </div>

          <!-- Detail grid -->
          <div class="grid sm:grid-cols-2 gap-0 border-b border-primary-100 divide-y sm:divide-y-0 sm:divide-x divide-primary-100">
            <div class="px-6 py-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500 mb-1">Beschrijving</p>
              <p class="text-xs text-primary-900/75 leading-relaxed">{sampleVendor.description}</p>
            </div>
            <div class="px-6 py-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500 mb-2">Contactgegevens</p>
              <p class="text-sm font-semibold text-primary-950">{sampleVendor.contact.person}</p>
              <p class="text-xs text-primary-500 mt-0.5">{sampleVendor.contact.email} · {sampleVendor.contact.phone}</p>
            </div>
          </div>

          <div class="grid sm:grid-cols-3 gap-0 border-b border-primary-100 divide-y sm:divide-y-0 sm:divide-x divide-primary-100">
            <div class="px-6 py-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500 mb-1">ISO Certificaat</p>
              <p class="text-sm font-semibold text-emerald-700">{sampleVendor.iso}</p>
            </div>
            <div class="px-6 py-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500 mb-1">Uitzondering</p>
              <p class="text-sm font-semibold text-primary-950">{sampleVendor.isoExclusion}</p>
            </div>
            <div class="px-6 py-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-primary-500 mb-1">Volgende beoordeling</p>
              <p class="text-sm font-semibold text-primary-950">{sampleVendor.nextReview}</p>
            </div>
          </div>

          <!-- Certificates + Documents -->
          <div class="grid lg:grid-cols-2 gap-0 divide-y lg:divide-y-0 lg:divide-x divide-primary-100">
            <div class="px-6 py-5">
              <div class="flex items-center justify-between mb-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-emerald-700">Certificaten</p>
                <span class="text-[10px] font-bold text-emerald-700 bg-emerald-50 border border-emerald-100 px-2 py-0.5 rounded-full">{sampleVendor.certificates.length}</span>
              </div>
              <ul class="space-y-2.5">
                {sampleVendor.certificates.map(c => (
                  <li class="flex items-center gap-3 p-2.5 rounded-lg bg-emerald-50/40 border border-emerald-100">
                    <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-semibold text-primary-900 truncate">{c.name}</p>
                      <p class="text-[10px] text-primary-500">Geldig tot {c.valid}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
            <div class="px-6 py-5">
              <div class="flex items-center justify-between mb-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-cyan-700">Documenten</p>
                <span class="text-[10px] font-bold text-cyan-700 bg-cyan-50 border border-cyan-100 px-2 py-0.5 rounded-full">{sampleVendor.documents.length}</span>
              </div>
              <ul class="space-y-2.5">
                {sampleVendor.documents.map(d => (
                  <li class="flex items-center gap-3 p-2.5 rounded-lg bg-cyan-50/40 border border-cyan-100">
                    <svg class="w-4 h-4 text-cyan-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-semibold text-primary-900 truncate">{d.name}</p>
                      <p class="text-[10px] text-primary-500">{d.type}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="px-6 py-3.5 bg-primary-50/40 border-t border-primary-100">
            <p class="text-xs text-primary-900/65"><span class="font-semibold text-primary-700">Opmerkingen: </span>{sampleVendor.notes}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Classificatie flow -->
    <section class="py-24 bg-gradient-to-b from-primary-50/40 to-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-cyan-600 mb-3">Classificatie</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Drie risiconiveaus, één duidelijke methodiek</h2>
          <p class="mt-4 text-lg text-primary-900/75">Iedere leverancier krijgt een classificatie op basis van datatoegang, kritikaliteit en impact bij uitval. De portal stuurt de review-frequentie automatisch op basis daarvan.</p>
        </div>
        <div class="grid sm:grid-cols-3 gap-5">
          {classificationLevels.map(c => (
            <div class:list={['p-6 rounded-2xl border-2', c.color]}>
              <div class="flex items-center justify-between mb-3">
                <h3 class:list={['text-xl font-bold', c.textColor]}>{c.level}</h3>
                <span class:list={['text-[10px] font-bold uppercase tracking-widest', c.textColor, 'opacity-70']}>~{c.percentage}</span>
              </div>
              <p class="text-sm text-primary-900/70 leading-relaxed">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3 tabs structuur -->
    <section class="py-24 bg-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-cyan-600 mb-3">Per leverancier</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Drie tabs per leverancier</h2>
          <p class="mt-4 text-lg text-primary-900/75">Open een leverancier en je vindt alles op zijn plek: beoordelingsgeschiedenis, contractdocumenten en up-to-date certificaten.</p>
        </div>
        <div class="grid sm:grid-cols-3 gap-5">
          {vendorTabs.map(t => (
            <div class="p-6 rounded-2xl border border-cyan-100 bg-cyan-50/30 hover:bg-cyan-50/50 transition-colors">
              <div class="w-10 h-10 rounded-xl bg-white border border-cyan-200 flex items-center justify-center text-cyan-700 mb-4 shadow-sm">
                {t.icon === 'star' && <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>}
                {t.icon === 'doc' && <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>}
                {t.icon === 'cert' && <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>}
              </div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-cyan-700 mb-1">Tab</p>
              <h3 class="text-base font-bold text-primary-950 mb-2">{t.name}</h3>
              <p class="text-sm text-primary-900/65 leading-relaxed">{t.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-24 bg-primary-50/30">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Leveranciersketen zichtbaar en beheerst</h2>
          <p class="mt-4 text-lg text-primary-900/75">De portal herinnert je automatisch aan volgende beoordelingen en koppelt leveranciersrisico's direct aan je Annex A-maatregelen.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {[
            { title: 'Leveranciersregister', desc: 'Centraal overzicht met contactgegevens, contracten, subverwerkers en de laatste beoordelingsdatum per leverancier.' },
            { title: 'Risicoclassificatie hoog / gem. / laag', desc: 'Classificeer op basis van welke data de leverancier verwerkt, welke systemen hij beheert en de impact bij uitval.' },
            { title: 'ISO-certificering volgen', desc: 'Leg per leverancier vast of deze ISO 27001, SOC 2 of een andere certificering heeft — en bewaar de vervaldatum.' },
            { title: 'Automatische reviewcyclus', desc: 'Stel in dat hoog-risico leveranciers jaarlijks en gemiddeld-risico leveranciers tweejaarlijks herbeoordeeld worden. De portal herinnert je op tijd.' },
            { title: 'Trendgrafiek', desc: 'Zie hoe je leveranciersklasseverdeling zich ontwikkelt en monitor of je risicopositie stabiel blijft.' },
            { title: 'Open beoordelingen tracker', desc: 'Dashboard toont welke leveranciers nog beoordeeld moeten worden en welke deadline nadert.' },
            { title: 'Contractuele vereisten', desc: 'Leg vast welke informatiebeveiligings- of privacy-clausules in contracten zijn opgenomen, inclusief verwerkersovereenkomsten.' },
            { title: 'Gekoppeld aan Annex A 5.19–5.23', desc: 'Alle relevante beheersmaatregelen voor leveranciersrelaties, contracten, ICT-toeleveringsketen en clouddiensten zijn direct gekoppeld.' },
            { title: 'Incidenten bij leveranciers', desc: 'Registreer incidenten die te herleiden zijn tot een leverancier, koppel CPAR\'s en voer verbetering door.' },
          ].map(f => (
            <div class="p-6 rounded-2xl border border-primary-100 bg-white hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-8 h-8 rounded-lg bg-cyan-50 flex items-center justify-center text-cyan-600 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h3 class="text-sm font-bold text-primary-950 mb-2">{f.title}</h3>
              <p class="text-sm text-primary-900/75 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>

        <!-- ISO callout -->
        <div class="mt-12 max-w-3xl mx-auto p-6 rounded-2xl bg-cyan-50 border border-cyan-100 flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-cyan-600 flex items-center justify-center text-white shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary-950 mb-1">Conform ISO 27001:2022 clausule 5.19 – 5.23</h3>
            <p class="text-sm text-primary-900/60 leading-relaxed">Het leveranciersbeheer dekt alle vereisten voor leveranciersrelaties (5.19), -overeenkomsten (5.20), de ICT-toeleveringsketen (5.21), monitoring en wijzigingsbeheer (5.22) en het gebruik van clouddiensten (5.23).</p>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
