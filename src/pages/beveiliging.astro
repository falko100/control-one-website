---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const measures = [
  {
    title: 'Encryptie',
    description: 'Alle data wordt versleuteld in rust (AES-256) en in transit (TLS 1.3). Uw compliance-gegevens zijn altijd beschermd.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"></path></svg>`,
  },
  {
    title: 'Toegangscontrole',
    description: 'Rolgebaseerde toegangscontrole (RBAC) zorgt ervoor dat gebruikers alleen zien wat bij hun rol past. SSO/SAML beschikbaar voor Enterprise.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"></path></svg>`,
  },
  {
    title: 'Beschikbaarheid',
    description: 'Gehost op betrouwbare Europese infrastructuur met 99.9% uptime SLA. Dagelijkse back-ups en disaster recovery procedures.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"></path></svg>`,
  },
  {
    title: 'Beveiligingsaudits',
    description: 'Regelmatige penetratietests en beveiligingsaudits door onafhankelijke partijen. Wij doen wat we prediken.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path></svg>`,
  },
  {
    title: 'Data-locatie',
    description: 'Uw data wordt opgeslagen in de Europese Unie en verlaat nooit de EU. Volledig AVG-conform.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.893 13.393l-1.135-1.135a2.252 2.252 0 01-.421-.585l-1.08-2.16a.414.414 0 00-.663-.107.827.827 0 01-.812.21l-1.273-.363a.89.89 0 00-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 01-1.81 1.025 1.055 1.055 0 01-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 01-1.383-2.46l.007-.042a2.25 2.25 0 01.29-.787l.09-.15a2.25 2.25 0 012.37-1.048l1.178.236a1.125 1.125 0 001.302-.795l.208-.73a1.125 1.125 0 00-.578-1.315l-.665-.332-.091.091a2.25 2.25 0 01-1.591.659h-.18c-.249 0-.487.1-.662.274a.931.931 0 01-1.458-1.137l1.411-2.353a2.25 2.25 0 00.286-.76m11.928 9.869A9 9 0 008.965 3.525m11.928 9.868A9 9 0 118.965 3.525"></path></svg>`,
  },
  {
    title: 'Incident Response',
    description: 'Gedocumenteerd incident response plan met duidelijke escalatieprocedures en communicatieprotocollen.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"></path></svg>`,
  },
];
---

<Layout title="Beveiliging: Control One">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-accent-400 bg-white/10 rounded-full">
            <span class="w-1.5 h-1.5 bg-accent-400 rounded-full"></span>
            Beveiliging
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Uw data is bij ons
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-primary-300">in veilige handen</span>
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-2xl mx-auto leading-relaxed">
            Wij nemen beveiliging serieus. Als ISO-compliance platform praktiseren we wat we prediken. Met encryptie, toegangscontrole en regelmatige audits.
          </p>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {measures.map(m => (
            <div class="p-6 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-12 h-12 rounded-xl bg-primary-50 text-primary-600 flex items-center justify-center mb-4">
                <Fragment set:html={m.icon} />
              </div>
              <h3 class="text-lg font-semibold text-primary-950 mb-2">{m.title}</h3>
              <p class="text-sm text-primary-900/60 leading-relaxed">{m.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-b from-primary-50/50 to-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="p-8 sm:p-12 rounded-3xl bg-white border border-primary-100 shadow-sm">
          <h2 class="text-2xl font-bold text-primary-950 mb-6">Onze beveiligingsbelofte</h2>
          <div class="space-y-4 text-primary-900/60 leading-relaxed">
            <p>Bij Control One begrijpen we dat u ons vertrouwt met gevoelige compliance-gegevens. Daarom hebben we beveiliging ingebouwd in elk aspect van ons platform.</p>
            <p>We ondergaan regelmatig onafhankelijke beveiligingsaudits en penetratietests. Onze infrastructuur is gehost in de EU op ISO 27001-gecertificeerde datacenters, en we volgen een strikt patch management beleid.</p>
            <p>Heeft u vragen over onze beveiligingsmaatregelen, of wilt u ons beveiligingsbeleid inzien? Neem gerust <a href="/contact" class="text-primary-600 hover:underline">contact</a> met ons op.</p>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
