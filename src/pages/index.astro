---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import InteractiveShowcase from '../components/InteractiveShowcase.astro';
import TemplatesBlock from '../components/TemplatesBlock.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import WhyControlOne from '../components/WhyControlOne.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Control One — ISO Compliance Software voor MKB | ISO 27001, 9001, 14001 & 45001" description="Control One is hét Nederlandse platform voor ISO-compliance. Implementeer ISO 27001, 9001, 14001 en 45001 zelf met onze stapsgewijze coach, sjablonen en tools. Gratis starten.">
  <Header />
  <main>
    <Hero />
    <InteractiveShowcase />
    <TemplatesBlock />
    <Features />
    <HowItWorks />
    <Testimonials />
    <WhyControlOne />
    <CTA />
  </main>
  <Footer />
</Layout>
