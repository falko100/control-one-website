---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Voeg 1 dag toe zodat posts op de publicatiedatum zelf altijd zichtbaar zijn (tijdzone-correctie)
const now = new Date(new Date().getTime() + 24 * 60 * 60 * 1000);
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.publishDate <= now);
const posts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Placeholder posts shown when no content collection posts exist for a category
const placeholderPosts = [
  {
    slug: null,
    title: 'ISO 27001:2022: Wat is er veranderd?',
    excerpt: 'De 2022-versie van ISO 27001 brengt belangrijke wijzigingen in Annex A. We leggen uit wat er veranderd is en wat het voor je organisatie betekent.',
    date: '15 februari 2026',
    category: 'ISO 27001',
    readTime: '5 min',
  },
  {
    slug: null,
    title: 'De complete gids voor risicobeoordeling',
    excerpt: 'Een risicobeoordeling is de kern van elk ISMS. Leer hoe je risico\'s identificeert, beoordeelt en behandelt met praktische voorbeelden.',
    date: '8 februari 2026',
    category: 'Risicobeheer',
    readTime: '8 min',
  },
  {
    slug: null,
    title: 'NIS2: wat Nederlandse bedrijven moeten weten',
    excerpt: 'De NIS2-richtlijn stelt nieuwe eisen aan cybersecurity. Valt je organisatie onder de richtlijn en wat moet je doen om compliant te worden?',
    date: '1 februari 2026',
    category: 'Wetgeving',
    readTime: '6 min',
  },
  {
    slug: null,
    title: '5 veelgemaakte fouten bij ISO-implementatie',
    excerpt: 'Van te veel documentatie tot gebrek aan managementbetrokkenheid: ontdek de vijf meest voorkomende fouten en hoe je ze vermijdt.',
    date: '25 januari 2026',
    category: 'Best practices',
    readTime: '4 min',
  },
  {
    slug: null,
    title: 'Interne audit: tips voor een effectieve aanpak',
    excerpt: 'Een interne audit is meer dan een checklist afvinken. Ontdek hoe je waardevolle inzichten haalt uit je auditprogramma.',
    date: '18 januari 2026',
    category: 'Audits',
    readTime: '7 min',
  },
  {
    slug: null,
    title: 'ISO 9001 en ISO 27001 combineren: zo doe je dat',
    excerpt: 'Veel organisaties implementeren meerdere ISO-normen. Leer hoe je overlap benut en dubbel werk voorkomt met een geïntegreerde aanpak.',
    date: '10 januari 2026',
    category: 'Multi-framework',
    readTime: '6 min',
  },
];

const realPosts = posts.map((post) => ({
  slug: post.slug,
  title: post.data.title,
  excerpt: post.data.description,
  date: post.data.publishDate.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' }),
  category: post.data.category,
  readTime: post.data.readTime,
}));

const displayPosts = realPosts.length > 0
  ? [...realPosts, ...placeholderPosts]
  : placeholderPosts;
---

<Layout
  title="Blog — ISO-compliance inzichten en best practices | Control One"
  description="Artikelen, gidsen en best practices over ISO 27001, ISO 9001, risicobeheer, interne audits en compliance. Blijf op de hoogte van de laatste ontwikkelingen."
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'Blog',
      name: 'Control One Blog',
      description: 'Artikelen, gidsen en best practices over ISO 27001, 9001, 14001, 45001 en compliance voor het MKB.',
      url: 'https://control-one.nl/blog',
      inLanguage: 'nl-NL',
      publisher: {
        '@type': 'Organization',
        name: 'Control One',
        logo: { '@type': 'ImageObject', url: 'https://control-one.nl/logo.svg' },
      },
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://control-one.nl/blog' },
      ],
    },
  ]}
>
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-accent-400 bg-white/10 rounded-full">
            <span class="w-1.5 h-1.5 bg-accent-400 rounded-full"></span>
            Blog
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Inzichten over
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-primary-300">compliance</span>
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-2xl mx-auto leading-relaxed">
            Artikelen, gidsen en best practices over ISO-compliance, informatiebeveiliging en kwaliteitsmanagement.
          </p>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid gap-8">
          {displayPosts.map((post, i) => (
            post.slug ? (
              <a
                href={`/blog/${post.slug}`}
                class:list={[
                  'group p-6 sm:p-8 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all block',
                  i === 0 && 'border-primary-200 shadow-md',
                ]}
              >
                <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-4">
                  <span class="inline-flex px-3 py-1 text-xs font-medium rounded-full bg-primary-50 text-primary-600 w-fit">
                    {post.category}
                  </span>
                  <div class="flex items-center gap-3 text-sm text-primary-900/40">
                    <span>{post.date}</span>
                    <span>·</span>
                    <span>{post.readTime} leestijd</span>
                  </div>
                </div>
                <h2 class="text-xl sm:text-2xl font-bold text-primary-950 mb-3 group-hover:text-primary-700 transition-colors">
                  {post.title}
                </h2>
                <p class="text-primary-900/60 leading-relaxed">{post.excerpt}</p>
                <div class="mt-4 flex items-center gap-1.5 text-sm font-medium text-primary-600 group-hover:text-primary-800 transition-colors">
                  Lees artikel
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </div>
              </a>
            ) : (
              <article class:list={[
                'group p-6 sm:p-8 rounded-2xl border border-primary-100 opacity-60',
              ]}>
                <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-4">
                  <span class="inline-flex px-3 py-1 text-xs font-medium rounded-full bg-primary-50 text-primary-600 w-fit">
                    {post.category}
                  </span>
                  <div class="flex items-center gap-3 text-sm text-primary-900/40">
                    <span>{post.date}</span>
                    <span>·</span>
                    <span>{post.readTime} leestijd</span>
                  </div>
                </div>
                <h2 class="text-xl sm:text-2xl font-bold text-primary-950 mb-3">
                  {post.title}
                </h2>
                <p class="text-primary-900/60 leading-relaxed">{post.excerpt}</p>
              </article>
            )
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
