---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const chapters = [
  { number: '4', title: 'Context van de organisatie', description: 'Begrijp de interne en externe factoren, belanghebbenden en het toepassingsgebied van uw EMS.' },
  { number: '5', title: 'Leiderschap', description: 'Zorg voor betrokkenheid van de directie, milieubeleid en organisatorische rollen.' },
  { number: '6', title: 'Planning', description: 'Identificeer milieuaspecten, compliance-verplichtingen, risico\'s en kansen.' },
  { number: '7', title: 'Ondersteuning', description: 'Beheer middelen, competenties, bewustzijn, communicatie en gedocumenteerde informatie.' },
  { number: '8', title: 'Uitvoering', description: 'Plan en beheers operationele processen, noodvoorbereiding en respons.' },
  { number: '9', title: 'Evaluatie van prestaties', description: 'Monitor milieuprestaties, voer interne audits uit en houd directiebeoordelingen.' },
  { number: '10', title: 'Verbetering', description: 'Pak afwijkingen aan, neem corrigerende maatregelen en streef naar continue milieuverbetering.' },
];

const benefits = [
  {
    title: 'Wettelijke compliance',
    description: 'Voldoe aantoonbaar aan milieuwetgeving en voorkom boetes en reputatieschade.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path></svg>`,
    gradient: 'from-emerald-500 to-green-600',
  },
  {
    title: 'Kostenbesparing',
    description: 'Verminder energie- en grondstofverbruik door systematisch milieubeheer.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"></path></svg>`,
    gradient: 'from-teal-500 to-cyan-600',
  },
  {
    title: 'Marktvoordeel',
    description: 'Versterk uw concurrentiepositie bij aanbestedingen en klanten die duurzaamheid eisen.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.023 6.023 0 01-7.54 0"></path></svg>`,
    gradient: 'from-lime-500 to-green-600',
  },
  {
    title: 'Duurzaamheid',
    description: 'Draag bij aan een beter milieu en communiceer uw inspanningen naar stakeholders.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 01-1.161.886l-.143.048a1.107 1.107 0 00-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 01-1.652.928l-.679-.906a1.125 1.125 0 00-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 00-8.862 12.872M12.75 3.031a9 9 0 016.69 14.036m0 0l-.177-.529A2.25 2.25 0 0017.128 15H16.5l-.324-.324a1.453 1.453 0 00-2.328.377l-.036.073a1.586 1.586 0 01-.982.816l-.99.282c-.55.157-.894.702-.8 1.267l.073.438a2.25 2.25 0 01-1.228 2.34l-.114.057a1.544 1.544 0 01-.765.071"></path></svg>`,
    gradient: 'from-green-500 to-emerald-600',
  },
];
---

<Layout title="ISO 14001 Milieumanagement — Control One">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-green-900 via-emerald-800 to-teal-900"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-green-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-teal-400/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-green-300 bg-white/10 rounded-full backdrop-blur-sm">
            <span class="w-1.5 h-1.5 bg-green-400 rounded-full"></span>
            Milieumanagement
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-[1.1]">
            ISO 14001
          </h1>
          <p class="mt-2 text-xl sm:text-2xl font-medium text-green-200">
            Environmental Management System
          </p>
          <p class="mt-6 text-lg text-green-300/80 max-w-2xl leading-relaxed">
            Implementeer een milieumanagementsysteem dat uw ecologische voetafdruk verkleint, kosten bespaart en compliance waarborgt — begeleid door Control One.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="/demo" class="inline-flex items-center px-6 py-3 text-base font-semibold text-green-900 bg-white hover:bg-green-50 rounded-lg transition-all shadow-lg">
              Start met ISO 14001
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </a>
            <a href="/features" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white/90 hover:text-white border border-white/20 hover:border-white/40 rounded-lg transition-all">
              Bekijk alle functies
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Voordelen</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Waarom ISO 14001 certificering?
          </h2>
          <p class="mt-4 text-lg text-primary-900/60">
            Een milieumanagementsysteem volgens ISO 14001 biedt concrete voordelen voor uw organisatie en het milieu.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {benefits.map(b => (
            <div class="group relative rounded-2xl overflow-hidden">
              <div class:list={['absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-300', b.gradient]}></div>
              <div class="relative p-6 rounded-2xl border border-primary-100 group-hover:border-transparent transition-colors bg-white group-hover:bg-transparent">
                <div class="w-12 h-12 rounded-xl bg-primary-50 group-hover:bg-white/20 text-primary-600 group-hover:text-white flex items-center justify-center mb-4 transition-colors">
                  <Fragment set:html={b.icon} />
                </div>
                <h3 class="font-semibold text-primary-950 group-hover:text-white mb-2 transition-colors">{b.title}</h3>
                <p class="text-sm text-primary-900/60 group-hover:text-white/80 leading-relaxed transition-colors">{b.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-b from-primary-50/50 to-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-16">
          <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Normstructuur</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Hoofdstukken 4–10
          </h2>
          <p class="mt-4 text-lg text-primary-900/60">
            Control One begeleidt u door elk hoofdstuk met voortgangsregistratie en directe koppeling naar uw documenten.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {chapters.map((ch, i) => (
            <div class:list={[
              'group relative p-6 rounded-2xl border bg-white hover:shadow-lg hover:shadow-primary-100/50 transition-all',
              i === 0 ? 'border-green-200 shadow-md' : 'border-primary-100',
            ]}>
              <div class:list={[
                'w-10 h-10 rounded-xl flex items-center justify-center font-bold text-sm mb-4',
                i === 0 ? 'bg-green-500 text-white' : 'bg-primary-50 text-primary-600',
              ]}>
                {ch.number}
              </div>
              <h3 class="font-semibold text-primary-950 mb-2">{ch.title}</h3>
              <p class="text-sm text-primary-900/50 leading-relaxed">{ch.description}</p>
            </div>
          ))}
          <div class="relative p-6 rounded-2xl bg-gradient-to-br from-green-600 to-teal-700 text-white overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
            <div class="relative">
              <div class="text-3xl font-bold mb-2">PDCA</div>
              <div class="text-green-200 text-sm font-medium mb-4">Continue verbetering</div>
              <p class="text-green-100/80 text-sm leading-relaxed">
                Alle hoofdstukken volgen de Plan-Do-Check-Act cyclus voor continue milieuverbetering.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
