---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const chapters = [
  {
    number: '4',
    title: 'Context van de organisatie',
    description: 'Analyseer je interne en externe context en identificeer milieuaspecten die impact hebben op je organisatie. Bepaal de scope van je EMS en leg vast welke partijen belang hebben bij je milieuprestaties.',
    vereist: 'Interne en externe omgevingsfactoren analyseren, milieuaspecten en -effecten identificeren, scope vaststellen en register van belanghebbenden opstellen.',
    documenten: ['Scope document', 'Milieucontextanalyse', 'Register van milieuaspecten', 'Register van belanghebbenden'],
    platform: 'Scopebepaling wizard, milieucontextanalyse template en automatisch gegenereerd scope document dat aansluit op auditorverwachtingen.',
  },
  {
    number: '5',
    title: 'Leiderschap',
    description: 'Toon managementbetrokkenheid via een helder milieubeleid en wijs rollen en verantwoordelijkheden toe. De directie draagt actief bij aan het behalen van milieudoelstellingen.',
    vereist: 'Milieubeleid vaststellen en communiceren, rollen en verantwoordelijkheden toewijzen, managementcommitment aantoonbaar maken.',
    documenten: ['Milieubeleid', 'Verantwoordelijkheidsmatrix', 'Organogram'],
    platform: 'Beleidsgenerator met goedkeuringsworkflow, verantwoordelijkheidsmatrix en rollenregister voor je EMS-team.',
  },
  {
    number: '6',
    title: 'Planning',
    description: 'Identificeer milieuaspecten en -effecten, beoordeel risico\'s en kansen en houd wettelijke verplichtingen bij. Stel meetbare milieudoelstellingen vast met concrete actieplannen.',
    vereist: 'Milieuaspecten en -effecten analyseren, wettelijke vereisten bijhouden, risico\'s en kansen beoordelen, milieudoelstellingen vaststellen met actieplan.',
    documenten: ['Milieuaspecten en -effectenanalyse', 'Wettelijke vereistenregister', 'Doelstellingenregister'],
    platform: 'Milieuaspectenregister met impactbeoordeling, wettelijke vereistetracker en doelstellingenbeheer met voortgangsregistratie.',
  },
  {
    number: '7',
    title: 'Ondersteuning',
    description: 'Zorg voor de juiste middelen, kennis en competenties voor milieubeheer. Stimuleer milieubewustzijn, regel communicatie intern en extern en beheer alle gedocumenteerde informatie.',
    vereist: 'Competenties borgen, milieubewustzijn creëren via trainingen, interne en externe communicatie regelen, gedocumenteerde informatie beheersen.',
    documenten: ['Competentiematrix', 'Trainingsregister', 'Communicatieplan', 'Documentbeheerbeleid'],
    platform: 'Centraal documentbeheer, competentieregister, trainingsregistratie en communicatiemodule voor intern en extern.',
  },
  {
    number: '8',
    title: 'Uitvoering',
    description: 'Implementeer operationele beheersmaatregelen voor processen met milieu-impact. Stel noodprocedures op, oefen ze regelmatig en beheers inkoop en uitbestede activiteiten.',
    vereist: 'Operationele beheersmaatregelen implementeren, inkoop en uitbesteding beheersen, noodprocedures opstellen en oefenen, afvalstromen registreren.',
    documenten: ['Operationele beheersprocedures', 'Noodprocedure', 'Afvalverwerkingslog', 'Leveranciersbeoordeling'],
    platform: 'Procedure-bibliotheek, afvalbeheermodule, noodplanregistratie, leveranciersbeheer en energieverbruiksregistratie.',
  },
  {
    number: '9',
    title: 'Evaluatie van prestaties',
    description: 'Meet en monitor milieuprestaties, voer nalevingsevaluaties uit en analyseer de resultaten. Interne audits en directiebeoordelingen zorgen voor sturing en continue aansturing van verbetering.',
    vereist: 'Milieuprestaties meten en analyseren, nalevingsevaluaties uitvoeren, intern auditprogramma uitvoeren en directiebeoordelingen houden.',
    documenten: ['Nalevingsevaluatierapport', 'Auditplan & auditrapport', 'KPI-overzicht', 'Directiebeoordelingsverslag'],
    platform: 'Auditworkflow met reminders, nalevingstracker, energieverbruiksregistratie en directiebeoordelingstemplates.',
  },
  {
    number: '10',
    title: 'Verbetering',
    description: 'Pak non-conformiteiten aan met gerichte corrigerende maatregelen en documenteer verbeteringen. Een systematische aanpak van continue verbetering houdt je EMS actueel en effectief.',
    vereist: 'Non-conformiteiten identificeren en analyseren, corrigerende maatregelen treffen en de effectiviteit bewaken, continue verbetering documenteren.',
    documenten: ['Non-conformiteitenregister', 'Corrigerende maatregelenplan', 'Verbeterregister'],
    platform: 'CPAR-beheer met vierstaps-verbeterproces, non-conformiteitentracker, verbeterdashboard en incidentregistratie.',
  },
];

const emsGroups = [
  {
    name: 'Handboek',
    dot: 'bg-blue-500',
    countStyle: 'text-blue-700 bg-blue-50',
    items: [
      { name: 'EMS Handboek', sub: 'ISO 14001:2015' },
      { name: 'Documentatiematrix', sub: 'Overzicht' },
      { name: 'Scope & toepassingsgebied', sub: 'H4 conform' },
    ],
  },
  {
    name: 'Beleid',
    dot: 'bg-emerald-500',
    countStyle: 'text-emerald-700 bg-emerald-50',
    items: [
      { name: 'Milieubeleid', sub: 'H5.2' },
      { name: 'Documentbeheerbeleid', sub: 'H7.5' },
      { name: 'Communicatieplan', sub: 'H7.4' },
      { name: 'Overzicht Verantwoordelijkheden', sub: 'H5.3' },
    ],
  },
  {
    name: 'Procedures',
    dot: 'bg-amber-500',
    countStyle: 'text-amber-700 bg-amber-50',
    items: [
      { name: 'Beheer MS Documentatie Procedure', sub: 'H7.5' },
      { name: 'Beheer MS Gegevens Procedure', sub: 'H7.5' },
      { name: 'Operationele beheersprocedures', sub: 'H8.1' },
      { name: 'Noodprocedure', sub: 'H8.2' },
      { name: 'Project Planning', sub: 'Template' },
      { name: 'ISO 14001 Checklist', sub: 'Pre-audit' },
    ],
  },
  {
    name: 'Registers & Analyses',
    dot: 'bg-indigo-500',
    countStyle: 'text-indigo-700 bg-indigo-50',
    items: [
      { name: 'Milieucontextanalyse', sub: 'H4.1' },
      { name: 'Register van milieuaspecten', sub: 'H4.3' },
      { name: 'Register van belanghebbenden', sub: 'H4.2' },
      { name: 'Scope document', sub: 'H4.3' },
      { name: 'Milieuaspecten en -effectenanalyse', sub: 'H6.1' },
      { name: 'Wettelijke vereistenregister', sub: 'H6.1.3' },
      { name: 'Doelstellingenregister', sub: 'H6.2' },
      { name: 'Competentiematrix', sub: 'H7.2' },
      { name: 'Trainingsregister', sub: 'H7.2' },
      { name: 'EMS Beheerd Gegevens Register', sub: 'Bijlage' },
      { name: 'EMS Beheerd Documenten Register', sub: 'Bijlage' },
    ],
  },
  {
    name: 'Formulieren & Rapporten',
    dot: 'bg-violet-500',
    countStyle: 'text-violet-700 bg-violet-50',
    items: [
      { name: 'Verantwoordelijkheidsmatrix', sub: 'H5.3' },
      { name: 'Organogram', sub: 'H5.3' },
      { name: 'Document Wijziging Verzoek Formulier', sub: 'Template' },
      { name: 'Afvalverwerkingslog', sub: 'H8.1' },
      { name: 'Leveranciersbeoordeling', sub: 'H8.4' },
      { name: 'Nalevingsevaluatierapport', sub: 'H9.1.2' },
      { name: 'KPI-overzicht', sub: 'H9.1' },
      { name: 'Directiebeoordelingsverslag', sub: 'H9.3' },
      { name: 'Non-conformiteitenregister', sub: 'H10.2' },
      { name: 'Corrigerende maatregelenplan', sub: 'H10.2' },
      { name: 'Verbeterregister', sub: 'H10.3' },
    ],
  },
  {
    name: 'Interne Audit',
    dot: 'bg-teal-500',
    countStyle: 'text-teal-700 bg-teal-50',
    items: [
      { name: 'Auditplan & auditrapport', sub: 'H9.2' },
      { name: 'Auditeren Stap-voor-Stap', sub: 'Handleiding' },
      { name: 'Gedragscode voor Interne Auditors', sub: 'Procedure' },
      { name: 'Interne Audit Feedback Formulier', sub: 'Template' },
      { name: 'Interne Audit Rapport Template', sub: 'Template' },
      { name: 'IA Checklist – EMS', sub: 'Checklist' },
      { name: 'IA Checklist – Milieuaspecten', sub: 'Checklist' },
      { name: 'IA Checklist – Naleving', sub: 'Checklist' },
      { name: 'Kennis Vereisten EMS Auditoren', sub: 'Template' },
    ],
  },
];

const benefits = [
  { title: 'Verminder milieu-impact', description: 'Identificeer en beheers de milieu-aspecten van je organisatie systematisch.' },
  { title: 'Voldoe aan milieuwetgeving', description: 'Aantoon naleving van alle toepasselijke milieuwetten en -vergunningen.' },
  { title: 'Verbeter je duurzaamheidsprofiel', description: 'ISO 14001-certificering versterkt je reputatie bij klanten en stakeholders die waarde hechten aan duurzaamheid.' },
  { title: 'Bespaar kosten', description: 'Efficiënter omgaan met energie, water en afval leidt tot directe kostenbesparingen.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Control One — ISO 14001 Software',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: 'https://control-one.nl/iso-14001',
  description: 'Implementeer ISO 14001:2015 met Control One. Beheer milieuaspecten, nalevingsevaluaties en EMS-documenten. Van milieubeleid tot continue verbetering in één platform.',
  featureList: [
    'Implementatiecoach voor ISO 14001:2015',
    'Milieuaspecten en -effecten registreren',
    'Nalevingsevaluaties',
    'EMS documentbeheer en sjablonen',
    'Interne audit module',
    'Doelstellingen en KPI-beheer',
  ],
  offers: {
    '@type': 'Offer',
    price: '49.00',
    priceCurrency: 'EUR',
    url: 'https://control-one.nl/pricing',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
    { '@type': 'ListItem', position: 2, name: 'Frameworks', item: 'https://control-one.nl/frameworks' },
    { '@type': 'ListItem', position: 3, name: 'ISO 14001', item: 'https://control-one.nl/iso-14001' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Wat is ISO 14001?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ISO 14001 is de internationale norm voor een Environmental Management System (EMS). De norm helpt organisaties bij het identificeren van milieuaspecten, het beheersen van milieu-impact en het voldoen aan milieuwetgeving. De huidige versie is ISO 14001:2015.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wat zijn milieuaspecten in ISO 14001?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Milieuaspecten zijn onderdelen van de activiteiten, producten of diensten van een organisatie die kunnen interacteren met het milieu — zoals energieverbruik, afvalproductie, uitstoot, watergebruik of transport. ISO 14001:2015 vereist dat een organisatie alle milieuaspecten identificeert en de significante aspecten actief beheerst.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wat is het verschil tussen ISO 14001 en de CSRD?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ISO 14001 is een vrijwillige certificeerbare norm voor milieumanagement binnen de organisatie. De Corporate Sustainability Reporting Directive (CSRD) is een verplichte EU-rapportageregeling voor grote ondernemingen, met rapportage over ESG-prestaties volgens de ESRS-standaarden. ISO 14001 ondersteunt de E-pijler van CSRD-rapportage.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kan ik ISO 14001 combineren met ISO 9001 en ISO 45001?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja. De drie normen volgen dezelfde High-Level Structure (HLS) en worden vaak samen geïmplementeerd als geïntegreerd kwaliteit-, milieu- en veiligheidssysteem (KAM of QHSE). Control One ondersteunt alle drie en mapt gedeelde beheersmaatregelen automatisch.',
      },
    },
  ],
};
---

<Layout
  title="ISO 14001 Software — Milieumanagement | Control One"
  description="Implementeer ISO 14001:2015 met Control One. Beheer milieuaspecten, nalevingsevaluaties en EMS-documenten. Van milieubeleid tot continue verbetering in één platform."
  jsonLd={[schema, breadcrumbSchema, faqSchema]}
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-green-400/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary-400/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

          <!-- Left: text content -->
          <div class="flex-1 max-w-2xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold tracking-wide uppercase text-green-400 bg-white/10 rounded-full backdrop-blur-sm">
              <span class="w-1.5 h-1.5 bg-green-400 rounded-full"></span>
              Milieumanagement
            </div>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-[1.1]">
              ISO 14001
            </h1>
            <p class="mt-2 text-xl sm:text-2xl font-medium text-primary-200">
              Environmental Management System
            </p>
            <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
              Implementeer een EMS volgens de internationale norm voor milieumanagement. Control One begeleidt je van milieuaspecten tot nalevingsevaluatie, stap voor stap.
            </p>
            <div class="mt-10 flex flex-col sm:flex-row gap-4">
              <a href="https://app.control-one.nl/register" class="inline-flex items-center px-6 py-3 text-base font-semibold text-primary-900 bg-white hover:bg-primary-50 rounded-lg transition-all shadow-lg">
                Start met ISO 14001
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
              </a>
              <a href="/features" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white/90 hover:text-white border border-white/20 hover:border-white/40 rounded-lg transition-all">
                Bekijk alle functies
              </a>
            </div>
          </div>

          <!-- Right: product visual (browser-chrome screenshot) -->
          <div class="flex-shrink-0 w-full lg:w-[620px] max-w-full">
            <div class="relative">
              <div class="absolute -inset-6 sm:-inset-10 bg-gradient-to-tr from-green-400/25 via-primary-500/15 to-green-400/15 rounded-[40px] blur-3xl pointer-events-none"></div>
              <div class="relative rounded-xl sm:rounded-2xl overflow-hidden shadow-2xl ring-1 ring-white/15 bg-primary-950">
                <div class="flex items-center gap-2 px-3 sm:px-4 py-2.5 bg-primary-900/90 border-b border-white/5">
                  <div class="flex gap-1.5">
                    <span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-amber-400/70"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-emerald-400/70"></span>
                  </div>
                  <div class="flex-1 flex justify-center">
                    <div class="px-3 py-1 rounded-md bg-white/[0.06] border border-white/10 text-[10px] sm:text-[11px] text-white/60 font-mono truncate max-w-[260px] sm:max-w-none">
                      app.control-one.nl / iso-14001 / coach
                    </div>
                  </div>
                  <div class="w-10 sm:w-14"></div>
                </div>
                <img
                  src="/screenshots/portal-coach.png"
                  alt="Control One implementatiecoach: stap-voor-stap naar ISO 14001 certificering"
                  width="1600"
                  height="1000"
                  class="w-full block bg-white object-cover object-top"
                  style="aspect-ratio: 16 / 9;"
                  fetchpriority="high"
                  data-lightbox
                />
              </div>

              <div class="hidden md:flex absolute -left-3 lg:-left-6 top-12 lg:top-16 px-3.5 py-2.5 rounded-2xl bg-white/95 backdrop-blur-md shadow-2xl border border-white/40 items-center gap-2.5">
                <div class="w-8 h-8 rounded-lg bg-green-100 text-green-700 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-widest text-primary-500 leading-none">Live</p>
                  <p class="mt-1 text-xs font-bold text-primary-950 leading-none">Implementatiecoach</p>
                </div>
              </div>

              <div class="hidden md:flex absolute -bottom-4 right-3 lg:-bottom-5 lg:right-8 px-3.5 py-2.5 rounded-2xl bg-primary-950 shadow-2xl ring-1 ring-green-400/40 items-center gap-2.5">
                <div class="w-8 h-8 rounded-full bg-green-400 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-primary-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-widest text-green-400/80 leading-none">Normdekking</p>
                  <p class="mt-1 text-xs font-bold text-white leading-none">100% ISO 14001:2015</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- What is ISO 14001 -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Wat is ISO 14001?</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight mb-6">
              De internationale norm voor milieumanagement
            </h2>
            <div class="text-primary-900/60 leading-relaxed space-y-4">
              <p>
                ISO 14001 is de wereldwijd meest gebruikte norm voor milieumanagementsystemen. Het biedt een systematische aanpak voor het identificeren, beheersen en verbeteren van de milieu-impact van je organisatie.
              </p>
              <p>
                Certificering toont aan klanten, overheden en stakeholders dat je organisatie milieubewust opereert en voldoet aan alle toepasselijke milieuwetgeving en -vergunningen.
              </p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {benefits.map(b => (
              <div class="p-5 rounded-2xl bg-gradient-to-br from-primary-50 to-white border border-primary-100">
                <h3 class="font-semibold text-primary-950 mb-2 text-sm">{b.title}</h3>
                <p class="text-xs text-primary-900/50 leading-relaxed">{b.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Zo werkt het in de portal -->
    <section class="py-24 bg-gradient-to-b from-white to-primary-50/40">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="text-sm font-semibold tracking-wide uppercase text-green-600 mb-3">Het platform</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">
            Zo werkt ISO 14001 in Control One
          </h2>
          <p class="mt-4 text-lg text-primary-900/60 leading-relaxed">
            Vier modules waarmee je je EMS implementeert, beheert en aantoonbaar maakt richting auditor of toezichthouder.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-6 max-w-5xl mx-auto">

          <article class="group rounded-3xl border border-primary-100 bg-white overflow-hidden shadow-sm hover:shadow-xl hover:border-primary-200 transition-all duration-300">
            <div class="relative aspect-video bg-primary-50 overflow-hidden">
              <img src="/screenshots/portal-dashboard.png" alt="Control One EMS-dashboard met milieuprestaties en KPI's" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" width="800" height="500" data-lightbox />
              <span class="absolute top-3 left-3 px-2.5 py-1 rounded-md bg-white/95 backdrop-blur text-[10px] font-bold uppercase tracking-widest text-primary-700 shadow">Module · Dashboard</span>
            </div>
            <div class="p-6">
              <h3 class="font-bold text-primary-950 text-lg mb-1.5">Dashboard &amp; rapportage</h3>
              <p class="text-sm text-primary-900/60 leading-relaxed">Real-time inzicht in milieuprestaties, doelstellingen en compliance-status. Direct exporteerbaar voor de directiebeoordeling.</p>
            </div>
          </article>

          <article class="group rounded-3xl border border-primary-100 bg-white overflow-hidden shadow-sm hover:shadow-xl hover:border-primary-200 transition-all duration-300">
            <div class="relative aspect-video bg-primary-50 overflow-hidden">
              <img src="/screenshots/portal-risks.png" alt="Milieuaspecten en risicobeoordeling in Control One" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" width="800" height="500" data-lightbox />
              <span class="absolute top-3 left-3 px-2.5 py-1 rounded-md bg-white/95 backdrop-blur text-[10px] font-bold uppercase tracking-widest text-green-700 shadow">Module · Milieuaspecten</span>
            </div>
            <div class="p-6">
              <h3 class="font-bold text-primary-950 text-lg mb-1.5">Milieuaspecten &amp; risico's</h3>
              <p class="text-sm text-primary-900/60 leading-relaxed">Identificeer significante milieuaspecten, beoordeel risico's en koppel beheersmaatregelen direct aan ISO 14001 H6.</p>
            </div>
          </article>

          <article class="group rounded-3xl border border-primary-100 bg-white overflow-hidden shadow-sm hover:shadow-xl hover:border-primary-200 transition-all duration-300">
            <div class="relative aspect-video bg-primary-50 overflow-hidden">
              <img src="/screenshots/portal-vendors.png" alt="Leveranciers en uitbestede processen in Control One" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" width="800" height="500" data-lightbox />
              <span class="absolute top-3 left-3 px-2.5 py-1 rounded-md bg-white/95 backdrop-blur text-[10px] font-bold uppercase tracking-widest text-amber-700 shadow">Module · Keten</span>
            </div>
            <div class="p-6">
              <h3 class="font-bold text-primary-950 text-lg mb-1.5">Leveranciers &amp; uitbesteed werk</h3>
