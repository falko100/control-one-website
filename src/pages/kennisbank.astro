---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import DemoCta from '../components/DemoCta.astro';
import Footer from '../components/Footer.astro';

// Based on the actual portal kennisbank structure
const categories = [
  { label: 'Portal & Navigatie', count: 2, color: 'text-teal-600 bg-teal-50 border-teal-100' },
  { label: 'ISO 27001', count: 5, color: 'text-teal-600 bg-teal-50 border-teal-100' },
  { label: 'Coach', count: 3, color: 'text-emerald-600 bg-emerald-50 border-emerald-100' },
  { label: 'Handboek & Managementsysteem', count: 2, color: 'text-violet-600 bg-violet-50 border-violet-100' },
  { label: 'Risicoanalyse', count: 3, color: 'text-red-600 bg-red-50 border-red-100' },
  { label: 'Leveranciers', count: 2, color: 'text-cyan-600 bg-cyan-50 border-cyan-100' },
  { label: 'Verklaring van Toepasselijkheid', count: 3, color: 'text-blue-600 bg-blue-50 border-blue-100' },
  { label: 'Checklist & Gap Analyse', count: 2, color: 'text-amber-600 bg-amber-50 border-amber-100' },
  { label: 'Audits', count: 3, color: 'text-orange-600 bg-orange-50 border-orange-100' },
  { label: "CPAR's", count: 2, color: 'text-rose-600 bg-rose-50 border-rose-100' },
  { label: 'Incidenten', count: 2, color: 'text-rose-600 bg-rose-50 border-rose-100' },
  { label: 'Directiebeoordeling', count: 2, color: 'text-indigo-600 bg-indigo-50 border-indigo-100' },
];

const annexCategories = [
  { label: 'A5 – Organisatorisch', count: 37, color: 'text-blue-600 bg-blue-50 border-blue-100' },
  { label: 'A6 – Mensen', count: 8, color: 'text-emerald-600 bg-emerald-50 border-emerald-100' },
  { label: 'A7 – Fysiek', count: 14, color: 'text-orange-600 bg-orange-50 border-orange-100' },
  { label: 'A8 – Technologisch', count: 35, color: 'text-violet-600 bg-violet-50 border-violet-100' },
];

// Voorbeeld artikel (sample)
const sampleArticle = {
  category: 'ISO 27001 Coach',
  title: 'Het toepassingsgebied (scope) bepalen',
  readingTime: '5 min',
  updatedAt: '2 mei 2026',
  toc: [
    'Waarom scope-bepaling cruciaal is',
    'Wat ISO 27001 vereist (clausule 4.3)',
    'Stappenplan in 6 stappen',
    'Veelgemaakte fouten',
    'Sjabloon: Scope-document',
  ],
  related: [
    { title: 'Context van de organisatie (H4)', category: 'Coach' },
    { title: 'Belanghebbenden in kaart brengen', category: 'Coach' },
    { title: 'A5.1 — Beleid voor informatiebeveiliging', category: 'A5' },
  ],
};

// Multi-language statistieken
const langStats = [
  { code: 'NL', name: 'Nederlands', categories: 17, color: 'bg-blue-50 border-blue-200 text-blue-700' },
  { code: 'EN', name: 'English', categories: 16, color: 'bg-emerald-50 border-emerald-200 text-emerald-700' },
];
---

<Layout
  title="Kennisbank — ISO-kennis en begeleiding | Control One"
  description="120+ kennisbankartikelen over ISO 27001, AVG, NIS2 en alle 93 Annex A-maatregelen. Gekoppeld aan je ISMS — één klik van artikel naar de juiste maatregel, risico of document."
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
        { '@type': 'ListItem', position: 2, name: 'Portal', item: 'https://control-one.nl/features' },
        { '@type': 'ListItem', position: 3, name: 'Kennisbank', item: 'https://control-one.nl/kennisbank' },
      ],
    },
    {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: 'Kennisbank — ISO kennis en begeleiding',
      description: '120+ kennisbankartikelen over ISO 27001, AVG, NIS2 en Annex A-maatregelen.',
      url: 'https://control-one.nl/kennisbank',
      inLanguage: 'nl-NL',
      isPartOf: { '@type': 'WebSite', name: 'Control One', url: 'https://control-one.nl' },
    },
  ]}
>
  <Header />
  <main>
    <section class="relative pt-32 pb-20 lg:pb-28 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-teal-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="lg:grid lg:grid-cols-[1fr_1.15fr] lg:gap-12 lg:items-center">
          <div class="max-w-xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-teal-400 bg-teal-400/10 rounded-full border border-teal-400/20">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
              Kennisbank
            </div>
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
              Alles wat je moet weten<br/><span class="text-teal-400">altijd binnen handbereik</span>
            </h1>
            <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
              Voor elke module een eigen rubriek, voor elk van de 93 Annex A-maatregelen een eigen artikel — in begrijpelijk Nederlands én Engels. Altijd één klik verwijderd vanuit je risico, maatregel of coach-stap.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3 text-xs font-medium text-white/80">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-teal-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                120+ artikelen
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-teal-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Artikel per Annex A-control
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-teal-300/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                NL &amp; EN
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
                Gratis uitproberen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href="/features" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Alle features</a>
            </div>
          </div>

          <!-- Hero afbeelding rechts -->
          <div class="mt-12 lg:mt-0">
            <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40">
              <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
                <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
                <div class="flex-1 min-w-0 max-w-[240px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center truncate">app.control-one.nl/kennisbank</div></div>
              </div>
              <!-- Kennisbank inline mockup -->
              <div class="bg-white p-5">
                <!-- Search bar -->
                <div class="flex items-center gap-2 mb-4 px-3 py-2 rounded-xl border border-teal-200 bg-teal-50/60">
                  <svg class="w-4 h-4 text-teal-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                  <span class="text-xs text-primary-400">Zoek in de kennisbank…</span>
                </div>
                <!-- Category pills -->
                <div class="flex gap-1.5 mb-4 flex-wrap">
                  <span class="px-2.5 py-1 rounded-full text-[10px] font-semibold bg-teal-500 text-white">Risicoanalyse</span>
                  <span class="px-2.5 py-1 rounded-full text-[10px] font-semibold bg-primary-50 text-primary-600 border border-primary-100">Audits</span>
                  <span class="px-2.5 py-1 rounded-full text-[10px] font-semibold bg-primary-50 text-primary-600 border border-primary-100">A5</span>
                  <span class="px-2.5 py-1 rounded-full text-[10px] font-semibold bg-primary-50 text-primary-600 border border-primary-100">A8</span>
                  <span class="px-2.5 py-1 rounded-full text-[10px] font-semibold bg-primary-50 text-primary-600 border border-primary-100">Coach</span>
                </div>
                <!-- Article list -->
                <div class="space-y-2">
                  {[
                    { title: 'Hoe stel je een risicoanalyse op conform ISO 27001:2022?', cat: 'Risicoanalyse', time: '7 min' },
                    { title: 'Verklaring van Toepasselijkheid: alle 93 maatregelen uitgelegd', cat: 'VvT', time: '10 min' },
                    { title: 'Wat is het verschil tussen inherent en residueel risico?', cat: 'Risicoanalyse', time: '4 min' },
                    { title: 'A5.23 — Informatiebeveiliging clouddiensten', cat: 'A5', time: '6 min' },
                    { title: 'Een interne audit voorbereiden zonder stress', cat: 'Audits', time: '8 min' },
                  ].map(a => (
                    <div class="flex items-center gap-2.5 p-2.5 rounded-lg bg-primary-50/40 hover:bg-teal-50/40 transition-colors">
                      <div class="w-7 h-7 rounded-lg bg-teal-50 flex items-center justify-center shrink-0 text-teal-500">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0118 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="text-xs font-semibold text-primary-950 truncate">{a.title}</p>
                        <div class="flex items-center gap-2 mt-0.5">
                          <span class="text-[9px] font-semibold px-1.5 py-0.5 rounded bg-teal-50 text-teal-700 border border-teal-100">{a.cat}</span>
                          <span class="text-[9px] text-primary-400">{a.time}</span>
                        </div>
                      </div>
                      <svg class="w-3.5 h-3.5 text-primary-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </div>
                  ))}
                </div>
                <div class="mt-3 text-center">
                  <span class="text-[10px] text-primary-400">120+ artikelen beschikbaar</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-10">
          <p class="text-sm font-semibold tracking-wide uppercase text-teal-600 mb-3">Per module</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-primary-950">Een rubriek voor elke portal-sectie</h2>
          <p class="mt-3 text-primary-900/75 text-sm max-w-xl mx-auto">De kennisbank volgt de structuur van je ISMS — zo vind je uitleg precies waar je er mee bezig bent.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 max-w-5xl mx-auto mb-16">
          {categories.map(cat => (
            <div class={`flex items-center justify-between p-4 rounded-xl border ${cat.color} transition-all hover:shadow-md`}>
              <span class="text-sm font-semibold">{cat.label}</span>
              <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-white/60">{cat.count} artikelen</span>
            </div>
          ))}
        </div>

        <div class="text-center mb-10">
          <p class="text-sm font-semibold tracking-wide uppercase text-teal-600 mb-3">Per Annex A-hoofdstuk</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-primary-950">Een artikel voor elke beheersmaatregel</h2>
          <p class="mt-3 text-primary-900/75 text-sm max-w-xl mx-auto">94 artikelen voor 93 Annex A-maatregelen — exacte uitleg per control, direct vanuit de maatregel bereikbaar.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 max-w-5xl mx-auto mb-16">
          {annexCategories.map(cat => (
            <div class={`flex flex-col p-4 rounded-xl border ${cat.color} transition-all hover:shadow-md`}>
              <span class="text-[10px] font-semibold uppercase tracking-wide opacity-70">Annex A</span>
              <span class="text-sm font-semibold">{cat.label}</span>
              <span class="mt-2 text-2xl font-bold">{cat.count}</span>
              <span class="text-[10px] opacity-70">artikelen</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Mid-page Demo CTA -->
    <DemoCta
      module="Kennisbank"
      title="Benieuwd hoe de Kennisbank werkt in de portal?"
      description="Stap door een interactieve rondleiding en zie hoe je per maatregel direct uitleg, voorbeelden en sjablonen vindt zonder de portal te verlaten."
      ctaText="Bekijk de live demo"
      urlPath="kennisbank / artikel"
      accentBg="bg-teal-500"
      accentText="text-teal-300"
      variant="kennisbank"
    />

    <!-- Sample artikel + extra content -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-teal-600 mb-3">Voorbeeld</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Eén kennisbankartikel van dichtbij</h2>
          <p class="mt-4 text-lg text-primary-900/75">Iedere uitleg volgt dezelfde structuur: korte intro, waarom-en-wat, stappenplan, voorbeelden en gerelateerde artikelen of sjablonen.</p>
        </div>

        <div class="max-w-5xl mx-auto rounded-2xl overflow-hidden border border-teal-100 bg-white shadow-2xl shadow-teal-100/40">
          <!-- Header -->
          <div class="px-6 py-5 bg-gradient-to-r from-teal-50 to-primary-50/40 border-b border-teal-100">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-[10px] font-bold uppercase tracking-widest text-teal-700 bg-teal-100 px-2 py-0.5 rounded">{sampleArticle.category}</span>
              <span class="text-[10px] text-primary-500">·</span>
              <span class="text-[10px] text-primary-500">{sampleArticle.readingTime} leestijd</span>
              <span class="text-[10px] text-primary-500">·</span>
              <span class="text-[10px] text-primary-500">Bijgewerkt {sampleArticle.updatedAt}</span>
            </div>
            <h3 class="text-2xl font-bold text-primary-950 leading-tight">{sampleArticle.title}</h3>
          </div>

          <!-- Body -->
          <div class="grid lg:grid-cols-[1fr_280px] gap-0 divide-y lg:divide-y-0 lg:divide-x divide-teal-100">
            <div class="px-6 py-6">
              <p class="text-[10px] font-bold uppercase tracking-widest text-teal-700 mb-3">Inhoudsopgave</p>
              <ol class="space-y-2.5">
                {sampleArticle.toc.map((t, i) => (
                  <li class="flex items-start gap-2.5">
                    <span class="text-xs font-mono font-bold text-teal-700 shrink-0 w-6">{(i+1).toString().padStart(2,'0')}</span>
                    <span class="text-sm text-primary-900/80 leading-relaxed">{t}</span>
                  </li>
                ))}
              </ol>

              <div class="mt-6 p-4 rounded-xl bg-teal-50/50 border border-teal-100">
                <p class="text-[10px] font-bold uppercase tracking-widest text-teal-700 mb-1.5">Praktijkvoorbeeld</p>
                <p class="text-xs text-primary-900/75 leading-relaxed">Een SaaS-bedrijf met 25 FTE bepaalt de scope op "ontwikkeling, levering en support van het ControlOne-platform". De productie-cloud, kantoorlocatie Enschede en alle medewerkers vallen erbinnen. Marketing-website en demo-omgevingen zijn expliciet uitgesloten met onderbouwing.</p>
              </div>
            </div>

            <!-- Related panel -->
            <div class="px-6 py-6 bg-teal-50/30">
              <p class="text-[10px] font-bold uppercase tracking-widest text-teal-700 mb-3">Gerelateerd</p>
              <ul class="space-y-2.5">
                {sampleArticle.related.map(r => (
                  <li class="p-3 rounded-lg bg-white border border-teal-100">
                    <p class="text-[10px] font-bold uppercase tracking-widest text-teal-600 mb-0.5">{r.category}</p>
                    <p class="text-xs font-semibold text-primary-900 leading-snug">{r.title}</p>
                  </li>
                ))}
              </ul>
              <div class="mt-4 p-3 rounded-lg bg-primary-950 text-white">
                <p class="text-[10px] font-bold uppercase tracking-widest text-teal-300 mb-1">Sjabloon</p>
                <p class="text-xs font-semibold leading-snug">Scope-document Word-template</p>
                <p class="text-[10px] text-white/60 mt-1">Direct downloadbaar binnen artikel</p>
              </div>
            </div>
          </div>

          <!-- Footer -->
          <div class="px-6 py-3.5 bg-primary-50/40 border-t border-teal-100 flex items-center justify-between text-[11px] text-primary-500 flex-wrap gap-2">
            <span>Direct bereikbaar via zoekbalk in iedere portal-pagina</span>
            <span class="font-semibold text-teal-700">Beschikbaar in NL · EN</span>
          </div>
        </div>

        <!-- Multi-language stats -->
        <div class="mt-16 max-w-3xl mx-auto">
          <div class="text-center mb-8">
            <p class="text-sm font-semibold tracking-wide uppercase text-teal-600 mb-2">Meertalig</p>
            <h3 class="text-2xl font-bold text-primary-950 tracking-tight">Volledig in NL en EN beschikbaar</h3>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            {langStats.map(l => (
              <div class:list={['p-5 rounded-2xl border-2 flex items-center gap-4', l.color]}>
                <div class="w-14 h-14 rounded-xl bg-white border border-current/20 flex items-center justify-center font-bold text-xl">{l.code}</div>
                <div class="flex-1">
                  <p class="text-base font-bold">{l.name}</p>
                  <p class="text-xs opacity-80">{l.categories} categorieën · 100+ artikelen</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Feature cards -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {[
            { title: 'Begrijpelijk Nederlands & Engels', desc: 'Elk artikel volledig beschikbaar in beide talen. Schakel instant om zonder ooit een vertaler in te hoeven schakelen.' },
            { title: 'Gekoppeld aan je ISMS', desc: 'Artikelen linken direct naar de bijbehorende maatregel, coach-stap of module. Van lezen naar doen in één klik.' },
            { title: 'Artikel per Annex A-control', desc: 'Alle 93 maatregelen hebben een eigen uitlegartikel — met de norm, de bedoeling, praktijkvoorbeelden en do\'s &amp; don\'ts.' },
            { title: 'Snel zoeken', desc: 'Zoek op clausule (A5.15), module (risicoanalyse) of normterm (SoA). Globaal zoeken is ook vanuit de header van de portal beschikbaar.' },
            { title: 'Coach-integratie', desc: 'Tijdens het doorlopen van een coach-stap toont de portal automatisch de relevante kennisbankartikelen.' },
            { title: 'Altijd actueel', desc: 'De kennisbank wordt continu bijgewerkt bij nieuwe inzichten, jurisprudentie en wijzigingen in wet- en regelgeving zoals NIS2.' },
          ].map(f => (
            <div class="p-6 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center text-teal-600 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h3 class="text-sm font-bold text-primary-950 mb-2">{f.title}</h3>
              <p class="text-sm text-primary-900/75 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>

        <!-- Quote callout -->
        <div class="mt-16 max-w-2xl mx-auto text-center">
          <blockquote class="text-lg font-medium text-primary-900 italic leading-relaxed">
            "Eindelijk uitleg over ISO 27001 die ik als niet-technisch directeur ook begrijp en direct kan gebruiken."
          </blockquote>
          <p class="mt-4 text-sm text-primary-900/50">– Klant uit de zakelijke dienstverlening</p>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
