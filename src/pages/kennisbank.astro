---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const categories = [
  { label: 'ISO 27001:2022', count: 24, color: 'text-teal-600 bg-teal-50 border-teal-100' },
  { label: 'AVG / GDPR', count: 18, color: 'text-blue-600 bg-blue-50 border-blue-100' },
  { label: 'NIS2', count: 12, color: 'text-violet-600 bg-violet-50 border-violet-100' },
  { label: 'Risicoanalyse', count: 9, color: 'text-red-600 bg-red-50 border-red-100' },
  { label: 'Audits & CPAR', count: 14, color: 'text-orange-600 bg-orange-50 border-orange-100' },
  { label: 'Implementatiegids', count: 31, color: 'text-emerald-600 bg-emerald-50 border-emerald-100' },
];
---

<Layout title="Kennisbank — ISO-kennis en begeleiding | Control One" description="Toegang tot onze kennisbank met uitleg over ISO-normen, best practices en implementatietips. Begrijp wat elke ISO-clausule van je vraagt.">
  <Header />
  <main>
    <section class="relative pt-32 pb-24 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-teal-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-teal-400 bg-teal-400/10 rounded-full border border-teal-400/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
            Kennisbank
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
            Alles wat je moet weten<br/><span class="text-teal-400">altijd binnen handbereik</span>
          </h1>
          <p class="mt-6 text-lg text-primary-300/80 max-w-xl leading-relaxed">
            De Control One kennisbank bevat uitleg, richtlijnen en stappenplannen voor ISO 27001, AVG, NIS2 en meer. Geschreven in begrijpelijk Nederlands, direct toepasbaar in je organisatie.
          </p>
          <div class="mt-8 flex gap-4">
            <a href="https://app.control-one.nl/register" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
              Gratis uitproberen
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/features" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Alle features</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-0 bg-white">
      <div class="max-w-5xl mx-auto px-6 -mt-8">
        <div class="rounded-2xl overflow-hidden border border-primary-100 shadow-2xl shadow-primary-200/30">
          <div class="flex items-center gap-3 px-4 py-2.5 bg-primary-50 border-b border-primary-100">
            <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span><span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span></div>
            <div class="flex-1 max-w-[240px] mx-auto"><div class="bg-white/80 rounded px-3 py-0.5 text-xs text-primary-400 border border-primary-100 text-center">app.control-one.nl/kennisbank</div></div>
          </div>
          <!-- Kennisbank inline mockup -->
          <div class="bg-white p-6">
            <!-- Search bar -->
            <div class="flex items-center gap-2 mb-5 px-4 py-2.5 rounded-xl border border-teal-200 bg-teal-50/60">
              <svg class="w-4 h-4 text-teal-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              <span class="text-sm text-primary-400">Zoek in de kennisbank…</span>
            </div>
            <!-- Category pills -->
            <div class="flex gap-2 mb-5 flex-wrap">
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-teal-500 text-white">ISO 27001:2022</span>
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-primary-50 text-primary-600 border border-primary-100">AVG / GDPR</span>
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-primary-50 text-primary-600 border border-primary-100">NIS2</span>
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-primary-50 text-primary-600 border border-primary-100">Risicoanalyse</span>
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-primary-50 text-primary-600 border border-primary-100">Audits & CPAR</span>
            </div>
            <!-- Article list -->
            <div class="space-y-3">
              {[
                { title: 'Wat is ISO 27001 en waarom is het relevant voor jouw organisatie?', cat: 'ISO 27001', time: '4 min', level: 'Basis' },
                { title: 'Hoe stel je een risicoanalyse op conform ISO 27001:2022?', cat: 'Risicoanalyse', time: '7 min', level: 'Gevorderd' },
                { title: 'Verklaring van Toepasselijkheid: alle 93 maatregelen uitgelegd', cat: 'ISO 27001', time: '10 min', level: 'Uitgebreid' },
                { title: 'Aanvullende vereisten NIS2: wat verandert er voor jouw sector?', cat: 'NIS2', time: '5 min', level: 'Basis' },
              ].map(a => (
                <div class="flex items-center gap-3 p-3 rounded-xl bg-primary-50/40 hover:bg-teal-50/40 transition-colors">
                  <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center shrink-0 text-teal-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0118 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-primary-950 truncate">{a.title}</p>
                    <div class="flex items-center gap-2 mt-0.5">
                      <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-teal-50 text-teal-700 border border-teal-100">{a.cat}</span>
                      <span class="text-[10px] text-primary-400">{a.time} leestijd · {a.level}</span>
                    </div>
                  </div>
                  <svg class="w-4 h-4 text-primary-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </div>
              ))}
            </div>
            <div class="mt-4 text-center">
              <span class="text-xs text-primary-400">108 artikelen beschikbaar, inbegrepen in elk abonnement</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-2xl font-bold text-primary-950">Kennisbank categorieën</h2>
          <p class="mt-2 text-primary-900/55 text-sm">Meer dan 100 artikelen, richtlijnen en stappenplannen</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto mb-16">
          {categories.map(cat => (
            <div class={`flex items-center justify-between p-4 rounded-xl border ${cat.color} transition-all hover:shadow-md`}>
              <span class="text-sm font-semibold">{cat.label}</span>
              <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-white/60">{cat.count} artikelen</span>
            </div>
          ))}
        </div>

        <!-- Feature cards -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {[
            { title: 'Begrijpelijk Nederlands', desc: 'Geen ISO-jargon, maar heldere uitleg die ook niet-juristen en niet-IT\'ers begrijpen en direct kunnen toepassen.' },
            { title: 'Contextgevoelig zoeken', desc: 'Stel een vraag in gewone taal en de kennisbank toont direct het meest relevante artikel of de bijbehorende maatregel.' },
            { title: 'Gekoppeld aan je ISMS', desc: 'Artikelen zijn direct gekoppeld aan maatregelen, templates en taken in je ISMS. Één klik naar de praktijk.' },
            { title: 'Altijd actueel', desc: 'De kennisbank wordt continu bijgewerkt bij wijzigingen in wet- en regelgeving zoals ISO 27001:2022 en NIS2.' },
            { title: 'Coach-integratie', desc: 'Aanbevolen kennisbanklessen verschijnen automatisch in uw implementatiecoach op het juiste moment.' },
            { title: 'Downloadbare checklists', desc: 'Elk artikel bevat een praktische checklist of template die direct te gebruiken is in je eigen organisatie.' },
          ].map(f => (
            <div class="p-6 rounded-2xl border border-primary-100 hover:shadow-lg hover:shadow-primary-100/50 transition-all">
              <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center text-teal-600 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h3 class="text-sm font-bold text-primary-950 mb-2">{f.title}</h3>
              <p class="text-sm text-primary-900/55 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>

        <!-- Quote callout -->
        <div class="mt-16 max-w-2xl mx-auto text-center">
          <blockquote class="text-lg font-medium text-primary-900 italic leading-relaxed">
            "Eindelijk uitleg over ISO 27001 die ik als niet-technisch directeur ook begrijp en direct kan gebruiken."
          </blockquote>
          <p class="mt-4 text-sm text-primary-900/50">– Klant uit de zakelijke dienstverlening</p>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
