                Nederlands, praktisch en zonder consultancy-jargon
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== HOE EEN IMPLEMENTATIEPAKKET WERKT ===== -->
    <section class="py-24 bg-gradient-to-b from-primary-50/40 to-white">
