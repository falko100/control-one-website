---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const uurbasisVoorbeelden = [
  {
    title: 'Interne audit',
    desc: 'Een onafhankelijke interne audit door een ervaren auditor, inclusief bevindingen en rapport in je portal.',
    icon: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Pre-audit check',
    desc: 'Vlak voor je certificeringsaudit alles nog één keer kritisch laten doorlopen door een expert.',
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  },
  {
    title: 'Risicoanalyse-sessie',
    desc: 'Samen met je team risico\'s en kansen identificeren en beoordelen in een begeleide werksessie.',
    icon: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
  },
  {
    title: 'Directiebeoordeling begeleiden',
    desc: 'De jaarlijkse management review voorbereiden en voorzitten, zodat alle verplichte punten aan bod komen.',
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
  },
  {
    title: 'Documentreview',
    desc: 'Je beleid, procedures en handboek laten toetsen op volledigheid en aansluiting op de norm.',
    icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  },
  {
    title: 'Sparren met een expert',
    desc: 'Een uur videobellen over een specifiek vraagstuk: scope, uitsluitingen, leveranciers of een lastige maatregel.',
    icon: 'M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z',
  },
];

const pakketStappen = [
  {
    num: '01',
    title: 'Kennismaking',
    desc: 'We bespreken je organisatie, de norm die je wilt behalen en hoeveel je zelf wilt (en kunt) oppakken.',
  },
  {
    num: '02',
    title: 'Inschatting',
    desc: 'Samen maken we een realistische inschatting van de implementatie: welke onderdelen doe jij, waar helpen wij.',
  },
  {
    num: '03',
    title: 'Vaste pakketprijs',
    desc: 'Op basis van de inschatting ontvang je één vaste prijs voor het hele traject. Geen verrassingen achteraf.',
  },
  {
    num: '04',
    title: 'Samen uitvoeren',
    desc: 'We werken in jouw Control One portal, volgens de coach. Alles wat we samen bouwen blijft van jou.',
  },
];

// Voorbeeld-takenverdeling in het implementatievoorstel-mockup
const voorstelTaken = [
  { taak: 'Contextanalyse & scope', wie: 'Jij' },
  { taak: 'Risicoanalyse', wie: 'Samen' },
  { taak: 'Beleid & documentatie', wie: 'Jij' },
  { taak: 'Implementatie maatregelen', wie: 'Jij' },
  { taak: 'Interne audit', wie: 'Wij' },
  { taak: 'Voorbereiding certificeringsaudit', wie: 'Samen' },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'ISO Consultancy',
  serviceType: 'ISO-implementatie begeleiding',
  provider: {
    '@type': 'Organization',
    name: 'Control One',
    url: 'https://control-one.nl',
  },
  areaServed: 'NL',
  description: 'Optionele consultancy naast het Control One platform: inzet op uurbasis (zoals interne audits) of implementatiepakketten met vaste prijs.',
  offers: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'PriceSpecification',
      price: '0',
      priceCurrency: 'EUR',
      description: 'Prijs op aanvraag',
    },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://control-one.nl' },
    { '@type': 'ListItem', position: 2, name: 'Consultancy', item: 'https://control-one.nl/consultancy' },
  ],
};
---

<Layout
  title="Consultancy — Persoonlijke begeleiding bij je ISO-traject | Control One"
  description="Met Control One implementeer je ISO zelfstandig. Liever persoonlijke begeleiding? Dat kan ook: op uurbasis of als volledig implementatiepakket met vaste prijs."
  jsonLd={[serviceSchema, breadcrumbSchema]}
>
  <Header />
  <main>

    <!-- ===== HERO ===== -->
    <section class="relative pt-32 pb-20 lg:pb-28 overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2d5fa8 0%, #2554a0 60%, #2d5fa8 100%);"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-emerald-400/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="lg:grid lg:grid-cols-[1.1fr_1fr] lg:gap-14 lg:items-center">
          <div class="max-w-xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold tracking-widest uppercase text-emerald-300 bg-emerald-400/10 rounded-full border border-emerald-400/20">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
              Consultancy · 100% optioneel
            </div>
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white leading-[1.1]">
              ISO implementeer je zelf.<br/><span class="text-emerald-300">Of samen met ons.</span>
            </h1>
            <p class="mt-6 text-lg text-primary-300/80 leading-relaxed">
              Het platform is zo ingericht dat je ISO volledig zelfstandig implementeert. Heb je toch liever persoonlijke begeleiding? Daar hebben we prima mogelijkheden voor: los op uurbasis of als volledig implementatiepakket met vaste prijs.
            </p>
            <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3.5 text-base font-medium text-white/90 max-w-xl">
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-emerald-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Op uurbasis of als pakket
              </div>
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-emerald-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Altijd bij te schakelen
              </div>
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-emerald-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Altijd in jouw eigen portal
              </div>
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-emerald-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Heldere prijsopgave vooraf
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-primary-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-all shadow-lg">
                Plan een kennismaking
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href="/pricing" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white border border-white/20 hover:border-white/40 hover:bg-white/5 rounded-lg transition-all">Liever volledig zelf? Bekijk de pakketten</a>
            </div>
          </div>

          <!-- Hero sfeerfoto rechts -->
          <div class="mt-12 lg:mt-0">
            <div class="relative">
              <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40">
                <img src="/team/office-4.webp" alt="Overleg met een Control One consultant" class="w-full object-cover" style="min-height: 320px; max-height: 420px;" loading="eager" />
              </div>
              <div class="absolute -bottom-5 left-6 right-6 sm:left-10 sm:right-auto bg-white rounded-xl border border-primary-100 shadow-xl px-5 py-4 flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-primary-950">Precies zoveel hulp als jij wilt</p>
                  <p class="text-xs text-primary-500">Van één sparsessie tot een volledig traject</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== INSTAPPEN KAN OP ELK MOMENT ===== -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="text-sm font-semibold tracking-wide uppercase text-emerald-600 mb-3">Wanneer jij wilt</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">Elk moment is een goed moment.<br/><span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #0e2470 0%, #196bd7 50%, #01a2e8 100%);">Schakel begeleiding in wanneer jij wilt</span></h2>
          <p class="mt-4 text-lg text-primary-900/75">Je hoeft bij de start niets te beslissen. Begin zelfstandig in de portal als je dat wilt, en schakel begeleiding in wanneer het jou uitkomt: vanaf dag één, halverwege of pas tegen de audit aan.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          <div class="p-7 rounded-2xl border border-primary-100 bg-white hover:shadow-lg hover:shadow-primary-100/50 transition-all">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-700 text-white flex items-center justify-center shadow-md shadow-primary-300/40 mb-5">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3v1.5M3 21v-6m0 0l2.77-.693a9 9 0 016.208.682l.108.054a9 9 0 006.086.71l3.114-.732a48.524 48.524 0 01-.005-10.499l-3.11.732a9 9 0 01-6.085-.711l-.108-.054a9 9 0 00-6.208-.682L3 4.5M3 15V4.5"/></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-widest text-primary-500 mb-1.5">Instapmoment</p>
            <h3 class="text-lg font-bold text-primary-950 mb-2">Vanaf de start</h3>
            <p class="text-sm text-primary-900/70 leading-relaxed">Direct begeleiding vanaf dag één? We plannen het traject samen in en spreken vooraf af wie wat oppakt.</p>
          </div>

          <div class="p-7 rounded-2xl border border-primary-100 bg-white hover:shadow-lg hover:shadow-primary-100/50 transition-all">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-sky-400 to-sky-600 text-white flex items-center justify-center shadow-md shadow-sky-300/40 mb-5">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-widest text-primary-500 mb-1.5">Instapmoment</p>
            <h3 class="text-lg font-bold text-primary-950 mb-2">Halverwege je traject</h3>
            <p class="text-sm text-primary-900/70 leading-relaxed">Al zelfstandig begonnen en wil je toch ondersteuning bij een onderdeel? We sluiten naadloos aan waar jij gebleven bent.</p>
          </div>

          <div class="p-7 rounded-2xl border border-primary-100 bg-white hover:shadow-lg hover:shadow-primary-100/50 transition-all">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-700 text-white flex items-center justify-center shadow-md shadow-emerald-300/40 mb-5">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.85 2.25h12.3c.621 0 1.125.504 1.125 1.125v3.026a9.06 9.06 0 01-1.5 5.001c-.319.478-.68.928-1.081 1.348m-9.388 0a9.06 9.06 0 01-1.081-1.348 9.06 9.06 0 01-1.5-5.001V3.375c0-.621.504-1.125 1.125-1.125z"/></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-widest text-primary-500 mb-1.5">Instapmoment</p>
            <h3 class="text-lg font-bold text-primary-950 mb-2">Tegen de audit aan</h3>
            <p class="text-sm text-primary-900/70 leading-relaxed">Alles zelf gedaan en alleen nog een interne audit of pre-audit check nodig? Ook dat kan als losse inzet.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TWEELUIK: PORTAL + CONSULTANCY ===== -->
    <section class="py-24 bg-gradient-to-b from-white to-primary-50/30">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="text-sm font-semibold tracking-wide uppercase text-emerald-600 mb-3">Begeleiding</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-primary-950 tracking-tight">De portal is de basis, <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #0e2470 0%, #196bd7 50%, #01a2e8 100%);">consultancy de optie</span></h2>
          <p class="mt-4 text-lg text-primary-900/75">Elk abonnement bevat alles wat je nodig hebt om zelfstandig te certificeren. Consultancy voegt daar persoonlijke expertise aan toe, alleen wanneer jij daarom vraagt.</p>
        </div>

        <div class="relative grid lg:grid-cols-2 lg:grid-rows-[auto_auto_1fr_auto] gap-8">
          <!-- Plus-teken tussen de twee luiken -->
          <div class="hidden lg:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-white border border-primary-200 shadow-lg items-center justify-center">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6"/></svg>
          </div>

          <!-- Links: de portal -->
          <div class="bg-white rounded-3xl border border-primary-200 shadow-xl shadow-primary-200/50 ring-1 ring-primary-200/60 overflow-hidden flex flex-col lg:grid lg:grid-rows-subgrid lg:row-span-4">
            <div class="px-8 py-3.5 flex items-center justify-center gap-2" style="background: linear-gradient(90deg, #2d5fa8 0%, #2554a0 100%);">
              <svg class="w-4 h-4 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <p class="text-xs font-bold uppercase tracking-widest text-white">Standaard inbegrepen in elk pakket</p>
            </div>
            <div class="px-8 pt-5 pb-6 border-b border-primary-100">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-14 h-14 rounded-2xl bg-primary-50 border border-primary-100 flex items-center justify-center shrink-0 shadow-sm">
                  <img src="/favicon.svg" alt="Control One" class="w-9 h-9" loading="lazy" />
                </div>
                <h3 class="text-2xl font-bold text-primary-950">De Control One portal</h3>
              </div>
              <p class="text-sm text-primary-900/70 leading-relaxed">Alles wat je nodig hebt om zelfstandig te certificeren, in één compleet platform. Elk abonnement bevat alle modules en functies, zonder meerkosten. Van de online implementatiecoach tot documentbeheer en audits: je kunt er direct mee aan de slag.</p>
            </div>
            <div class="px-8 pt-4 pb-6 flex-1">
              <ul class="space-y-3">
                {[
                  '28-stappen online implementatiecoach',
                  'Kant-en-klare sjablonen voor beleid en procedures',
                  'Risicoanalyse met risicomatrix',
                  'Documentbeheer met versies en reviewcyclus',
                  'Interne audits, CPAR\'s en directiebeoordelingen',
                  'Maatregelen en Verklaring van Toepasselijkheid',
                  'Kennisbank met praktische uitleg per stap',
                ].map(item => (
                  <li class="flex items-start gap-2.5 text-sm text-primary-800/80">
                    <svg class="w-4 h-4 text-primary-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="px-8 py-6 bg-primary-50/50 border-t border-primary-100 flex items-center justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sm font-bold text-primary-950">Inbegrepen in elk abonnement</p>
                <p class="text-xs text-primary-500">Zelfstandig certificeren, zonder meerkosten</p>
              </div>
              <a href="/pricing" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-primary-700 hover:bg-primary-800 rounded-xl transition-all shadow-sm shadow-primary-700/20 whitespace-nowrap">
                Bekijk prijzen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
            </div>
          </div>

          <!-- Rechts: optionele consultancy -->
          <div class="bg-white rounded-3xl border-2 border-dashed border-emerald-300 overflow-hidden flex flex-col lg:grid lg:grid-rows-subgrid lg:row-span-4">
            <div class="px-8 py-3.5 bg-emerald-50 border-b border-emerald-100 flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v12m6-6H6"/></svg>
              <p class="text-xs font-bold uppercase tracking-widest text-emerald-700">Optioneel · flexibel bij te schakelen</p>
            </div>
            <div class="px-8 pt-5 pb-6 border-b border-primary-100">
              <div class="flex items-center gap-4 mb-4">
                <img src="/falko.jpg" alt="Consultant bij Control One" class="w-14 h-14 rounded-full object-cover ring-2 ring-emerald-300 shadow-md shrink-0" loading="lazy" />
                <h3 class="text-2xl font-bold text-primary-950">Persoonlijke consultancy</h3>
              </div>
              <p class="text-sm text-primary-900/70 leading-relaxed">Wil je toch begeleiding bij je implementatie? Dan helpen we je graag met optionele consultancy, precies op de onderdelen waar jij dat wilt. Van een volledig implementatietraject tot losse uren, bijvoorbeeld voor het uitvoeren van de interne audit.</p>
            </div>
            <div class="px-8 pt-4 pb-6 flex-1">
              <ul class="space-y-3">
                {[
                  'Persoonlijke begeleiding door een ervaren consultant',
                  'Interne audit door een onafhankelijke auditor',
                  'Begeleide werksessies met je team',
                  'Review van documenten en risicoanalyse',
                  'Volledig implementatietraject met vaste prijs',
                  'Sparren met een expert over lastige vraagstukken',
                  'We werken in jouw portal, het resultaat is van jou',
                ].map(item => (
