        <span class="usp-d" style="font-size:18px;"><span class="dot"></span>Start Gratis in 1 Minuut</span>
      </div>
      <!-- Headline -->
      <div style="position:absolute;left:72px;top:320px;right:72px;">
        <h2 class="hl-d" style="font-size:180px;letter-spacing:-0.04em;line-height:0.9;">
          28 stappen.<br/>
          <span style="background:linear-gradient(90deg,#1563b8,#01a2e8);-webkit-background-clip:text;background-clip:text;color:transparent;">Nul twijfel.</span>
        </h2>
        <p class="sub-d" style="margin-top:40px;font-size:28px;max-width:820px;">
          De coach die je stap voor stap naar certificaat leidt. Probeer 14 dagen gratis, geen creditcard.
