      </div>
      <!-- Step dots visual -->
      <div style="position:absolute;bottom:120px;left:72px;right:72px;">
        <div style="display:grid;grid-template-columns:repeat(28,1fr);gap:8px;max-width:960px;">
          {Array.from({length:28}).map((_,i) => (
            <div style={`height:14px;border-radius:6px;background:${i<24?'linear-gradient(90deg,#1563b8,#01a2e8)':'rgba(2,9,90,0.12)'};`}></div>
          ))}
        </div>
        <div style="margin-top:22px;display:flex;justify-content:space-between;font-size:16px;font-weight:600;color:rgba(2,9,90,0.55);">
          <span>Gap analyse</span>
          <span>Risicoanalyse</span>
          <span>Documenten</span>
          <span>Audit</span>
        </div>
      </div>
    </div>
  </div>

  <!-- CONCEPT C: 4 normen 1 platform -->
  <div class="ad-wrapper">
    <span class="ad-label">rda-square-c-4-normen.png <span class="ad-dims">· 1200×1200</span></span>
    <div class="ad-banner bg-accent" data-name="rda-square-c-4-normen" style="width:1200px;height:1200px;">
