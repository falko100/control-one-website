            </div>
          </div>
          <div style="position:relative;padding:36px 32px;border-radius:24px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.18);overflow:hidden;">
            <div style="position:absolute;left:0;top:32px;bottom:32px;width:3px;background:linear-gradient(180deg,#6fd0f0,#01a2e8);border-radius:999px;"></div>
            <div style="padding-left:16px;">
              <div style="font-size:12px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:rgba(111,208,240,0.85);">ISO</div>
              <div style="margin-top:6px;font-size:84px;font-weight:800;letter-spacing:-0.05em;line-height:0.95;background:linear-gradient(180deg,#ffffff 30%,#6fd0f0 100%);-webkit-background-clip:text;background-clip:text;color:transparent;">9001</div>
              <div style="margin-top:14px;height:1px;background:linear-gradient(to right,rgba(111,208,240,0.4),transparent);"></div>
