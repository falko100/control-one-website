---
// Ads Preview — alle Google Ads banners in upload-klare formaten.
// Deze pagina is uitsluitend voor interne export. Niet voor SEO.

// Banner registry: elke banner heeft name, width, height, category.
const banners = [
  // RDA Marketing — SQUARE 1:1 (1200×1200)
  { name: 'rda-square-a-zonder-consultant',  w: 1200, h: 1200, variant: 'square',    concept: 'A' },
  { name: 'rda-square-b-28-stappen',         w: 1200, h: 1200, variant: 'square',    concept: 'B' },
  { name: 'rda-square-c-4-normen',           w: 1200, h: 1200, variant: 'square',    concept: 'C' },
  { name: 'rda-square-d-gratis-1min',        w: 1200, h: 1200, variant: 'square',    concept: 'D' },

  // RDA Marketing — LANDSCAPE 1.91:1 (1200×628)
  { name: 'rda-landscape-a-zonder-consultant', w: 1200, h: 628, variant: 'landscape', concept: 'A' },
  { name: 'rda-landscape-b-28-stappen',        w: 1200, h: 628, variant: 'landscape', concept: 'B' },
  { name: 'rda-landscape-c-4-normen',          w: 1200, h: 628, variant: 'landscape', concept: 'C' },
  { name: 'rda-landscape-d-gratis-1min',       w: 1200, h: 628, variant: 'landscape', concept: 'D' },

  // RDA Marketing — PORTRAIT 4:5 (960×1200)
  { name: 'rda-portrait-a-zonder-consultant', w: 960, h: 1200, variant: 'portrait', concept: 'A' },
  { name: 'rda-portrait-b-28-stappen',        w: 960, h: 1200, variant: 'portrait', concept: 'B' },
  { name: 'rda-portrait-d-gratis-1min',       w: 960, h: 1200, variant: 'portrait', concept: 'D' },

  // Logo assets
  { name: 'logo-square-1200x1200',        w: 1200, h: 1200, variant: 'logo-square' },
  { name: 'logo-landscape-1200x300',      w: 1200, h: 300,  variant: 'logo-landscape' },

  // Classic uploaded display
  { name: 'banner-300x250-zonder-consultant', w: 300, h: 250, variant: 'medium-rectangle', concept: 'A' },
  { name: 'banner-300x250-28-stappen',        w: 300, h: 250, variant: 'medium-rectangle', concept: 'B' },
  { name: 'banner-300x250-gratis-1min',       w: 300, h: 250, variant: 'medium-rectangle', concept: 'D' },
  { name: 'banner-728x90-zonder-consultant',  w: 728, h: 90,  variant: 'leaderboard',      concept: 'A' },
  { name: 'banner-728x90-28-stappen',         w: 728, h: 90,  variant: 'leaderboard',      concept: 'B' },
  { name: 'banner-728x90-gratis-1min',        w: 728, h: 90,  variant: 'leaderboard',      concept: 'D' },
  { name: 'banner-320x50-zonder-consultant',  w: 320, h: 50,  variant: 'mobile-banner' },
  { name: 'banner-160x600-vertical',          w: 160, h: 600, variant: 'wide-skyscraper' },
  { name: 'banner-300x600-halfpage',          w: 300, h: 600, variant: 'half-page' },
  { name: 'banner-970x250-billboard',         w: 970, h: 250, variant: 'billboard' },
];
---
<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <title>Control One — Google Ads Preview</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=TikTok+Sans:opsz,wght@12..36,300..900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --c-deep:     #02095a;
      --c-deeper:   #030a4a;
      --c-primary:  #1563b8;
      --c-primary2: #196bd7;
      --c-primary3: #2d8dda;
      --c-accent:   #6fd0f0;
      --c-accent2:  #01a2e8;
      --c-white:    #ffffff;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { font-family: 'TikTok Sans', system-ui, sans-serif; background: #f4f6fb; color: #0f172a; -webkit-font-smoothing: antialiased; }
    body { padding: 40px 40px 120px; }
    h1.preview-title { font-size: 28px; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 8px; }
    p.preview-sub { color: #64748b; margin-bottom: 40px; font-size: 14px; }
    .ad-section { margin-bottom: 56px; }
    .ad-section-title { font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #475569; margin-bottom: 4px; }
    .ad-section-desc { font-size: 12px; color: #94a3b8; margin-bottom: 16px; }
    .ad-wrapper { display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px; align-items: flex-start; }
    .ad-label { font-size: 11px; font-weight: 600; color: #475569; font-family: ui-monospace, monospace; }
    .ad-dims { color: #94a3b8; font-weight: 400; }

    /* === BANNER SHELL === */
    .ad-banner {
      position: relative;
      overflow: hidden;
      font-family: 'TikTok Sans', sans-serif;
      -webkit-font-smoothing: antialiased;
      text-rendering: geometricPrecision;
      line-height: 1;
    }

    /* Dark theme */
    .bg-dark {
      background:
        radial-gradient(ellipse at 110% -10%, rgba(111,208,240,0.25) 0%, transparent 55%),
        radial-gradient(ellipse at -10% 110%, rgba(21,99,184,0.35) 0%, transparent 60%),
        linear-gradient(135deg, #02095a 0%, #0a1a7a 50%, #02095a 100%);
    }
    /* Light theme */
    .bg-light {
      background:
        radial-gradient(ellipse at 100% 0%, rgba(111,208,240,0.35) 0%, transparent 55%),
        radial-gradient(ellipse at 0% 100%, rgba(21,99,184,0.10) 0%, transparent 60%),
        linear-gradient(135deg, #ffffff 0%, #eef4fb 100%);
    }
    /* Accent theme (deep blue with accent highlight) */
    .bg-accent {
      background:
        radial-gradient(ellipse at 20% 80%, rgba(111,208,240,0.35) 0%, transparent 55%),
        linear-gradient(135deg, #1563b8 0%, #02095a 100%);
    }

    /* Common text styles */
    .hl   { font-weight: 800; color: #fff; letter-spacing: -0.02em; line-height: 1.02; }
    .hl-d { font-weight: 800; color: #02095a; letter-spacing: -0.02em; line-height: 1.02; }
    .sub  { font-weight: 500; color: rgba(255,255,255,0.75); line-height: 1.35; }
    .sub-d{ font-weight: 500; color: rgba(2,9,90,0.65); line-height: 1.35; }
    .eyebrow   { font-size: 12px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #6fd0f0; }
    .eyebrow-d { font-size: 12px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #1563b8; }

    .chip {
      display: inline-flex; align-items: center;
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.08);
      border-radius: 999px;
      font-weight: 600;
      color: #fff;
    }
    .chip-d {
      display: inline-flex; align-items: center;
      border: 1px solid rgba(2,9,90,0.12);
      background: rgba(2,9,90,0.04);
      border-radius: 999px;
      font-weight: 600;
      color: #02095a;
    }

    /* Logo inline — we inline to guarantee exact rendering */
    .logo-inline {
      display: inline-block;
      vertical-align: middle;
    }

    /* Brand mark (checkmark-in-cube) as SVG */
    .brandmark {
      display: inline-block;
    }

    /* Screenshot-safe: lock each banner pixel-perfect */
    .ad-banner, .ad-banner * { transform: translateZ(0); }

    /* Ring visual (step grid) */
    .step-dots { display: flex; gap: 6px; }
    .step-dot {
      width: 10px; height: 10px; border-radius: 999px;
      background: rgba(111,208,240, 0.85);
      box-shadow: 0 0 10px rgba(111,208,240,0.6);
    }
    .step-dot.faint { background: rgba(255,255,255,0.25); box-shadow: none; }

    /* Framework badge blocks */
    .fw-grid { display: grid; gap: 8px; }

    /* Trust rule for minimum banners */
    .iso-list {
      display: flex; gap: 10px; flex-wrap: wrap;
      font-weight: 700; color: rgba(255,255,255,0.92);
    }
    .iso-dot {
      width: 6px; height: 6px; border-radius: 999px;
      background: #6fd0f0;
      display: inline-block;
      margin-right: 6px;
      vertical-align: middle;
    }

    /* Prevent scrollbars from showing up in large banners */
    .ad-banner { isolation: isolate; }

    /* ===== USP CHIP — "Start Gratis in 1 Minuut" ===== */
    .usp {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 18px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(111,208,240,0.26), rgba(111,208,240,0.06));
      border: 1px solid rgba(111,208,240,0.5);
      box-shadow: 0 0 24px rgba(111,208,240,0.18);
      font-weight: 700;
      color: #ffffff;
      letter-spacing: -0.005em;
    }
    .usp .dot {
      width: 8px; height: 8px; border-radius: 999px;
      background: #6fd0f0;
      box-shadow: 0 0 12px #6fd0f0, 0 0 4px #ffffff;
    }
    .usp-d {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 999px;
      background: linear-gradient(90deg, #1563b8, #01a2e8);
      color: #ffffff;
      font-weight: 700;
      box-shadow: 0 6px 18px rgba(21,99,184,0.28);
      letter-spacing: -0.005em;
    }
    .usp-d .dot {
      width: 8px; height: 8px; border-radius: 999px;
      background: #ffffff;
    }
    /* Big attention-grabbing USP for Concept D */
    .usp-hero {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      padding: 16px 28px;
      border-radius: 999px;
      background: linear-gradient(90deg, #1563b8 0%, #01a2e8 100%);
      color: #ffffff;
      font-weight: 800;
      box-shadow:
        0 20px 48px rgba(1,162,232,0.35),
        0 0 0 1px rgba(255,255,255,0.14) inset;
      letter-spacing: -0.01em;
    }
    .usp-hero .dot {
      width: 10px; height: 10px; border-radius: 999px;
      background: #ffffff;
      box-shadow: 0 0 14px #ffffff;
    }
  </style>
</head>
<body>

<h1 class="preview-title">Control One — Google Ads Banners</h1>
<p class="preview-sub">
  Elke banner is pixel-perfect gerenderd op de exacte upload-afmetingen van Google Ads.
  Hieronder staan {banners.length} formaten. Gebruik <code>scripts/export-ads.mjs</code> om PNG's te exporteren naar <code>public/ads-export/</code>.
</p>

<!-- ============================================================= -->
<!-- RDA MARKETING SQUARE 1:1 — 1200×1200                            -->
<!-- ============================================================= -->
<section class="ad-section">
  <p class="ad-section-title">RDA Marketing Image · Square (1:1)</p>
  <p class="ad-section-desc">Aanbevolen 1200×1200 · Verplicht voor Responsive Display Ads</p>

  <!-- CONCEPT A: zonder consultant -->
  <div class="ad-wrapper">
    <span class="ad-label">rda-square-a-zonder-consultant.png <span class="ad-dims">· 1200×1200</span></span>
    <div class="ad-banner bg-dark" data-name="rda-square-a-zonder-consultant" style="width:1200px;height:1200px;">
      <!-- Logo top-left -->
      <div style="position:absolute;top:72px;left:72px;">
        <img src="/logo-footer.svg" alt="Control One" style="height:72px;width:auto;" />
      </div>
      <!-- Badge eyebrow — USP -->
      <div style="position:absolute;top:72px;right:72px;">
        <span class="usp" style="font-size:18px;"><span class="dot"></span>Start Gratis in 1 Minuut</span>
      </div>
      <!-- Main headline block -->
      <div style="position:absolute;left:72px;top:360px;right:72px;">
        <h2 class="hl" style="font-size:128px;letter-spacing:-0.03em;line-height:0.98;">
          ISO behalen<br/>zonder<br/>consultant.
        </h2>
        <p class="sub" style="margin-top:36px;font-size:28px;max-width:820px;">
          Control One begeleidt je stap voor stap tot certificaat. Start gratis, geen creditcard.
        </p>
      </div>
      <!-- Framework row bottom -->
      <div style="position:absolute;bottom:96px;left:72px;right:72px;">
        <div class="iso-list" style="font-size:22px;letter-spacing:0.02em;">
          <span><span class="iso-dot"></span>ISO 27001</span>
          <span><span class="iso-dot"></span>ISO 9001</span>
          <span><span class="iso-dot"></span>ISO 14001</span>
          <span><span class="iso-dot"></span>ISO 45001</span>
        </div>
        <div style="margin-top:18px;height:2px;background:linear-gradient(to right, rgba(111,208,240,0.6), transparent);"></div>
      </div>
    </div>
  </div>

  <!-- CONCEPT B: 28 stappen -->
  <div class="ad-wrapper">
    <span class="ad-label">rda-square-b-28-stappen.png <span class="ad-dims">· 1200×1200</span></span>
    <div class="ad-banner bg-light" data-name="rda-square-b-28-stappen" style="width:1200px;height:1200px;">
      <!-- Logo -->
      <div style="position:absolute;top:72px;left:72px;">
        <img src="/logo.svg" alt="Control One" style="height:72px;width:auto;" />
      </div>
      <!-- Eyebrow — USP -->
